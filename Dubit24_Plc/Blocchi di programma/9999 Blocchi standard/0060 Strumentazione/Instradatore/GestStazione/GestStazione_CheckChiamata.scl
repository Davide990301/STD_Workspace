FUNCTION "GestStazione_CheckChiamata" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.1
   VAR_INPUT 
      K_StazioneSorgente : Int;
      K_StazioneDestinazione : Int;
   END_VAR


BEGIN
	ENO :=
	"Percorso".Stazione[#K_StazioneSorgente].Destinazione[#K_StazioneDestinazione].IN.Attivo AND
	"Percorso".Stazione[#K_StazioneDestinazione].OUT.Chiamata;
END_FUNCTION

