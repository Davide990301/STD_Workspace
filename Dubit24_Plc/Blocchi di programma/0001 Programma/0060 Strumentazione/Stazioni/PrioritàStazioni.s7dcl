    END_VAR

    K_StazioneVisualizzata := 16;
        K_StazioniConPriorità[0] := 16;
        K_StazioniConPriorità[1] := 18;
        K_StazioniSorgenti[0] := 48;
        K_StazioniSorgenti[1] := 49;
