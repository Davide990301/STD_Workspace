    VAR RETAIN
        {
            S7_MLC := "MLC_4ac";
            S7_Setpoint := "True"
        }
        K_StazioneVisualizzata : Int;
        { S7_Setpoint := "True" }
        K_StazioniConPriorità : Array[0.._.K_NumStazione] of Int;
        {
            S7_MLC := "MLC_4Lq";
            S7_Setpoint := "True"
        }
        K_StazioniSorgenti : Array[0.._.K_NumStazione] of Int;
        {
            S7_MLC := "MLC_4ZD";
