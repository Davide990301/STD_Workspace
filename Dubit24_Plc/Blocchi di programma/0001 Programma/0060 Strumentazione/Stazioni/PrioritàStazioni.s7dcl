        }
        K_StazioniDestinazioni : Array[0.._.K_NumStazione] of Int;
        StazioniSorgenti_PrioritàHmi : Array[0.._.K_NumStazione] of _.Priorità;
        StazioniDestinazioni_PrioritàHmi : Array[0.._.K_NumStazione] of _.Priorità;
        Old_StazioniSorgenti_PrioritàHmi : Array[0.._.K_NumStazione] of _.Priorità;
        Old_StazioniDestinazioni_PrioritàHmi : Array[0.._.K_NumStazione] of _.Priorità;
        { S7_Setpoint := "True" }
