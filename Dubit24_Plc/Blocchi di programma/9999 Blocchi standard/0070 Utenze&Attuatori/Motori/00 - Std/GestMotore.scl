FUNCTION "GestMotore" : Void
{ S7_Optimized_Access := 'TRUE' }
VERSION : 0.2
   VAR_INPUT 
      K_Motore : Int;
      K_TipoMotore : Int;
      K_Zona : Int;
   END_VAR

   VAR_TEMP 
      PI_Mitsubishi : Struct
         STW : Word;
         ActualSpeed : DInt;
         Current : DInt;
         DCBus : DInt;
         AlarmCode : DInt;
         CurrentPeak : DInt;
         DCBusPeak : DInt;
         Appo7 : DInt;
         Appo8 : DInt;
         Appo9 : DInt;
         Appo10 : DInt;
         Appo11 : DInt;
         Appo12 : DInt;
         Appo13 : DInt;
         Appo14 : DInt;
      END_STRUCT;
      PO_Mitsubishi : Struct
         CTW : Word;
         Speed_SP : DInt;
         Acc : DInt;
         Dec : DInt;
         FStart : DInt;
         Appo5 : DInt;
         Appo6 : DInt;
         Appo7 : DInt;
         Appo8 : DInt;
         Appo9 : DInt;
         Appo10 : DInt;
      END_STRUCT;
      PI_Siemens : Struct
         STW : Word;
         ActualSpeed : Int;
         ActualCurrent : Int;
         ActualTorque : Int;
         WarningCode : Int;
         FaultCode : Int;
      END_STRUCT;
      PO_Siemens : Struct
         CTW : Word;
         Speed : Int;
         Spare01 : Int;
         Spare02 : Int;
         Spare03 : Int;
         Spare04 : Int;
      END_STRUCT;
      PI_Schneider : Struct
         STW : Word;
         ActualSpeed : Int;
         Enrgy : Int;
         Segnalaz_Code : Int;
         Spare_01 : Int;
         Spare_02 : Int;
      END_STRUCT;
      PO_Schneider : Struct
         CTW : Word;
         Speed_SP : Int;
         Acc_SP : Int;
         Dec_SP : Int;
         Spare_01 : Int;
         Spare_02 : Int;
      END_STRUCT;
      PI_Movimot : Struct
         STW1 : Word;
         OutputCurrent : Word;
         STW2 : Word;
      END_STRUCT;
      PO_Movimot : Struct
         CTW : Word;
         Speed : Int;
         AccRich : Int;
      END_STRUCT;
      PI_MoviGear : Struct
         STW : Word;
         Actual_Speed : Int;
         Status_Fault : Int;
         Actual_Torque : Int;
         DI : Word;
      END_STRUCT;
      PO_MoviGear : Struct
         CTW : Word;
         Target_Speed : Int;
         Acceleration : Int;
         Deceleration : Int;
         DO : Word;
      END_STRUCT;
      PI_Danfoss : Struct
         STW : Word;
         ActualSpeed : Int;
         CodAllarme_W1 : Int;
         CodAllarme_W2 : Int;
         CodWarning_W1 : Int;
         CodWarning_W2 : Int;
      END_STRUCT;
      PO_Danfoss : Struct
         CTW : Word;
         Speed : Int;
         AccRich : Int;
         DecRich : Int;
         PCD_Spare01 : Int;
         PCD_Spare02 : Int;
      END_STRUCT;
      PI_INVT : Struct
         PKW01 : Word;
         PKW02 : Word;
         PKW03 : Word;
         PKW04 : Word;
         STW : Word;
         ActualSpeed : Int;
         BusVoltage : Int;
         OutputCurrent : Int;
         FaultCode : Int;
         Sapre1 : Int;
         Sapre2 : Int;
         Sapre3 : Int;
      END_STRUCT;
      PO_INVT : Struct
         PKW01 : Word;
         PKW02 : Word;
         PKW03 : Word;
         PKW04 : Word;
         CTW : Word;
         Speed : Int;
         Spare1 : Int;
         Spare2 : Int;
         Spare3 : Int;
         Spare4 : Int;
         Spare5 : Int;
         Spare6 : Int;
      END_STRUCT;
      PI_Movitrac : Struct
         STW1 : Word;
         ActualSpeed : Int;
         ActualCurrent : Word;
      END_STRUCT;
      PO_MoviTrac : Struct
         CTW : Word;
         Speed : Int;
         Reserved : Int;
      END_STRUCT;
      PI_Nidec : Struct
         STW : Word;
         ActualSpeed : DInt;
         ActualCurrent : DInt;
         ActualDCBus : Int;
         FaultCode : USInt;
      END_STRUCT;
      PO_Nidec : Struct
         CTW : Word;
         Speed : DInt;
         RampAcc : DInt;
         RampDec : DInt;
      END_STRUCT;
      TempEnc : Struct
         RcvDaEncoderSick : Struct
            ZSW2_ENC : Word;
            G1_ZSW : Word;
            Position01 : DWord;
            Position02 : DWord;
            Speed : DInt;
         END_STRUCT;
         SendAEncoderSick : Struct
            STW2_ENC : Word;
            G1_STW : Word;
         END_STRUCT;
         RcvDaEncoder_Ottico : Struct
            Posizione : DInt;
            Velocita : Int;
         END_STRUCT;
         RcvDaEncoder_Magnetico : Struct
            Posizione : DInt;
         END_STRUCT;
         arrRecord : Array[0..15] of Byte;
         PosizioneLettaEnc : DInt;
         VelocitaLettaEnc : DInt;
         AppoSetupRich : DInt;
         AppoSetupEncoder : UDInt;
         SpazioUltimoCiclo : DInt;
         AppoScrEncoder : DWord;
      END_STRUCT;
      TempTelem : Struct
         RcvDaEncoder : Struct
            M05_IN_ActPos : DWord;
            Status : Struct
               M10Status_IN_AvvPlaus : Bool;
               M10Status_IN_AvvTemp : Bool;
               M10Status_IN_AvvLiv : Bool;
               M10Status_IN_Avvlaser : Bool;
               M10Status_IN_ErrPlaus : Bool;
               M10Status_IN_ErrTemp : Bool;
               M10Status_IN_ErrLiv : Bool;
               M10Status_IN_ErrLaser : Bool;
               M10Status_IN_Spento : Bool;
               M10Status_IN_RiscaldaOn : Bool;
               M10Status_IN_MF1On : Bool;
               M10Status_IN_MF2On : Bool;
               M10Status_IN_Res1 : Bool;
               M10Status_IN_Res2 : Bool;
               M10Status_IN_Res3 : Bool;
               M10Status_IN_NoDist : Bool;
            END_STRUCT;
         END_STRUCT;
         SendAEncode : Struct
            M05_OUT_Preset : DWord;
            Status : Struct
               M10Status_OUT_Res1 : Bool;
               M10Status_OUT_Res2 : Bool;
               M10Status_OUT_Res3 : Bool;
               M10Status_OUT_Res4 : Bool;
               M10Status_OUT_Res5 : Bool;
               M10Status_OUT_Res6 : Bool;
               M10Status_OUT_Res7 : Bool;
               M10Status_OUT_Res8 : Bool;
               M10Status_OUT_Disabil : Bool;
               M10Status_OUT_Res9 : Bool;
               M10Status_OUT_Res10 : Bool;
               M10Status_OUT_Res11 : Bool;
               M10Status_OUT_Res12 : Bool;
               M10Status_OUT_Res13 : Bool;
               M10Status_OUT_Res14 : Bool;
               M10Status_OUT_Res15 : Bool;
            END_STRUCT;
         END_STRUCT;
         arrRecord : Array[0..15] of Byte;
         AppoSetupRich : DInt;
      END_STRUCT;
      ReqDirPos : Bool;
      ReqDirNeg : Bool;
      FunzPositioning : Bool;
      ReqDecBassa : Bool;
      ReqDecStop : Bool;
      ReqStop : Bool;
      ReqCambioVel : Bool;
      CambioPercLavoro : Bool;
      CambioReqVel : Bool;
      CambioReqAcc : Bool;
      CambioReqDec : Bool;
      REQSetup : Bool;
      REQSetupPannello : Bool;
      DistTrgMagPrec : Bool;
      DistTrgMinPrec : Bool;
      RitMotInPrecisione : Bool;
      UnaDirezioneRichiesta : Bool;
      ReqRicTempoProfilo : Bool;
      BloccaAcc : Bool;
      AbilDirPos : Bool;
      AbilDirNeg : Bool;
      SetUpSuSensore : Bool;
      SetUpFermoMeccanico : Bool;
      RichCmdFreno : Bool;
      SpazioFrenoDir : DInt;
      VeloFrenoDir : DInt;
      AppoMoltPrecisione : DInt;
      DecActRich : DInt;
      RicircoloTotale : DInt;
      MezzoRicircoloTotale : DInt;
      DistCambioVel : DInt;
      SpazioStop : DInt;
      SpazioBassa : DInt;
      SpazioCambioVel : DInt;
      DistTRG_ASS : DInt;
      VeloBassaConv : Real;
      SpazioStop_01 : Real;
      SpazioStop_02 : Real;
      SpazioStop_03 : Real;
      SpazioStop_04 : Real;
      SpazioCambioVel_01 : Real;
      SpazioCambioVel_02 : Real;
      VeloProfilo : Real;
      TempoAcc : Real;
      TempoDec_Iniziale : Real;
      TempoDec_Finale : Real;
      TempoVFix : Real;
      K_MotoreInt : Int;
      K_ZonaInt : Int;
      CounterAllarme : Int;
   END_VAR


BEGIN
	REGION Diagnostica programmatore
	    (*Passiamo tutte le costanti di accesso agli array in modo da verificarle e controllarle*)
	    "Diagnostica"(K_Attuale_ArrayInCuiAccediamo := #K_Motore,
	                  K_NumMax_MassimoValoreDellArrayInCuiAccediamo := "K_NumMotore",
	                  K_Tipo_ArrayInCuiAccediamo := "K_TipoMotore",
	                  K_Attuale_DiChiAccede := #K_Motore,
	                  K_Tipo_DiChiAccede := "K_TipoSezionePastorizzatore",
	                  K_AttualeInterno => #K_MotoreInt);
	    
	    "Diagnostica"(K_Attuale_ArrayInCuiAccediamo := #K_Zona,
	                  K_NumMax_MassimoValoreDellArrayInCuiAccediamo := "K_NumZona",
	                  K_Tipo_ArrayInCuiAccediamo := "K_TipoMotore",
	                  K_Attuale_DiChiAccede := #K_Motore,
	                  K_Tipo_DiChiAccede := "K_TipoMotore",
	                  K_AttualeInterno => #K_ZonaInt);
	END_REGION ;
	REGION From inverter
	    CASE "Motore".M[#K_MotoreInt].HW.TipoCollInverter OF
	        1:
	            REGION PN Mitsubishi
	                (*
	                BIT 00: Drive PI:Ready to Switch ON
	                BIT 01: Drive PI:Ready to Operate
	                BIT 02: Drive PI:Operation Enabled
	                BIT 03: Drive PI:Fault Present
	                BIT 04: Drive PI:Coast Stop
	                BIT 05: Drive PI:Quick Stop
	                BIT 06: Drive PI:Switch ON Inhibited
	                BIT 07: Drive PI:Warning
	                BIT 08: 
	                BIT 09: Drive PI: Control ON
	                BIT 10: 
	                BIT 11: 
	                BIT 12: 
	                BIT 13: 
	                BIT 14: 
	                BIT 15:
	                *)
	                "Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD => #PI_Mitsubishi);
	                "Motore".M[#K_MotoreInt].In.NoComunInv := ("Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv OR "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv) <> 0;
	                IF NOT "Motore".M[#K_MotoreInt].In.NoComunInv THEN
	                    (*Appoggio la Status Word per HMI*)
	                    "Motore".M[#K_MotoreInt].HMI.STW1 := #PI_Mitsubishi.STW;
	                    (*Controllo se l'inverter Ã¨ in Fault e relativo Codice*)
	                    "Motore".M[#K_MotoreInt].In.DriverFault := "Zona".Z[#K_Zona].Out.CentralinaOk AND #PI_Mitsubishi.STW.%X3;
	                    IF "Motore".M[#K_MotoreInt].In.DriverFault THEN
	                        "Motore".M[#K_MotoreInt].HMI.CodiceAllarme := #PI_Mitsubishi.AlarmCode;
	                    END_IF;
	                    (* Calcolo La velocitÃ  letta dall'inverter *)
	                    "Motore".M[#K_MotoreInt].Out.MotorSpeed := TRUNC(ABS(DINT_TO_REAL(#PI_Mitsubishi.ActualSpeed)) * DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) / 10000.0);
	                    (* Assegno il segnale di Inverter RUN *)
	                    "Motore".M[#K_MotoreInt].In.MotoreRun := #PI_Mitsubishi.STW.%X2;
	                ELSE
	                    (* In caso di mancanza Comunicazione, Azzero i dati *)
	                    "Motore".M[#K_MotoreInt].Out.MotorSpeed := 0;
	                    "Motore".M[#K_MotoreInt].In.MotoreRun := "Motore".M[#K_MotoreInt].In.DriverFault := "Motore".M[#K_MotoreInt].In.DriverWarning := false;
	                END_IF;
	            END_REGION
	        2:
	            REGION PN Siemens
	                (*
	                Definizione Parola di Stato:
	                Bit 00: Drive PI: Ready TO Switch "ON"
	                Bit 01: Drive PI: Ready TO Operate
	                Bit 02: Drive PI: Operation Enabled. The Drive Follows the Setpoint
	                Bit 03: Drive PI: Fault
	                Bit 04: Drive PI: Coast Stop (OFF2) command is NOT Active
	                Bit 05: Drive PI: Quick Stop (OFF3) command is NOT Active
	                Bit 06: Drive PI: Switching on inhibited
	                Bit 07: Drive PI: Warning
	                Bit 08: Drive PI: Setpoint/Actual Value deviation within tolerance range.
	                Bit 09: Drive PI: Master control requested
	                Bit 10: Drive PI: Maximum frequency reached OR exceeded
	                Bit 11: Drive PI: Motor at Current/Torque limit
	                Bit 12: Drive PI: Motor Holding Brake Open
	                Bit 13: Drive PI: Motor Overload
	                Bit 14: Drive PI: Motor Rotation (1 = CW; 0 = CCW).
	                Bit 15: Drive PI: Inverter Overload
	                *)
	                "Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD => #PI_Siemens);
	                "Motore".M[#K_MotoreInt].In.NoComunInv := ("Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv OR "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv) <> 0;
	                IF NOT "Motore".M[#K_MotoreInt].In.NoComunInv THEN
	                    (*Appoggio la Status Word per HMI*)
	                    "Motore".M[#K_MotoreInt].HMI.STW1 := #PI_Siemens.STW;
	                    (*Controllo se l'inverter Ã¨ in Fault e relativo Codice*)
	                    "Motore".M[#K_MotoreInt].In.DriverFault := "Zona".Z[#K_Zona].Out.CentralinaOk AND (#PI_Siemens.STW.%X3 OR NOT #PI_Siemens.STW.%X9);
	                    IF "Motore".M[#K_MotoreInt].In.DriverFault THEN
	                        "Motore".M[#K_MotoreInt].HMI.CodiceAllarme := #PI_Siemens.FaultCode;
	                    END_IF;
	                    (*Controllo se l'inverter Ã¨ in Warning e relativo Codice*)
	                    "Motore".M[#K_MotoreInt].In.DriverWarning := "Zona".Z[#K_Zona].Out.CentralinaOk AND #PI_Siemens.STW.%X7;
	                    IF "Motore".M[#K_MotoreInt].In.DriverWarning THEN
	                        "Motore".M[#K_MotoreInt].HMI.CodiceWarning := #PI_Siemens.WarningCode;
	                    END_IF;
	                    (* Calcolo La velocitÃ  letta dall'inverter *)
	                    "Motore".M[#K_MotoreInt].Out.MotorSpeed := INT_TO_DINT(#PI_Siemens.ActualSpeed) * "Motore".M[#K_MotoreInt].Prm.C.VelMax / 16384;
	                    (* Assegno il segnale di Inverter RUN *)
	                    "Motore".M[#K_MotoreInt].In.MotoreRun := #PI_Siemens.STW.%X2;
	                ELSE
	                    (* In caso di mancanza Comunicazione, Azzero i dati *)
	                    "Motore".M[#K_MotoreInt].Out.MotorSpeed := 0;
	                    "Motore".M[#K_MotoreInt].In.MotoreRun := "Motore".M[#K_MotoreInt].In.DriverFault := "Motore".M[#K_MotoreInt].In.DriverWarning := false;
	                END_IF;
	            END_REGION
	        3:
	            REGION PN_Schneider
	                (*
	                BIT 00: Drive PI: Mains power supply is switched on, electronics are initialized, pulses are inhibited
	                BIT 01: Drive PI: Refer to control word 1, bit 0
	                BIT 02: Drive PI: Drive follows a reference frequency.
	                BIT 03: Drive PI: An error has been detected.
	                BIT 04: Drive PI: 1= --, 0= Coast stop (OFF 2) command is present
	                BIT 05: Drive PI: 1= --, 0= Quick Stop (OFF 3) command is present.
	                BIT 06: Drive PI: The drive is in Switching on inhibited operating state.
	                BIT 07: Drive PI: Warning information present in the service/maintenance parameter, acknowledgement required.
	                BIT 08: Actual value is within a tolerance band; dynamic speed discrepancies are permissible.
	                BIT 09: The automation system controls the drive.
	                BIT 10: Actual output frequency â‰¥ reference frequency which may be set via the parameter number.
	                BIT 11: Drive PI: Reserved
	                BIT 12: Drive PI: Reserved
	                BIT 13: Drive PI: Reserved
	                BIT 14: Drive PI: Reserved
	                BIT 15: Drive PI: Reserved
	                *)
	                "Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD => #PI_Schneider);
	                "Motore".M[#K_MotoreInt].In.NoComunInv := ("Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv OR "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv) <> 0;
	                IF NOT "Motore".M[#K_MotoreInt].In.NoComunInv THEN
	                    (*Appoggio la Status Word per HMI*)
	                    "Motore".M[#K_MotoreInt].HMI.STW1 := #PI_Schneider.STW;
	                    (*Controllo se l'inverter Ã¨ in Fault e relativo Codice*)
	                    "Motore".M[#K_MotoreInt].In.DriverFault := "Zona".Z[#K_Zona].Out.CentralinaOk AND #PI_Schneider.STW.%X3;
	                    IF "Motore".M[#K_MotoreInt].In.DriverFault THEN
	                        "Motore".M[#K_MotoreInt].HMI.CodiceAllarme := #PI_Schneider.Segnalaz_Code;
	                    END_IF;
	                    // Inverter in warning
	                    "Motore".M[#K_MotoreInt].In.DriverWarning := "Zona".Z[#K_Zona].Out.CentralinaOk AND #PI_Schneider.STW.%X7;
	                    IF "Motore".M[#K_MotoreInt].In.DriverWarning THEN
	                        "Motore".M[#K_MotoreInt].HMI.CodiceWarning := #PI_Schneider.Spare_01;
	                    END_IF;
	                    (* Calcolo La velocitÃ  letta dall'inverter *)
	                    "Motore".M[#K_MotoreInt].Out.MotorSpeed := ABS(INT_TO_DINT(#PI_Schneider.ActualSpeed) * "Motore".M[#K_MotoreInt].Prm.C.VelMax / 3000);
	                    (* Assegno il segnale di Inverter RUN *)
	                    "Motore".M[#K_MotoreInt].In.MotoreRun := #PI_Schneider.STW.%X2;
	                ELSE
	                    (* In caso di mancanza Comunicazione, Azzero i dati *)
	                    "Motore".M[#K_MotoreInt].Out.MotorSpeed := 0;
	                    "Motore".M[#K_MotoreInt].In.MotoreRun := "Motore".M[#K_MotoreInt].In.DriverFault := "Motore".M[#K_MotoreInt].In.DriverWarning := false;
	                END_IF;
	            END_REGION
	        4:
	            REGION PN Movimot
	                (*
	                Status Word 01
	                
	                BIT 08: Alarm Code Bit 00
	                BIT 09: Alarm Code Bit 01
	                BIT 10: Alarm Code Bit 02
	                BIT 11: Alarm Code Bit 03
	                BIT 12: Alarm Code Bit 04
	                BIT 13: Alarm Code Bit 05
	                BIT 14: Alarm Code Bit 06
	                BIT 15: Alarm Code Bit 07
	                BIT 00: 0=Control Not Enabled / 1=Enabled
	                BIT 01: 0=Inverter Not Ready / 1=Ready
	                BIT 02: 0=PO Data Not Enabled / 1=Enabled
	                BIT 03: Reserved
	                BIT 04: Reserved
	                BIT 05: 0=OK / 1=Malfunction/Warning
	                BIT 06: Reserved
	                BIT 07: Reserved
	                
	                Status Word 02
	                
	                BIT 08: 0=Brake Released / 1= Brake Applied
	                BIT 09: 0=Not Ready For Operation / 1=Ready
	                BIT 10: 0=Stop / 1=Motor Run CW
	                BIT 11: 0=Stop / 1=Motor Run CCW
	                BIT 12: 0=Stop / 1=Set Point F2
	                BIT 13: Reserved
	                BIT 14: Reserved
	                BIT 15: Reserved
	                BIT 00: 0=Control Not Enabled / 1=Enabled
	                BIT 01: 0=Inverter Not Ready / 1=Ready
	                BIT 02: 0=PO Data Not Enabled / 1=Enabled
	                BIT 03: Reserved
	                BIT 04: Reserved
	                BIT 05: 0=OK / 1=Malfunction/Warning
	                BIT 06: Reserved
	                BIT 07: Reserved
	                *)
	                "Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD => #PI_Movimot);
	                "Motore".M[#K_MotoreInt].In.NoComunInv := ("Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv OR "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv) <> 0;
	                IF NOT "Motore".M[#K_MotoreInt].In.NoComunInv THEN
	                    (*Appoggio la Status Word per HMI*)
	                    "Motore".M[#K_MotoreInt].HMI.STW1 := #PI_Movimot.STW1;
	                    "Motore".M[#K_MotoreInt].HMI.STW2 := #PI_Movimot.OutputCurrent;
	                    "Motore".M[#K_MotoreInt].HMI.STW3 := #PI_Movimot.STW2;
	                    (* Controllo Stato Sezionatore Aperto *)
	                    "Motore".M[#K_MotoreInt].In.SezAperto := FALSE;
	                    IF #PI_Movimot.STW1.%X5 AND #PI_Movimot.STW1.%X8 AND #PI_Movimot.STW1.%X9 AND #PI_Movimot.STW1.%X10 AND
	                        #PI_Movimot.STW1.%X11 AND NOT #PI_Movimot.STW1.%X12 AND #PI_Movimot.STW1.%X13 AND #PI_Movimot.STW1.%X14 AND
	                        NOT #PI_Movimot.STW1.%X15 AND "Zona".Z[#K_Zona].Out.CentralinaOk THEN
	                        IF "Motore".M[#K_MotoreInt].Dati.ContOffSezAperto < 0 THEN
	                            "Motore".M[#K_MotoreInt].In.SezAperto := TRUE;
	                        ELSE
	                            "Motore".M[#K_MotoreInt].Dati.ContOffSezAperto -= REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                        END_IF;
	                    ELSE
	                        "Motore".M[#K_MotoreInt].Dati.ContOffSezAperto := 4000;
	                    END_IF;
	                    (*Controllo se l'inverter Ã¨ in Fault e relativo Codice*)
	                    "Motore".M[#K_MotoreInt].In.DriverFault := "Zona".Z[#K_Zona].Out.CentralinaOk AND NOT "Motore".M[#K_MotoreInt].In.SezAperto AND (#PI_Movimot.STW1.%X5 OR NOT #PI_Movimot.STW1.%X1 OR NOT #PI_Movimot.STW1.%X2);
	                    IF "Motore".M[#K_MotoreInt].In.DriverFault THEN
	                        "Motore".M[#K_MotoreInt].HMI.CodiceAllarme := #PI_Movimot.STW1.%B1;
	                    END_IF;
	                    (* Calcolo La velocitÃ  letta dall'inverter *)
	                    "Motore".M[#K_MotoreInt].Out.MotorSpeed := TRUNC("Motore".M[#K_MotoreInt].Out.Vel);
	                    (* Assegno il segnale di Inverter RUN *)
	                    "Motore".M[#K_MotoreInt].In.MotoreRun := #PI_Movimot.STW1.%X0 AND #PI_Movimot.STW2.%X1;
	                ELSE
	                    (* In caso di mancanza Comunicazione, Azzero i dati *)
	                    "Motore".M[#K_MotoreInt].Out.MotorSpeed := 0;
	                    "Motore".M[#K_MotoreInt].In.MotoreRun := "Motore".M[#K_MotoreInt].In.DriverFault := "Motore".M[#K_MotoreInt].In.DriverWarning := false;
	                END_IF;
	            END_REGION
	        5:
	            REGION PN MoviGear
	                (*
	                BIT 00: Ready
	                BIT 01: STO Disattivato
	                BIT 02: Output Stage Pronto
	                BIT 03: Freno Rilasciato
	                BIT 04: Motore in movimento
	                BIT 05: Motore Riferenziato
	                BIT 06: Nuova posizione Relativa Applicata
	                BIT 07: In Posizione
	                BIT 08: Fault
	                BIT 09: Warning
	                BIT 10: Attivato Motore 2
	                BIT 11: VelocitÃ  Attuale = A Target
	                BIT 12: Limiti SW Disattivati
	                BIT 13: Riservato
	                BIT 14: Stand By Attivo
	                BIT 15: HandShake
	                *)
	                "Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD => #PI_MoviGear);
	                "Motore".M[#K_MotoreInt].In.NoComunInv := ("Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv OR "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv) <> 0;
	                IF NOT "Motore".M[#K_MotoreInt].In.NoComunInv THEN
	                    (*Appoggio la Status Word per HMI*)
	                    "Motore".M[#K_MotoreInt].HMI.STW1 := #PI_MoviGear.STW;
	                    (*Controllo se l'inverter Ã¨ in Fault e relativo Codice*)
	                    "Motore".M[#K_MotoreInt].In.DriverFault := "Zona".Z[#K_Zona].Out.CentralinaOk AND (#PI_MoviGear.STW.%X8 OR NOT #PI_MoviGear.STW.%X0);
	                    IF "Motore".M[#K_MotoreInt].In.DriverFault THEN
	                        IF NOT #PI_MoviGear.STW.%X0 THEN
	                            "Motore".M[#K_MotoreInt].HMI.CodiceAllarme := #PI_MoviGear.Status_Fault;
	                        ELSE
	                            "Motore".M[#K_MotoreInt].HMI.CodiceAllarme := 1;
	                        END_IF;
	                    END_IF;
	                    (*Controllo se l'inverter Ã¨ in Warning e relativo Codice*)
	                    "Motore".M[#K_MotoreInt].In.DriverWarning := "Zona".Z[#K_Zona].Out.CentralinaOk AND #PI_MoviGear.STW.%X9;
	                    IF "Motore".M[#K_MotoreInt].In.DriverWarning THEN
	                        "Motore".M[#K_MotoreInt].HMI.CodiceWarning := "Motore".M[#K_MotoreInt].HMI.CodiceWarning;
	                    END_IF;
	                    (* Calcolo La velocitÃ  letta dall'inverter *)
	                    "Motore".M[#K_MotoreInt].Out.MotorSpeed := ABS(INT_TO_DINT(#PI_MoviGear.Actual_Speed)) * "Motore".M[#K_MotoreInt].Prm.C.VelMax / 3000;
	                    (* Assegno il segnale di Inverter RUN *)
	                    "Motore".M[#K_MotoreInt].In.MotoreRun := #PI_MoviGear.STW.%X0 AND #PI_MoviGear.STW.%X2;
	                ELSE
	                    (* In caso di mancanza Comunicazione, Azzero i dati *)
	                    "Motore".M[#K_MotoreInt].Out.MotorSpeed := 0;
	                    "Motore".M[#K_MotoreInt].In.MotoreRun := "Motore".M[#K_MotoreInt].In.DriverFault := "Motore".M[#K_MotoreInt].In.DriverWarning := false;
	                END_IF;
	            END_REGION
	        6:
	            REGION PN Danfoss
	                (*
	                BIT 00: 0=Control NOT Ready       1=Ready
	                BIT 01: 0=Drive NOT Ready       1=Ready
	                BIT 02: 0=Coasting        1=Enable
	                BIT 03: 0=No error        1=Trip
	                BIT 04: OFF/ON 2
	                BIT 05: OFF/ON 3
	                BIT 06: 0=Start possible        1=NOT possible
	                BIT 07: 0=No warning        1=Warning
	                BIT 08: 0= Speed><REF       1= Speed=REF
	                BIT 09: 0=Local oper       1=Bus control
	                BIT 10: 0=Out Freq.Limit     1=Freq.Limit OK
	                BIT 11: 0=No operation      1=In operation
	                BIT 12: 0=Drive OK       1=Stopped, Autostart
	                BIT 13: 0=Voltage OK       1=Voltage exceeded
	                BIT 14: 0=OFF      1=Comparatore 0 ON
	                BIT 15: 0=OFF      1=Comparatore 1 ON
	                *)
	                "Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD => #PI_Danfoss);
	                "Motore".M[#K_MotoreInt].In.NoComunInv := ("Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv OR "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv) <> 0;
	                IF NOT "Motore".M[#K_MotoreInt].In.NoComunInv THEN
	                    (*Appoggio la Status Word per HMI*)
	                    "Motore".M[#K_MotoreInt].HMI.STW1 := #PI_Danfoss.STW;
	                    (*Controllo se l'inverter Ã¨ in Fault e relativo Codice*)
	                    "Motore".M[#K_MotoreInt].In.DriverFault := "Zona".Z[#K_Zona].Out.CentralinaOk AND (#PI_Danfoss.STW.%X3 OR NOT #PI_Danfoss.STW.%X9);
	                    IF "Motore".M[#K_MotoreInt].In.DriverFault THEN
	                        "Motore".M[#K_MotoreInt].HMI.CodiceAllarme := #PI_Danfoss.CodAllarme_W2 OR SHL(IN := #PI_Danfoss.CodAllarme_W1, N := 16);
	                    END_IF;
	                    (*Controllo se l'inverter Ã¨ in Warning e relativo Codice*)
	                    "Motore".M[#K_MotoreInt].In.DriverWarning := "Zona".Z[#K_Zona].Out.CentralinaOk AND #PI_Danfoss.STW.%X7;
	                    IF "Motore".M[#K_MotoreInt].In.DriverWarning THEN
	                        "Motore".M[#K_MotoreInt].HMI.CodiceAllarme := #PI_Danfoss.CodWarning_W2 OR SHL(IN := #PI_Danfoss.CodWarning_W1, N := 16);
	                    END_IF;
	                    (* Calcolo La velocitÃ  letta dall'inverter *)
	                    "Motore".M[#K_MotoreInt].Out.MotorSpeed := ABS(INT_TO_DINT(#PI_Danfoss.ActualSpeed)) * "Motore".M[#K_MotoreInt].Prm.C.VelMax / 16384;
	                    (* Assegno il segnale di Inverter RUN *)
	                    "Motore".M[#K_MotoreInt].In.MotoreRun := #PI_Danfoss.STW.%X2 AND #PI_Danfoss.STW.%X11;
	                ELSE
	                    (* In caso di mancanza Comunicazione, Azzero i dati *)
	                    "Motore".M[#K_MotoreInt].Out.MotorSpeed := 0;
	                    "Motore".M[#K_MotoreInt].In.MotoreRun := "Motore".M[#K_MotoreInt].In.DriverFault := "Motore".M[#K_MotoreInt].In.DriverWarning := false;
	                END_IF;
	            END_REGION
	        7:
	            REGION PN Movitrac
	                (*
	                Status Word 01
	                
	                BIT 08: Alarm Code Bit 00
	                BIT 09: Alarm Code Bit 01
	                BIT 10: Alarm Code Bit 02
	                BIT 11: Alarm Code Bit 03
	                BIT 12: Alarm Code Bit 04
	                BIT 13: Alarm Code Bit 05
	                BIT 14: Alarm Code Bit 06
	                BIT 15: Alarm Code Bit 07
	                BIT 00: 0=Control Not Enabled / 1=Enabled
	                BIT 01: 0=Inverter Not Ready / 1=Ready
	                BIT 02: 0=PO Data Not Enabled / 1=Enabled
	                BIT 03: Reserved
	                BIT 04: Reserved
	                BIT 05: 0=OK / 1=Malfunction/Warning
	                BIT 06: Reserved
	                BIT 07: Reserved
	                *)
	                "Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD => #PI_Movitrac);
	                "Motore".M[#K_MotoreInt].In.NoComunInv := ("Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv OR "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv) <> 0;
	                IF NOT "Motore".M[#K_MotoreInt].In.NoComunInv THEN
	                    (*Appoggio la Status Word per HMI*)
	                    "Motore".M[#K_MotoreInt].HMI.STW1 := #PI_Movitrac.STW1;
	                    (*Controllo se l'inverter Ã¨ in Fault e relativo Codice*)
	                    "Motore".M[#K_MotoreInt].In.DriverFault := "Zona".Z[#K_Zona].Out.CentralinaOk AND (#PI_Movitrac.STW1.%X5 OR NOT #PI_Movitrac.STW1.%X1 OR NOT #PI_Movitrac.STW1.%X2);
	                    IF "Motore".M[#K_MotoreInt].In.DriverFault THEN
	                        "Motore".M[#K_MotoreInt].HMI.CodiceAllarme := #PI_Movitrac.STW1.%B1;
	                    END_IF;
	                    (* Calcolo La velocitÃ  letta dall'inverter *)
	                    "Motore".M[#K_MotoreInt].Out.MotorSpeed := ABS(INT_TO_DINT(#PI_Movitrac.ActualSpeed)) * "Motore".M[#K_MotoreInt].Prm.C.VelMax / 16384;
	                    (* Assegno il segnale di Inverter RUN *)
	                    "Motore".M[#K_MotoreInt].In.MotoreRun := #PI_Movitrac.STW1.%X0;
	                ELSE
	                    (* In caso di mancanza Comunicazione, Azzero i dati *)
	                    "Motore".M[#K_MotoreInt].Out.MotorSpeed := 0;
	                    "Motore".M[#K_MotoreInt].In.MotoreRun := "Motore".M[#K_MotoreInt].In.DriverFault := "Motore".M[#K_MotoreInt].In.DriverWarning := false;
	                END_IF;
	            END_REGION
	        8:
	            REGION PN INVT
	                (*
	                Bit   Descr
	                0â€“7     Running state
	                Value   Desc
	                1       Forward running
	                2       Reverse running
	                3       Stopped
	                4       Faulty
	                5       POFF
	                Bit:8 Bus voltage established: 0=Not ready to Run, 1=Ready to Run
	                Bit 9â€“10: Motor group feedback
	                BIT 11: 0=Asynchronous Motor 1=Syncronous Motor
	                BIT 12:Overload pre-alarm feedback  0=No overload pre-alarm generated 1=Overload pre-alarm generated
	                Bit     Descr
	                13â€“14   Run/Stop mode
	                Value   Desc
	                0       Keypad-based control
	                1       Terminal-based control
	                2       Communication-based control
	                3       Reserved
	                BIT 15Heartbeat feedback : 0=OFF      1=Comparatore 1 ON
	                *)
	                "Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD => #PI_INVT);
	                "Motore".M[#K_MotoreInt].In.NoComunInv := ("Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv OR "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv) <> 0;
	                IF NOT "Motore".M[#K_MotoreInt].In.NoComunInv THEN
	                    (*Appoggio la Status Word per HMI*)
	                    "Motore".M[#K_MotoreInt].HMI.STW1 := #PI_INVT.STW;
	                    (*Controllo se l'inverter Ã¨ in Fault e relativo Codice*)
	                    "Motore".M[#K_MotoreInt].In.DriverFault := #PI_INVT.STW.%B0 = 4 AND "Zona".Z[#K_Zona].Out.CentralinaOk;
	                    IF "Motore".M[#K_MotoreInt].In.DriverFault THEN
	                        "Motore".M[#K_MotoreInt].HMI.CodiceAllarme := #PI_INVT.FaultCode;
	                    END_IF;
	                    (*Controllo se l'inverter Ã¨ in Warning e relativo Codice*)
	                    "Motore".M[#K_MotoreInt].In.DriverWarning := #PI_INVT.STW.%X12;
	                    (* Calcolo La velocitÃ  letta dall'inverter *)
	                    "Motore".M[#K_MotoreInt].Out.MotorSpeed := ABS(INT_TO_DINT(#PI_INVT.ActualSpeed)) * "Motore".M[#K_MotoreInt].Prm.C.VelMax / 10000;
	                    (* Assegno il segnale di Inverter RUN *)
	                    "Motore".M[#K_MotoreInt].In.MotoreRun := #PI_INVT.STW.%X8;
	                ELSE
	                    (* In caso di mancanza Comunicazione, Azzero i dati *)
	                    "Motore".M[#K_MotoreInt].Out.MotorSpeed := 0;
	                    "Motore".M[#K_MotoreInt].In.MotoreRun := "Motore".M[#K_MotoreInt].In.DriverFault := "Motore".M[#K_MotoreInt].In.DriverWarning := false;
	                END_IF;
	            END_REGION
	        9:
	            REGION NIDEC
	                (*
	                BIT 00: Drive Healthy
	                BIT 01: Drive Active
	                BIT 02: Zero Frequency
	                BIT 03: Running At OR Below Minimum Frequency
	                BIT 04: Below Set Frequency
	                BIT 05: At Frequency
	                BIT 06: Above Set Frequency
	                BIT 07: Rated Load Reached
	                BIT 08: Current Limit Active
	                BIT 09: Regenerating
	                BIT 10: Braking IGBT Active
	                BIT 11: Braking Resistor Alarm
	                BIT 12: Reverse Direction Commanded
	                BIT 13: Reverse Direction Running
	                BIT 14: Supply Loss
	                *)
	                IF NOT "Motore".M[#K_MotoreInt].In.NoComunInv THEN
	                    //VariantGet(SRC := #PI_Inv, DST => #PI_Nidec);
	                    "Motore".M[#K_MotoreInt].HMI.STW1 := #PI_Nidec.STW;
	                    (*Controllo se l'inverter Ã¨ in Fault e relativo Codice*)
	                    "Motore".M[#K_MotoreInt].In.DriverFault := NOT #PI_Nidec.STW.%X0 AND "Zona".Z[#K_Zona].Out.CentralinaOk;
	                    IF "Motore".M[#K_MotoreInt].In.DriverFault THEN
	                        "Motore".M[#K_MotoreInt].HMI.CodiceAllarme := #PI_Nidec.FaultCode;
	                    END_IF;
	                    (* Calcolo La velocitÃ  letta dall'inverter *)
	                    "Motore".M[#K_MotoreInt].Out.MotorSpeed := ABS(#PI_Nidec.ActualSpeed) * "Motore".M[#K_MotoreInt].Prm.C.VelMax / 10000;
	                    (* Assegno il segnale di Inverter RUN *)
	                    "Motore".M[#K_MotoreInt].In.MotoreRun := #PI_Nidec.STW.%X1;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Out.MotorSpeed := 0;
	                    "Motore".M[#K_MotoreInt].In.MotoreRun := "Motore".M[#K_MotoreInt].In.DriverFault := "Motore".M[#K_MotoreInt].In.DriverWarning := false;
	                END_IF;
	            END_REGION
	    END_CASE;
	END_REGION
	REGION Encoder manager
	    IF "Zona".Z[#K_Zona].Out.Auto THEN
	        "Motore".M[#K_MotoreInt].HMI.Setup := "Motore".M[#K_MotoreInt].HMI.ManMov := false;
	        "Motore".M[#K_MotoreInt].HMI.ModoInizializza := 0;
	    END_IF;
	    REGION Calcolo Target Position Teorica
	        #RicircoloTotale := "Motore".M[#K_MotoreInt].Prm.Enc.ModuloPosEnc - "Motore".M[#K_MotoreInt].Prm.Enc.ModuloNegEnc;
	        #MezzoRicircoloTotale := #RicircoloTotale / 2;
	        IF "Motore".M[#K_MotoreInt].Out.InMarcia THEN
	            "Motore".M[#K_MotoreInt].Prm.C.TrgPos += "Motore".M[#K_MotoreInt].Out.Vel * "Zona".Comuni.TempoCicloCpu_r / 1000.0;
	            "Motore".M[#K_MotoreInt].Dati.TrgPosDint := TRUNC("Motore".M[#K_MotoreInt].Prm.C.TrgPos);
	            IF "Motore".M[#K_MotoreInt].Prm.Mech.EndLess THEN
	                IF "Motore".M[#K_MotoreInt].Dati.TrgPosDint < "Motore".M[#K_MotoreInt].Prm.Enc.ModuloNegEnc THEN
	                    // Aggiorno l'ultima posizione di target memorizzata
	                    "Motore".M[#K_MotoreInt].Prm.C.TrgPos += DINT_TO_REAL(#RicircoloTotale);
	                    "Motore".M[#K_MotoreInt].Dati.TrgPosDint := "Motore".M[#K_MotoreInt].Dati.OldTrgPosDint := TRUNC("Motore".M[#K_MotoreInt].Prm.C.TrgPos);
	                ELSIF "Motore".M[#K_MotoreInt].Dati.TrgPosDint > "Motore".M[#K_MotoreInt].Prm.Enc.ModuloPosEnc THEN
	                    "Motore".M[#K_MotoreInt].Prm.C.TrgPos -= DINT_TO_REAL(#RicircoloTotale);
	                    "Motore".M[#K_MotoreInt].Dati.TrgPosDint := "Motore".M[#K_MotoreInt].Dati.OldTrgPosDint := TRUNC("Motore".M[#K_MotoreInt].Prm.C.TrgPos);
	                END_IF;
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].Prm.Enc.EncoderLess THEN
	                "Motore".M[#K_MotoreInt].Out.ActPos := "Motore".M[#K_MotoreInt].Dati.TrgPosDint;
	                "Motore".M[#K_MotoreInt].Prm.C.EncPos := "Motore".M[#K_MotoreInt].Prm.C.TrgPos;
	            END_IF;
	        END_IF;
	    END_REGION
	    REGION Condizioni Setup Encoder        
	        IF "Motore".M[#K_MotoreInt].In.Setup THEN
	            #REQSetup := TRUE;
	        ELSIF "Motore".M[#K_MotoreInt].HMI.Setup THEN
	            #REQSetupPannello := "Motore".M[#K_MotoreInt].HMI.PulsanteSetupPremuto AND "Zona".Z[#K_Zona].Gen.Reset;
	            IF #REQSetupPannello THEN
	                "Motore".M[#K_MotoreInt].Out.EncoderHomed := FALSE;
	                #SetUpSuSensore := "Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 2 OR "Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 10;
	                #SetUpFermoMeccanico := "Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 4 OR "Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 12;
	                IF NOT #SetUpSuSensore AND NOT #SetUpFermoMeccanico THEN
	                    #REQSetup := TRUE;
	                    "Motore".M[#K_MotoreInt].Allarmi.SetupEncoderEseg := TRUE;
	                END_IF;
	            END_IF;
	        END_IF;
	    END_REGION
	    REGION Setup Su Sensore
	        IF #SetUpSuSensore OR "Motore".M[#K_MotoreInt].Dati.SetupSensoreTrovato THEN
	            REGION Tempo OFF Marcia Motore
	                IF NOT "Motore".M[#K_MotoreInt].Dati.MotoreFermo THEN
	                    "Motore".M[#K_MotoreInt].Dati.ContTOffMotoreMarcia := 1000;
	                    "Motore".M[#K_MotoreInt].Dati.TOffMotoreMarcia := true;
	                ELSE
	                    IF "Motore".M[#K_MotoreInt].Dati.ContTOffMotoreMarcia > 0 THEN
	                        "Motore".M[#K_MotoreInt].Dati.ContTOffMotoreMarcia -= REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                    ELSE
	                        "Motore".M[#K_MotoreInt].Dati.TOffMotoreMarcia := false;
	                    END_IF;
	                END_IF;
	            END_REGION ;
	            #REQSetup := "Motore".M[#K_MotoreInt].Out.SetUpSensEseg := "Motore".M[#K_MotoreInt].Dati.SetupSensoreTrovato AND NOT "Motore".M[#K_MotoreInt].Dati.TOffMotoreMarcia;
	            IF #REQSetup THEN
	                "Motore".M[#K_MotoreInt].Allarmi.SetupEncoderEseg := TRUE;
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].Out.SetUpSensEseg THEN
	                IF NOT "Motore".M[#K_MotoreInt].Dati.AppoImpEsecSetUP THEN
	                    "Motore".M[#K_MotoreInt].Dati.Encoder.ValoKSetupSuSens := "Motore".M[#K_MotoreInt].Out.ActPos - "Motore".M[#K_MotoreInt].Dati.PosImpulsoSetup;
	                    "Motore".M[#K_MotoreInt].Dati.AppoImpEsecSetUP := TRUE;
	                END_IF;
	            ELSE
	                "Motore".M[#K_MotoreInt].Dati.AppoImpEsecSetUP := FALSE;
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].Out.SetUpSensEseg AND NOT #SetUpSuSensore THEN
	                IF "Motore".M[#K_MotoreInt].Dati.ContSetUPEncoder > 300 THEN
	                    "Motore".M[#K_MotoreInt].Dati.SetupSensoreTrovato := false;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Dati.ContSetUPEncoder += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                END_IF;
	            ELSE
	                "Motore".M[#K_MotoreInt].Dati.ContSetUPEncoder := 0;
	            END_IF;
	            IF NOT "Motore".M[#K_MotoreInt].Dati.SetupSensoreTrovato THEN
	                IF NOT "Motore".M[#K_MotoreInt].In.SensAzz THEN
	                    IF ("Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 2 AND "Motore".M[#K_MotoreInt].Dati.ActVelNeg) OR
	                        ("Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 10 AND "Motore".M[#K_MotoreInt].Dati.ActVelPos) THEN
	                        "Motore".M[#K_MotoreInt].Dati.SetupSensoreTrovato := true;
	                        "Motore".M[#K_MotoreInt].Dati.PosImpulsoSetup := "Motore".M[#K_MotoreInt].Out.ActPos;
	                    END_IF;
	                ELSIF ("Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 2 AND "Motore".M[#K_MotoreInt].Out.ActDirPos) OR
	                    ("Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 10 AND "Motore".M[#K_MotoreInt].Out.ActDirNeg) THEN
	                    "Motore".M[#K_MotoreInt].Dati.ContTimeOutAzzeramento := 0;
	                END_IF;
	                "Motore".M[#K_MotoreInt].In.CmdPosRich := ("Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 2 AND NOT "Motore".M[#K_MotoreInt].In.SensAzz) OR ("Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 10 AND "Motore".M[#K_MotoreInt].In.SensAzz);
	                "Motore".M[#K_MotoreInt].In.CmdNegRich := ("Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 10 AND NOT "Motore".M[#K_MotoreInt].In.SensAzz) OR ("Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 2 AND "Motore".M[#K_MotoreInt].In.SensAzz);
	                IF "Motore".M[#K_MotoreInt].In.CmdPosRich THEN
	                    "Motore".M[#K_MotoreInt].In.CmdVelocitaRich := "Motore".M[#K_MotoreInt].Prm.VelSgancioFrenoPos;
	                ELSIF "Motore".M[#K_MotoreInt].In.CmdNegRich THEN
	                    "Motore".M[#K_MotoreInt].In.CmdVelocitaRich := "Motore".M[#K_MotoreInt].Prm.VelSgancioFrenoNeg;
	                END_IF;
	            ELSE
	                "Motore".M[#K_MotoreInt].In.CmdPosRich := "Motore".M[#K_MotoreInt].In.CmdNegRich := "Motore".M[#K_MotoreInt].In.Positioning := false;
	            END_IF;
	        END_IF;
	    END_REGION
	    REGION SetupSuFermoMeccanico
	        IF #SetUpFermoMeccanico OR "Motore".M[#K_MotoreInt].Dati.SetupFermoMeccTrovato THEN
	            REGION Tempo OFF Marcia Motore
	                IF NOT "Motore".M[#K_MotoreInt].Dati.MotoreFermo THEN
	                    "Motore".M[#K_MotoreInt].Dati.ContTOffMotoreMarcia := 1000;
	                    "Motore".M[#K_MotoreInt].Dati.TOffMotoreMarcia := true;
	                ELSE
	                    IF "Motore".M[#K_MotoreInt].Dati.ContTOffMotoreMarcia > 0 THEN
	                        "Motore".M[#K_MotoreInt].Dati.ContTOffMotoreMarcia -= REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                    ELSE
	                        "Motore".M[#K_MotoreInt].Dati.TOffMotoreMarcia := false;
	                    END_IF;
	                END_IF;
	            END_REGION ;
	            #REQSetup := "Motore".M[#K_MotoreInt].Dati.SetupFermoMeccTrovato AND NOT "Motore".M[#K_MotoreInt].Dati.TOffMotoreMarcia;
	            IF #REQSetup THEN
	                "Motore".M[#K_MotoreInt].Allarmi.SetupEncoderEseg := TRUE;
	            END_IF;
	            IF #REQSetup THEN
	                IF NOT "Motore".M[#K_MotoreInt].Dati.AppoImpEsecSetUP THEN
	                    "Motore".M[#K_MotoreInt].Dati.Encoder.ValoKSetupSuSens := "Motore".M[#K_MotoreInt].Out.ActPos - "Motore".M[#K_MotoreInt].Dati.PosImpulsoSetup;
	                    "Motore".M[#K_MotoreInt].Dati.AppoImpEsecSetUP := TRUE;
	                END_IF;
	            END_IF;
	            IF #REQSetup AND NOT #SetUpFermoMeccanico THEN
	                IF "Motore".M[#K_MotoreInt].Dati.ContSetUPEncoder > 300 THEN
	                    IF NOT #SetUpFermoMeccanico THEN
	                        "Motore".M[#K_MotoreInt].Dati.SetupFermoMeccTrovato := false;
	                    END_IF;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Dati.ContSetUPEncoder += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                END_IF;
	            ELSE
	                "Motore".M[#K_MotoreInt].Dati.ContSetUPEncoder := 0;
	            END_IF;
	            IF NOT "Motore".M[#K_MotoreInt].Dati.SetupFermoMeccTrovato THEN
	                "Motore".M[#K_MotoreInt].Dati.AppoImpEsecSetUP := FALSE;
	                IF "Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 4 THEN
	                    "Motore".M[#K_MotoreInt].In.CmdPosRich := true;
	                    "Motore".M[#K_MotoreInt].In.CmdVelocitaRich := "Motore".M[#K_MotoreInt].Prm.VelSgancioFrenoPos;
	                    IF "Motore".M[#K_MotoreInt].Out.ActDirPos AND "Motore".M[#K_MotoreInt].Out.ActPos <= "Motore".M[#K_MotoreInt].Dati.MaxPosRicercaFermoMeccanico THEN
	                        "Motore".M[#K_MotoreInt].Dati.ContFermoMeccTrovato += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                    ELSE
	                        "Motore".M[#K_MotoreInt].Dati.MaxPosRicercaFermoMeccanico := "Motore".M[#K_MotoreInt].Out.ActPos;
	                        "Motore".M[#K_MotoreInt].Dati.ContFermoMeccTrovato := 0;
	                    END_IF;
	                ELSE
	                    "Motore".M[#K_MotoreInt].In.CmdNegRich := true;
	                    "Motore".M[#K_MotoreInt].In.CmdVelocitaRich := "Motore".M[#K_MotoreInt].Prm.VelSgancioFrenoNeg;
	                    IF "Motore".M[#K_MotoreInt].Out.ActDirNeg AND "Motore".M[#K_MotoreInt].Out.ActPos >= "Motore".M[#K_MotoreInt].Dati.MaxPosRicercaFermoMeccanico THEN
	                        "Motore".M[#K_MotoreInt].Dati.ContFermoMeccTrovato += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                    ELSE
	                        "Motore".M[#K_MotoreInt].Dati.MaxPosRicercaFermoMeccanico := "Motore".M[#K_MotoreInt].Out.ActPos;
	                        "Motore".M[#K_MotoreInt].Dati.ContFermoMeccTrovato := 0;
	                    END_IF;
	                END_IF;
	                "Motore".M[#K_MotoreInt].Dati.SetupFermoMeccTrovato := "Motore".M[#K_MotoreInt].Dati.ContFermoMeccTrovato > 500;
	                "Motore".M[#K_MotoreInt].Dati.PosImpulsoSetup := "Motore".M[#K_MotoreInt].Dati.MaxPosRicercaFermoMeccanico;
	                "Motore".M[#K_MotoreInt].Dati.ContCheckFollowError := 0;
	            ELSE
	                "Motore".M[#K_MotoreInt].In.CmdPosRich := "Motore".M[#K_MotoreInt].In.CmdNegRich := "Motore".M[#K_MotoreInt].In.Positioning := false;
	            END_IF;
	        END_IF;
	    END_REGION
	    REGION Gestione Encoder
	        (* Gestisco l'Allarme di Setup Eseguito per memorizzare su HMI l'esecuzione del Setuo*)
	        IF "Motore".M[#K_MotoreInt].Allarmi.SetupEncoderEseg THEN
	            "Motore".M[#K_MotoreInt].Dati.ContSegnSetup += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	            IF "Motore".M[#K_MotoreInt].Dati.ContSegnSetup > 3000 THEN
	                "Motore".M[#K_MotoreInt].Allarmi.SetupEncoderEseg := false;
	                "Motore".M[#K_MotoreInt].Dati.ContSegnSetup := 0;
	            END_IF;
	        END_IF;
	        (* Una volta selezionato su HMI il Setup, se non avviene entro 3 secondi viene deselezionato *)
	        IF "Motore".M[#K_MotoreInt].HMI.Setup AND NOT #REQSetupPannello THEN
	            "Motore".M[#K_MotoreInt].Dati.ContTORichSetup += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	            IF "Motore".M[#K_MotoreInt].Dati.ContTORichSetup > 3000 THEN
	                "Motore".M[#K_MotoreInt].HMI.Setup := false;
	            END_IF;
	        ELSE
	            "Motore".M[#K_MotoreInt].Dati.ContTORichSetup := 0;
	        END_IF;
	        IF NOT "Motore".M[#K_MotoreInt].Prm.Enc.EncoderLess THEN
	            (* Richiamo la gestione dell'Encoder *)
	            IF "Motore".M[#K_MotoreInt].Prm.Enc.Mounting <> 11 THEN
	                REGION CalcoloPosizioneSetup
	                    IF #REQSetup THEN
	                        CASE "Motore".M[#K_MotoreInt].Prm.Enc.SetupMode OF
	                            0: // Encoder HMI
	                                IF "Motore".M[#K_MotoreInt].Prm.Enc.SetupDoppio THEN
	                                    #TempEnc.AppoSetupRich := "Motore".M[#K_MotoreInt].HMI.ValoreSetupEncoder * 2;
	                                ELSE
	                                    #TempEnc.#AppoSetupRich := "Motore".M[#K_MotoreInt].HMI.ValoreSetupEncoder;
	                                END_IF;
	                                IF NOT "Motore".M[#K_MotoreInt].Prm.Enc.ModoCalcoloK THEN
	                                    "Motore".M[#K_MotoreInt].HMI.ValoreSetupRichiesto := "Motore".M[#K_MotoreInt].Prm.Enc.KSetup + #TempEnc.AppoSetupRich;
	                                ELSE
	                                    "Motore".M[#K_MotoreInt].HMI.ValoreSetupRichiesto := "Motore".M[#K_MotoreInt].Prm.Enc.KSetup - #TempEnc.AppoSetupRich;
	                                END_IF;
	                            1: // Encoder Esterno
	                                "Motore".M[#K_MotoreInt].HMI.ValoreSetupRichiesto := "Motore".M[#K_MotoreInt].In.ValoSetupEnc;
	                            2, 10: // Ricerca Sensore 
	                                "Motore".M[#K_MotoreInt].HMI.ValoreSetupRichiesto := "Motore".M[#K_MotoreInt].HMI.ValoreSetupSensore + "Motore".M[#K_MotoreInt].Dati.Encoder.ValoKSetupSuSens;
	                            4, 12: // Ricerca Coppia
	                                "Motore".M[#K_MotoreInt].HMI.ValoreSetupRichiesto := "Motore".M[#K_MotoreInt].HMI.ValoreSetupSensore + "Motore".M[#K_MotoreInt].Dati.Encoder.ValoKSetupSuSens;
	                        END_CASE;
	                    END_IF;
	                END_REGION
	                REGION Lettura Encoder Dal Campo
	                    CASE "Motore".M[#K_MotoreInt].HW.TipoEncoder OF
	                        1:
	                            "Motore".M[#K_MotoreInt].Dati.Encoder.#RetValRdEnc := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Encoder, RECORD => #TempEnc.RcvDaEncoderSick);
	                            #TempEnc.#PosizioneLettaEnc := DWORD_TO_DINT(IN := SHR(IN := #TempEnc.RcvDaEncoderSick.Position01, N := 2));
	                            #TempEnc.VelocitaLettaEnc := #TempEnc.RcvDaEncoderSick.Speed;
	                            "Motore".M[#K_MotoreInt].Out.VelEncoder := ABS(TRUNC(DINT_TO_REAL(#TempEnc.VelocitaLettaEnc) * "Motore".M[#K_MotoreInt].Prm.C.SpazioGiroEncoder / "Motore".M[#K_MotoreInt].Prm.Enc.ImpRev * 100.0));
	                            IF (#TempEnc.RcvDaEncoderSick.G1_ZSW.%X15 OR #TempEnc.RcvDaEncoderSick.G1_ZSW.%X12) AND NOT #REQSetup THEN
	                                #TempEnc.SendAEncoderSick.G1_STW := 16#0000;
	                                #TempEnc.SendAEncoderSick.G1_STW.%X15 := #TempEnc.RcvDaEncoderSick.G1_ZSW.%X15;
	                                #TempEnc.SendAEncoderSick.STW2_ENC := 16#400;
	                                "Motore".M[#K_MotoreInt].Dati.Encoder.#RetValScrEnc := DPWR_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Encoder, RECORD := #TempEnc.SendAEncoderSick);
	                            END_IF;
	                        9: // Sick Telemetrica
	                            "Motore".M[#K_MotoreInt].Prm.Enc.Mounting := USint#1;
	                            "Motore".M[#K_MotoreInt].Dati.Encoder.#RetValRdEnc := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Encoder, RECORD => #TempTelem.RcvDaEncoder);
	                            "Motore".M[#K_MotoreInt].Dati.Encoder.#RetValRdEnc := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_PrmEncoder, RECORD => #TempTelem.RcvDaEncoder.Status);
	                            // Valore arriva in decimi di mm (*100 = converto in millesimi di millimetro)
	                            #TempEnc.#PosizioneLettaEnc := DWORD_TO_DINT(#TempTelem.RcvDaEncoder.M05_IN_ActPos * 100);
	                        10:
	                            "Motore".M[#K_MotoreInt].Dati.Encoder.#RetValRdEnc := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Encoder, RECORD => #TempEnc.#RcvDaEncoder_Ottico);
	                            #TempEnc.#PosizioneLettaEnc := #TempEnc.#RcvDaEncoder_Ottico.Posizione;
	                        11:
	                            "Motore".M[#K_MotoreInt].Dati.Encoder.#RetValRdEnc := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Encoder, RECORD => #TempEnc.#RcvDaEncoder_Magnetico);
	                            #TempEnc.#PosizioneLettaEnc := #TempEnc.#RcvDaEncoder_Magnetico.Posizione;
	                    END_CASE;
	                    "Motore".M[#K_MotoreInt].In.NoComunEnc := "Motore".M[#K_MotoreInt].Dati.Encoder.#RetValRdEnc <> 0 OR #TempEnc.#PosizioneLettaEnc = 0;
	                END_REGION
	                IF NOT "Motore".M[#K_MotoreInt].Prm.Mech.EndLess THEN
	                    REGION Gestione Encoder
	                        REGION CalcoloPosizione
	                            IF NOT "Motore".M[#K_MotoreInt].In.NoComunEnc THEN
	                                IF NOT "Motore".M[#K_MotoreInt].Prm.Enc.Direction THEN
	                                    IF "Motore".M[#K_MotoreInt].HW.TipoEncoder = 9 THEN
	                                        // Se Telemetrica (=9) Cambio Calcolo
	                                        IF #TempEnc.PosizioneLettaEnc <> 0 THEN
	                                            "Motore".M[#K_MotoreInt].Prm.C.EncPos := DINT_TO_REAL(#TempEnc.#PosizioneLettaEnc);
	                                        ELSE
	                                            "Motore".M[#K_MotoreInt].Allarmi.EncMismatch := true;
	                                        END_IF;
	                                    ELSE
	                                        "Motore".M[#K_MotoreInt].Prm.C.EncPos := DINT_TO_REAL(#TempEnc.PosizioneLettaEnc - "Motore".M[#K_MotoreInt].Dati.Encoder.MezzoRicircoloEncoder) / "Motore".M[#K_MotoreInt].Prm.Enc.ImpRev * "Motore".M[#K_MotoreInt].Prm.C.SpazioGiroEncoder;
	                                    END_IF;
	                                ELSE
	                                    IF "Motore".M[#K_MotoreInt].HW.TipoEncoder = 9 THEN
	                                        // Se Telemetrica (=9) Cambio Calcolo
	                                        IF #TempEnc.PosizioneLettaEnc <> 0 THEN
	                                            "Motore".M[#K_MotoreInt].Prm.C.EncPos := DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Enc.KSetup - #TempEnc.#PosizioneLettaEnc);
	                                        ELSE
	                                            "Motore".M[#K_MotoreInt].Allarmi.EncMismatch := true;
	                                        END_IF;
	                                    ELSE
	                                        "Motore".M[#K_MotoreInt].Prm.C.EncPos := DINT_TO_REAL(- #TempEnc.PosizioneLettaEnc + "Motore".M[#K_MotoreInt].Dati.Encoder.MezzoRicircoloEncoder) / "Motore".M[#K_MotoreInt].Prm.Enc.ImpRev * "Motore".M[#K_MotoreInt].Prm.C.SpazioGiroEncoder;
	                                    END_IF;
	                                END_IF;
	                            END_IF;
	                        END_REGION
	                        REGION Gestione Setup Encoder
	                            IF #REQSetup THEN
	                                IF NOT "Motore".M[#K_MotoreInt].Dati.Encoder.RichSetupEnc THEN
	                                    "Motore".M[#K_MotoreInt].Out.EncoderHomed := false;
	                                END_IF;
	                                IF NOT "Motore".M[#K_MotoreInt].Prm.Enc.Direction THEN
	                                    #TempEnc.#AppoSetupEncoder := DINT_TO_UDINT(TRUNC(DINT_TO_REAL("Motore".M[#K_MotoreInt].HMI.ValoreSetupRichiesto) / "Motore".M[#K_MotoreInt].Prm.C.SpazioGiroEncoder * "Motore".M[#K_MotoreInt].Prm.Enc.ImpRev) + "Motore".M[#K_MotoreInt].Dati.Encoder.MezzoRicircoloEncoder);
	                                ELSE
	                                    #TempEnc.#AppoSetupEncoder := DINT_TO_UDINT(TRUNC(DINT_TO_REAL(- "Motore".M[#K_MotoreInt].HMI.ValoreSetupRichiesto) / "Motore".M[#K_MotoreInt].Prm.C.SpazioGiroEncoder * "Motore".M[#K_MotoreInt].Prm.Enc.ImpRev) + "Motore".M[#K_MotoreInt].Dati.Encoder.MezzoRicircoloEncoder);
	                                END_IF;
	                                IF "Motore".M[#K_MotoreInt].HW.TipoEncoder = 9 THEN
	                                    IF NOT "Motore".M[#K_MotoreInt].Prm.Enc.ModoCalcoloK THEN
	                                        #TempEnc.#AppoSetupEncoder := DINT_TO_UDINT("Motore".M[#K_MotoreInt].HMI.ValoreSetupRichiesto);
	                                    ELSE
	                                        #TempEnc.#AppoSetupEncoder := DINT_TO_UDINT("Motore".M[#K_MotoreInt].HMI.ValoreSetupEncoder);
	                                    END_IF;
	                                END_IF;
	                                IF #TempEnc.PosizioneLettaEnc <> #TempEnc.#AppoSetupEncoder OR #TempEnc.RcvDaEncoderSick.G1_ZSW.%X12 THEN
	                                    CASE "Motore".M[#K_MotoreInt].HW.TipoEncoder OF
	                                        1:
	                                            #TempEnc.#arrRecord[0] := 1;
	                                            #TempEnc.#arrRecord[1] := 2; (*Request ID = Change parameter*)
	                                            #TempEnc.#arrRecord[2] := 0; (*DO-ID*)
	                                            #TempEnc.#arrRecord[3] := 1; (*No. of parameters*)
	                                            #TempEnc.#arrRecord[4] := 16#10; (*Attribute = Value*)
	                                            #TempEnc.#arrRecord[5] := 0; (*No. of elements*)
	                                            #TempEnc.#arrRecord[6] := 16#fd; (*PNU high byte*)
	                                            #TempEnc.#arrRecord[7] := 16#e8; (*PNU low byte*)
	                                            #TempEnc.#arrRecord[8] := 0; (*Subindex high byte*)
	                                            #TempEnc.#arrRecord[9] := 0; (*Subindex low byte*)
	                                            #TempEnc.#arrRecord[10] := 16#43;
	                                            #TempEnc.#arrRecord[11] := 1;
	                                            #TempEnc.#arrRecord[12] := #TempEnc.#AppoSetupEncoder.%B3;
	                                            #TempEnc.#arrRecord[13] := #TempEnc.#AppoSetupEncoder.%B2;
	                                            #TempEnc.#arrRecord[14] := #TempEnc.#AppoSetupEncoder.%B1;
	                                            #TempEnc.#arrRecord[15] := #TempEnc.#AppoSetupEncoder.%B0;
	                              
	                              "WRREC"(REQ := "Motore".M[#K_MotoreInt].Dati.Encoder.RichSetupEnc AND NOT "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.BUSY AND NOT "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.DONE AND NOT "Motore".M[#K_MotoreInt].Dati.Encoder.PrmEncSend,
	                                      ID := "Motore".M[#K_MotoreInt].HW.HWIO_PrmEncoder,
	                                      INDEX := 16#B02E,
	                                      LEN := 16,
	                                      DONE => "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.DONE,
	                                      BUSY => "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.BUSY,
	                                      ERROR => "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.ERROR,
	                                      STATUS => "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.STATUS,
	                                      RECORD := #TempEnc.#arrRecord);
	                             
	                              IF "Motore".M[#K_MotoreInt].Dati.Encoder.RichSetupEnc THEN
	                                  IF "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.DONE THEN
	                                                    "Motore".M[#K_MotoreInt].Dati.Encoder.PrmEncSend := true;
	                                                END_IF;
	                                            ELSE
	                                                "Motore".M[#K_MotoreInt].Dati.Encoder.PrmEncSend := false;
	                                            END_IF;
	                                            IF "Motore".M[#K_MotoreInt].Dati.Encoder.PrmEncSend AND NOT #TempEnc.RcvDaEncoderSick.G1_ZSW.%X12 THEN
	                                                #TempEnc.SendAEncoderSick.G1_STW := 16#1000;
	                                            ELSE
	                                                #TempEnc.SendAEncoderSick.G1_STW := 0;
	                                            END_IF;
	                                            #TempEnc.SendAEncoderSick.STW2_ENC := 16#400;
	                                            "Motore".M[#K_MotoreInt].Dati.Encoder.#RetValScrEnc := DPWR_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Encoder, RECORD := #TempEnc.SendAEncoderSick);
	                                        9: // Setup Telemetrica
	                                            // Divido Valore per 100 per scrivere Valore in Decimi di mm
	                                            #TempTelem.SendAEncode.M05_OUT_Preset := UDINT_TO_DWORD(IN := #TempEnc.#AppoSetupEncoder / 100);
	                                            // Alzo bit richiesta Setup
	                                            #TempTelem.SendAEncode.M05_OUT_Preset.%X31 := TRUE;
	                                            "Motore".M[#K_MotoreInt].Dati.Encoder.#RetValScrEnc := DPWR_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Encoder, RECORD := #TempTelem.SendAEncode);
	                                            "Motore".M[#K_MotoreInt].Dati.Encoder.#RichSetupEnc := true;
	                                        10:
	                                            #TempEnc.#AppoScrEncoder := (#TempEnc.#AppoSetupEncoder) OR dw#16#C0000000;
	                              
	                              "WRREC"(REQ := "Motore".M[#K_MotoreInt].Dati.Encoder.RichSetupEnc AND NOT "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.BUSY AND NOT "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.DONE,
	                                      ID := "Motore".M[#K_MotoreInt].HW.HWIO_PrmEncoder,
	                                      INDEX := 2,
	                                      LEN := 4,
	                                      DONE => "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.DONE,
	                                      BUSY => "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.BUSY,
	                                      ERROR => "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.ERROR,
	                                      STATUS => "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.STATUS,
	                                      RECORD := #TempEnc.AppoScrEncoder);
	                              
	                                        11:
	                                            #TempEnc.#AppoScrEncoder := #TempEnc.#AppoSetupEncoder;
	                                            "WRREC"(REQ := "Motore".M[#K_MotoreInt].Dati.Encoder.RichSetupEnc AND NOT "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.BUSY AND NOT "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.DONE,
	                                                    ID := "Motore".M[#K_MotoreInt].HW.HWIO_PrmEncoder,
	                                                    INDEX := 2,
	                                                    LEN := 4,
	                                                    DONE => "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.DONE,
	                                                    BUSY => "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.BUSY,
	                                                    ERROR => "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.ERROR,
	                                                    STATUS => "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.STATUS,
	                                                    RECORD := #TempEnc.AppoScrEncoder);
	                              
	                                    END_CASE;
	                                    "Motore".M[#K_MotoreInt].Dati.Encoder.#RichSetupEnc := true;
	                                ELSE
	                                    "Motore".M[#K_MotoreInt].Out.EncoderHomed := true;
	                                END_IF;
	                            ELSE
	                                IF "Motore".M[#K_MotoreInt].Dati.Encoder.RichSetupEnc THEN
	                                    CASE "Motore".M[#K_MotoreInt].HW.TipoEncoder OF
	                                        9:
	                                            #TempTelem.SendAEncode.M05_OUT_Preset := 0;
	                                            "Motore".M[#K_MotoreInt].Dati.Encoder.#RetValScrEnc := DPWR_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Encoder, RECORD := #TempTelem.SendAEncode);
	                                    END_CASE;
	                                    "Motore".M[#K_MotoreInt].Dati.Encoder.RichSetupEnc := false;
	                                END_IF;
	                            END_IF;
	                        END_REGION
	                    END_REGION
	                ELSE
	                    REGION Gestione Encoder EndLess
	                        REGION Gestione Setup Encoder
	                            IF #REQSetup THEN
	                                "Motore".M[#K_MotoreInt].Out.EncoderHomed := true;
	                                "Motore".M[#K_MotoreInt].Prm.C.EncPos := DINT_TO_REAL("Motore".M[#K_MotoreInt].HMI.ValoreSetupRichiesto);
	                                "Motore".M[#K_MotoreInt].In.Setup := false;
	                            END_IF;
	                        END_REGION
	                        REGION REGION CalcoloPosizione
	                            IF NOT "Motore".M[#K_MotoreInt].In.NoComunEnc THEN
	                                #TempEnc.SpazioUltimoCiclo := #TempEnc.PosizioneLettaEnc - "Motore".M[#K_MotoreInt].Dati.Encoder.o_OldPosEncoder;
	                                IF #TempEnc.SpazioUltimoCiclo <> 0 THEN
	                                    IF ABS(#TempEnc.SpazioUltimoCiclo) > "Motore".M[#K_MotoreInt].Dati.Encoder.#MezzoRicircoloEncoder THEN
	                                        IF #TempEnc.PosizioneLettaEnc < "Motore".M[#K_MotoreInt].Dati.Encoder.o_OldPosEncoder THEN
	                                            #TempEnc.SpazioUltimoCiclo := "Motore".M[#K_MotoreInt].Dati.Encoder.#RicircoloEncoder - "Motore".M[#K_MotoreInt].Dati.Encoder.o_OldPosEncoder + #TempEnc.PosizioneLettaEnc;
	                                        ELSE
	                                            #TempEnc.SpazioUltimoCiclo := #TempEnc.PosizioneLettaEnc - "Motore".M[#K_MotoreInt].Dati.Encoder.#RicircoloEncoder - "Motore".M[#K_MotoreInt].Dati.Encoder.o_OldPosEncoder;
	                                        END_IF;
	                                    END_IF;
	                                    "Motore".M[#K_MotoreInt].Dati.Encoder.o_OldPosEncoder := #TempEnc.PosizioneLettaEnc;
	                                    IF NOT "Motore".M[#K_MotoreInt].Prm.Enc.Direction THEN
	                                        "Motore".M[#K_MotoreInt].Prm.C.EncPos += DINT_TO_REAL(#TempEnc.SpazioUltimoCiclo) * "Motore".M[#K_MotoreInt].Prm.C.SpazioGiroEncoder / "Motore".M[#K_MotoreInt].Prm.Enc.ImpRev;
	                                    ELSE
	                                        "Motore".M[#K_MotoreInt].Prm.C.EncPos -= DINT_TO_REAL(#TempEnc.SpazioUltimoCiclo) * "Motore".M[#K_MotoreInt].Prm.C.SpazioGiroEncoder / "Motore".M[#K_MotoreInt].Prm.Enc.ImpRev;
	                                    END_IF;
	                                    IF "Motore".M[#K_MotoreInt].Prm.C.EncPos > DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Enc.ModuloPosEnc) THEN
	                                        "Motore".M[#K_MotoreInt].Prm.C.EncPos -= DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Enc.ModuloPosEnc - "Motore".M[#K_MotoreInt].Prm.Enc.ModuloNegEnc);
	                                    ELSIF "Motore".M[#K_MotoreInt].Prm.C.EncPos < DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Enc.ModuloNegEnc) THEN
	                                        "Motore".M[#K_MotoreInt].Prm.C.EncPos += DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Enc.ModuloPosEnc - "Motore".M[#K_MotoreInt].Prm.Enc.ModuloNegEnc);
	                                    END_IF;
	                                END_IF;
	                            END_IF;
	                        END_REGION
	                    END_REGION
	                END_IF;
	            END_IF;
	            (* Assegnazione dati Posizione Encoder *)
	            "Motore".M[#K_MotoreInt].Out.ActPos := TRUNC("Motore".M[#K_MotoreInt].Prm.C.EncPos);
	            IF #REQSetup THEN
	                "Motore".M[#K_MotoreInt].Dati.PosizioneAlloStop := "Motore".M[#K_MotoreInt].Dati.PosizioneCheckDirezione := "Motore".M[#K_MotoreInt].Dati.TrgPosDint := "Motore".M[#K_MotoreInt].Dati.OldTrgPosDint := "Motore".M[#K_MotoreInt].Dati.OldEncoder := "Motore".M[#K_MotoreInt].Out.ActPos;
	                "Motore".M[#K_MotoreInt].Prm.C.TrgPos := "Motore".M[#K_MotoreInt].Prm.C.EncPos;
	            END_IF;
	        ELSIF #REQSetup THEN
	            (* Gestione Posizione Encoder Simulata *)
	            "Motore".M[#K_MotoreInt].Dati.PosizioneAlloStop := "Motore".M[#K_MotoreInt].Dati.PosizioneCheckDirezione := "Motore".M[#K_MotoreInt].Dati.TrgPosDint := "Motore".M[#K_MotoreInt].Dati.OldTrgPosDint := "Motore".M[#K_MotoreInt].Dati.OldEncoder := "Motore".M[#K_MotoreInt].Out.ActPos := "Motore".M[#K_MotoreInt].HMI.ValoreSetupEncoder;
	            "Motore".M[#K_MotoreInt].Prm.C.TrgPos := "Motore".M[#K_MotoreInt].Prm.C.EncPos := DINT_TO_REAL("Motore".M[#K_MotoreInt].HMI.ValoreSetupEncoder);
	            "Motore".M[#K_MotoreInt].In.Setup := false;
	        END_IF;
	    END_REGION
	    REGION Spazio Ciclo PLC    
	        IF "Motore".M[#K_MotoreInt].Out.ActPos <> "Motore".M[#K_MotoreInt].Dati.OldEncoder THEN
	            "Motore".M[#K_MotoreInt].Out.SpazioCicloEnc := "Motore".M[#K_MotoreInt].Out.ActPos - "Motore".M[#K_MotoreInt].Dati.OldEncoder;
	            IF "Motore".M[#K_MotoreInt].Prm.Mech.EndLess THEN
	                IF ABS("Motore".M[#K_MotoreInt].Out.SpazioCicloEnc) > #MezzoRicircoloTotale THEN
	                    IF "Motore".M[#K_MotoreInt].Dati.OldEncoder > "Motore".M[#K_MotoreInt].Out.ActPos THEN
	                        "Motore".M[#K_MotoreInt].Out.SpazioCicloEnc := "Motore".M[#K_MotoreInt].Prm.Enc.ModuloPosEnc - "Motore".M[#K_MotoreInt].Dati.OldEncoder - "Motore".M[#K_MotoreInt].Prm.Enc.ModuloNegEnc + "Motore".M[#K_MotoreInt].Out.ActPos;
	                    ELSE
	                        "Motore".M[#K_MotoreInt].Out.SpazioCicloEnc := "Motore".M[#K_MotoreInt].Out.ActPos - "Motore".M[#K_MotoreInt].Prm.Enc.ModuloPosEnc + "Motore".M[#K_MotoreInt].Prm.Enc.ModuloNegEnc - "Motore".M[#K_MotoreInt].Dati.OldEncoder;
	                    END_IF;
	                END_IF;
	            END_IF;
	            "Motore".M[#K_MotoreInt].Dati.OldEncoder := "Motore".M[#K_MotoreInt].Out.ActPos;
	        ELSE
	            "Motore".M[#K_MotoreInt].Out.SpazioCicloEnc := 0;
	        END_IF;
	    END_REGION
	END_REGION ;
	REGION Limits
	    "Motore".M[#K_MotoreInt].Allarmi.Parametri := false;
	    REGION Abilita Cambio Direzione    
	        IF "Motore".M[#K_MotoreInt].Prm.TCambioDir = 0 OR "Motore".M[#K_MotoreInt].Prm.CambioDirNoFreno THEN
	            #AbilDirPos := #AbilDirNeg := true;
	            "Motore".M[#K_MotoreInt].Dati.ContCambioDirPos := "Motore".M[#K_MotoreInt].Dati.ContCambioDirNeg := -1;
	        ELSE
	            IF "Motore".M[#K_MotoreInt].Out.ActDirNeg THEN
	                "Motore".M[#K_MotoreInt].Dati.ContCambioDirPos := "Motore".M[#K_MotoreInt].Prm.TCambioDir;
	            ELSIF "Motore".M[#K_MotoreInt].Out.ActDirPos THEN
	                "Motore".M[#K_MotoreInt].Dati.ContCambioDirNeg := "Motore".M[#K_MotoreInt].Prm.TCambioDir;
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].Dati.ContCambioDirPos < 0 THEN
	                #AbilDirPos := true;
	            ELSE
	                "Motore".M[#K_MotoreInt].Dati.ContCambioDirPos -= REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                #AbilDirPos := false;
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].Dati.ContCambioDirNeg < 0 THEN
	                #AbilDirNeg := true;
	            ELSE
	                "Motore".M[#K_MotoreInt].Dati.ContCambioDirNeg -= REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                #AbilDirNeg := false;
	            END_IF;
	        END_IF;
	    END_REGION
	    IF NOT "Motore".M[#K_MotoreInt].Prm.EscludiFunzPos THEN
	        REGION Abilita movimento motore / Posizionamento
	            "Motore".M[#K_MotoreInt].Out.Pronto := FALSE;
	            IF "Zona".Z[#K_Zona].Out.CentralinaOk THEN
	                IF NOT "Motore".M[#K_MotoreInt].In.SezAperto AND NOT "Motore".M[#K_MotoreInt].In.DriverFault AND NOT "Motore".M[#K_MotoreInt].In.NoComunInv THEN
	                    IF NOT "Motore".M[#K_MotoreInt].In.TerVentolaOff AND NOT "Motore".M[#K_MotoreInt].In.CinghiaRotta AND NOT "Motore".M[#K_MotoreInt].In.SpinaSicNoInPos AND ("Motore".M[#K_MotoreInt].In.AnticadutaON OR NOT "Motore".M[#K_MotoreInt].Prm.AnticadutaPresente) THEN
	                        "Motore".M[#K_MotoreInt].Out.Pronto := NOT "Motore".M[#K_MotoreInt].Dati.MotorStop;
	                    ELSIF "Zona".Z[#K_ZonaInt].Out.Man AND "Zona".Z[#K_ZonaInt].Gen.Reset AND ("Motore".M[#K_MotoreInt].In.CmdPosRich OR "Motore".M[#K_MotoreInt].In.CmdNegRich) THEN
	                        "Motore".M[#K_MotoreInt].Out.Pronto := TRUE;
	                    END_IF;
	                END_IF;
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].In.Positioning THEN
	                #FunzPositioning := NOT "Motore".M[#K_MotoreInt].In.CmdPosRich AND NOT "Motore".M[#K_MotoreInt].In.CmdNegRich AND NOT #REQSetupPannello AND "Motore".M[#K_MotoreInt].Out.Pronto AND (NOT "Motore".M[#K_MotoreInt].In.NoComunEnc OR "Motore".M[#K_MotoreInt].Prm.Enc.EncoderLess);
	            ELSE
	                #FunzPositioning := FALSE;
	            END_IF;
	        END_REGION
	        REGION Controllo Limiti
	            IF "Motore".M[#K_MotoreInt].Prm.Mech.EndLess THEN
	(* In caso di Funzionamento EndLess, i limiti di posizione non possono superare gli estremi del ricircolo *)
	                "Motore".M[#K_MotoreInt].Prm.LimitePos := MIN(IN1 := "Motore".M[#K_MotoreInt].Prm.LimitePos, IN2 := "Motore".M[#K_MotoreInt].Prm.Enc.ModuloPosEnc);
	                "Motore".M[#K_MotoreInt].Prm.LimiteNeg := MAX(IN1 := "Motore".M[#K_MotoreInt].Prm.LimiteNeg, IN2 := "Motore".M[#K_MotoreInt].Prm.Enc.ModuloNegEnc);
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].Prm.LimitePos <= "Motore".M[#K_MotoreInt].Prm.LimiteNeg THEN
	                "Motore".M[#K_MotoreInt].Prm.LimitePos := "Motore".M[#K_MotoreInt].Prm.LimiteNeg + 1;
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].In.AttivaLimVarNeg THEN
	                "Motore".M[#K_MotoreInt].In.LimiteVarNeg := MIN(IN1 := "Motore".M[#K_MotoreInt].Prm.LimitePos, IN2 := "Motore".M[#K_MotoreInt].In.LimiteVarNeg);
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].In.AttivaLimVarPos THEN
	                "Motore".M[#K_MotoreInt].In.LimiteVarPos := MAX(IN1 := "Motore".M[#K_MotoreInt].Prm.LimiteNeg, IN2 := "Motore".M[#K_MotoreInt].In.LimiteVarPos);
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].In.AttivaLimVarNeg AND "Motore".M[#K_MotoreInt].In.AttivaLimVarPos THEN
	                IF "Motore".M[#K_MotoreInt].In.LimiteVarPos <= "Motore".M[#K_MotoreInt].In.LimiteVarNeg THEN
	                    "Motore".M[#K_MotoreInt].In.LimiteVarPos := "Motore".M[#K_MotoreInt].In.LimiteVarNeg + 1;
	                END_IF;
	            END_IF;
	        END_REGION
	        REGION Posizione Destinazione Assoluta/Relativa
	            "Motore".M[#K_MotoreInt].Allarmi.TrgPosMaxPos := "Motore".M[#K_MotoreInt].Allarmi.TrgPosMinNeg := "Motore".M[#K_MotoreInt].Allarmi.TrgPosMaxPosVar := "Motore".M[#K_MotoreInt].Allarmi.TrgPosMinNegVar := false;
	            IF "Motore".M[#K_MotoreInt].In.PosRelativo THEN
	                IF NOT "Motore".M[#K_MotoreInt].Dati.AppoImpMovRelativo THEN
	                    "Motore".M[#K_MotoreInt].Out.DistTRG := "Motore".M[#K_MotoreInt].Dati.MovRelRichiesto := "Motore".M[#K_MotoreInt].In.TrgPosRel;
	                END_IF;
	                IF NOT "Motore".M[#K_MotoreInt].Prm.Mech.EndLess THEN
	                    IF "Motore".M[#K_MotoreInt].Out.ActPos - "Motore".M[#K_MotoreInt].Out.DistTRG < "Motore".M[#K_MotoreInt].Prm.LimiteNeg THEN
	                        "Motore".M[#K_MotoreInt].Out.DistTRG := "Motore".M[#K_MotoreInt].Dati.MovRelRichiesto := "Motore".M[#K_MotoreInt].Out.ActPos - "Motore".M[#K_MotoreInt].Prm.LimiteNeg;
	                        IF #FunzPositioning THEN
	                            "Motore".M[#K_MotoreInt].Allarmi.Parametri := "Motore".M[#K_MotoreInt].Allarmi.TrgPosMinNeg := TRUE;
	                        END_IF;
	                    END_IF;
	                    IF "Motore".M[#K_MotoreInt].In.AttivaLimVarNeg THEN
	                        IF "Motore".M[#K_MotoreInt].Out.ActPos - "Motore".M[#K_MotoreInt].Out.DistTRG < "Motore".M[#K_MotoreInt].In.LimiteVarNeg THEN
	                            "Motore".M[#K_MotoreInt].Out.DistTRG := "Motore".M[#K_MotoreInt].Dati.MovRelRichiesto := "Motore".M[#K_MotoreInt].Out.ActPos - "Motore".M[#K_MotoreInt].In.LimiteVarNeg;
	                            IF #FunzPositioning THEN
	                                "Motore".M[#K_MotoreInt].Allarmi.Parametri := "Motore".M[#K_MotoreInt].Allarmi.TrgPosMinNegVar := TRUE;
	                            END_IF;
	                        END_IF;
	                    END_IF;
	                    IF "Motore".M[#K_MotoreInt].Out.ActPos + "Motore".M[#K_MotoreInt].Out.DistTRG > "Motore".M[#K_MotoreInt].Prm.LimitePos THEN
	                        "Motore".M[#K_MotoreInt].Out.DistTRG := "Motore".M[#K_MotoreInt].Dati.MovRelRichiesto := "Motore".M[#K_MotoreInt].Prm.LimitePos - "Motore".M[#K_MotoreInt].Out.ActPos;
	                        IF #FunzPositioning THEN
	                            "Motore".M[#K_MotoreInt].Allarmi.Parametri := "Motore".M[#K_MotoreInt].Allarmi.TrgPosMaxPos := TRUE;
	                        END_IF;
	                    END_IF;
	                    IF "Motore".M[#K_MotoreInt].In.AttivaLimVarPos THEN
	                        IF "Motore".M[#K_MotoreInt].Out.ActPos + "Motore".M[#K_MotoreInt].Out.DistTRG > "Motore".M[#K_MotoreInt].In.LimiteVarPos THEN
	                            "Motore".M[#K_MotoreInt].Out.DistTRG := "Motore".M[#K_MotoreInt].Dati.MovRelRichiesto := "Motore".M[#K_MotoreInt].In.LimiteVarPos - "Motore".M[#K_MotoreInt].Out.ActPos;
	                            IF #FunzPositioning THEN
	                                "Motore".M[#K_MotoreInt].Allarmi.Parametri := "Motore".M[#K_MotoreInt].Allarmi.TrgPosMaxPosVar := TRUE;
	                            END_IF;
	                        END_IF;
	                    END_IF;
	                    "Motore".M[#K_MotoreInt].Dati.MovRelRichiesto := ABS("Motore".M[#K_MotoreInt].Dati.MovRelRichiesto);
	                END_IF;
	            ELSE
	                "Motore".M[#K_MotoreInt].Out.TrgPosFiltrata := "Motore".M[#K_MotoreInt].In.TrgPos;
	                IF "Motore".M[#K_MotoreInt].Out.TrgPosFiltrata < "Motore".M[#K_MotoreInt].Prm.LimiteNeg THEN
	                    "Motore".M[#K_MotoreInt].Out.TrgPosFiltrata := "Motore".M[#K_MotoreInt].Prm.LimiteNeg;
	                    IF #FunzPositioning THEN
	                        "Motore".M[#K_MotoreInt].Allarmi.Parametri := "Motore".M[#K_MotoreInt].Allarmi.TrgPosMinNeg := TRUE;
	                    END_IF;
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].In.AttivaLimVarNeg THEN
	                    IF "Motore".M[#K_MotoreInt].Out.TrgPosFiltrata < "Motore".M[#K_MotoreInt].In.LimiteVarNeg THEN
	                        "Motore".M[#K_MotoreInt].Out.TrgPosFiltrata := "Motore".M[#K_MotoreInt].In.LimiteVarNeg;
	                        IF #FunzPositioning THEN
	                            "Motore".M[#K_MotoreInt].Allarmi.Parametri := "Motore".M[#K_MotoreInt].Allarmi.TrgPosMinNegVar := TRUE;
	                        END_IF;
	                    END_IF;
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].Out.TrgPosFiltrata > "Motore".M[#K_MotoreInt].Prm.LimitePos THEN
	                    "Motore".M[#K_MotoreInt].Out.TrgPosFiltrata := "Motore".M[#K_MotoreInt].Prm.LimitePos;
	                    IF #FunzPositioning THEN
	                        "Motore".M[#K_MotoreInt].Allarmi.Parametri := "Motore".M[#K_MotoreInt].Allarmi.TrgPosMaxPos := TRUE;
	                    END_IF;
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].In.AttivaLimVarPos THEN
	                    IF "Motore".M[#K_MotoreInt].Out.TrgPosFiltrata > "Motore".M[#K_MotoreInt].In.LimiteVarPos THEN
	                        "Motore".M[#K_MotoreInt].Out.TrgPosFiltrata := "Motore".M[#K_MotoreInt].In.LimiteVarPos;
	                        IF #FunzPositioning THEN
	                            "Motore".M[#K_MotoreInt].Allarmi.Parametri := "Motore".M[#K_MotoreInt].Allarmi.TrgPosMaxPosVar := TRUE;
	                        END_IF;
	                    END_IF;
	                END_IF;
	            END_IF;
	            "Motore".M[#K_MotoreInt].Dati.AppoImpMovRelativo := "Motore".M[#K_MotoreInt].In.PosRelativo;
	        END_REGION
	        REGION Calcolo La Distanza Dal Target
	            IF NOT "Motore".M[#K_MotoreInt].In.PosRelativo THEN
	                "Motore".M[#K_MotoreInt].Out.DistTRG := "Motore".M[#K_MotoreInt].Out.TrgPosFiltrata - "Motore".M[#K_MotoreInt].Out.ActPos;
	                IF "Motore".M[#K_MotoreInt].Prm.Mech.EndLess THEN
	                    IF (#RicircoloTotale - "Motore".M[#K_MotoreInt].Out.DistTRG) < "Motore".M[#K_MotoreInt].Prm.Precisione THEN
	                        "Motore".M[#K_MotoreInt].Out.DistTRG := #RicircoloTotale - "Motore".M[#K_MotoreInt].Out.DistTRG;
	                    END_IF;
	                    IF #RicircoloTotale + "Motore".M[#K_MotoreInt].Out.DistTRG < "Motore".M[#K_MotoreInt].Prm.Precisione THEN
	                        "Motore".M[#K_MotoreInt].Out.DistTRG := #RicircoloTotale + "Motore".M[#K_MotoreInt].Out.DistTRG;
	                    END_IF;
	                    IF "Motore".M[#K_MotoreInt].In.ForzaEndLessPos THEN
	                        IF "Motore".M[#K_MotoreInt].Out.DistTRG < - "Motore".M[#K_MotoreInt].Prm.Precisione THEN
	                            "Motore".M[#K_MotoreInt].Out.DistTRG := "Motore".M[#K_MotoreInt].Out.DistTRG + #RicircoloTotale;
	                        END_IF;
	                    ELSIF "Motore".M[#K_MotoreInt].In.ForzaEndLessNeg THEN
	                        IF "Motore".M[#K_MotoreInt].Out.DistTRG > "Motore".M[#K_MotoreInt].Prm.Precisione THEN
	                            "Motore".M[#K_MotoreInt].Out.DistTRG := "Motore".M[#K_MotoreInt].Out.DistTRG - #RicircoloTotale;
	                        END_IF;
	                    ELSIF "Motore".M[#K_MotoreInt].In.ForzaEndLessBreve THEN
	                        IF "Motore".M[#K_MotoreInt].Out.DistTRG > #MezzoRicircoloTotale THEN
	                            "Motore".M[#K_MotoreInt].Out.DistTRG := "Motore".M[#K_MotoreInt].Out.DistTRG - #RicircoloTotale;
	                        ELSIF "Motore".M[#K_MotoreInt].Out.DistTRG < - #MezzoRicircoloTotale THEN
	                            "Motore".M[#K_MotoreInt].Out.DistTRG := "Motore".M[#K_MotoreInt].Out.DistTRG + #RicircoloTotale;
	                        END_IF;
	                    END_IF;
	                END_IF;
	            ELSE
	                "Motore".M[#K_MotoreInt].Out.DistTRG -= "Motore".M[#K_MotoreInt].Out.SpazioCicloEnc;
	            END_IF;
	            #DistTRG_ASS := ABS("Motore".M[#K_MotoreInt].Out.DistTRG);
	        END_REGION
	        REGION Time-Out Motore in Posizione
	            #DistTrgMagPrec := "Motore".M[#K_MotoreInt].Out.DistTRG > "Motore".M[#K_MotoreInt].Prm.Precisione;
	            #DistTrgMinPrec := "Motore".M[#K_MotoreInt].Out.DistTRG < - "Motore".M[#K_MotoreInt].Prm.Precisione;
	            IF NOT #DistTrgMagPrec AND NOT #DistTrgMinPrec THEN
	                IF "Motore".M[#K_MotoreInt].Dati.ContMotoreInPrec < 2000 THEN
	                    "Motore".M[#K_MotoreInt].Dati.ContMotoreInPrec += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                ELSE
	                    #RitMotInPrecisione := true;
	                END_IF;
	            ELSE
	                #RitMotInPrecisione := FALSE;
	                "Motore".M[#K_MotoreInt].Dati.ContMotoreInPrec := 0;
	            END_IF;
	        END_REGION
	        REGION Direzione Richiesta da Posizionatore
	            IF "Motore".M[#K_MotoreInt].Out.DistTRG > "Motore".M[#K_MotoreInt].Prm.SpazioArrestoPos THEN
	                IF #DistTrgMagPrec THEN
	                    "Motore".M[#K_MotoreInt].Out.RichMovPos := TRUE;
	                ELSIF #RitMotInPrecisione THEN
	                    "Motore".M[#K_MotoreInt].Out.RichMovPos := FALSE;
	                END_IF;
	                "Motore".M[#K_MotoreInt].Out.RichMovNeg := FALSE;
	                "Motore".M[#K_MotoreInt].Out.PosOK := NOT "Motore".M[#K_MotoreInt].Out.RichMovPos;
	            ELSIF "Motore".M[#K_MotoreInt].Out.DistTRG < - "Motore".M[#K_MotoreInt].Prm.SpazioArrestoNeg THEN
	                IF #DistTrgMinPrec THEN
	                    "Motore".M[#K_MotoreInt].Out.RichMovNeg := TRUE;
	                ELSIF #RitMotInPrecisione THEN
	                    "Motore".M[#K_MotoreInt].Out.RichMovNeg := FALSE;
	                END_IF;
	                "Motore".M[#K_MotoreInt].Out.RichMovPos := FALSE;
	                "Motore".M[#K_MotoreInt].Out.PosOK := NOT "Motore".M[#K_MotoreInt].Out.RichMovNeg;
	            ELSE
	                "Motore".M[#K_MotoreInt].Out.RichMovPos := FALSE;
	                "Motore".M[#K_MotoreInt].Out.RichMovNeg := FALSE;
	                "Motore".M[#K_MotoreInt].Out.PosOK := TRUE;
	            END_IF;
	        END_REGION
	        REGION Adattamento Perc.In Lavoro
	            #CambioPercLavoro := "Motore".M[#K_MotoreInt].Dati.Memo_PercentualeRich <> "Motore".M[#K_MotoreInt].In.PercentualeRichiesta;
	            IF #CambioPercLavoro THEN
	                IF "Motore".M[#K_MotoreInt].In.PercentualeRichiesta < 20 OR "Motore".M[#K_MotoreInt].In.PercentualeRichiesta > 100 THEN
	                    "Motore".M[#K_MotoreInt].In.PercentualeRichiesta := 100;
	                END_IF;
	                "Motore".M[#K_MotoreInt].Dati.Memo_PercentualeRich := "Motore".M[#K_MotoreInt].In.PercentualeRichiesta;
	            END_IF;
	(* Controllo cambio VelocitÃ  Richiesta *)
	            #CambioReqVel := "Motore".M[#K_MotoreInt].Dati.Memo_Req_Vel <> "Motore".M[#K_MotoreInt].In.CmdVelocitaRich OR #CambioPercLavoro OR "Motore".M[#K_MotoreInt].Allarmi.TrgVelMinFreno OR "Motore".M[#K_MotoreInt].Allarmi.TrgVelMaxMax;
	            IF #CambioReqVel THEN
	                "Motore".M[#K_MotoreInt].Dati.Memo_Req_Vel := "Motore".M[#K_MotoreInt].In.CmdVelocitaRich;
	                "Motore".M[#K_MotoreInt].Dati.VeloRichPerc := "Motore".M[#K_MotoreInt].Dati.Memo_Req_Vel * "Motore".M[#K_MotoreInt].In.PercentualeRichiesta / DINT#100;
	            END_IF;
	(* Controllo Cambio Accelerazione richiesta *)
	            #CambioReqAcc := "Motore".M[#K_MotoreInt].Dati.Memo_Req_Acc <> "Motore".M[#K_MotoreInt].In.Acc OR #CambioPercLavoro OR "Motore".M[#K_MotoreInt].Allarmi.AccRichZero OR "Motore".M[#K_MotoreInt].Allarmi.AccRichMaxMaxDec;
	            IF #CambioReqAcc THEN
	                "Motore".M[#K_MotoreInt].Dati.Memo_Req_Acc := MAX(IN1 := "Motore".M[#K_MotoreInt].In.Acc, IN2 := 10);
	                "Motore".M[#K_MotoreInt].Dati.AccRichPerc := "Motore".M[#K_MotoreInt].Dati.Memo_Req_Acc * "Motore".M[#K_MotoreInt].In.PercentualeRichiesta / DINT#100;
	            END_IF;
	(* Controllo Cambio Decelerazione richiesta *)
	            #CambioReqDec := "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec <> "Motore".M[#K_MotoreInt].In.Dec OR #CambioPercLavoro OR "Motore".M[#K_MotoreInt].Allarmi.DecRichZero OR "Motore".M[#K_MotoreInt].Allarmi.DecRichMaxMaxDec;
	            IF #CambioReqDec THEN
	                "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec := MAX(IN1 := "Motore".M[#K_MotoreInt].In.Dec, IN2 := 10);
	                "Motore".M[#K_MotoreInt].Dati.DecRichPerc := "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec * "Motore".M[#K_MotoreInt].In.PercentualeRichiesta / DINT#100;
	            END_IF;
	        END_REGION
	        #VeloBassaConv := DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.VelBassa);
	        REGION Direzione Movimento Richiesta
	            IF ("Motore".M[#K_MotoreInt].Out.RichMovPos AND "Motore".M[#K_MotoreInt].In.ConsMovimentoPos AND #FunzPositioning OR "Motore".M[#K_MotoreInt].In.CmdPosRich) AND "Motore".M[#K_MotoreInt].Out.Pronto AND #AbilDirPos THEN
	                #ReqDirPos := TRUE;
	                #ReqDirNeg := FALSE;
	                #UnaDirezioneRichiesta := TRUE;
	            ELSIF ("Motore".M[#K_MotoreInt].Out.RichMovNeg AND "Motore".M[#K_MotoreInt].In.ConsMovimentoNeg AND #FunzPositioning OR "Motore".M[#K_MotoreInt].In.CmdNegRich) AND "Motore".M[#K_MotoreInt].Out.Pronto AND #AbilDirNeg THEN
	                #ReqDirPos := FALSE;
	                #ReqDirNeg := TRUE;
	                #UnaDirezioneRichiesta := TRUE;
	            ELSE
	                #ReqDirPos := FALSE;
	                #ReqDirNeg := FALSE;
	                #UnaDirezioneRichiesta := FALSE;
	            END_IF;
	        END_REGION
	        REGION Posizione PiÃ¹ e Meno Inerzia
	            "Motore".M[#K_MotoreInt].Out.ActPosPiuInerzia := "Motore".M[#K_MotoreInt].Out.ActPos + "Motore".M[#K_MotoreInt].Prm.Inerzia;
	            "Motore".M[#K_MotoreInt].Out.ActPosMenoInerzia := "Motore".M[#K_MotoreInt].Out.ActPos - "Motore".M[#K_MotoreInt].Prm.Inerzia;
	            "Motore".M[#K_MotoreInt].Out.MinTrg := "Motore".M[#K_MotoreInt].Out.DistTRG > "Motore".M[#K_MotoreInt].Prm.Inerzia;
	            "Motore".M[#K_MotoreInt].Out.MaxTrg := "Motore".M[#K_MotoreInt].Out.DistTRG < - "Motore".M[#K_MotoreInt].Prm.Inerzia;
	            "Motore".M[#K_MotoreInt].Out.ActInInerzia := NOT "Motore".M[#K_MotoreInt].Out.MinTrg AND NOT "Motore".M[#K_MotoreInt].Out.MaxTrg;
	            IF "Motore".M[#K_MotoreInt].Prm.Mech.EndLess THEN
	                IF "Motore".M[#K_MotoreInt].Out.ActPosMenoInerzia < "Motore".M[#K_MotoreInt].Prm.Enc.ModuloNegEnc THEN
	                    "Motore".M[#K_MotoreInt].Out.ActPosMenoInerzia += #RicircoloTotale;
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].Out.ActPosPiuInerzia > "Motore".M[#K_MotoreInt].Prm.Enc.ModuloPosEnc THEN
	                    "Motore".M[#K_MotoreInt].Out.ActPosPiuInerzia -= #RicircoloTotale;
	                END_IF;
	            END_IF;
	            "Motore".M[#K_MotoreInt].Out.MaxLimPos := "Motore".M[#K_MotoreInt].Out.ActPosPiuInerzia >= "Motore".M[#K_MotoreInt].Prm.LimitePos;
	            "Motore".M[#K_MotoreInt].Out.MinLimNeg := "Motore".M[#K_MotoreInt].Out.ActPosMenoInerzia <= "Motore".M[#K_MotoreInt].Prm.LimiteNeg;
	        END_REGION
	    ELSE
	        REGION Abilita movimento motore
	            "Motore".M[#K_MotoreInt].Out.Pronto := FALSE;
	            IF "Zona".Z[#K_Zona].Out.CentralinaOk THEN
	                IF NOT "Motore".M[#K_MotoreInt].In.SezAperto AND NOT "Motore".M[#K_MotoreInt].In.DriverFault AND NOT "Motore".M[#K_MotoreInt].In.NoComunInv AND NOT "Motore".M[#K_MotoreInt].In.TerVentolaOff THEN
	                    "Motore".M[#K_MotoreInt].Out.Pronto := TRUE;
	                END_IF;
	            END_IF;
	            #FunzPositioning := FALSE;
	            
	            #CambioReqVel := "Motore".M[#K_MotoreInt].Dati.VeloRichPerc <> "Motore".M[#K_MotoreInt].In.CmdVelocitaRich;
	            IF #CambioReqVel THEN
	                "Motore".M[#K_MotoreInt].Dati.VeloRichPerc := "Motore".M[#K_MotoreInt].In.CmdVelocitaRich;
	            END_IF;
	(* Controllo Cambio Accelerazione richiesta *)
	            #CambioReqAcc := "Motore".M[#K_MotoreInt].Dati.AccRichPerc <> "Motore".M[#K_MotoreInt].In.Acc;
	            IF #CambioReqAcc THEN
	                "Motore".M[#K_MotoreInt].Dati.AccRichPerc := "Motore".M[#K_MotoreInt].In.Acc;
	            END_IF;
	(* Controllo Cambio Decelerazione richiesta *)
	            #CambioReqDec := "Motore".M[#K_MotoreInt].Dati.DecRichPerc <> "Motore".M[#K_MotoreInt].In.Dec;
	            IF #CambioReqDec THEN
	                "Motore".M[#K_MotoreInt].Dati.DecRichPerc := "Motore".M[#K_MotoreInt].In.Dec;
	            END_IF;
	        END_REGION
	        REGION Direzione Movimento Richiesta
	            IF "Motore".M[#K_MotoreInt].In.CmdPosRich AND "Motore".M[#K_MotoreInt].Out.Pronto AND #AbilDirPos THEN
	                #ReqDirPos := TRUE;
	                #ReqDirNeg := FALSE;
	                #UnaDirezioneRichiesta := TRUE;
	            ELSIF "Motore".M[#K_MotoreInt].In.CmdNegRich AND "Motore".M[#K_MotoreInt].Out.Pronto AND #AbilDirNeg THEN
	                #ReqDirPos := FALSE;
	                #ReqDirNeg := TRUE;
	                #UnaDirezioneRichiesta := TRUE;
	            ELSE
	                #ReqDirPos := FALSE;
	                #ReqDirNeg := FALSE;
	                #UnaDirezioneRichiesta := FALSE;
	            END_IF;
	        END_REGION
	    END_IF;
	END_REGION ;
	REGION Parameter profile
	    REGION Velocità  Minima
	        IF NOT "Motore".M[#K_MotoreInt].Dati.ActVelPos AND NOT "Motore".M[#K_MotoreInt].Dati.ActVelNeg AND #ReqDirNeg OR "Motore".M[#K_MotoreInt].Dati.ActVelNeg THEN
	            #SpazioFrenoDir := "Motore".M[#K_MotoreInt].Prm.SpazioArrestoNeg;
	            #VeloFrenoDir := "Motore".M[#K_MotoreInt].Prm.VelSgancioFrenoNeg;
	        ELSE
	            #SpazioFrenoDir := "Motore".M[#K_MotoreInt].Prm.SpazioArrestoPos;
	            #VeloFrenoDir := "Motore".M[#K_MotoreInt].Prm.VelSgancioFrenoPos;
	        END_IF;
	    END_REGION
	    REGION Controllo Velocità 
	        (* Controllo che la velocitÃ  sia all'interno del limite Sgancio Freno < VeloRich < VeloMax *)
	        "Motore".M[#K_MotoreInt].Allarmi.TrgVelMinFreno := false;
	        "Motore".M[#K_MotoreInt].Allarmi.TrgVelMaxMax := false;
	        "Motore".M[#K_MotoreInt].Allarmi.TrgVelCamMinFreno := false;
	        "Motore".M[#K_MotoreInt].Allarmi.TrgVelCamMaxMax := false;
	        IF #UnaDirezioneRichiesta THEN
	            IF "Motore".M[#K_MotoreInt].Dati.VeloRichPerc < #VeloFrenoDir THEN
	                "Motore".M[#K_MotoreInt].Allarmi.TrgVelMinFreno := true;
	                "Motore".M[#K_MotoreInt].Allarmi.Parametri := TRUE;
	                "Motore".M[#K_MotoreInt].Dati.VeloRichPerc := #VeloFrenoDir;
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].Dati.VeloRichPerc > "Motore".M[#K_MotoreInt].Prm.C.VelMax THEN
	                "Motore".M[#K_MotoreInt].Allarmi.TrgVelMaxMax := true;
	                "Motore".M[#K_MotoreInt].Allarmi.Parametri := TRUE;
	                "Motore".M[#K_MotoreInt].Dati.VeloRichPerc := "Motore".M[#K_MotoreInt].Prm.C.VelMax;
	            END_IF;
	            (* Controllo che la velocitÃ  di cambio VelocitÃ  sia all'interno del limite Sgancio Freno < VeloRich < VeloMax *)
	            IF "Motore".M[#K_MotoreInt].In.CambioVelDaPunto THEN
	                "Motore".M[#K_MotoreInt].Dati.VeloDopoCambioRich := "Motore".M[#K_MotoreInt].In.VelCambioVel;
	                IF "Motore".M[#K_MotoreInt].Dati.VeloDopoCambioRich < #VeloFrenoDir THEN
	                    "Motore".M[#K_MotoreInt].Allarmi.TrgVelCamMinFreno := true;
	                    "Motore".M[#K_MotoreInt].Allarmi.Parametri := TRUE;
	                    "Motore".M[#K_MotoreInt].Dati.VeloDopoCambioRich := #VeloFrenoDir;
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].Dati.VeloDopoCambioRich > "Motore".M[#K_MotoreInt].Prm.C.VelMax THEN
	                    "Motore".M[#K_MotoreInt].Allarmi.TrgVelCamMaxMax := true;
	                    "Motore".M[#K_MotoreInt].Allarmi.Parametri := TRUE;
	                    "Motore".M[#K_MotoreInt].Dati.VeloDopoCambioRich := "Motore".M[#K_MotoreInt].Prm.C.VelMax;
	                END_IF;
	            END_IF;
	        END_IF;
	    END_REGION
	    REGION Controllo Decelerazione di emergenza     
	        IF "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec_Emergenza <> "Motore".M[#K_MotoreInt].Prm.DecEmergenza THEN
	            "Motore".M[#K_MotoreInt].Allarmi.DecEmergenzaRichZero := "Motore".M[#K_MotoreInt].Prm.DecEmergenza < 100;
	            IF "Motore".M[#K_MotoreInt].Allarmi.DecEmergenzaRichZero THEN
	                "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec_Emergenza := 100;
	                "Motore".M[#K_MotoreInt].Allarmi.Parametri := TRUE;
	                #CambioReqAcc := true;
	                #CambioReqDec := true;
	            ELSE
	                "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec_Emergenza := "Motore".M[#K_MotoreInt].Prm.DecEmergenza;
	            END_IF;
	        END_IF;
	    END_REGION
	    REGION Controllo Decelerazione
	        IF #CambioReqDec THEN
	            "Motore".M[#K_MotoreInt].Allarmi.DecRichZero := "Motore".M[#K_MotoreInt].Dati.DecRichPerc < 100;
	            IF "Motore".M[#K_MotoreInt].Allarmi.DecRichZero THEN
	                "Motore".M[#K_MotoreInt].Dati.DecRichPerc := 100;
	                "Motore".M[#K_MotoreInt].Allarmi.Parametri := TRUE;
	            END_IF;
	            "Motore".M[#K_MotoreInt].Allarmi.DecRichMaxMaxDec := "Motore".M[#K_MotoreInt].Dati.DecRichPerc > "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec_Emergenza;
	            IF "Motore".M[#K_MotoreInt].Allarmi.DecRichMaxMaxDec THEN
	                "Motore".M[#K_MotoreInt].Dati.DecRichPerc := "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec_Emergenza;
	                "Motore".M[#K_MotoreInt].Allarmi.Parametri := TRUE;
	            END_IF;
	        END_IF;
	    END_REGION ;
	    REGION Controllo Decelerazione Finale
	        "Motore".M[#K_MotoreInt].Allarmi.DecFinaleRichZero := "Motore".M[#K_MotoreInt].Prm.DecFinale < 100;
	        IF "Motore".M[#K_MotoreInt].Allarmi.DecFinaleRichZero THEN
	            "Motore".M[#K_MotoreInt].Prm.DecFinale := 100;
	            "Motore".M[#K_MotoreInt].Allarmi.Parametri := TRUE;
	        END_IF;
	        "Motore".M[#K_MotoreInt].Allarmi.DecFinaleRichMaxMaxDec := "Motore".M[#K_MotoreInt].Prm.DecFinale > "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec_Emergenza;
	        IF "Motore".M[#K_MotoreInt].Allarmi.DecFinaleRichMaxMaxDec THEN
	            "Motore".M[#K_MotoreInt].Prm.DecFinale := "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec_Emergenza;
	            "Motore".M[#K_MotoreInt].Allarmi.Parametri := TRUE;
	        END_IF;
	        IF "Motore".M[#K_MotoreInt].Prm.DecFinale <> "Motore".M[#K_MotoreInt].Dati.DecReqFinaleInLavo THEN
	            IF NOT "Motore".M[#K_MotoreInt].Out.InMarcia OR "Motore".M[#K_MotoreInt].Prm.DecFinale > "Motore".M[#K_MotoreInt].Dati.DecReqFinaleInLavo THEN
	                "Motore".M[#K_MotoreInt].Dati.DecReqFinaleInLavo := "Motore".M[#K_MotoreInt].Prm.DecFinale;
	            END_IF;
	        END_IF;
	    END_REGION ;
	    REGION From inverter
	        CASE "Motore".M[#K_MotoreInt].HW.TipoCollInverter OF
	            1:
	                REGION PN Mitsubishi
	                    (*
	                    BIT 00: Drive PI:Ready to Switch ON
	                    BIT 01: Drive PI:Ready to Operate
	                    BIT 02: Drive PI:Operation Enabled
	                    BIT 03: Drive PI:Fault Present
	                    BIT 04: Drive PI:Coast Stop
	                    BIT 05: Drive PI:Quick Stop
	                    BIT 06: Drive PI:Switch ON Inhibited
	                    BIT 07: Drive PI:Warning
	                    BIT 08: 
	                    BIT 09: Drive PI: Control ON
	                    BIT 10: 
	                    BIT 11: 
	                    BIT 12: 
	                    BIT 13: 
	                    BIT 14: 
	                    BIT 15:
	                    *)
	                    "Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD => #PI_Mitsubishi);
	                    "Motore".M[#K_MotoreInt].In.NoComunInv := ("Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv OR "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv) <> 0;
	                    IF NOT "Motore".M[#K_MotoreInt].In.NoComunInv THEN
	                        (*Appoggio la Status Word per HMI*)
	                        "Motore".M[#K_MotoreInt].HMI.STW1 := #PI_Mitsubishi.STW;
	                        (*Controllo se l'inverter Ã¨ in Fault e relativo Codice*)
	                        "Motore".M[#K_MotoreInt].In.DriverFault := "Zona".Z[#K_Zona].Out.CentralinaOk AND #PI_Mitsubishi.STW.%X3;
	                        IF "Motore".M[#K_MotoreInt].In.DriverFault THEN
	                            "Motore".M[#K_MotoreInt].HMI.CodiceAllarme := #PI_Mitsubishi.AlarmCode;
	                        END_IF;
	                        (* Calcolo La velocitÃ  letta dall'inverter *)
	                        "Motore".M[#K_MotoreInt].Out.MotorSpeed := TRUNC(ABS(DINT_TO_REAL(#PI_Mitsubishi.ActualSpeed)) * DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) / 10000.0);
	                        (* Assegno il segnale di Inverter RUN *)
	                        "Motore".M[#K_MotoreInt].In.MotoreRun := #PI_Mitsubishi.STW.%X2;
	                    ELSE
	                        (* In caso di mancanza Comunicazione, Azzero i dati *)
	                        "Motore".M[#K_MotoreInt].Out.MotorSpeed := 0;
	                        "Motore".M[#K_MotoreInt].In.MotoreRun := "Motore".M[#K_MotoreInt].In.DriverFault := "Motore".M[#K_MotoreInt].In.DriverWarning := false;
	                    END_IF;
	                END_REGION
	            2:
	                REGION PN Siemens
	                    (*
	                    Definizione Parola di Stato:
	                    Bit 00: Drive PI: Ready TO Switch "ON"
	                    Bit 01: Drive PI: Ready TO Operate
	                    Bit 02: Drive PI: Operation Enabled. The Drive Follows the Setpoint
	                    Bit 03: Drive PI: Fault
	                    Bit 04: Drive PI: Coast Stop (OFF2) command is NOT Active
	                    Bit 05: Drive PI: Quick Stop (OFF3) command is NOT Active
	                    Bit 06: Drive PI: Switching on inhibited
	                    Bit 07: Drive PI: Warning
	                    Bit 08: Drive PI: Setpoint/Actual Value deviation within tolerance range.
	                    Bit 09: Drive PI: Master control requested
	                    Bit 10: Drive PI: Maximum frequency reached OR exceeded
	                    Bit 11: Drive PI: Motor at Current/Torque limit
	                    Bit 12: Drive PI: Motor Holding Brake Open
	                    Bit 13: Drive PI: Motor Overload
	                    Bit 14: Drive PI: Motor Rotation (1 = CW; 0 = CCW).
	                    Bit 15: Drive PI: Inverter Overload
	                    *)
	                    "Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD => #PI_Siemens);
	                    "Motore".M[#K_MotoreInt].In.NoComunInv := ("Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv OR "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv) <> 0;
	                    IF NOT "Motore".M[#K_MotoreInt].In.NoComunInv THEN
	                        (*Appoggio la Status Word per HMI*)
	                        "Motore".M[#K_MotoreInt].HMI.STW1 := #PI_Siemens.STW;
	                        (*Controllo se l'inverter Ã¨ in Fault e relativo Codice*)
	                        "Motore".M[#K_MotoreInt].In.DriverFault := "Zona".Z[#K_Zona].Out.CentralinaOk AND (#PI_Siemens.STW.%X3 OR NOT #PI_Siemens.STW.%X9);
	                        IF "Motore".M[#K_MotoreInt].In.DriverFault THEN
	                            "Motore".M[#K_MotoreInt].HMI.CodiceAllarme := #PI_Siemens.FaultCode;
	                        END_IF;
	                        (*Controllo se l'inverter Ã¨ in Warning e relativo Codice*)
	                        "Motore".M[#K_MotoreInt].In.DriverWarning := "Zona".Z[#K_Zona].Out.CentralinaOk AND #PI_Siemens.STW.%X7;
	                        IF "Motore".M[#K_MotoreInt].In.DriverWarning THEN
	                            "Motore".M[#K_MotoreInt].HMI.CodiceWarning := #PI_Siemens.WarningCode;
	                        END_IF;
	                        (* Calcolo La velocitÃ  letta dall'inverter *)
	                        "Motore".M[#K_MotoreInt].Out.MotorSpeed := INT_TO_DINT(#PI_Siemens.ActualSpeed) * "Motore".M[#K_MotoreInt].Prm.C.VelMax / 16384;
	                        (* Assegno il segnale di Inverter RUN *)
	                        "Motore".M[#K_MotoreInt].In.MotoreRun := #PI_Siemens.STW.%X2;
	                    ELSE
	                        (* In caso di mancanza Comunicazione, Azzero i dati *)
	                        "Motore".M[#K_MotoreInt].Out.MotorSpeed := 0;
	                        "Motore".M[#K_MotoreInt].In.MotoreRun := "Motore".M[#K_MotoreInt].In.DriverFault := "Motore".M[#K_MotoreInt].In.DriverWarning := false;
	                    END_IF;
	                END_REGION
	            3:
	                REGION PN_Schneider
	                    (*
	                    BIT 00: Drive PI: Mains power supply is switched on, electronics are initialized, pulses are inhibited
	                    BIT 01: Drive PI: Refer to control word 1, bit 0
	                    BIT 02: Drive PI: Drive follows a reference frequency.
	                    BIT 03: Drive PI: An error has been detected.
	                    BIT 04: Drive PI: 1= --, 0= Coast stop (OFF 2) command is present
	                    BIT 05: Drive PI: 1= --, 0= Quick Stop (OFF 3) command is present.
	                    BIT 06: Drive PI: The drive is in Switching on inhibited operating state.
	                    BIT 07: Drive PI: Warning information present in the service/maintenance parameter, acknowledgement required.
	                    BIT 08: Actual value is within a tolerance band; dynamic speed discrepancies are permissible.
	                    BIT 09: The automation system controls the drive.
	                    BIT 10: Actual output frequency â‰¥ reference frequency which may be set via the parameter number.
	                    BIT 11: Drive PI: Reserved
	                    BIT 12: Drive PI: Reserved
	                    BIT 13: Drive PI: Reserved
	                    BIT 14: Drive PI: Reserved
	                    BIT 15: Drive PI: Reserved
	                    *)
	                    "Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD => #PI_Schneider);
	                    "Motore".M[#K_MotoreInt].In.NoComunInv := ("Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv OR "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv) <> 0;
	                    IF NOT "Motore".M[#K_MotoreInt].In.NoComunInv THEN
	                        (*Appoggio la Status Word per HMI*)
	                        "Motore".M[#K_MotoreInt].HMI.STW1 := #PI_Schneider.STW;
	                        (*Controllo se l'inverter Ã¨ in Fault e relativo Codice*)
	                        "Motore".M[#K_MotoreInt].In.DriverFault := "Zona".Z[#K_Zona].Out.CentralinaOk AND #PI_Schneider.STW.%X3;
	                        IF "Motore".M[#K_MotoreInt].In.DriverFault THEN
	                            "Motore".M[#K_MotoreInt].HMI.CodiceAllarme := #PI_Schneider.Segnalaz_Code;
	                        END_IF;
	                        // Inverter in warning
	                        "Motore".M[#K_MotoreInt].In.DriverWarning := "Zona".Z[#K_Zona].Out.CentralinaOk AND #PI_Schneider.STW.%X7;
	                        IF "Motore".M[#K_MotoreInt].In.DriverWarning THEN
	                            "Motore".M[#K_MotoreInt].HMI.CodiceWarning := #PI_Schneider.Spare_01;
	                        END_IF;
	                        (* Calcolo La velocitÃ  letta dall'inverter *)
	                        "Motore".M[#K_MotoreInt].Out.MotorSpeed := ABS(INT_TO_DINT(#PI_Schneider.ActualSpeed) * "Motore".M[#K_MotoreInt].Prm.C.VelMax / 3000);
	                        (* Assegno il segnale di Inverter RUN *)
	                        "Motore".M[#K_MotoreInt].In.MotoreRun := #PI_Schneider.STW.%X2;
	                    ELSE
	                        (* In caso di mancanza Comunicazione, Azzero i dati *)
	                        "Motore".M[#K_MotoreInt].Out.MotorSpeed := 0;
	                        "Motore".M[#K_MotoreInt].In.MotoreRun := "Motore".M[#K_MotoreInt].In.DriverFault := "Motore".M[#K_MotoreInt].In.DriverWarning := false;
	                    END_IF;
	                END_REGION
	            4:
	                REGION PN Movimot
	                    (*
	                    Status Word 01
	                    
	                    BIT 08: Alarm Code Bit 00
	                    BIT 09: Alarm Code Bit 01
	                    BIT 10: Alarm Code Bit 02
	                    BIT 11: Alarm Code Bit 03
	                    BIT 12: Alarm Code Bit 04
	                    BIT 13: Alarm Code Bit 05
	                    BIT 14: Alarm Code Bit 06
	                    BIT 15: Alarm Code Bit 07
	                    BIT 00: 0=Control Not Enabled / 1=Enabled
	                    BIT 01: 0=Inverter Not Ready / 1=Ready
	                    BIT 02: 0=PO Data Not Enabled / 1=Enabled
	                    BIT 03: Reserved
	                    BIT 04: Reserved
	                    BIT 05: 0=OK / 1=Malfunction/Warning
	                    BIT 06: Reserved
	                    BIT 07: Reserved
	                    
	                    Status Word 02
	                    
	                    BIT 08: 0=Brake Released / 1= Brake Applied
	                    BIT 09: 0=Not Ready For Operation / 1=Ready
	                    BIT 10: 0=Stop / 1=Motor Run CW
	                    BIT 11: 0=Stop / 1=Motor Run CCW
	                    BIT 12: 0=Stop / 1=Set Point F2
	                    BIT 13: Reserved
	                    BIT 14: Reserved
	                    BIT 15: Reserved
	                    BIT 00: 0=Control Not Enabled / 1=Enabled
	                    BIT 01: 0=Inverter Not Ready / 1=Ready
	                    BIT 02: 0=PO Data Not Enabled / 1=Enabled
	                    BIT 03: Reserved
	                    BIT 04: Reserved
	                    BIT 05: 0=OK / 1=Malfunction/Warning
	                    BIT 06: Reserved
	                    BIT 07: Reserved
	                    *)
	                    "Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD => #PI_Movimot);
	                    "Motore".M[#K_MotoreInt].In.NoComunInv := ("Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv OR "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv) <> 0;
	                    IF NOT "Motore".M[#K_MotoreInt].In.NoComunInv THEN
	                        (*Appoggio la Status Word per HMI*)
	                        "Motore".M[#K_MotoreInt].HMI.STW1 := #PI_Movimot.STW1;
	                        "Motore".M[#K_MotoreInt].HMI.STW2 := #PI_Movimot.OutputCurrent;
	                        "Motore".M[#K_MotoreInt].HMI.STW3 := #PI_Movimot.STW2;
	                        (* Controllo Stato Sezionatore Aperto *)
	                        "Motore".M[#K_MotoreInt].In.SezAperto := FALSE;
	                        IF #PI_Movimot.STW1.%X5 AND #PI_Movimot.STW1.%X8 AND #PI_Movimot.STW1.%X9 AND #PI_Movimot.STW1.%X10 AND
	                            #PI_Movimot.STW1.%X11 AND NOT #PI_Movimot.STW1.%X12 AND #PI_Movimot.STW1.%X13 AND #PI_Movimot.STW1.%X14 AND
	                            NOT #PI_Movimot.STW1.%X15 AND "Zona".Z[#K_Zona].Out.CentralinaOk THEN
	                            IF "Motore".M[#K_MotoreInt].Dati.ContOffSezAperto < 0 THEN
	                                "Motore".M[#K_MotoreInt].In.SezAperto := TRUE;
	                            ELSE
	                                "Motore".M[#K_MotoreInt].Dati.ContOffSezAperto -= REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                            END_IF;
	                        ELSE
	                            "Motore".M[#K_MotoreInt].Dati.ContOffSezAperto := 4000;
	                        END_IF;
	                        (*Controllo se l'inverter Ã¨ in Fault e relativo Codice*)
	                        "Motore".M[#K_MotoreInt].In.DriverFault := "Zona".Z[#K_Zona].Out.CentralinaOk AND NOT "Motore".M[#K_MotoreInt].In.SezAperto AND (#PI_Movimot.STW1.%X5 OR NOT #PI_Movimot.STW1.%X1 OR NOT #PI_Movimot.STW1.%X2);
	                        IF "Motore".M[#K_MotoreInt].In.DriverFault THEN
	                            "Motore".M[#K_MotoreInt].HMI.CodiceAllarme := #PI_Movimot.STW1.%B1;
	                        END_IF;
	                        (* Calcolo La velocitÃ  letta dall'inverter *)
	                        "Motore".M[#K_MotoreInt].Out.MotorSpeed := TRUNC("Motore".M[#K_MotoreInt].Out.Vel);
	                        (* Assegno il segnale di Inverter RUN *)
	                        "Motore".M[#K_MotoreInt].In.MotoreRun := #PI_Movimot.STW1.%X0 AND #PI_Movimot.STW2.%X1;
	                    ELSE
	                        (* In caso di mancanza Comunicazione, Azzero i dati *)
	                        "Motore".M[#K_MotoreInt].Out.MotorSpeed := 0;
	                        "Motore".M[#K_MotoreInt].In.MotoreRun := "Motore".M[#K_MotoreInt].In.DriverFault := "Motore".M[#K_MotoreInt].In.DriverWarning := false;
	                    END_IF;
	                END_REGION
	            5:
	                REGION PN MoviGear
	                    (*
	                    BIT 00: Ready
	                    BIT 01: STO Disattivato
	                    BIT 02: Output Stage Pronto
	                    BIT 03: Freno Rilasciato
	                    BIT 04: Motore in movimento
	                    BIT 05: Motore Riferenziato
	                    BIT 06: Nuova posizione Relativa Applicata
	                    BIT 07: In Posizione
	                    BIT 08: Fault
	                    BIT 09: Warning
	                    BIT 10: Attivato Motore 2
	                    BIT 11: VelocitÃ  Attuale = A Target
	                    BIT 12: Limiti SW Disattivati
	                    BIT 13: Riservato
	                    BIT 14: Stand By Attivo
	                    BIT 15: HandShake
	                    *)
	                    "Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD => #PI_MoviGear);
	                    "Motore".M[#K_MotoreInt].In.NoComunInv := ("Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv OR "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv) <> 0;
	                    IF NOT "Motore".M[#K_MotoreInt].In.NoComunInv THEN
	                        (*Appoggio la Status Word per HMI*)
	                        "Motore".M[#K_MotoreInt].HMI.STW1 := #PI_MoviGear.STW;
	                        (*Controllo se l'inverter Ã¨ in Fault e relativo Codice*)
	                        "Motore".M[#K_MotoreInt].In.DriverFault := "Zona".Z[#K_Zona].Out.CentralinaOk AND (#PI_MoviGear.STW.%X8 OR NOT #PI_MoviGear.STW.%X0);
	                        IF "Motore".M[#K_MotoreInt].In.DriverFault THEN
	                            IF NOT #PI_MoviGear.STW.%X0 THEN
	                                "Motore".M[#K_MotoreInt].HMI.CodiceAllarme := #PI_MoviGear.Status_Fault;
	                            ELSE
	                                "Motore".M[#K_MotoreInt].HMI.CodiceAllarme := 1;
	                            END_IF;
	                        END_IF;
	                        (*Controllo se l'inverter Ã¨ in Warning e relativo Codice*)
	                        "Motore".M[#K_MotoreInt].In.DriverWarning := "Zona".Z[#K_Zona].Out.CentralinaOk AND #PI_MoviGear.STW.%X9;
	                        IF "Motore".M[#K_MotoreInt].In.DriverWarning THEN
	                            "Motore".M[#K_MotoreInt].HMI.CodiceWarning := "Motore".M[#K_MotoreInt].HMI.CodiceWarning;
	                        END_IF;
	                        (* Calcolo La velocitÃ  letta dall'inverter *)
	                        "Motore".M[#K_MotoreInt].Out.MotorSpeed := ABS(INT_TO_DINT(#PI_MoviGear.Actual_Speed)) * "Motore".M[#K_MotoreInt].Prm.C.VelMax / 3000;
	                        (* Assegno il segnale di Inverter RUN *)
	                        "Motore".M[#K_MotoreInt].In.MotoreRun := #PI_MoviGear.STW.%X0 AND #PI_MoviGear.STW.%X2;
	                    ELSE
	                        (* In caso di mancanza Comunicazione, Azzero i dati *)
	                        "Motore".M[#K_MotoreInt].Out.MotorSpeed := 0;
	                        "Motore".M[#K_MotoreInt].In.MotoreRun := "Motore".M[#K_MotoreInt].In.DriverFault := "Motore".M[#K_MotoreInt].In.DriverWarning := false;
	                    END_IF;
	                END_REGION
	            6:
	                REGION PN Danfoss
	                    (*
	                    BIT 00: 0=Control NOT Ready       1=Ready
	                    BIT 01: 0=Drive NOT Ready       1=Ready
	                    BIT 02: 0=Coasting        1=Enable
	                    BIT 03: 0=No error        1=Trip
	                    BIT 04: OFF/ON 2
	                    BIT 05: OFF/ON 3
	                    BIT 06: 0=Start possible        1=NOT possible
	                    BIT 07: 0=No warning        1=Warning
	                    BIT 08: 0= Speed><REF       1= Speed=REF
	                    BIT 09: 0=Local oper       1=Bus control
	                    BIT 10: 0=Out Freq.Limit     1=Freq.Limit OK
	                    BIT 11: 0=No operation      1=In operation
	                    BIT 12: 0=Drive OK       1=Stopped, Autostart
	                    BIT 13: 0=Voltage OK       1=Voltage exceeded
	                    BIT 14: 0=OFF      1=Comparatore 0 ON
	                    BIT 15: 0=OFF      1=Comparatore 1 ON
	                    *)
	                    "Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD => #PI_Danfoss);
	                    "Motore".M[#K_MotoreInt].In.NoComunInv := ("Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv OR "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv) <> 0;
	                    IF NOT "Motore".M[#K_MotoreInt].In.NoComunInv THEN
	                        (*Appoggio la Status Word per HMI*)
	                        "Motore".M[#K_MotoreInt].HMI.STW1 := #PI_Danfoss.STW;
	                        (*Controllo se l'inverter Ã¨ in Fault e relativo Codice*)
	                        "Motore".M[#K_MotoreInt].In.DriverFault := "Zona".Z[#K_Zona].Out.CentralinaOk AND (#PI_Danfoss.STW.%X3 OR NOT #PI_Danfoss.STW.%X9);
	                        IF "Motore".M[#K_MotoreInt].In.DriverFault THEN
	                            "Motore".M[#K_MotoreInt].HMI.CodiceAllarme := #PI_Danfoss.CodAllarme_W2 OR SHL(IN := #PI_Danfoss.CodAllarme_W1, N := 16);
	                        END_IF;
	                        (*Controllo se l'inverter Ã¨ in Warning e relativo Codice*)
	                        "Motore".M[#K_MotoreInt].In.DriverWarning := "Zona".Z[#K_Zona].Out.CentralinaOk AND #PI_Danfoss.STW.%X7;
	                        IF "Motore".M[#K_MotoreInt].In.DriverWarning THEN
	                            "Motore".M[#K_MotoreInt].HMI.CodiceAllarme := #PI_Danfoss.CodWarning_W2 OR SHL(IN := #PI_Danfoss.CodWarning_W1, N := 16);
	                        END_IF;
	                        (* Calcolo La velocitÃ  letta dall'inverter *)
	                        "Motore".M[#K_MotoreInt].Out.MotorSpeed := ABS(INT_TO_DINT(#PI_Danfoss.ActualSpeed)) * "Motore".M[#K_MotoreInt].Prm.C.VelMax / 16384;
	                        (* Assegno il segnale di Inverter RUN *)
	                        "Motore".M[#K_MotoreInt].In.MotoreRun := #PI_Danfoss.STW.%X2 AND #PI_Danfoss.STW.%X11;
	                    ELSE
	                        (* In caso di mancanza Comunicazione, Azzero i dati *)
	                        "Motore".M[#K_MotoreInt].Out.MotorSpeed := 0;
	                        "Motore".M[#K_MotoreInt].In.MotoreRun := "Motore".M[#K_MotoreInt].In.DriverFault := "Motore".M[#K_MotoreInt].In.DriverWarning := false;
	                    END_IF;
	                END_REGION
	            7:
	                REGION PN Movitrac
	                    (*
	                    Status Word 01
	                    
	                    BIT 08: Alarm Code Bit 00
	                    BIT 09: Alarm Code Bit 01
	                    BIT 10: Alarm Code Bit 02
	                    BIT 11: Alarm Code Bit 03
	                    BIT 12: Alarm Code Bit 04
	                    BIT 13: Alarm Code Bit 05
	                    BIT 14: Alarm Code Bit 06
	                    BIT 15: Alarm Code Bit 07
	                    BIT 00: 0=Control Not Enabled / 1=Enabled
	                    BIT 01: 0=Inverter Not Ready / 1=Ready
	                    BIT 02: 0=PO Data Not Enabled / 1=Enabled
	                    BIT 03: Reserved
	                    BIT 04: Reserved
	                    BIT 05: 0=OK / 1=Malfunction/Warning
	                    BIT 06: Reserved
	                    BIT 07: Reserved
	                    *)
	                    "Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD => #PI_Movitrac);
	                    "Motore".M[#K_MotoreInt].In.NoComunInv := ("Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv OR "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv) <> 0;
	                    IF NOT "Motore".M[#K_MotoreInt].In.NoComunInv THEN
	                        (*Appoggio la Status Word per HMI*)
	                        "Motore".M[#K_MotoreInt].HMI.STW1 := #PI_Movitrac.STW1;
	                        (*Controllo se l'inverter Ã¨ in Fault e relativo Codice*)
	                        "Motore".M[#K_MotoreInt].In.DriverFault := "Zona".Z[#K_Zona].Out.CentralinaOk AND (#PI_Movitrac.STW1.%X5 OR NOT #PI_Movitrac.STW1.%X1 OR NOT #PI_Movitrac.STW1.%X2);
	                        IF "Motore".M[#K_MotoreInt].In.DriverFault THEN
	                            "Motore".M[#K_MotoreInt].HMI.CodiceAllarme := #PI_Movitrac.STW1.%B1;
	                        END_IF;
	                        (* Calcolo La velocitÃ  letta dall'inverter *)
	                        "Motore".M[#K_MotoreInt].Out.MotorSpeed := ABS(INT_TO_DINT(#PI_Movitrac.ActualSpeed)) * "Motore".M[#K_MotoreInt].Prm.C.VelMax / 16384;
	                        (* Assegno il segnale di Inverter RUN *)
	                        "Motore".M[#K_MotoreInt].In.MotoreRun := #PI_Movitrac.STW1.%X0;
	                    ELSE
	                        (* In caso di mancanza Comunicazione, Azzero i dati *)
	                        "Motore".M[#K_MotoreInt].Out.MotorSpeed := 0;
	                        "Motore".M[#K_MotoreInt].In.MotoreRun := "Motore".M[#K_MotoreInt].In.DriverFault := "Motore".M[#K_MotoreInt].In.DriverWarning := false;
	                    END_IF;
	                END_REGION
	            8:
	                REGION PN INVT
	                    (*
	                    Bit   Descr
	                    0â€“7     Running state
	                    Value   Desc
	                    1       Forward running
	                    2       Reverse running
	                    3       Stopped
	                    4       Faulty
	                    5       POFF
	                    Bit:8 Bus voltage established: 0=Not ready to Run, 1=Ready to Run
	                    Bit 9â€“10: Motor group feedback
	                    BIT 11: 0=Asynchronous Motor 1=Syncronous Motor
	                    BIT 12:Overload pre-alarm feedback  0=No overload pre-alarm generated 1=Overload pre-alarm generated
	                    Bit     Descr
	                    13â€“14   Run/Stop mode
	                    Value   Desc
	                    0       Keypad-based control
	                    1       Terminal-based control
	                    2       Communication-based control
	                    3       Reserved
	                    BIT 15Heartbeat feedback : 0=OFF      1=Comparatore 1 ON
	                    *)
	                    "Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD => #PI_INVT);
	                    "Motore".M[#K_MotoreInt].In.NoComunInv := ("Motore".M[#K_MotoreInt].Dati.RetVal_Read_Inv OR "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv) <> 0;
	                    IF NOT "Motore".M[#K_MotoreInt].In.NoComunInv THEN
	                        (*Appoggio la Status Word per HMI*)
	                        "Motore".M[#K_MotoreInt].HMI.STW1 := #PI_INVT.STW;
	                        (*Controllo se l'inverter Ã¨ in Fault e relativo Codice*)
	                        "Motore".M[#K_MotoreInt].In.DriverFault := #PI_INVT.STW.%B0 = 4 AND "Zona".Z[#K_Zona].Out.CentralinaOk;
	                        IF "Motore".M[#K_MotoreInt].In.DriverFault THEN
	                            "Motore".M[#K_MotoreInt].HMI.CodiceAllarme := #PI_INVT.FaultCode;
	                        END_IF;
	                        (*Controllo se l'inverter Ã¨ in Warning e relativo Codice*)
	                        "Motore".M[#K_MotoreInt].In.DriverWarning := #PI_INVT.STW.%X12;
	                        (* Calcolo La velocitÃ  letta dall'inverter *)
	                        "Motore".M[#K_MotoreInt].Out.MotorSpeed := ABS(INT_TO_DINT(#PI_INVT.ActualSpeed)) * "Motore".M[#K_MotoreInt].Prm.C.VelMax / 10000;
	                        (* Assegno il segnale di Inverter RUN *)
	                        "Motore".M[#K_MotoreInt].In.MotoreRun := #PI_INVT.STW.%X8;
	                    ELSE
	                        (* In caso di mancanza Comunicazione, Azzero i dati *)
	                        "Motore".M[#K_MotoreInt].Out.MotorSpeed := 0;
	                        "Motore".M[#K_MotoreInt].In.MotoreRun := "Motore".M[#K_MotoreInt].In.DriverFault := "Motore".M[#K_MotoreInt].In.DriverWarning := false;
	                    END_IF;
	                END_REGION
	            9:
	                REGION NIDEC
	                    (*
	                    BIT 00: Drive Healthy
	                    BIT 01: Drive Active
	                    BIT 02: Zero Frequency
	                    BIT 03: Running At OR Below Minimum Frequency
	                    BIT 04: Below Set Frequency
	                    BIT 05: At Frequency
	                    BIT 06: Above Set Frequency
	                    BIT 07: Rated Load Reached
	                    BIT 08: Current Limit Active
	                    BIT 09: Regenerating
	                    BIT 10: Braking IGBT Active
	                    BIT 11: Braking Resistor Alarm
	                    BIT 12: Reverse Direction Commanded
	                    BIT 13: Reverse Direction Running
	                    BIT 14: Supply Loss
	                    *)
	                    IF NOT "Motore".M[#K_MotoreInt].In.NoComunInv THEN
	                        //VariantGet(SRC := #PI_Inv, DST => #PI_Nidec);
	                        "Motore".M[#K_MotoreInt].HMI.STW1 := #PI_Nidec.STW;
	                        (*Controllo se l'inverter Ã¨ in Fault e relativo Codice*)
	                        "Motore".M[#K_MotoreInt].In.DriverFault := NOT #PI_Nidec.STW.%X0 AND "Zona".Z[#K_Zona].Out.CentralinaOk;
	                        IF "Motore".M[#K_MotoreInt].In.DriverFault THEN
	                            "Motore".M[#K_MotoreInt].HMI.CodiceAllarme := #PI_Nidec.FaultCode;
	                        END_IF;
	                        (* Calcolo La velocitÃ  letta dall'inverter *)
	                        "Motore".M[#K_MotoreInt].Out.MotorSpeed := ABS(#PI_Nidec.ActualSpeed) * "Motore".M[#K_MotoreInt].Prm.C.VelMax / 10000;
	                        (* Assegno il segnale di Inverter RUN *)
	                        "Motore".M[#K_MotoreInt].In.MotoreRun := #PI_Nidec.STW.%X1;
	                    ELSE
	                        "Motore".M[#K_MotoreInt].Out.MotorSpeed := 0;
	                        "Motore".M[#K_MotoreInt].In.MotoreRun := "Motore".M[#K_MotoreInt].In.DriverFault := "Motore".M[#K_MotoreInt].In.DriverWarning := false;
	                    END_IF;
	                END_REGION
	        END_CASE;
	    END_REGION
	    REGION Encoder manager
	        IF "Zona".Z[#K_Zona].Out.Auto THEN
	            "Motore".M[#K_MotoreInt].HMI.Setup := "Motore".M[#K_MotoreInt].HMI.ManMov := false;
	            "Motore".M[#K_MotoreInt].HMI.ModoInizializza := 0;
	        END_IF;
	        REGION Calcolo Target Position Teorica
	            #RicircoloTotale := "Motore".M[#K_MotoreInt].Prm.Enc.ModuloPosEnc - "Motore".M[#K_MotoreInt].Prm.Enc.ModuloNegEnc;
	            #MezzoRicircoloTotale := #RicircoloTotale / 2;
	            IF "Motore".M[#K_MotoreInt].Out.InMarcia THEN
	                "Motore".M[#K_MotoreInt].Prm.C.TrgPos += "Motore".M[#K_MotoreInt].Out.Vel * "Zona".Comuni.TempoCicloCpu_r / 1000.0;
	                "Motore".M[#K_MotoreInt].Dati.TrgPosDint := TRUNC("Motore".M[#K_MotoreInt].Prm.C.TrgPos);
	                IF "Motore".M[#K_MotoreInt].Prm.Mech.EndLess THEN
	                    IF "Motore".M[#K_MotoreInt].Dati.TrgPosDint < "Motore".M[#K_MotoreInt].Prm.Enc.ModuloNegEnc THEN
	                        // Aggiorno l'ultima posizione di target memorizzata
	                        "Motore".M[#K_MotoreInt].Prm.C.TrgPos += DINT_TO_REAL(#RicircoloTotale);
	                        "Motore".M[#K_MotoreInt].Dati.TrgPosDint := "Motore".M[#K_MotoreInt].Dati.OldTrgPosDint := TRUNC("Motore".M[#K_MotoreInt].Prm.C.TrgPos);
	                    ELSIF "Motore".M[#K_MotoreInt].Dati.TrgPosDint > "Motore".M[#K_MotoreInt].Prm.Enc.ModuloPosEnc THEN
	                        "Motore".M[#K_MotoreInt].Prm.C.TrgPos -= DINT_TO_REAL(#RicircoloTotale);
	                        "Motore".M[#K_MotoreInt].Dati.TrgPosDint := "Motore".M[#K_MotoreInt].Dati.OldTrgPosDint := TRUNC("Motore".M[#K_MotoreInt].Prm.C.TrgPos);
	                    END_IF;
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].Prm.Enc.EncoderLess THEN
	                    "Motore".M[#K_MotoreInt].Out.ActPos := "Motore".M[#K_MotoreInt].Dati.TrgPosDint;
	                    "Motore".M[#K_MotoreInt].Prm.C.EncPos := "Motore".M[#K_MotoreInt].Prm.C.TrgPos;
	                END_IF;
	            END_IF;
	        END_REGION
	        REGION Condizioni Setup Encoder        
	            IF "Motore".M[#K_MotoreInt].In.Setup THEN
	                #REQSetup := TRUE;
	            ELSIF "Motore".M[#K_MotoreInt].HMI.Setup THEN
	                #REQSetupPannello := "Motore".M[#K_MotoreInt].HMI.PulsanteSetupPremuto AND "Zona".Z[#K_Zona].Gen.Reset;
	                IF #REQSetupPannello THEN
	                    "Motore".M[#K_MotoreInt].Out.EncoderHomed := FALSE;
	                    #SetUpSuSensore := "Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 2 OR "Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 10;
	                    #SetUpFermoMeccanico := "Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 4 OR "Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 12;
	                    IF NOT #SetUpSuSensore AND NOT #SetUpFermoMeccanico THEN
	                        #REQSetup := TRUE;
	                        "Motore".M[#K_MotoreInt].Allarmi.SetupEncoderEseg := TRUE;
	                    END_IF;
	                END_IF;
	            END_IF;
	        END_REGION
	        REGION Setup Su Sensore
	            IF #SetUpSuSensore OR "Motore".M[#K_MotoreInt].Dati.SetupSensoreTrovato THEN
	                REGION Tempo OFF Marcia Motore
	                    IF NOT "Motore".M[#K_MotoreInt].Dati.MotoreFermo THEN
	                        "Motore".M[#K_MotoreInt].Dati.ContTOffMotoreMarcia := 1000;
	                        "Motore".M[#K_MotoreInt].Dati.TOffMotoreMarcia := true;
	                    ELSE
	                        IF "Motore".M[#K_MotoreInt].Dati.ContTOffMotoreMarcia > 0 THEN
	                            "Motore".M[#K_MotoreInt].Dati.ContTOffMotoreMarcia -= REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                        ELSE
	                            "Motore".M[#K_MotoreInt].Dati.TOffMotoreMarcia := false;
	                        END_IF;
	                    END_IF;
	                END_REGION ;
	                #REQSetup := "Motore".M[#K_MotoreInt].Out.SetUpSensEseg := "Motore".M[#K_MotoreInt].Dati.SetupSensoreTrovato AND NOT "Motore".M[#K_MotoreInt].Dati.TOffMotoreMarcia;
	                IF #REQSetup THEN
	                    "Motore".M[#K_MotoreInt].Allarmi.SetupEncoderEseg := TRUE;
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].Out.SetUpSensEseg THEN
	                    IF NOT "Motore".M[#K_MotoreInt].Dati.AppoImpEsecSetUP THEN
	                        "Motore".M[#K_MotoreInt].Dati.Encoder.ValoKSetupSuSens := "Motore".M[#K_MotoreInt].Out.ActPos - "Motore".M[#K_MotoreInt].Dati.PosImpulsoSetup;
	                        "Motore".M[#K_MotoreInt].Dati.AppoImpEsecSetUP := TRUE;
	                    END_IF;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Dati.AppoImpEsecSetUP := FALSE;
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].Out.SetUpSensEseg AND NOT #SetUpSuSensore THEN
	                    IF "Motore".M[#K_MotoreInt].Dati.ContSetUPEncoder > 300 THEN
	                        "Motore".M[#K_MotoreInt].Dati.SetupSensoreTrovato := false;
	                    ELSE
	                        "Motore".M[#K_MotoreInt].Dati.ContSetUPEncoder += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                    END_IF;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Dati.ContSetUPEncoder := 0;
	                END_IF;
	                IF NOT "Motore".M[#K_MotoreInt].Dati.SetupSensoreTrovato THEN
	                    IF NOT "Motore".M[#K_MotoreInt].In.SensAzz THEN
	                        IF ("Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 2 AND "Motore".M[#K_MotoreInt].Dati.ActVelNeg) OR
	                            ("Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 10 AND "Motore".M[#K_MotoreInt].Dati.ActVelPos) THEN
	                            "Motore".M[#K_MotoreInt].Dati.SetupSensoreTrovato := true;
	                            "Motore".M[#K_MotoreInt].Dati.PosImpulsoSetup := "Motore".M[#K_MotoreInt].Out.ActPos;
	                        END_IF;
	                    ELSIF ("Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 2 AND "Motore".M[#K_MotoreInt].Out.ActDirPos) OR
	                        ("Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 10 AND "Motore".M[#K_MotoreInt].Out.ActDirNeg) THEN
	                        "Motore".M[#K_MotoreInt].Dati.ContTimeOutAzzeramento := 0;
	                    END_IF;
	                    "Motore".M[#K_MotoreInt].In.CmdPosRich := ("Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 2 AND NOT "Motore".M[#K_MotoreInt].In.SensAzz) OR ("Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 10 AND "Motore".M[#K_MotoreInt].In.SensAzz);
	                    "Motore".M[#K_MotoreInt].In.CmdNegRich := ("Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 10 AND NOT "Motore".M[#K_MotoreInt].In.SensAzz) OR ("Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 2 AND "Motore".M[#K_MotoreInt].In.SensAzz);
	                    IF "Motore".M[#K_MotoreInt].In.CmdPosRich THEN
	                        "Motore".M[#K_MotoreInt].In.CmdVelocitaRich := "Motore".M[#K_MotoreInt].Prm.VelSgancioFrenoPos;
	                    ELSIF "Motore".M[#K_MotoreInt].In.CmdNegRich THEN
	                        "Motore".M[#K_MotoreInt].In.CmdVelocitaRich := "Motore".M[#K_MotoreInt].Prm.VelSgancioFrenoNeg;
	                    END_IF;
	                ELSE
	                    "Motore".M[#K_MotoreInt].In.CmdPosRich := "Motore".M[#K_MotoreInt].In.CmdNegRich := "Motore".M[#K_MotoreInt].In.Positioning := false;
	                END_IF;
	            END_IF;
	        END_REGION
	        REGION SetupSuFermoMeccanico
	            IF #SetUpFermoMeccanico OR "Motore".M[#K_MotoreInt].Dati.SetupFermoMeccTrovato THEN
	                REGION Tempo OFF Marcia Motore
	                    IF NOT "Motore".M[#K_MotoreInt].Dati.MotoreFermo THEN
	                        "Motore".M[#K_MotoreInt].Dati.ContTOffMotoreMarcia := 1000;
	                        "Motore".M[#K_MotoreInt].Dati.TOffMotoreMarcia := true;
	                    ELSE
	                        IF "Motore".M[#K_MotoreInt].Dati.ContTOffMotoreMarcia > 0 THEN
	                            "Motore".M[#K_MotoreInt].Dati.ContTOffMotoreMarcia -= REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                        ELSE
	                            "Motore".M[#K_MotoreInt].Dati.TOffMotoreMarcia := false;
	                        END_IF;
	                    END_IF;
	                END_REGION ;
	                #REQSetup := "Motore".M[#K_MotoreInt].Dati.SetupFermoMeccTrovato AND NOT "Motore".M[#K_MotoreInt].Dati.TOffMotoreMarcia;
	                IF #REQSetup THEN
	                    "Motore".M[#K_MotoreInt].Allarmi.SetupEncoderEseg := TRUE;
	                END_IF;
	                IF #REQSetup THEN
	                    IF NOT "Motore".M[#K_MotoreInt].Dati.AppoImpEsecSetUP THEN
	                        "Motore".M[#K_MotoreInt].Dati.Encoder.ValoKSetupSuSens := "Motore".M[#K_MotoreInt].Out.ActPos - "Motore".M[#K_MotoreInt].Dati.PosImpulsoSetup;
	                        "Motore".M[#K_MotoreInt].Dati.AppoImpEsecSetUP := TRUE;
	                    END_IF;
	                END_IF;
	                IF #REQSetup AND NOT #SetUpFermoMeccanico THEN
	                    IF "Motore".M[#K_MotoreInt].Dati.ContSetUPEncoder > 300 THEN
	                        IF NOT #SetUpFermoMeccanico THEN
	                            "Motore".M[#K_MotoreInt].Dati.SetupFermoMeccTrovato := false;
	                        END_IF;
	                    ELSE
	                        "Motore".M[#K_MotoreInt].Dati.ContSetUPEncoder += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                    END_IF;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Dati.ContSetUPEncoder := 0;
	                END_IF;
	                IF NOT "Motore".M[#K_MotoreInt].Dati.SetupFermoMeccTrovato THEN
	                    "Motore".M[#K_MotoreInt].Dati.AppoImpEsecSetUP := FALSE;
	                    IF "Motore".M[#K_MotoreInt].Prm.Enc.SetupMode = 4 THEN
	                        "Motore".M[#K_MotoreInt].In.CmdPosRich := true;
	                        "Motore".M[#K_MotoreInt].In.CmdVelocitaRich := "Motore".M[#K_MotoreInt].Prm.VelSgancioFrenoPos;
	                        IF "Motore".M[#K_MotoreInt].Out.ActDirPos AND "Motore".M[#K_MotoreInt].Out.ActPos <= "Motore".M[#K_MotoreInt].Dati.MaxPosRicercaFermoMeccanico THEN
	                            "Motore".M[#K_MotoreInt].Dati.ContFermoMeccTrovato += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                        ELSE
	                            "Motore".M[#K_MotoreInt].Dati.MaxPosRicercaFermoMeccanico := "Motore".M[#K_MotoreInt].Out.ActPos;
	                            "Motore".M[#K_MotoreInt].Dati.ContFermoMeccTrovato := 0;
	                        END_IF;
	                    ELSE
	                        "Motore".M[#K_MotoreInt].In.CmdNegRich := true;
	                        "Motore".M[#K_MotoreInt].In.CmdVelocitaRich := "Motore".M[#K_MotoreInt].Prm.VelSgancioFrenoNeg;
	                        IF "Motore".M[#K_MotoreInt].Out.ActDirNeg AND "Motore".M[#K_MotoreInt].Out.ActPos >= "Motore".M[#K_MotoreInt].Dati.MaxPosRicercaFermoMeccanico THEN
	                            "Motore".M[#K_MotoreInt].Dati.ContFermoMeccTrovato += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                        ELSE
	                            "Motore".M[#K_MotoreInt].Dati.MaxPosRicercaFermoMeccanico := "Motore".M[#K_MotoreInt].Out.ActPos;
	                            "Motore".M[#K_MotoreInt].Dati.ContFermoMeccTrovato := 0;
	                        END_IF;
	                    END_IF;
	                    "Motore".M[#K_MotoreInt].Dati.SetupFermoMeccTrovato := "Motore".M[#K_MotoreInt].Dati.ContFermoMeccTrovato > 500;
	                    "Motore".M[#K_MotoreInt].Dati.PosImpulsoSetup := "Motore".M[#K_MotoreInt].Dati.MaxPosRicercaFermoMeccanico;
	                    "Motore".M[#K_MotoreInt].Dati.ContCheckFollowError := 0;
	                ELSE
	                    "Motore".M[#K_MotoreInt].In.CmdPosRich := "Motore".M[#K_MotoreInt].In.CmdNegRich := "Motore".M[#K_MotoreInt].In.Positioning := false;
	                END_IF;
	            END_IF;
	        END_REGION
	        REGION Gestione Encoder
	            (* Gestisco l'Allarme di Setup Eseguito per memorizzare su HMI l'esecuzione del Setuo*)
	            IF "Motore".M[#K_MotoreInt].Allarmi.SetupEncoderEseg THEN
	                "Motore".M[#K_MotoreInt].Dati.ContSegnSetup += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                IF "Motore".M[#K_MotoreInt].Dati.ContSegnSetup > 3000 THEN
	                    "Motore".M[#K_MotoreInt].Allarmi.SetupEncoderEseg := false;
	                    "Motore".M[#K_MotoreInt].Dati.ContSegnSetup := 0;
	                END_IF;
	            END_IF;
	            (* Una volta selezionato su HMI il Setup, se non avviene entro 3 secondi viene deselezionato *)
	            IF "Motore".M[#K_MotoreInt].HMI.Setup AND NOT #REQSetupPannello THEN
	                "Motore".M[#K_MotoreInt].Dati.ContTORichSetup += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                IF "Motore".M[#K_MotoreInt].Dati.ContTORichSetup > 3000 THEN
	                    "Motore".M[#K_MotoreInt].HMI.Setup := false;
	                END_IF;
	            ELSE
	                "Motore".M[#K_MotoreInt].Dati.ContTORichSetup := 0;
	            END_IF;
	            IF NOT "Motore".M[#K_MotoreInt].Prm.Enc.EncoderLess THEN
	                (* Richiamo la gestione dell'Encoder *)
	                IF "Motore".M[#K_MotoreInt].Prm.Enc.Mounting <> 11 THEN
	                    REGION CalcoloPosizioneSetup
	                        IF #REQSetup THEN
	                            CASE "Motore".M[#K_MotoreInt].Prm.Enc.SetupMode OF
	                                0: // Encoder HMI
	                                    IF "Motore".M[#K_MotoreInt].Prm.Enc.SetupDoppio THEN
	                                        #TempEnc.AppoSetupRich := "Motore".M[#K_MotoreInt].HMI.ValoreSetupEncoder * 2;
	                                    ELSE
	                                        #TempEnc.#AppoSetupRich := "Motore".M[#K_MotoreInt].HMI.ValoreSetupEncoder;
	                                    END_IF;
	                                    IF NOT "Motore".M[#K_MotoreInt].Prm.Enc.ModoCalcoloK THEN
	                                        "Motore".M[#K_MotoreInt].HMI.ValoreSetupRichiesto := "Motore".M[#K_MotoreInt].Prm.Enc.KSetup + #TempEnc.AppoSetupRich;
	                                    ELSE
	                                        "Motore".M[#K_MotoreInt].HMI.ValoreSetupRichiesto := "Motore".M[#K_MotoreInt].Prm.Enc.KSetup - #TempEnc.AppoSetupRich;
	                                    END_IF;
	                                1: // Encoder Esterno
	                                    "Motore".M[#K_MotoreInt].HMI.ValoreSetupRichiesto := "Motore".M[#K_MotoreInt].In.ValoSetupEnc;
	                                2, 10: // Ricerca Sensore 
	                                    "Motore".M[#K_MotoreInt].HMI.ValoreSetupRichiesto := "Motore".M[#K_MotoreInt].HMI.ValoreSetupSensore + "Motore".M[#K_MotoreInt].Dati.Encoder.ValoKSetupSuSens;
	                                4, 12: // Ricerca Coppia
	                                    "Motore".M[#K_MotoreInt].HMI.ValoreSetupRichiesto := "Motore".M[#K_MotoreInt].HMI.ValoreSetupSensore + "Motore".M[#K_MotoreInt].Dati.Encoder.ValoKSetupSuSens;
	                            END_CASE;
	                        END_IF;
	                    END_REGION
	                    REGION Lettura Encoder Dal Campo
	                        CASE "Motore".M[#K_MotoreInt].HW.TipoEncoder OF
	                            1:
	                                "Motore".M[#K_MotoreInt].Dati.Encoder.#RetValRdEnc := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Encoder, RECORD => #TempEnc.RcvDaEncoderSick);
	                                #TempEnc.#PosizioneLettaEnc := DWORD_TO_DINT(IN := SHR(IN := #TempEnc.RcvDaEncoderSick.Position01, N := 2));
	                                #TempEnc.VelocitaLettaEnc := #TempEnc.RcvDaEncoderSick.Speed;
	                                "Motore".M[#K_MotoreInt].Out.VelEncoder := ABS(TRUNC(DINT_TO_REAL(#TempEnc.VelocitaLettaEnc) * "Motore".M[#K_MotoreInt].Prm.C.SpazioGiroEncoder / "Motore".M[#K_MotoreInt].Prm.Enc.ImpRev * 100.0));
	                                IF (#TempEnc.RcvDaEncoderSick.G1_ZSW.%X15 OR #TempEnc.RcvDaEncoderSick.G1_ZSW.%X12) AND NOT #REQSetup THEN
	                                    #TempEnc.SendAEncoderSick.G1_STW := 16#0000;
	                                    #TempEnc.SendAEncoderSick.G1_STW.%X15 := #TempEnc.RcvDaEncoderSick.G1_ZSW.%X15;
	                                    #TempEnc.SendAEncoderSick.STW2_ENC := 16#400;
	                                    "Motore".M[#K_MotoreInt].Dati.Encoder.#RetValScrEnc := DPWR_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Encoder, RECORD := #TempEnc.SendAEncoderSick);
	                                END_IF;
	                            9: // Sick Telemetrica
	                                "Motore".M[#K_MotoreInt].Prm.Enc.Mounting := USint#1;
	                                "Motore".M[#K_MotoreInt].Dati.Encoder.#RetValRdEnc := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Encoder, RECORD => #TempTelem.RcvDaEncoder);
	                                "Motore".M[#K_MotoreInt].Dati.Encoder.#RetValRdEnc := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_PrmEncoder, RECORD => #TempTelem.RcvDaEncoder.Status);
	                                // Valore arriva in decimi di mm (*100 = converto in millesimi di millimetro)
	                                #TempEnc.#PosizioneLettaEnc := DWORD_TO_DINT(#TempTelem.RcvDaEncoder.M05_IN_ActPos * 100);
	                            10:
	                                "Motore".M[#K_MotoreInt].Dati.Encoder.#RetValRdEnc := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Encoder, RECORD => #TempEnc.#RcvDaEncoder_Ottico);
	                                #TempEnc.#PosizioneLettaEnc := #TempEnc.#RcvDaEncoder_Ottico.Posizione;
	                            11:
	                                "Motore".M[#K_MotoreInt].Dati.Encoder.#RetValRdEnc := DPRD_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Encoder, RECORD => #TempEnc.#RcvDaEncoder_Magnetico);
	                                #TempEnc.#PosizioneLettaEnc := #TempEnc.#RcvDaEncoder_Magnetico.Posizione;
	                        END_CASE;
	                        "Motore".M[#K_MotoreInt].In.NoComunEnc := "Motore".M[#K_MotoreInt].Dati.Encoder.#RetValRdEnc <> 0 OR #TempEnc.#PosizioneLettaEnc = 0;
	                    END_REGION
	                    IF NOT "Motore".M[#K_MotoreInt].Prm.Mech.EndLess THEN
	                        REGION Gestione Encoder
	                            REGION CalcoloPosizione
	                                IF NOT "Motore".M[#K_MotoreInt].In.NoComunEnc THEN
	                                    IF NOT "Motore".M[#K_MotoreInt].Prm.Enc.Direction THEN
	                                        IF "Motore".M[#K_MotoreInt].HW.TipoEncoder = 9 THEN
	                                            // Se Telemetrica (=9) Cambio Calcolo
	                                            IF #TempEnc.PosizioneLettaEnc <> 0 THEN
	                                                "Motore".M[#K_MotoreInt].Prm.C.EncPos := DINT_TO_REAL(#TempEnc.#PosizioneLettaEnc);
	                                            ELSE
	                                                "Motore".M[#K_MotoreInt].Allarmi.EncMismatch := true;
	                                            END_IF;
	                                        ELSE
	                                            "Motore".M[#K_MotoreInt].Prm.C.EncPos := DINT_TO_REAL(#TempEnc.PosizioneLettaEnc - "Motore".M[#K_MotoreInt].Dati.Encoder.MezzoRicircoloEncoder) / "Motore".M[#K_MotoreInt].Prm.Enc.ImpRev * "Motore".M[#K_MotoreInt].Prm.C.SpazioGiroEncoder;
	                                        END_IF;
	                                    ELSE
	                                        IF "Motore".M[#K_MotoreInt].HW.TipoEncoder = 9 THEN
	                                            // Se Telemetrica (=9) Cambio Calcolo
	                                            IF #TempEnc.PosizioneLettaEnc <> 0 THEN
	                                                "Motore".M[#K_MotoreInt].Prm.C.EncPos := DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Enc.KSetup - #TempEnc.#PosizioneLettaEnc);
	                                            ELSE
	                                                "Motore".M[#K_MotoreInt].Allarmi.EncMismatch := true;
	                                            END_IF;
	                                        ELSE
	                                            "Motore".M[#K_MotoreInt].Prm.C.EncPos := DINT_TO_REAL(- #TempEnc.PosizioneLettaEnc + "Motore".M[#K_MotoreInt].Dati.Encoder.MezzoRicircoloEncoder) / "Motore".M[#K_MotoreInt].Prm.Enc.ImpRev * "Motore".M[#K_MotoreInt].Prm.C.SpazioGiroEncoder;
	                                        END_IF;
	                                    END_IF;
	                                END_IF;
	                            END_REGION
	                            REGION Gestione Setup Encoder
	                                IF #REQSetup THEN
	                                    IF NOT "Motore".M[#K_MotoreInt].Dati.Encoder.RichSetupEnc THEN
	                                        "Motore".M[#K_MotoreInt].Out.EncoderHomed := false;
	                                    END_IF;
	                                    IF NOT "Motore".M[#K_MotoreInt].Prm.Enc.Direction THEN
	                                        #TempEnc.#AppoSetupEncoder := DINT_TO_UDINT(TRUNC(DINT_TO_REAL("Motore".M[#K_MotoreInt].HMI.ValoreSetupRichiesto) / "Motore".M[#K_MotoreInt].Prm.C.SpazioGiroEncoder * "Motore".M[#K_MotoreInt].Prm.Enc.ImpRev) + "Motore".M[#K_MotoreInt].Dati.Encoder.MezzoRicircoloEncoder);
	                                    ELSE
	                                        #TempEnc.#AppoSetupEncoder := DINT_TO_UDINT(TRUNC(DINT_TO_REAL(- "Motore".M[#K_MotoreInt].HMI.ValoreSetupRichiesto) / "Motore".M[#K_MotoreInt].Prm.C.SpazioGiroEncoder * "Motore".M[#K_MotoreInt].Prm.Enc.ImpRev) + "Motore".M[#K_MotoreInt].Dati.Encoder.MezzoRicircoloEncoder);
	                                    END_IF;
	                                    IF "Motore".M[#K_MotoreInt].HW.TipoEncoder = 9 THEN
	                                        IF NOT "Motore".M[#K_MotoreInt].Prm.Enc.ModoCalcoloK THEN
	                                            #TempEnc.#AppoSetupEncoder := DINT_TO_UDINT("Motore".M[#K_MotoreInt].HMI.ValoreSetupRichiesto);
	                                        ELSE
	                                            #TempEnc.#AppoSetupEncoder := DINT_TO_UDINT("Motore".M[#K_MotoreInt].HMI.ValoreSetupEncoder);
	                                        END_IF;
	                                    END_IF;
	                                    IF #TempEnc.PosizioneLettaEnc <> #TempEnc.#AppoSetupEncoder OR #TempEnc.RcvDaEncoderSick.G1_ZSW.%X12 THEN
	                                        CASE "Motore".M[#K_MotoreInt].HW.TipoEncoder OF
	                                            1:
	                                                #TempEnc.#arrRecord[0] := 1;
	                                                #TempEnc.#arrRecord[1] := 2; (*Request ID = Change parameter*)
	                                                #TempEnc.#arrRecord[2] := 0; (*DO-ID*)
	                                                #TempEnc.#arrRecord[3] := 1; (*No. of parameters*)
	                                                #TempEnc.#arrRecord[4] := 16#10; (*Attribute = Value*)
	                                                #TempEnc.#arrRecord[5] := 0; (*No. of elements*)
	                                                #TempEnc.#arrRecord[6] := 16#fd; (*PNU high byte*)
	                                                #TempEnc.#arrRecord[7] := 16#e8; (*PNU low byte*)
	                                                #TempEnc.#arrRecord[8] := 0; (*Subindex high byte*)
	                                                #TempEnc.#arrRecord[9] := 0; (*Subindex low byte*)
	                                                #TempEnc.#arrRecord[10] := 16#43;
	                                                #TempEnc.#arrRecord[11] := 1;
	                                                #TempEnc.#arrRecord[12] := #TempEnc.#AppoSetupEncoder.%B3;
	                                                #TempEnc.#arrRecord[13] := #TempEnc.#AppoSetupEncoder.%B2;
	                                                #TempEnc.#arrRecord[14] := #TempEnc.#AppoSetupEncoder.%B1;
	                                                #TempEnc.#arrRecord[15] := #TempEnc.#AppoSetupEncoder.%B0;
	                                                
	                                                "WRREC"(REQ := "Motore".M[#K_MotoreInt].Dati.Encoder.RichSetupEnc AND NOT "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.BUSY AND NOT "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.DONE AND NOT "Motore".M[#K_MotoreInt].Dati.Encoder.PrmEncSend,
	                                           ID := "Motore".M[#K_MotoreInt].HW.HWIO_PrmEncoder,
	                                           INDEX := 16#B02E,
	                                           LEN := 16,
	                                           DONE => "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.DONE,
	                                           BUSY => "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.BUSY,
	                                           ERROR => "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.ERROR,
	                                           STATUS => "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.STATUS,
	                                           RECORD := #TempEnc.#arrRecord);
	                                                
	                                                IF "Motore".M[#K_MotoreInt].Dati.Encoder.RichSetupEnc THEN
	                                                    IF "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.DONE THEN
	                                                        "Motore".M[#K_MotoreInt].Dati.Encoder.PrmEncSend := true;
	                                                    END_IF;
	                                                ELSE
	                                                    "Motore".M[#K_MotoreInt].Dati.Encoder.PrmEncSend := false;
	                                                END_IF;
	                                                IF "Motore".M[#K_MotoreInt].Dati.Encoder.PrmEncSend AND NOT #TempEnc.RcvDaEncoderSick.G1_ZSW.%X12 THEN
	                                                    #TempEnc.SendAEncoderSick.G1_STW := 16#1000;
	                                                ELSE
	                                                    #TempEnc.SendAEncoderSick.G1_STW := 0;
	                                                END_IF;
	                                                #TempEnc.SendAEncoderSick.STW2_ENC := 16#400;
	                                                "Motore".M[#K_MotoreInt].Dati.Encoder.#RetValScrEnc := DPWR_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Encoder, RECORD := #TempEnc.SendAEncoderSick);
	                                            9: // Setup Telemetrica
	                                                // Divido Valore per 100 per scrivere Valore in Decimi di mm
	                                                #TempTelem.SendAEncode.M05_OUT_Preset := UDINT_TO_DWORD(IN := #TempEnc.#AppoSetupEncoder / 100);
	                                                // Alzo bit richiesta Setup
	                                                #TempTelem.SendAEncode.M05_OUT_Preset.%X31 := TRUE;
	                                                "Motore".M[#K_MotoreInt].Dati.Encoder.#RetValScrEnc := DPWR_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Encoder, RECORD := #TempTelem.SendAEncode);
	                                                "Motore".M[#K_MotoreInt].Dati.Encoder.#RichSetupEnc := true;
	                                            10:
	                                                #TempEnc.#AppoScrEncoder := (#TempEnc.#AppoSetupEncoder) OR dw#16#C0000000;
	                                                "WRREC"(REQ := "Motore".M[#K_MotoreInt].Dati.Encoder.RichSetupEnc AND NOT "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.BUSY AND NOT "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.DONE,
	                                           ID := "Motore".M[#K_MotoreInt].HW.HWIO_Encoder,
	                                           INDEX := 2,
	                                           LEN := 4,
	                                           DONE => "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.DONE,
	                                           BUSY => "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.BUSY,
	                                           ERROR => "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.ERROR,
	                                           STATUS => "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.STATUS,
	                                           RECORD := #TempEnc.AppoScrEncoder);
	                                            11:
	                                                #TempEnc.#AppoScrEncoder := #TempEnc.#AppoSetupEncoder;
	                                                "WRREC"(REQ := "Motore".M[#K_MotoreInt].Dati.Encoder.RichSetupEnc AND NOT "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.BUSY AND NOT "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.DONE,
	                                           ID := "Motore".M[#K_MotoreInt].HW.HWIO_Encoder,
	                                           INDEX := 2,
	                                           LEN := 4,
	                                           DONE => "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.DONE,
	                                           BUSY => "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.BUSY,
	                                           ERROR => "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.ERROR,
	                                           STATUS => "Motore".M[#K_MotoreInt].Dati.SetupPN.Output.STATUS,
	                                           RECORD := #TempEnc.AppoScrEncoder);
	                                        END_CASE;
	                                        "Motore".M[#K_MotoreInt].Dati.Encoder.#RichSetupEnc := true;
	                                    ELSE
	                                        "Motore".M[#K_MotoreInt].Out.EncoderHomed := true;
	                                    END_IF;
	                                ELSE
	                                    IF "Motore".M[#K_MotoreInt].Dati.Encoder.RichSetupEnc THEN
	                                        CASE "Motore".M[#K_MotoreInt].HW.TipoEncoder OF
	                                            9:
	                                                #TempTelem.SendAEncode.M05_OUT_Preset := 0;
	                                                "Motore".M[#K_MotoreInt].Dati.Encoder.#RetValScrEnc := DPWR_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Encoder, RECORD := #TempTelem.SendAEncode);
	                                        END_CASE;
	                                        "Motore".M[#K_MotoreInt].Dati.Encoder.RichSetupEnc := false;
	                                    END_IF;
	                                END_IF;
	                            END_REGION
	                        END_REGION
	                    ELSE
	                        REGION Gestione Encoder EndLess
	                            REGION Gestione Setup Encoder
	                                IF #REQSetup THEN
	                                    "Motore".M[#K_MotoreInt].Out.EncoderHomed := true;
	                                    "Motore".M[#K_MotoreInt].Prm.C.EncPos := DINT_TO_REAL("Motore".M[#K_MotoreInt].HMI.ValoreSetupRichiesto);
	                                    "Motore".M[#K_MotoreInt].In.Setup := false;
	                                END_IF;
	                            END_REGION
	                            REGION REGION CalcoloPosizione
	                                IF NOT "Motore".M[#K_MotoreInt].In.NoComunEnc THEN
	                                    #TempEnc.SpazioUltimoCiclo := #TempEnc.PosizioneLettaEnc - "Motore".M[#K_MotoreInt].Dati.Encoder.o_OldPosEncoder;
	                                    IF #TempEnc.SpazioUltimoCiclo <> 0 THEN
	                                        IF ABS(#TempEnc.SpazioUltimoCiclo) > "Motore".M[#K_MotoreInt].Dati.Encoder.#MezzoRicircoloEncoder THEN
	                                            IF #TempEnc.PosizioneLettaEnc < "Motore".M[#K_MotoreInt].Dati.Encoder.o_OldPosEncoder THEN
	                                                #TempEnc.SpazioUltimoCiclo := "Motore".M[#K_MotoreInt].Dati.Encoder.#RicircoloEncoder - "Motore".M[#K_MotoreInt].Dati.Encoder.o_OldPosEncoder + #TempEnc.PosizioneLettaEnc;
	                                            ELSE
	                                                #TempEnc.SpazioUltimoCiclo := #TempEnc.PosizioneLettaEnc - "Motore".M[#K_MotoreInt].Dati.Encoder.#RicircoloEncoder - "Motore".M[#K_MotoreInt].Dati.Encoder.o_OldPosEncoder;
	                                            END_IF;
	                                        END_IF;
	                                        "Motore".M[#K_MotoreInt].Dati.Encoder.o_OldPosEncoder := #TempEnc.PosizioneLettaEnc;
	                                        IF NOT "Motore".M[#K_MotoreInt].Prm.Enc.Direction THEN
	                                            "Motore".M[#K_MotoreInt].Prm.C.EncPos += DINT_TO_REAL(#TempEnc.SpazioUltimoCiclo) * "Motore".M[#K_MotoreInt].Prm.C.SpazioGiroEncoder / "Motore".M[#K_MotoreInt].Prm.Enc.ImpRev;
	                                        ELSE
	                                            "Motore".M[#K_MotoreInt].Prm.C.EncPos -= DINT_TO_REAL(#TempEnc.SpazioUltimoCiclo) * "Motore".M[#K_MotoreInt].Prm.C.SpazioGiroEncoder / "Motore".M[#K_MotoreInt].Prm.Enc.ImpRev;
	                                        END_IF;
	                                        IF "Motore".M[#K_MotoreInt].Prm.C.EncPos > DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Enc.ModuloPosEnc) THEN
	                                            "Motore".M[#K_MotoreInt].Prm.C.EncPos -= DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Enc.ModuloPosEnc - "Motore".M[#K_MotoreInt].Prm.Enc.ModuloNegEnc);
	                                        ELSIF "Motore".M[#K_MotoreInt].Prm.C.EncPos < DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Enc.ModuloNegEnc) THEN
	                                            "Motore".M[#K_MotoreInt].Prm.C.EncPos += DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Enc.ModuloPosEnc - "Motore".M[#K_MotoreInt].Prm.Enc.ModuloNegEnc);
	                                        END_IF;
	                                    END_IF;
	                                END_IF;
	                            END_REGION
	                        END_REGION
	                    END_IF;
	                END_IF;
	                (* Assegnazione dati Posizione Encoder *)
	                "Motore".M[#K_MotoreInt].Out.ActPos := TRUNC("Motore".M[#K_MotoreInt].Prm.C.EncPos);
	                IF #REQSetup THEN
	                    "Motore".M[#K_MotoreInt].Dati.PosizioneAlloStop := "Motore".M[#K_MotoreInt].Dati.PosizioneCheckDirezione := "Motore".M[#K_MotoreInt].Dati.TrgPosDint := "Motore".M[#K_MotoreInt].Dati.OldTrgPosDint := "Motore".M[#K_MotoreInt].Dati.OldEncoder := "Motore".M[#K_MotoreInt].Out.ActPos;
	                    "Motore".M[#K_MotoreInt].Prm.C.TrgPos := "Motore".M[#K_MotoreInt].Prm.C.EncPos;
	                END_IF;
	            ELSIF #REQSetup THEN
	                (* Gestione Posizione Encoder Simulata *)
	                "Motore".M[#K_MotoreInt].Dati.PosizioneAlloStop := "Motore".M[#K_MotoreInt].Dati.PosizioneCheckDirezione := "Motore".M[#K_MotoreInt].Dati.TrgPosDint := "Motore".M[#K_MotoreInt].Dati.OldTrgPosDint := "Motore".M[#K_MotoreInt].Dati.OldEncoder := "Motore".M[#K_MotoreInt].Out.ActPos := "Motore".M[#K_MotoreInt].HMI.ValoreSetupEncoder;
	                "Motore".M[#K_MotoreInt].Prm.C.TrgPos := "Motore".M[#K_MotoreInt].Prm.C.EncPos := DINT_TO_REAL("Motore".M[#K_MotoreInt].HMI.ValoreSetupEncoder);
	                "Motore".M[#K_MotoreInt].In.Setup := false;
	            END_IF;
	        END_REGION
	        REGION Spazio Ciclo PLC    
	            IF "Motore".M[#K_MotoreInt].Out.ActPos <> "Motore".M[#K_MotoreInt].Dati.OldEncoder THEN
	                "Motore".M[#K_MotoreInt].Out.SpazioCicloEnc := "Motore".M[#K_MotoreInt].Out.ActPos - "Motore".M[#K_MotoreInt].Dati.OldEncoder;
	                IF "Motore".M[#K_MotoreInt].Prm.Mech.EndLess THEN
	                    IF ABS("Motore".M[#K_MotoreInt].Out.SpazioCicloEnc) > #MezzoRicircoloTotale THEN
	                        IF "Motore".M[#K_MotoreInt].Dati.OldEncoder > "Motore".M[#K_MotoreInt].Out.ActPos THEN
	                            "Motore".M[#K_MotoreInt].Out.SpazioCicloEnc := "Motore".M[#K_MotoreInt].Prm.Enc.ModuloPosEnc - "Motore".M[#K_MotoreInt].Dati.OldEncoder - "Motore".M[#K_MotoreInt].Prm.Enc.ModuloNegEnc + "Motore".M[#K_MotoreInt].Out.ActPos;
	                        ELSE
	                            "Motore".M[#K_MotoreInt].Out.SpazioCicloEnc := "Motore".M[#K_MotoreInt].Out.ActPos - "Motore".M[#K_MotoreInt].Prm.Enc.ModuloPosEnc + "Motore".M[#K_MotoreInt].Prm.Enc.ModuloNegEnc - "Motore".M[#K_MotoreInt].Dati.OldEncoder;
	                        END_IF;
	                    END_IF;
	                END_IF;
	                "Motore".M[#K_MotoreInt].Dati.OldEncoder := "Motore".M[#K_MotoreInt].Out.ActPos;
	            ELSE
	                "Motore".M[#K_MotoreInt].Out.SpazioCicloEnc := 0;
	            END_IF;
	        END_REGION
	    END_REGION ;
	    REGION Limits
	        "Motore".M[#K_MotoreInt].Allarmi.Parametri := false;
	        REGION Abilita Cambio Direzione    
	            IF "Motore".M[#K_MotoreInt].Prm.TCambioDir = 0 OR "Motore".M[#K_MotoreInt].Prm.CambioDirNoFreno THEN
	                #AbilDirPos := #AbilDirNeg := true;
	                "Motore".M[#K_MotoreInt].Dati.ContCambioDirPos := "Motore".M[#K_MotoreInt].Dati.ContCambioDirNeg := -1;
	            ELSE
	                IF "Motore".M[#K_MotoreInt].Out.ActDirNeg THEN
	                    "Motore".M[#K_MotoreInt].Dati.ContCambioDirPos := "Motore".M[#K_MotoreInt].Prm.TCambioDir;
	                ELSIF "Motore".M[#K_MotoreInt].Out.ActDirPos THEN
	                    "Motore".M[#K_MotoreInt].Dati.ContCambioDirNeg := "Motore".M[#K_MotoreInt].Prm.TCambioDir;
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].Dati.ContCambioDirPos < 0 THEN
	                    #AbilDirPos := true;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Dati.ContCambioDirPos -= REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                    #AbilDirPos := false;
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].Dati.ContCambioDirNeg < 0 THEN
	                    #AbilDirNeg := true;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Dati.ContCambioDirNeg -= REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                    #AbilDirNeg := false;
	                END_IF;
	            END_IF;
	        END_REGION
	        IF NOT "Motore".M[#K_MotoreInt].Prm.EscludiFunzPos THEN
	            REGION Abilita movimento motore / Posizionamento
	                "Motore".M[#K_MotoreInt].Out.Pronto := FALSE;
	                IF "Zona".Z[#K_Zona].Out.CentralinaOk THEN
	                    IF NOT "Motore".M[#K_MotoreInt].In.SezAperto AND NOT "Motore".M[#K_MotoreInt].In.DriverFault AND NOT "Motore".M[#K_MotoreInt].In.NoComunInv THEN
	                        IF NOT "Motore".M[#K_MotoreInt].In.TerVentolaOff AND NOT "Motore".M[#K_MotoreInt].In.CinghiaRotta AND NOT "Motore".M[#K_MotoreInt].In.SpinaSicNoInPos AND ("Motore".M[#K_MotoreInt].In.AnticadutaON OR NOT "Motore".M[#K_MotoreInt].Prm.AnticadutaPresente) THEN
	                            "Motore".M[#K_MotoreInt].Out.Pronto := NOT "Motore".M[#K_MotoreInt].Dati.MotorStop;
	                        ELSIF "Zona".Z[#K_ZonaInt].Out.Man AND "Zona".Z[#K_Zona].Gen.Reset AND ("Motore".M[#K_MotoreInt].In.CmdPosRich OR "Motore".M[#K_MotoreInt].In.CmdNegRich) THEN
	                            "Motore".M[#K_MotoreInt].Out.Pronto := TRUE;
	                        END_IF;
	                    END_IF;
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].In.Positioning THEN
	                    #FunzPositioning := NOT "Motore".M[#K_MotoreInt].In.CmdPosRich AND NOT "Motore".M[#K_MotoreInt].In.CmdNegRich AND NOT #REQSetupPannello AND "Motore".M[#K_MotoreInt].Out.Pronto AND (NOT "Motore".M[#K_MotoreInt].In.NoComunEnc OR "Motore".M[#K_MotoreInt].Prm.Enc.EncoderLess);
	                ELSE
	                    #FunzPositioning := FALSE;
	                END_IF;
	            END_REGION
	            REGION Controllo Limiti
	                IF "Motore".M[#K_MotoreInt].Prm.Mech.EndLess THEN
	                    (* In caso di Funzionamento EndLess, i limiti di posizione non possono superare gli estremi del ricircolo *)
	                    "Motore".M[#K_MotoreInt].Prm.LimitePos := MIN(IN1 := "Motore".M[#K_MotoreInt].Prm.LimitePos, IN2 := "Motore".M[#K_MotoreInt].Prm.Enc.ModuloPosEnc);
	                    "Motore".M[#K_MotoreInt].Prm.LimiteNeg := MAX(IN1 := "Motore".M[#K_MotoreInt].Prm.LimiteNeg, IN2 := "Motore".M[#K_MotoreInt].Prm.Enc.ModuloNegEnc);
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].Prm.LimitePos <= "Motore".M[#K_MotoreInt].Prm.LimiteNeg THEN
	                    "Motore".M[#K_MotoreInt].Prm.LimitePos := "Motore".M[#K_MotoreInt].Prm.LimiteNeg + 1;
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].In.AttivaLimVarNeg THEN
	                    "Motore".M[#K_MotoreInt].In.LimiteVarNeg := MIN(IN1 := "Motore".M[#K_MotoreInt].Prm.LimitePos, IN2 := "Motore".M[#K_MotoreInt].In.LimiteVarNeg);
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].In.AttivaLimVarPos THEN
	                    "Motore".M[#K_MotoreInt].In.LimiteVarPos := MAX(IN1 := "Motore".M[#K_MotoreInt].Prm.LimiteNeg, IN2 := "Motore".M[#K_MotoreInt].In.LimiteVarPos);
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].In.AttivaLimVarNeg AND "Motore".M[#K_MotoreInt].In.AttivaLimVarPos THEN
	                    IF "Motore".M[#K_MotoreInt].In.LimiteVarPos <= "Motore".M[#K_MotoreInt].In.LimiteVarNeg THEN
	                        "Motore".M[#K_MotoreInt].In.LimiteVarPos := "Motore".M[#K_MotoreInt].In.LimiteVarNeg + 1;
	                    END_IF;
	                END_IF;
	            END_REGION
	            REGION Posizione Destinazione Assoluta/Relativa
	                "Motore".M[#K_MotoreInt].Allarmi.TrgPosMaxPos := "Motore".M[#K_MotoreInt].Allarmi.TrgPosMinNeg := "Motore".M[#K_MotoreInt].Allarmi.TrgPosMaxPosVar := "Motore".M[#K_MotoreInt].Allarmi.TrgPosMinNegVar := false;
	                IF "Motore".M[#K_MotoreInt].In.PosRelativo THEN
	                    IF NOT "Motore".M[#K_MotoreInt].Dati.AppoImpMovRelativo THEN
	                        "Motore".M[#K_MotoreInt].Out.DistTRG := "Motore".M[#K_MotoreInt].Dati.MovRelRichiesto := "Motore".M[#K_MotoreInt].In.TrgPosRel;
	                    END_IF;
	                    IF NOT "Motore".M[#K_MotoreInt].Prm.Mech.EndLess THEN
	                        IF "Motore".M[#K_MotoreInt].Out.ActPos - "Motore".M[#K_MotoreInt].Out.DistTRG < "Motore".M[#K_MotoreInt].Prm.LimiteNeg THEN
	                            "Motore".M[#K_MotoreInt].Out.DistTRG := "Motore".M[#K_MotoreInt].Dati.MovRelRichiesto := "Motore".M[#K_MotoreInt].Out.ActPos - "Motore".M[#K_MotoreInt].Prm.LimiteNeg;
	                            IF #FunzPositioning THEN
	                                "Motore".M[#K_MotoreInt].Allarmi.Parametri := "Motore".M[#K_MotoreInt].Allarmi.TrgPosMinNeg := TRUE;
	                            END_IF;
	                        END_IF;
	                        IF "Motore".M[#K_MotoreInt].In.AttivaLimVarNeg THEN
	                            IF "Motore".M[#K_MotoreInt].Out.ActPos - "Motore".M[#K_MotoreInt].Out.DistTRG < "Motore".M[#K_MotoreInt].In.LimiteVarNeg THEN
	                                "Motore".M[#K_MotoreInt].Out.DistTRG := "Motore".M[#K_MotoreInt].Dati.MovRelRichiesto := "Motore".M[#K_MotoreInt].Out.ActPos - "Motore".M[#K_MotoreInt].In.LimiteVarNeg;
	                                IF #FunzPositioning THEN
	                                    "Motore".M[#K_MotoreInt].Allarmi.Parametri := "Motore".M[#K_MotoreInt].Allarmi.TrgPosMinNegVar := TRUE;
	                                END_IF;
	                            END_IF;
	                        END_IF;
	                        IF "Motore".M[#K_MotoreInt].Out.ActPos + "Motore".M[#K_MotoreInt].Out.DistTRG > "Motore".M[#K_MotoreInt].Prm.LimitePos THEN
	                            "Motore".M[#K_MotoreInt].Out.DistTRG := "Motore".M[#K_MotoreInt].Dati.MovRelRichiesto := "Motore".M[#K_MotoreInt].Prm.LimitePos - "Motore".M[#K_MotoreInt].Out.ActPos;
	                            IF #FunzPositioning THEN
	                                "Motore".M[#K_MotoreInt].Allarmi.Parametri := "Motore".M[#K_MotoreInt].Allarmi.TrgPosMaxPos := TRUE;
	                            END_IF;
	                        END_IF;
	                        IF "Motore".M[#K_MotoreInt].In.AttivaLimVarPos THEN
	                            IF "Motore".M[#K_MotoreInt].Out.ActPos + "Motore".M[#K_MotoreInt].Out.DistTRG > "Motore".M[#K_MotoreInt].In.LimiteVarPos THEN
	                                "Motore".M[#K_MotoreInt].Out.DistTRG := "Motore".M[#K_MotoreInt].Dati.MovRelRichiesto := "Motore".M[#K_MotoreInt].In.LimiteVarPos - "Motore".M[#K_MotoreInt].Out.ActPos;
	                                IF #FunzPositioning THEN
	                                    "Motore".M[#K_MotoreInt].Allarmi.Parametri := "Motore".M[#K_MotoreInt].Allarmi.TrgPosMaxPosVar := TRUE;
	                                END_IF;
	                            END_IF;
	                        END_IF;
	                        "Motore".M[#K_MotoreInt].Dati.MovRelRichiesto := ABS("Motore".M[#K_MotoreInt].Dati.MovRelRichiesto);
	                    END_IF;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Out.TrgPosFiltrata := "Motore".M[#K_MotoreInt].In.TrgPos;
	                    IF "Motore".M[#K_MotoreInt].Out.TrgPosFiltrata < "Motore".M[#K_MotoreInt].Prm.LimiteNeg THEN
	                        "Motore".M[#K_MotoreInt].Out.TrgPosFiltrata := "Motore".M[#K_MotoreInt].Prm.LimiteNeg;
	                        IF #FunzPositioning THEN
	                            "Motore".M[#K_MotoreInt].Allarmi.Parametri := "Motore".M[#K_MotoreInt].Allarmi.TrgPosMinNeg := TRUE;
	                        END_IF;
	                    END_IF;
	                    IF "Motore".M[#K_MotoreInt].In.AttivaLimVarNeg THEN
	                        IF "Motore".M[#K_MotoreInt].Out.TrgPosFiltrata < "Motore".M[#K_MotoreInt].In.LimiteVarNeg THEN
	                            "Motore".M[#K_MotoreInt].Out.TrgPosFiltrata := "Motore".M[#K_MotoreInt].In.LimiteVarNeg;
	                            IF #FunzPositioning THEN
	                                "Motore".M[#K_MotoreInt].Allarmi.Parametri := "Motore".M[#K_MotoreInt].Allarmi.TrgPosMinNegVar := TRUE;
	                            END_IF;
	                        END_IF;
	                    END_IF;
	                    IF "Motore".M[#K_MotoreInt].Out.TrgPosFiltrata > "Motore".M[#K_MotoreInt].Prm.LimitePos THEN
	                        "Motore".M[#K_MotoreInt].Out.TrgPosFiltrata := "Motore".M[#K_MotoreInt].Prm.LimitePos;
	                        IF #FunzPositioning THEN
	                            "Motore".M[#K_MotoreInt].Allarmi.Parametri := "Motore".M[#K_MotoreInt].Allarmi.TrgPosMaxPos := TRUE;
	                        END_IF;
	                    END_IF;
	                    IF "Motore".M[#K_MotoreInt].In.AttivaLimVarPos THEN
	                        IF "Motore".M[#K_MotoreInt].Out.TrgPosFiltrata > "Motore".M[#K_MotoreInt].In.LimiteVarPos THEN
	                            "Motore".M[#K_MotoreInt].Out.TrgPosFiltrata := "Motore".M[#K_MotoreInt].In.LimiteVarPos;
	                            IF #FunzPositioning THEN
	                                "Motore".M[#K_MotoreInt].Allarmi.Parametri := "Motore".M[#K_MotoreInt].Allarmi.TrgPosMaxPosVar := TRUE;
	                            END_IF;
	                        END_IF;
	                    END_IF;
	                END_IF;
	                "Motore".M[#K_MotoreInt].Dati.AppoImpMovRelativo := "Motore".M[#K_MotoreInt].In.PosRelativo;
	            END_REGION
	            REGION Calcolo La Distanza Dal Target
	                IF NOT "Motore".M[#K_MotoreInt].In.PosRelativo THEN
	                    "Motore".M[#K_MotoreInt].Out.DistTRG := "Motore".M[#K_MotoreInt].Out.TrgPosFiltrata - "Motore".M[#K_MotoreInt].Out.ActPos;
	                    IF "Motore".M[#K_MotoreInt].Prm.Mech.EndLess THEN
	                        IF (#RicircoloTotale - "Motore".M[#K_MotoreInt].Out.DistTRG) < "Motore".M[#K_MotoreInt].Prm.Precisione THEN
	                            "Motore".M[#K_MotoreInt].Out.DistTRG := #RicircoloTotale - "Motore".M[#K_MotoreInt].Out.DistTRG;
	                        END_IF;
	                        IF #RicircoloTotale + "Motore".M[#K_MotoreInt].Out.DistTRG < "Motore".M[#K_MotoreInt].Prm.Precisione THEN
	                            "Motore".M[#K_MotoreInt].Out.DistTRG := #RicircoloTotale + "Motore".M[#K_MotoreInt].Out.DistTRG;
	                        END_IF;
	                        IF "Motore".M[#K_MotoreInt].In.ForzaEndLessPos THEN
	                            IF "Motore".M[#K_MotoreInt].Out.DistTRG < - "Motore".M[#K_MotoreInt].Prm.Precisione THEN
	                                "Motore".M[#K_MotoreInt].Out.DistTRG := "Motore".M[#K_MotoreInt].Out.DistTRG + #RicircoloTotale;
	                            END_IF;
	                        ELSIF "Motore".M[#K_MotoreInt].In.ForzaEndLessNeg THEN
	                            IF "Motore".M[#K_MotoreInt].Out.DistTRG > "Motore".M[#K_MotoreInt].Prm.Precisione THEN
	                                "Motore".M[#K_MotoreInt].Out.DistTRG := "Motore".M[#K_MotoreInt].Out.DistTRG - #RicircoloTotale;
	                            END_IF;
	                        ELSIF "Motore".M[#K_MotoreInt].In.ForzaEndLessBreve THEN
	                            IF "Motore".M[#K_MotoreInt].Out.DistTRG > #MezzoRicircoloTotale THEN
	                                "Motore".M[#K_MotoreInt].Out.DistTRG := "Motore".M[#K_MotoreInt].Out.DistTRG - #RicircoloTotale;
	                            ELSIF "Motore".M[#K_MotoreInt].Out.DistTRG < - #MezzoRicircoloTotale THEN
	                                "Motore".M[#K_MotoreInt].Out.DistTRG := "Motore".M[#K_MotoreInt].Out.DistTRG + #RicircoloTotale;
	                            END_IF;
	                        END_IF;
	                    END_IF;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Out.DistTRG -= "Motore".M[#K_MotoreInt].Out.SpazioCicloEnc;
	                END_IF;
	                #DistTRG_ASS := ABS("Motore".M[#K_MotoreInt].Out.DistTRG);
	            END_REGION
	            REGION Time-Out Motore in Posizione
	                #DistTrgMagPrec := "Motore".M[#K_MotoreInt].Out.DistTRG > "Motore".M[#K_MotoreInt].Prm.Precisione;
	                #DistTrgMinPrec := "Motore".M[#K_MotoreInt].Out.DistTRG < - "Motore".M[#K_MotoreInt].Prm.Precisione;
	                IF NOT #DistTrgMagPrec AND NOT #DistTrgMinPrec THEN
	                    IF "Motore".M[#K_MotoreInt].Dati.ContMotoreInPrec < 2000 THEN
	                        "Motore".M[#K_MotoreInt].Dati.ContMotoreInPrec += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                    ELSE
	                        #RitMotInPrecisione := true;
	                    END_IF;
	                ELSE
	                    #RitMotInPrecisione := FALSE;
	                    "Motore".M[#K_MotoreInt].Dati.ContMotoreInPrec := 0;
	                END_IF;
	            END_REGION
	            REGION Direzione Richiesta da Posizionatore
	                IF "Motore".M[#K_MotoreInt].Out.DistTRG > "Motore".M[#K_MotoreInt].Prm.SpazioArrestoPos THEN
	                    IF #DistTrgMagPrec THEN
	                        "Motore".M[#K_MotoreInt].Out.RichMovPos := TRUE;
	                    ELSIF #RitMotInPrecisione THEN
	                        "Motore".M[#K_MotoreInt].Out.RichMovPos := FALSE;
	                    END_IF;
	                    "Motore".M[#K_MotoreInt].Out.RichMovNeg := FALSE;
	                    "Motore".M[#K_MotoreInt].Out.PosOK := NOT "Motore".M[#K_MotoreInt].Out.RichMovPos;
	                ELSIF "Motore".M[#K_MotoreInt].Out.DistTRG < - "Motore".M[#K_MotoreInt].Prm.SpazioArrestoNeg THEN
	                    IF #DistTrgMinPrec THEN
	                        "Motore".M[#K_MotoreInt].Out.RichMovNeg := TRUE;
	                    ELSIF #RitMotInPrecisione THEN
	                        "Motore".M[#K_MotoreInt].Out.RichMovNeg := FALSE;
	                    END_IF;
	                    "Motore".M[#K_MotoreInt].Out.RichMovPos := FALSE;
	                    "Motore".M[#K_MotoreInt].Out.PosOK := NOT "Motore".M[#K_MotoreInt].Out.RichMovNeg;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Out.RichMovPos := FALSE;
	                    "Motore".M[#K_MotoreInt].Out.RichMovNeg := FALSE;
	                    "Motore".M[#K_MotoreInt].Out.PosOK := TRUE;
	                END_IF;
	            END_REGION
	            REGION Adattamento Perc.In Lavoro
	                #CambioPercLavoro := "Motore".M[#K_MotoreInt].Dati.Memo_PercentualeRich <> "Motore".M[#K_MotoreInt].In.PercentualeRichiesta;
	                IF #CambioPercLavoro THEN
	                    IF "Motore".M[#K_MotoreInt].In.PercentualeRichiesta < 20 OR "Motore".M[#K_MotoreInt].In.PercentualeRichiesta > 100 THEN
	                        "Motore".M[#K_MotoreInt].In.PercentualeRichiesta := 100;
	                    END_IF;
	                    "Motore".M[#K_MotoreInt].Dati.Memo_PercentualeRich := "Motore".M[#K_MotoreInt].In.PercentualeRichiesta;
	                END_IF;
	(* Controllo cambio VelocitÃ  Richiesta *)
	                #CambioReqVel := "Motore".M[#K_MotoreInt].Dati.Memo_Req_Vel <> "Motore".M[#K_MotoreInt].In.CmdVelocitaRich OR #CambioPercLavoro OR "Motore".M[#K_MotoreInt].Allarmi.TrgVelMinFreno OR "Motore".M[#K_MotoreInt].Allarmi.TrgVelMaxMax;
	                IF #CambioReqVel THEN
	                    "Motore".M[#K_MotoreInt].Dati.Memo_Req_Vel := "Motore".M[#K_MotoreInt].In.CmdVelocitaRich;
	                    "Motore".M[#K_MotoreInt].Dati.VeloRichPerc := "Motore".M[#K_MotoreInt].Dati.Memo_Req_Vel * "Motore".M[#K_MotoreInt].In.PercentualeRichiesta / DINT#100;
	                END_IF;
	(* Controllo Cambio Accelerazione richiesta *)
	                #CambioReqAcc := "Motore".M[#K_MotoreInt].Dati.Memo_Req_Acc <> "Motore".M[#K_MotoreInt].In.Acc OR #CambioPercLavoro OR "Motore".M[#K_MotoreInt].Allarmi.AccRichZero OR "Motore".M[#K_MotoreInt].Allarmi.AccRichMaxMaxDec;
	                IF #CambioReqAcc THEN
	                    "Motore".M[#K_MotoreInt].Dati.Memo_Req_Acc := MAX(IN1 := "Motore".M[#K_MotoreInt].In.Acc, IN2 := 10);
	                    "Motore".M[#K_MotoreInt].Dati.AccRichPerc := "Motore".M[#K_MotoreInt].Dati.Memo_Req_Acc * "Motore".M[#K_MotoreInt].In.PercentualeRichiesta / DINT#100;
	                END_IF;
	(* Controllo Cambio Decelerazione richiesta *)
	                #CambioReqDec := "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec <> "Motore".M[#K_MotoreInt].In.Dec OR #CambioPercLavoro OR "Motore".M[#K_MotoreInt].Allarmi.DecRichZero OR "Motore".M[#K_MotoreInt].Allarmi.DecRichMaxMaxDec;
	                IF #CambioReqDec THEN
	                    "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec := MAX(IN1 := "Motore".M[#K_MotoreInt].In.Dec, IN2 := 10);
	                    "Motore".M[#K_MotoreInt].Dati.DecRichPerc := "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec * "Motore".M[#K_MotoreInt].In.PercentualeRichiesta / DINT#100;
	                END_IF;
	            END_REGION
	            #VeloBassaConv := DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.VelBassa);
	            REGION Direzione Movimento Richiesta
	                IF ("Motore".M[#K_MotoreInt].Out.RichMovPos AND "Motore".M[#K_MotoreInt].In.ConsMovimentoPos AND #FunzPositioning OR "Motore".M[#K_MotoreInt].In.CmdPosRich) AND "Motore".M[#K_MotoreInt].Out.Pronto AND #AbilDirPos THEN
	                    #ReqDirPos := TRUE;
	                    #ReqDirNeg := FALSE;
	                    #UnaDirezioneRichiesta := TRUE;
	                ELSIF ("Motore".M[#K_MotoreInt].Out.RichMovNeg AND "Motore".M[#K_MotoreInt].In.ConsMovimentoNeg AND #FunzPositioning OR "Motore".M[#K_MotoreInt].In.CmdNegRich) AND "Motore".M[#K_MotoreInt].Out.Pronto AND #AbilDirNeg THEN
	                    #ReqDirPos := FALSE;
	                    #ReqDirNeg := TRUE;
	                    #UnaDirezioneRichiesta := TRUE;
	                ELSE
	                    #ReqDirPos := FALSE;
	                    #ReqDirNeg := FALSE;
	                    #UnaDirezioneRichiesta := FALSE;
	                END_IF;
	            END_REGION
	            REGION Posizione PiÃ¹ e Meno Inerzia
	                "Motore".M[#K_MotoreInt].Out.ActPosPiuInerzia := "Motore".M[#K_MotoreInt].Out.ActPos + "Motore".M[#K_MotoreInt].Prm.Inerzia;
	                "Motore".M[#K_MotoreInt].Out.ActPosMenoInerzia := "Motore".M[#K_MotoreInt].Out.ActPos - "Motore".M[#K_MotoreInt].Prm.Inerzia;
	                "Motore".M[#K_MotoreInt].Out.MinTrg := "Motore".M[#K_MotoreInt].Out.DistTRG > "Motore".M[#K_MotoreInt].Prm.Inerzia;
	                "Motore".M[#K_MotoreInt].Out.MaxTrg := "Motore".M[#K_MotoreInt].Out.DistTRG < - "Motore".M[#K_MotoreInt].Prm.Inerzia;
	                "Motore".M[#K_MotoreInt].Out.ActInInerzia := NOT "Motore".M[#K_MotoreInt].Out.MinTrg AND NOT "Motore".M[#K_MotoreInt].Out.MaxTrg;
	                IF "Motore".M[#K_MotoreInt].Prm.Mech.EndLess THEN
	                    IF "Motore".M[#K_MotoreInt].Out.ActPosMenoInerzia < "Motore".M[#K_MotoreInt].Prm.Enc.ModuloNegEnc THEN
	                        "Motore".M[#K_MotoreInt].Out.ActPosMenoInerzia += #RicircoloTotale;
	                    END_IF;
	                    IF "Motore".M[#K_MotoreInt].Out.ActPosPiuInerzia > "Motore".M[#K_MotoreInt].Prm.Enc.ModuloPosEnc THEN
	                        "Motore".M[#K_MotoreInt].Out.ActPosPiuInerzia -= #RicircoloTotale;
	                    END_IF;
	                END_IF;
	                "Motore".M[#K_MotoreInt].Out.MaxLimPos := "Motore".M[#K_MotoreInt].Out.ActPosPiuInerzia >= "Motore".M[#K_MotoreInt].Prm.LimitePos;
	                "Motore".M[#K_MotoreInt].Out.MinLimNeg := "Motore".M[#K_MotoreInt].Out.ActPosMenoInerzia <= "Motore".M[#K_MotoreInt].Prm.LimiteNeg;
	            END_REGION
	        ELSE
	            REGION Abilita movimento motore
	                "Motore".M[#K_MotoreInt].Out.Pronto := FALSE;
	                IF "Zona".Z[#K_Zona].Out.CentralinaOk THEN
	                    IF NOT "Motore".M[#K_MotoreInt].In.SezAperto AND NOT "Motore".M[#K_MotoreInt].In.DriverFault AND NOT "Motore".M[#K_MotoreInt].In.NoComunInv AND NOT "Motore".M[#K_MotoreInt].In.TerVentolaOff THEN
	                        "Motore".M[#K_MotoreInt].Out.Pronto := TRUE;
	                    END_IF;
	                END_IF;
	                #FunzPositioning := FALSE;
	                
	                #CambioReqVel := "Motore".M[#K_MotoreInt].Dati.VeloRichPerc <> "Motore".M[#K_MotoreInt].In.CmdVelocitaRich;
	                IF #CambioReqVel THEN
	                    "Motore".M[#K_MotoreInt].Dati.VeloRichPerc := "Motore".M[#K_MotoreInt].In.CmdVelocitaRich;
	                END_IF;
	(* Controllo Cambio Accelerazione richiesta *)
	                #CambioReqAcc := "Motore".M[#K_MotoreInt].Dati.AccRichPerc <> "Motore".M[#K_MotoreInt].In.Acc;
	                IF #CambioReqAcc THEN
	                    "Motore".M[#K_MotoreInt].Dati.AccRichPerc := "Motore".M[#K_MotoreInt].In.Acc;
	                END_IF;
	(* Controllo Cambio Decelerazione richiesta *)
	                #CambioReqDec := "Motore".M[#K_MotoreInt].Dati.DecRichPerc <> "Motore".M[#K_MotoreInt].In.Dec;
	                IF #CambioReqDec THEN
	                    "Motore".M[#K_MotoreInt].Dati.DecRichPerc := "Motore".M[#K_MotoreInt].In.Dec;
	                END_IF;
	            END_REGION
	            REGION Direzione Movimento Richiesta
	                IF "Motore".M[#K_MotoreInt].In.CmdPosRich AND "Motore".M[#K_MotoreInt].Out.Pronto AND #AbilDirPos THEN
	                    #ReqDirPos := TRUE;
	                    #ReqDirNeg := FALSE;
	                    #UnaDirezioneRichiesta := TRUE;
	                ELSIF "Motore".M[#K_MotoreInt].In.CmdNegRich AND "Motore".M[#K_MotoreInt].Out.Pronto AND #AbilDirNeg THEN
	                    #ReqDirPos := FALSE;
	                    #ReqDirNeg := TRUE;
	                    #UnaDirezioneRichiesta := TRUE;
	                ELSE
	                    #ReqDirPos := FALSE;
	                    #ReqDirNeg := FALSE;
	                    #UnaDirezioneRichiesta := FALSE;
	                END_IF;
	            END_REGION
	        END_IF;
	    END_REGION ;
	    REGION Parameter profile
	        REGION VelocitÃ  Minima
	            IF NOT "Motore".M[#K_MotoreInt].Dati.ActVelPos AND NOT "Motore".M[#K_MotoreInt].Dati.ActVelNeg AND #ReqDirNeg OR "Motore".M[#K_MotoreInt].Dati.ActVelNeg THEN
	                #SpazioFrenoDir := "Motore".M[#K_MotoreInt].Prm.SpazioArrestoNeg;
	                #VeloFrenoDir := "Motore".M[#K_MotoreInt].Prm.VelSgancioFrenoNeg;
	            ELSE
	                #SpazioFrenoDir := "Motore".M[#K_MotoreInt].Prm.SpazioArrestoPos;
	                #VeloFrenoDir := "Motore".M[#K_MotoreInt].Prm.VelSgancioFrenoPos;
	            END_IF;
	        END_REGION
	        REGION Controllo VelocitÃ 
	(* Controllo che la velocitÃ  sia all'interno del limite Sgancio Freno < VeloRich < VeloMax *)
	            "Motore".M[#K_MotoreInt].Allarmi.TrgVelMinFreno := false;
	            "Motore".M[#K_MotoreInt].Allarmi.TrgVelMaxMax := false;
	            "Motore".M[#K_MotoreInt].Allarmi.TrgVelCamMinFreno := false;
	            "Motore".M[#K_MotoreInt].Allarmi.TrgVelCamMaxMax := false;
	            IF #UnaDirezioneRichiesta THEN
	                IF "Motore".M[#K_MotoreInt].Dati.VeloRichPerc < #VeloFrenoDir THEN
	                    "Motore".M[#K_MotoreInt].Allarmi.TrgVelMinFreno := true;
	                    "Motore".M[#K_MotoreInt].Allarmi.Parametri := TRUE;
	                    "Motore".M[#K_MotoreInt].Dati.VeloRichPerc := #VeloFrenoDir;
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].Dati.VeloRichPerc > "Motore".M[#K_MotoreInt].Prm.C.VelMax THEN
	                    "Motore".M[#K_MotoreInt].Allarmi.TrgVelMaxMax := true;
	                    "Motore".M[#K_MotoreInt].Allarmi.Parametri := TRUE;
	                    "Motore".M[#K_MotoreInt].Dati.VeloRichPerc := "Motore".M[#K_MotoreInt].Prm.C.VelMax;
	                END_IF;
	                (* Controllo che la velocitÃ  di cambio VelocitÃ  sia all'interno del limite Sgancio Freno < VeloRich < VeloMax *)
	                IF "Motore".M[#K_MotoreInt].In.CambioVelDaPunto THEN
	                    "Motore".M[#K_MotoreInt].Dati.VeloDopoCambioRich := "Motore".M[#K_MotoreInt].In.VelCambioVel;
	                    IF "Motore".M[#K_MotoreInt].Dati.VeloDopoCambioRich < #VeloFrenoDir THEN
	                        "Motore".M[#K_MotoreInt].Allarmi.TrgVelCamMinFreno := true;
	                        "Motore".M[#K_MotoreInt].Allarmi.Parametri := TRUE;
	                        "Motore".M[#K_MotoreInt].Dati.VeloDopoCambioRich := #VeloFrenoDir;
	                    END_IF;
	                    IF "Motore".M[#K_MotoreInt].Dati.VeloDopoCambioRich > "Motore".M[#K_MotoreInt].Prm.C.VelMax THEN
	                        "Motore".M[#K_MotoreInt].Allarmi.TrgVelCamMaxMax := true;
	                        "Motore".M[#K_MotoreInt].Allarmi.Parametri := TRUE;
	                        "Motore".M[#K_MotoreInt].Dati.VeloDopoCambioRich := "Motore".M[#K_MotoreInt].Prm.C.VelMax;
	                    END_IF;
	                END_IF;
	            END_IF;
	        END_REGION
	        REGION Controllo Decelerazione di emergenza     
	            IF "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec_Emergenza <> "Motore".M[#K_MotoreInt].Prm.DecEmergenza THEN
	                "Motore".M[#K_MotoreInt].Allarmi.DecEmergenzaRichZero := "Motore".M[#K_MotoreInt].Prm.DecEmergenza < 100;
	                IF "Motore".M[#K_MotoreInt].Allarmi.DecEmergenzaRichZero THEN
	                    "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec_Emergenza := 100;
	                    "Motore".M[#K_MotoreInt].Allarmi.Parametri := TRUE;
	                    #CambioReqAcc := true;
	                    #CambioReqDec := true;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec_Emergenza := "Motore".M[#K_MotoreInt].Prm.DecEmergenza;
	                END_IF;
	            END_IF;
	        END_REGION
	        REGION Controllo Decelerazione
	            IF #CambioReqDec THEN
	                "Motore".M[#K_MotoreInt].Allarmi.DecRichZero := "Motore".M[#K_MotoreInt].Dati.DecRichPerc < 100;
	                IF "Motore".M[#K_MotoreInt].Allarmi.DecRichZero THEN
	                    "Motore".M[#K_MotoreInt].Dati.DecRichPerc := 100;
	                    "Motore".M[#K_MotoreInt].Allarmi.Parametri := TRUE;
	                END_IF;
	                "Motore".M[#K_MotoreInt].Allarmi.DecRichMaxMaxDec := "Motore".M[#K_MotoreInt].Dati.DecRichPerc > "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec_Emergenza;
	                IF "Motore".M[#K_MotoreInt].Allarmi.DecRichMaxMaxDec THEN
	                    "Motore".M[#K_MotoreInt].Dati.DecRichPerc := "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec_Emergenza;
	                    "Motore".M[#K_MotoreInt].Allarmi.Parametri := TRUE;
	                END_IF;
	            END_IF;
	        END_REGION
	        REGION Controllo Decelerazione Finale
	            "Motore".M[#K_MotoreInt].Allarmi.DecFinaleRichZero := "Motore".M[#K_MotoreInt].Prm.DecFinale < 100;
	            IF "Motore".M[#K_MotoreInt].Allarmi.DecFinaleRichZero THEN
	                "Motore".M[#K_MotoreInt].Prm.DecFinale := 100;
	                "Motore".M[#K_MotoreInt].Allarmi.Parametri := TRUE;
	            END_IF;
	            "Motore".M[#K_MotoreInt].Allarmi.DecFinaleRichMaxMaxDec := "Motore".M[#K_MotoreInt].Prm.DecFinale > "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec_Emergenza;
	            IF "Motore".M[#K_MotoreInt].Allarmi.DecFinaleRichMaxMaxDec THEN
	                "Motore".M[#K_MotoreInt].Prm.DecFinale := "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec_Emergenza;
	                "Motore".M[#K_MotoreInt].Allarmi.Parametri := TRUE;
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].Prm.DecFinale <> "Motore".M[#K_MotoreInt].Dati.DecReqFinaleInLavo THEN
	                IF NOT "Motore".M[#K_MotoreInt].Out.InMarcia OR "Motore".M[#K_MotoreInt].Prm.DecFinale > "Motore".M[#K_MotoreInt].Dati.DecReqFinaleInLavo THEN
	                    "Motore".M[#K_MotoreInt].Dati.DecReqFinaleInLavo := "Motore".M[#K_MotoreInt].Prm.DecFinale;
	                END_IF;
	            END_IF;
	        END_REGION
	        REGION Controllo Accelerazione 
	            IF #CambioReqAcc THEN
	                "Motore".M[#K_MotoreInt].Allarmi.AccRichZero := "Motore".M[#K_MotoreInt].Dati.AccRichPerc < 100;
	                IF "Motore".M[#K_MotoreInt].Allarmi.AccRichZero THEN
	                    "Motore".M[#K_MotoreInt].Dati.AccRichPerc := 100;
	                    "Motore".M[#K_MotoreInt].Allarmi.Parametri := TRUE;
	                END_IF;
	                "Motore".M[#K_MotoreInt].Allarmi.AccRichMaxMaxDec := "Motore".M[#K_MotoreInt].Dati.AccRichPerc > "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec_Emergenza;
	                IF "Motore".M[#K_MotoreInt].Allarmi.AccRichMaxMaxDec THEN
	                    "Motore".M[#K_MotoreInt].Dati.AccRichPerc := "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec_Emergenza;
	                    "Motore".M[#K_MotoreInt].Allarmi.Parametri := TRUE;
	                END_IF;
	            END_IF;
	        END_REGION
	        REGION Assegnazione decelerazione
	            IF "Motore".M[#K_MotoreInt].Dati.DecRichPerc <> "Motore".M[#K_MotoreInt].Dati.DecReqInLavo THEN
	                IF NOT "Motore".M[#K_MotoreInt].Out.InMarcia OR "Motore".M[#K_MotoreInt].Dati.DecRichPerc > "Motore".M[#K_MotoreInt].Dati.DecReqInLavo OR "Motore".M[#K_MotoreInt].Out.VelAss < #VeloBassaConv THEN
	                    "Motore".M[#K_MotoreInt].Dati.DecReqInLavo := "Motore".M[#K_MotoreInt].Dati.DecRichPerc;
	                END_IF;
	            END_IF;
	        END_REGION
	        REGION Assegnazione decelerazione D'emergenza
	            IF "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec_Emergenza <> "Motore".M[#K_MotoreInt].Dati.DecReqEmergInLavo THEN
	                IF NOT "Motore".M[#K_MotoreInt].Out.InMarcia OR "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec_Emergenza > "Motore".M[#K_MotoreInt].Dati.DecReqEmergInLavo THEN
	                    "Motore".M[#K_MotoreInt].Dati.DecReqEmergInLavo := "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec_Emergenza;
	                END_IF;
	            END_IF;
	        END_REGION
	        REGION Calcolo Lo Spazio Di Arresto
	            #ReqDecBassa := FALSE;
	            #ReqDecStop := FALSE;
	            #BloccaAcc := FALSE;
	            IF "Motore".M[#K_MotoreInt].Out.InMarcia THEN
	                IF "Motore".M[#K_MotoreInt].Out.VelAss > #VeloBassaConv THEN
	                    #SpazioStop_01 := (SQR(IN := "Motore".M[#K_MotoreInt].Out.VelAss) - SQR(IN := #VeloBassaConv)) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.DecReqInLavo) / 2.0;
	                    #SpazioStop_02 := DINT_TO_REAL(IN := "Motore".M[#K_MotoreInt].Prm.TBassaVel) * #VeloBassaConv / 1000.0;
	                    #SpazioStop_03 := (SQR(IN := #VeloBassaConv) - SQR(IN := DINT_TO_REAL(#VeloFrenoDir))) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.DecReqFinaleInLavo) / 2.0;
	                ELSE
	                    #SpazioStop_01 := 0.0;
	                    #SpazioStop_02 := 0.0;
	                    #SpazioStop_03 := (SQR(IN := "Motore".M[#K_MotoreInt].Out.VelAss) - SQR(IN := DINT_TO_REAL(#VeloFrenoDir))) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.DecReqFinaleInLavo) / 2.0;
	                    ;
	                END_IF;
	                #SpazioStop_04 := INT_TO_REAL("Motore".M[#K_MotoreInt].Prm.TReazioneSistema) * ("Motore".M[#K_MotoreInt].Out.VelAss - DINT_TO_REAL(#VeloFrenoDir)) / 1000.0;
	                #SpazioStop := TRUNC(IN := #SpazioStop_03 + #SpazioStop_04) + #SpazioFrenoDir;
	                #SpazioBassa := TRUNC(IN := #SpazioStop_01 + #SpazioStop_02) + #SpazioStop;
	                IF #FunzPositioning THEN
	                    #BloccaAcc := TRUNC(("Motore".M[#K_MotoreInt].Out.VelAss * INT_TO_REAL("Motore".M[#K_MotoreInt].Prm.TMinVCost) / 1000.0)) + #SpazioStop > #DistTRG_ASS;
	                    #ReqDecBassa := #DistTRG_ASS < #SpazioBassa;
	                    #ReqDecStop := #DistTRG_ASS < #SpazioStop;
	                END_IF;
	            ELSE
	                #SpazioBassa := #SpazioStop := #SpazioFrenoDir;
	            END_IF;
	        END_REGION
	        REGION Calcolo lo spazio passaggio seconda Vel.
	            IF #FunzPositioning AND "Motore".M[#K_MotoreInt].In.CambioVelDaPunto AND NOT "Motore".M[#K_MotoreInt].Dati.MotoreFermo THEN
	                // Lo spazio di cambio velocitÃ  Ã¨ dato dalla somma dei seguenti fattori:
	                
	                // 1) Spazio necessario al cambio velocitÃ  dell'asse calcolando una rampa trapezoidale.
	                // 2) Simulazione dello spazio percorso dall'asse durante la reazione del segnale analogico.
	                
	                // Condizione 01 -Trapezio passaggio dalla velocitÃ  di lavoro alla velocitÃ  bassa
	                #SpazioCambioVel_01 := ("Motore".M[#K_MotoreInt].Out.VelAss ** 2 - DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.VeloDopoCambioRich) ** 2) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.DecReqInLavo) / 2.0;
	                #SpazioCambioVel_02 := INT_TO_REAL("Motore".M[#K_MotoreInt].Prm.TReazioneSistema) * "Motore".M[#K_MotoreInt].Out.VelAss / 1000.0;
	                #SpazioCambioVel := TRUNC(#SpazioCambioVel_01 + #SpazioCambioVel_02);
	                // Continua solo se cambio velocitÃ  Ã¨ attivo
	                // Calcolo la distanza dal cambio velocitÃ 
	                IF NOT "Motore".M[#K_MotoreInt].In.PosRelativo THEN
	                    IF "Motore".M[#K_MotoreInt].Prm.Mech.EndLess THEN
	                        WHILE "Motore".M[#K_MotoreInt].In.PosCambioVel > "Motore".M[#K_MotoreInt].Prm.Enc.ModuloPosEnc DO
	                            "Motore".M[#K_MotoreInt].In.PosCambioVel -= #RicircoloTotale;
	                        END_WHILE;
	                        WHILE "Motore".M[#K_MotoreInt].In.PosCambioVel < "Motore".M[#K_MotoreInt].Prm.Enc.ModuloNegEnc DO
	                            "Motore".M[#K_MotoreInt].In.PosCambioVel += #RicircoloTotale;
	                        END_WHILE;
	                    END_IF;
	                    IF "Motore".M[#K_MotoreInt].Dati.ActVelPos THEN
	                        #DistCambioVel := "Motore".M[#K_MotoreInt].Out.ActPos + #SpazioCambioVel - "Motore".M[#K_MotoreInt].In.PosCambioVel;
	                    ELSE
	                        #DistCambioVel := "Motore".M[#K_MotoreInt].Out.ActPos - #SpazioCambioVel - "Motore".M[#K_MotoreInt].In.PosCambioVel;
	                    END_IF;
	                    IF "Motore".M[#K_MotoreInt].Prm.Mech.EndLess THEN
	                        IF #DistCambioVel > #MezzoRicircoloTotale THEN
	                            #DistCambioVel -= #RicircoloTotale;
	                        END_IF;
	                        IF #DistCambioVel < - #MezzoRicircoloTotale THEN
	                            #DistCambioVel += #RicircoloTotale;
	                        END_IF;
	                    END_IF;
	                    #ReqCambioVel := #DistCambioVel >= 0 AND "Motore".M[#K_MotoreInt].Dati.ActVelPos OR #DistCambioVel < 0 AND "Motore".M[#K_MotoreInt].Dati.ActVelNeg;
	                ELSE
	                    #ReqCambioVel := "Motore".M[#K_MotoreInt].Dati.MovRelRichiesto - #DistTRG_ASS + #SpazioCambioVel > "Motore".M[#K_MotoreInt].In.PosCambioVel;
	                END_IF;
	            ELSE
	                #ReqCambioVel := FALSE;
	                #SpazioCambioVel := 0;
	            END_IF;
	            
	        END_REGION
	        REGION Pos.Motore + Spazio Arresto
	            IF "Motore".M[#K_MotoreInt].Out.InMarcia THEN
	                "Motore".M[#K_MotoreInt].Out.SpazioStop := #SpazioBassa;
	                IF "Motore".M[#K_MotoreInt].Dati.ActVelPos THEN
	                    "Motore".M[#K_MotoreInt].Out.ActPosPiuStop := "Motore".M[#K_MotoreInt].Out.ActPos + #SpazioBassa;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Out.ActPosPiuStop := "Motore".M[#K_MotoreInt].Out.ActPos - #SpazioBassa;
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].Prm.Mech.EndLess THEN
	                    IF "Motore".M[#K_MotoreInt].Out.ActPosPiuStop < "Motore".M[#K_MotoreInt].Prm.Enc.ModuloNegEnc THEN
	                        "Motore".M[#K_MotoreInt].Out.ActPosPiuStop += #RicircoloTotale;
	                    END_IF;
	                    IF "Motore".M[#K_MotoreInt].Out.ActPosPiuStop > "Motore".M[#K_MotoreInt].Prm.Enc.ModuloPosEnc THEN
	                        "Motore".M[#K_MotoreInt].Out.ActPosPiuStop -= #RicircoloTotale;
	                    END_IF;
	                END_IF;
	            ELSE
	                "Motore".M[#K_MotoreInt].Out.ActPosPiuStop := "Motore".M[#K_MotoreInt].Out.ActPos;
	                "Motore".M[#K_MotoreInt].Out.SpazioStop := 0;
	            END_IF;
	        END_REGION
	    END_REGION ;
	    REGION Delay brake
	        REGION Ritrado Aggancio/Sgancio Freno
	            IF "Motore".M[#K_MotoreInt].Prm.FrenoPresente THEN
	                IF "Motore".M[#K_MotoreInt].Prm.FBKFrenoPresente THEN
	                    "Motore".M[#K_MotoreInt].Dati.StatoFreno := "Motore".M[#K_MotoreInt].In.FrenoSganciato;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Dati.StatoFreno := "Motore".M[#K_MotoreInt].Out.CmdFreno;
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].Dati.StatoFreno THEN
	                    "Motore".M[#K_MotoreInt].Dati.ContAggancioFreno := 0;
	                    "Motore".M[#K_MotoreInt].Dati.RitAggancioFreno := false;
	                    IF NOT "Motore".M[#K_MotoreInt].Out.RitSgancioFreno THEN
	                        "Motore".M[#K_MotoreInt].Out.RitSgancioFreno := "Motore".M[#K_MotoreInt].Dati.ContSgancioFreno >= "Motore".M[#K_MotoreInt].Prm.TSgancioFreno;
	                        "Motore".M[#K_MotoreInt].Dati.ContSgancioFreno += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                    END_IF;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Dati.ContSgancioFreno := 0;
	                    "Motore".M[#K_MotoreInt].Out.RitSgancioFreno := false;
	                    IF NOT "Motore".M[#K_MotoreInt].Dati.RitAggancioFreno THEN
	                        "Motore".M[#K_MotoreInt].Dati.RitAggancioFreno := "Motore".M[#K_MotoreInt].Dati.ContAggancioFreno >= "Motore".M[#K_MotoreInt].Prm.TAggancioFreno;
	                        "Motore".M[#K_MotoreInt].Dati.ContAggancioFreno += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                    END_IF;
	                END_IF;
	            ELSE
	                "Motore".M[#K_MotoreInt].Out.RitSgancioFreno := "Motore".M[#K_MotoreInt].Out.CmdFreno;
	                "Motore".M[#K_MotoreInt].Dati.RitAggancioFreno := NOT "Motore".M[#K_MotoreInt].Out.RitSgancioFreno;
	            END_IF;
	        END_REGION
	        REGION Premagnetizzazione
	            IF "Motore".M[#K_MotoreInt].Dati.MotoreFermo THEN
	                "Motore".M[#K_MotoreInt].Prm.C.ContPrema := 0;
	                "Motore".M[#K_MotoreInt].Out.PremaOK := false;
	            ELSIF NOT "Motore".M[#K_MotoreInt].Out.PremaOK THEN
	                IF "Motore".M[#K_MotoreInt].Prm.VelPrema <= 0 OR "Motore".M[#K_MotoreInt].Prm.VelPrema > #VeloFrenoDir THEN
	                    "Motore".M[#K_MotoreInt].Prm.VelPrema := #VeloFrenoDir;
	                END_IF;
	                "Motore".M[#K_MotoreInt].Prm.C.ContPrema += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                "Motore".M[#K_MotoreInt].Out.PremaOK := "Motore".M[#K_MotoreInt].Prm.C.ContPrema > "Motore".M[#K_MotoreInt].Prm.TPrema;
	            END_IF;
	        END_REGION
	        
	        IF "Motore".M[#K_MotoreInt].Out.PremaOK AND "Motore".M[#K_MotoreInt].Out.RitSgancioFreno AND #UnaDirezioneRichiesta THEN
	            "Motore".M[#K_MotoreInt].Out.InMarcia := true;
	        ELSIF "Motore".M[#K_MotoreInt].Dati.RitAggancioFreno THEN
	            "Motore".M[#K_MotoreInt].Out.InMarcia := false;
	        END_IF;
	        REGION TimeOut Premagnetizzazione
	            IF "Motore".M[#K_MotoreInt].In.Premagnetizza AND NOT "Motore".M[#K_MotoreInt].Out.InMarcia THEN
	                IF NOT "Zona".Z[#K_ZonaInt].Out.Auto OR NOT "Zona".Z[#K_Zona].Out.CentralinaOk OR "Motore".M[#K_MotoreInt].Out.Allarme OR "Motore".M[#K_MotoreInt].In.DriverFault THEN
	                    "Motore".M[#K_MotoreInt].In.Premagnetizza := "Motore".M[#K_MotoreInt].In.PremagnetizzaPos := "Motore".M[#K_MotoreInt].In.PremagnetizzaNeg := false;
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].Prm.VelPrema <> 1 THEN
	                    "Motore".M[#K_MotoreInt].Prm.PremaNoFreno := false;
	                END_IF;
	                "Motore".M[#K_MotoreInt].Prm.TOutPrema := MAX(IN1 := "Motore".M[#K_MotoreInt].Prm.TOutPrema, IN2 := "Motore".M[#K_MotoreInt].Prm.TPrema + 50);
	                IF NOT "Motore".M[#K_MotoreInt].Out.InMarcia THEN
	                    "Motore".M[#K_MotoreInt].Out.TOUTPrema := "Motore".M[#K_MotoreInt].Dati.ContTimeOutPrema > "Motore".M[#K_MotoreInt].Prm.TOutPrema;
	                    IF NOT "Motore".M[#K_MotoreInt].Out.TOUTPrema THEN
	                        "Motore".M[#K_MotoreInt].Dati.ContTimeOutPrema += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                    END_IF;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Dati.ContTimeOutPrema := 0;
	                END_IF;
	            ELSE
	                "Motore".M[#K_MotoreInt].Dati.ContTimeOutPrema := 0;
	                "Motore".M[#K_MotoreInt].Out.TOUTPrema := false;
	            END_IF;
	        END_REGION
	    END_REGION ;
	    REGION Request speed and brake command
	        #ReqStop := NOT #UnaDirezioneRichiesta;
	        IF (#ReqDirPos AND "Motore".M[#K_MotoreInt].Dati.ActVelNeg) OR (#ReqDirNeg AND "Motore".M[#K_MotoreInt].Dati.ActVelPos) THEN
	            #ReqStop := true;
	            "Motore".M[#K_MotoreInt].Dati.ContAbilAccDopoCambioDir := "Motore".M[#K_MotoreInt].Prm.TReazioneSistema;
	        ELSIF "Motore".M[#K_MotoreInt].Dati.ContAbilAccDopoCambioDir > 0 THEN
	            "Motore".M[#K_MotoreInt].Dati.ContAbilAccDopoCambioDir -= REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	        END_IF;
	        IF NOT #ReqStop AND NOT #ReqDecStop THEN
	            IF NOT "Motore".M[#K_MotoreInt].Out.PremaOK AND NOT "Motore".M[#K_MotoreInt].Out.InMarcia THEN
	                "Motore".M[#K_MotoreInt].Dati.VeloMinConv := DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.VelPrema);
	            ELSE
	                "Motore".M[#K_MotoreInt].Dati.VeloMinConv := DINT_TO_REAL(#VeloFrenoDir);
	            END_IF;
	            IF NOT "Motore".M[#K_MotoreInt].Out.InMarcia THEN
	                "Motore".M[#K_MotoreInt].Dati.ReqVelConv := "Motore".M[#K_MotoreInt].Dati.VeloMinConv;
	            ELSIF #ReqDecBassa THEN
	                "Motore".M[#K_MotoreInt].Dati.ReqVelConv := #VeloBassaConv;
	            ELSIF NOT #ReqCambioVel THEN
	                "Motore".M[#K_MotoreInt].Dati.ReqVelConv := DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.VeloRichPerc);
	            ELSE
	                "Motore".M[#K_MotoreInt].Dati.ReqVelConv := DINT_TO_REAL(MIN(IN1 := "Motore".M[#K_MotoreInt].Dati.VeloDopoCambioRich, IN2 := "Motore".M[#K_MotoreInt].Dati.VeloRichPerc));
	            END_IF;
	            "Motore".M[#K_MotoreInt].Out.FaseDec := "Motore".M[#K_MotoreInt].Dati.ReqVelConv < "Motore".M[#K_MotoreInt].Out.VelAss;
	        ELSE
	            "Motore".M[#K_MotoreInt].Out.FaseDec := TRUE;
	        END_IF;
	        IF NOT "Motore".M[#K_MotoreInt].Out.FaseDec THEN
	            "Motore".M[#K_MotoreInt].Out.FaseAcc := NOT #BloccaAcc AND "Motore".M[#K_MotoreInt].Dati.ReqVelConv > "Motore".M[#K_MotoreInt].Out.VelAss AND "Motore".M[#K_MotoreInt].Dati.ContAbilAccDopoCambioDir <= 0;
	            IF "Motore".M[#K_MotoreInt].Out.FaseAcc THEN
	                // Calcolo Accelerazione
	                "Motore".M[#K_MotoreInt].Out.VelAss += DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.AccRichPerc) * INT_TO_REAL(REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r)) / 1000.0;
	                "Motore".M[#K_MotoreInt].Out.VelAss := LIMIT(MN := "Motore".M[#K_MotoreInt].Dati.VeloMinConv, IN := "Motore".M[#K_MotoreInt].Out.VelAss, MX := "Motore".M[#K_MotoreInt].Dati.ReqVelConv);
	            END_IF;
	        ELSE
	            "Motore".M[#K_MotoreInt].Out.FaseAcc := false;
	            // Calcolo Decelerazione
	            IF NOT "Motore".M[#K_MotoreInt].Dati.MotoreFermo THEN
	                (* Seleziono la Decelerazione con cui devo lavorare *)
	                IF NOT "Motore".M[#K_MotoreInt].Out.Pronto THEN
	                    #DecActRich := "Motore".M[#K_MotoreInt].Dati.DecReqEmergInLavo;
	                ELSIF "Motore".M[#K_MotoreInt].Out.VelAss > #VeloBassaConv THEN
	                    #DecActRich := "Motore".M[#K_MotoreInt].Dati.DecReqInLavo;
	                ELSE
	                    #DecActRich := "Motore".M[#K_MotoreInt].Dati.DecReqFinaleInLavo;
	                END_IF;
	                "Motore".M[#K_MotoreInt].Out.VelAss -= DINT_TO_REAL(#DecActRich) * INT_TO_REAL(REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r)) / 1000.0;
	                "Motore".M[#K_MotoreInt].Out.VelAss := MAX(IN1 := "Motore".M[#K_MotoreInt].Dati.VeloMinConv, IN2 := "Motore".M[#K_MotoreInt].Out.VelAss);
	                // Forzo l'arresto se sono in zona di arresto
	                IF #ReqStop AND "Motore".M[#K_MotoreInt].Out.VelAss <= "Motore".M[#K_MotoreInt].Dati.VeloMinConv THEN
	                    IF "Motore".M[#K_MotoreInt].Prm.CambioDirNoFreno THEN
	                        IF "Motore".M[#K_MotoreInt].Dati.ActVelPos AND #ReqDirNeg THEN
	                            "Motore".M[#K_MotoreInt].Dati.ActVelPos := false;
	                            "Motore".M[#K_MotoreInt].Dati.ActVelNeg := true;
	                            #ReqStop := false;
	                            "Motore".M[#K_MotoreInt].Dati.CambioDirezioneAlVolo := true;
	                        ELSIF "Motore".M[#K_MotoreInt].Dati.ActVelNeg AND #ReqDirPos THEN
	                            "Motore".M[#K_MotoreInt].Dati.ActVelPos := true;
	                            "Motore".M[#K_MotoreInt].Dati.ActVelNeg := false;
	                            #ReqStop := false;
	                            "Motore".M[#K_MotoreInt].Dati.CambioDirezioneAlVolo := true;
	                        ELSE
	                            "Motore".M[#K_MotoreInt].Dati.CambioDirezioneAlVolo := false;
	                        END_IF;
	                    END_IF;
	                    IF NOT "Motore".M[#K_MotoreInt].Dati.CambioDirezioneAlVolo THEN
	                        IF "Motore".M[#K_MotoreInt].Dati.RitAggancioFreno OR "Motore".M[#K_MotoreInt].Allarmi.Freno OR "Motore".M[#K_MotoreInt].Allarmi.Freno2 THEN
	                            "Motore".M[#K_MotoreInt].Out.VelAss := 0.0;
	                        ELSE
	                            "Motore".M[#K_MotoreInt].Out.VelAss := DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.VelPrema);
	                        END_IF;
	                    END_IF;
	                END_IF;
	            END_IF;
	        END_IF;
	        REGION Gestione Direzione Del Movimento    
	            IF "Motore".M[#K_MotoreInt].Dati.MotoreFermo AND #ReqDirPos OR "Motore".M[#K_MotoreInt].Dati.ActVelPos THEN
	                "Motore".M[#K_MotoreInt].Out.Vel := "Motore".M[#K_MotoreInt].Out.VelAss;
	            ELSIF "Motore".M[#K_MotoreInt].Dati.MotoreFermo AND #ReqDirNeg OR "Motore".M[#K_MotoreInt].Dati.ActVelNeg THEN
	                "Motore".M[#K_MotoreInt].Out.Vel := - "Motore".M[#K_MotoreInt].Out.VelAss;
	            END_IF;
	        END_REGION
	        REGION Velo Premagnetizzazione
	            IF NOT "Motore".M[#K_MotoreInt].Out.InMarcia THEN
	                IF "Motore".M[#K_MotoreInt].In.Premagnetizza THEN
	                    IF NOT "Motore".M[#K_MotoreInt].Out.TOUTPrema AND NOT #UnaDirezioneRichiesta THEN
	                        IF "Motore".M[#K_MotoreInt].In.PremagnetizzaPos THEN
	                            "Motore".M[#K_MotoreInt].Out.VelAss := DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.VelPrema);
	                            "Motore".M[#K_MotoreInt].Out.Vel := "Motore".M[#K_MotoreInt].Out.VelAss;
	                        ELSIF "Motore".M[#K_MotoreInt].In.PremagnetizzaNeg THEN
	                            "Motore".M[#K_MotoreInt].Out.VelAss := DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.VelPrema);
	                            "Motore".M[#K_MotoreInt].Out.Vel := - "Motore".M[#K_MotoreInt].Out.VelAss;
	                        ELSIF "Motore".M[#K_MotoreInt].Out.RichMovPos THEN
	                            "Motore".M[#K_MotoreInt].Out.VelAss := DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.VelPrema);
	                            "Motore".M[#K_MotoreInt].Out.Vel := "Motore".M[#K_MotoreInt].Out.VelAss;
	                        ELSIF "Motore".M[#K_MotoreInt].Out.RichMovNeg THEN
	                            "Motore".M[#K_MotoreInt].Out.VelAss := DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.VelPrema);
	                            "Motore".M[#K_MotoreInt].Out.Vel := - "Motore".M[#K_MotoreInt].Out.VelAss;
	                        END_IF;
	                    END_IF;
	                END_IF;
	            END_IF;
	        END_REGION
	        REGION Controllo Direzione Motore
	            IF "Motore".M[#K_MotoreInt].Out.Vel > 0.0 THEN
	                "Motore".M[#K_MotoreInt].Dati.ActVelPos := TRUE;
	                "Motore".M[#K_MotoreInt].Dati.ActVelNeg := FALSE;
	                "Motore".M[#K_MotoreInt].Dati.MotoreFermo := FALSE;
	            ELSIF "Motore".M[#K_MotoreInt].Out.Vel < 0.0 THEN
	                "Motore".M[#K_MotoreInt].Dati.ActVelPos := FALSE;
	                "Motore".M[#K_MotoreInt].Dati.ActVelNeg := TRUE;
	                "Motore".M[#K_MotoreInt].Dati.MotoreFermo := FALSE;
	            ELSE
	                "Motore".M[#K_MotoreInt].Dati.ActVelPos := FALSE;
	                "Motore".M[#K_MotoreInt].Dati.ActVelNeg := FALSE;
	                "Motore".M[#K_MotoreInt].Dati.MotoreFermo := TRUE;
	            END_IF;
	            IF NOT "Motore".M[#K_MotoreInt].Prm.Mech.Direction THEN
	                "Motore".M[#K_MotoreInt].Out.CmdPosMotore := "Motore".M[#K_MotoreInt].Dati.ActVelPos;
	                "Motore".M[#K_MotoreInt].Out.CmdNegMotore := "Motore".M[#K_MotoreInt].Dati.ActVelNeg;
	            ELSE
	                "Motore".M[#K_MotoreInt].Out.CmdPosMotore := "Motore".M[#K_MotoreInt].Dati.ActVelNeg;
	                "Motore".M[#K_MotoreInt].Out.CmdNegMotore := "Motore".M[#K_MotoreInt].Dati.ActVelPos;
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].Out.InMarcia THEN
	                "Motore".M[#K_MotoreInt].Out.ActDirPos := "Motore".M[#K_MotoreInt].Dati.ActVelPos;
	                "Motore".M[#K_MotoreInt].Out.ActDirNeg := "Motore".M[#K_MotoreInt].Dati.ActVelNeg;
	            ELSE
	                "Motore".M[#K_MotoreInt].Out.ActDirNeg := "Motore".M[#K_MotoreInt].Out.ActDirPos := false;
	            END_IF;
	        END_REGION
	        REGION GestioneFreno
	            IF #UnaDirezioneRichiesta AND "Motore".M[#K_MotoreInt].Out.PremaOK OR "Motore".M[#K_MotoreInt].Out.InMarcia THEN
	                #RichCmdFreno := (NOT #ReqStop AND "Motore".M[#K_MotoreInt].Out.VelAss = "Motore".M[#K_MotoreInt].Dati.VeloMinConv OR "Motore".M[#K_MotoreInt].Out.VelAss > "Motore".M[#K_MotoreInt].Dati.VeloMinConv);
	            ELSE
	                IF "Motore".M[#K_MotoreInt].Prm.PremaNoFreno THEN
	                    #RichCmdFreno := "Motore".M[#K_MotoreInt].Out.PremaOK AND NOT "Motore".M[#K_MotoreInt].Out.TOUTPrema AND "Motore".M[#K_MotoreInt].Out.VelAss = 1.0;
	                ELSE
	                    #RichCmdFreno := false;
	                END_IF;
	            END_IF;
	            IF #RichCmdFreno THEN
	                REGION Tempo Off Inverter Pronto    
	                    IF "Motore".M[#K_MotoreInt].In.MotoreRun AND "Motore".M[#K_MotoreInt].Out.CmdFreno THEN
	                        "Motore".M[#K_MotoreInt].Dati.TOffInverterStatus := true;
	                        "Motore".M[#K_MotoreInt].Dati.ContTOffInverterStatus := 250;
	                    ELSIF "Motore".M[#K_MotoreInt].Dati.TOffInverterStatus THEN
	                        "Motore".M[#K_MotoreInt].Dati.ContTOffInverterStatus -= REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                        "Motore".M[#K_MotoreInt].Dati.TOffInverterStatus := "Motore".M[#K_MotoreInt].Dati.ContTOffInverterStatus > 0;
	                    END_IF;
	                END_REGION
	                "Motore".M[#K_MotoreInt].Out.CmdFreno := ("Motore".M[#K_MotoreInt].Out.Pronto AND "Motore".M[#K_MotoreInt].Dati.TOffInverterStatus OR "Motore".M[#K_MotoreInt].In.MotoreRun) AND ("Motore".M[#K_MotoreInt].Dati.ActVelPos OR "Motore".M[#K_MotoreInt].Dati.ActVelNeg);
	            ELSE
	                "Motore".M[#K_MotoreInt].Out.CmdFreno := FALSE;
	            END_IF;
	        END_REGION
	    END_REGION ;
	    REGION Allarms, siren, lamp
	        REGION Controllo Allarmi Presenti    
	            IF "Motore".M[#K_MotoreInt].Allarmi.Freno2 OR
	                "Motore".M[#K_MotoreInt].Allarmi.EncMismatch THEN
	                "Motore".M[#K_MotoreInt].Out.DisContattori := true;
	                "Motore".M[#K_MotoreInt].Out.Allarme := true;
	            ELSE
	                "Motore".M[#K_MotoreInt].Out.DisContattori := false;
	                IF "Motore".M[#K_MotoreInt].Allarmi.TOutMarcia OR
	                    "Motore".M[#K_MotoreInt].Allarmi.Freno OR
	                    "Motore".M[#K_MotoreInt].Allarmi.ConteggioEnc OR
	                    "Motore".M[#K_MotoreInt].Allarmi.Bloccato OR
	                    "Motore".M[#K_MotoreInt].Allarmi.TroppoVeloce OR
	                    "Motore".M[#K_MotoreInt].Allarmi.FolError OR
	                    "Motore".M[#K_MotoreInt].Allarmi.Direzione OR
	                    "Motore".M[#K_MotoreInt].Allarmi.TOUTMovimento OR
	                    "Motore".M[#K_MotoreInt].Allarmi.TOUT_Azzeramento OR
	                    "Motore".M[#K_MotoreInt].Allarmi.SezAperto OR
	                    "Motore".M[#K_MotoreInt].Allarmi.InverterFault OR
	                    "Motore".M[#K_MotoreInt].Allarmi.ComunInverter OR
	                    "Motore".M[#K_MotoreInt].Allarmi.ComunEncoder OR
	                    "Motore".M[#K_MotoreInt].Allarmi.TermicoVentola OR
	                    "Motore".M[#K_MotoreInt].Allarmi.RotturaCinghia OR
	                    "Motore".M[#K_MotoreInt].Allarmi.TimeOutAnticaduta OR
	                    "Motore".M[#K_MotoreInt].Allarmi.SpinaSicNoInPos
	                THEN
	                    "Motore".M[#K_MotoreInt].Out.Allarme := true;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Out.Allarme := false;
	                END_IF;
	            END_IF;
	            
	        END_REGION
	        REGION Gestione del reset, Lampada e Sirena    
	            IF "Zona".Z[#K_ZonaInt].Gen.Reset THEN
	                IF NOT "Motore".M[#K_MotoreInt].Out.Sirena THEN
	                    IF "Motore".M[#K_MotoreInt].Allarmi.EncMismatch THEN
	                        "Motore".M[#K_MotoreInt].Dati.PosizioneAlloStop := "Motore".M[#K_MotoreInt].Out.ActPos;
	                    END_IF;
	                    IF "Motore".M[#K_MotoreInt].Allarmi.Direzione THEN
	                        "Motore".M[#K_MotoreInt].Dati.MemoCheckInversione := 0;
	                    END_IF;
	                    
	                    "Motore".M[#K_MotoreInt].Allarmi.TOutMarcia := false;
	                    "Motore".M[#K_MotoreInt].Allarmi.Freno := false;
	                    "Motore".M[#K_MotoreInt].Allarmi.Freno2 := false;
	                    "Motore".M[#K_MotoreInt].Allarmi.ConteggioEnc := false;
	                    "Motore".M[#K_MotoreInt].Allarmi.FolError := false;
	                    "Motore".M[#K_MotoreInt].Allarmi.Bloccato := false;
	                    "Motore".M[#K_MotoreInt].Allarmi.TroppoVeloce := false;
	                    "Motore".M[#K_MotoreInt].Allarmi.Direzione := false;
	                    "Motore".M[#K_MotoreInt].Allarmi.EncMismatch := false;
	                    "Motore".M[#K_MotoreInt].Allarmi.TOUTMovimento := false;
	                    "Motore".M[#K_MotoreInt].Allarmi.TOUT_Azzeramento := false;
	                    "Motore".M[#K_MotoreInt].Allarmi.InverterFault := false;
	                    "Motore".M[#K_MotoreInt].Allarmi.ComunInverter := false;
	                    "Motore".M[#K_MotoreInt].Allarmi.ComunEncoder := false;
	                    "Motore".M[#K_MotoreInt].Allarmi.TermicoVentola := false;
	                    "Motore".M[#K_MotoreInt].Allarmi.RotturaCinghia := false;
	                    "Motore".M[#K_MotoreInt].Allarmi.TimeOutAnticaduta := false;
	                    "Motore".M[#K_MotoreInt].Allarmi.SpinaSicNoInPos := false;
	                END_IF;
	                "Motore".M[#K_MotoreInt].Out.Sirena := false;
	            END_IF;
	        END_REGION
	        REGION TimeOut Marcia Motore
	            IF NOT "Motore".M[#K_MotoreInt].Dati.MotoreFermo AND NOT "Motore".M[#K_MotoreInt].In.MotoreRun AND NOT "Motore".M[#K_MotoreInt].Allarmi.TOutMarcia AND NOT "Motore".M[#K_MotoreInt].In.DriverFault THEN
	                "Motore".M[#K_MotoreInt].Dati.ContTimeOutInverter += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                IF "Motore".M[#K_MotoreInt].Dati.ContTimeOutInverter > 500 THEN
	                    "Motore".M[#K_MotoreInt].Allarmi.TOutMarcia := true;
	                END_IF;
	            ELSE
	                "Motore".M[#K_MotoreInt].Dati.ContTimeOutInverter := 0;
	            END_IF;
	            
	        END_REGION
	        REGION Allarmi Freno
	            IF "Motore".M[#K_MotoreInt].Prm.FrenoPresente THEN
	                IF "Motore".M[#K_MotoreInt].Prm.FBKFrenoPresente THEN
	                    REGION Gestione del Time Out Freno 1 (Rilascio)
	                        IF "Motore".M[#K_MotoreInt].Out.CmdFreno AND NOT "Motore".M[#K_MotoreInt].Dati.StatoFreno AND NOT "Motore".M[#K_MotoreInt].Allarmi.Freno THEN
	                            "Motore".M[#K_MotoreInt].Dati.ContTimeOutFreno1 += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                            "Motore".M[#K_MotoreInt].Allarmi.Freno := "Motore".M[#K_MotoreInt].Dati.ContTimeOutFreno1 > 500;
	                        ELSE
	                            "Motore".M[#K_MotoreInt].Dati.ContTimeOutFreno1 := 0;
	                        END_IF;
	                    END_REGION
	                    REGION Gestione del Time Out Freno 2 (Aggancio)
	                        // Statement section REGION
	                        IF NOT "Motore".M[#K_MotoreInt].Out.CmdFreno THEN
	                            IF "Motore".M[#K_MotoreInt].Dati.ContTimeOutFreno2 < 150 THEN
	                                "Motore".M[#K_MotoreInt].Dati.ContTimeOutFreno2 += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                            ELSIF "Motore".M[#K_MotoreInt].Dati.StatoFreno THEN
	                                "Motore".M[#K_MotoreInt].Allarmi.Freno2 := TRUE;
	                            END_IF;
	                        ELSE
	                            "Motore".M[#K_MotoreInt].Dati.ContTimeOutFreno2 := 0;
	                        END_IF;
	                    END_REGION
	                END_IF;
	            END_IF;
	        END_REGION
	        REGION AllarmiEncoder
	            IF NOT "Motore".M[#K_MotoreInt].Prm.Enc.EncoderLess THEN
	                REGION Aggiornamento Stati Con Motore Fermo
	                    IF NOT "Motore".M[#K_MotoreInt].Out.InMarcia OR "Motore".M[#K_MotoreInt].Dati.CambioDirezioneAlVolo THEN
	                        "Motore".M[#K_MotoreInt].Dati.CambioDirezioneAlVolo := false;
	                        "Motore".M[#K_MotoreInt].Dati.TrgPosDint := "Motore".M[#K_MotoreInt].Dati.OldTrgPosDint := "Motore".M[#K_MotoreInt].Out.ActPos;
	                        "Motore".M[#K_MotoreInt].Prm.C.TrgPos := "Motore".M[#K_MotoreInt].Prm.C.EncPos;
	                        "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioTarget := "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioEncoder := 0;
	                        "Motore".M[#K_MotoreInt].Dati.ContCheckFollowError := 0;
	                    END_IF;
	                END_REGION
	                REGION Allarme conteggio Encoder
	                    // Se lo spazio percorso nell'ultimo ciclo programma dell'encoder Ã¨ 20 volte superiore 
	                    // Allo spazio teorico per la velocitÃ  richiesta
	                    IF NOT #REQSetup THEN
	                        IF "Motore".M[#K_MotoreInt].Out.SpazioCicloEnc > "Motore".M[#K_MotoreInt].Prm.C.VelMax * REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r) / 50 THEN
	                            "Motore".M[#K_MotoreInt].Allarmi.ConteggioEnc := true;
	                        END_IF;
	                    END_IF;
	                END_REGION
	                REGION Allarme d'inseguimento            
	                    #AppoMoltPrecisione := "Motore".M[#K_MotoreInt].Prm.Precisione * 10;
	                    IF "Motore".M[#K_MotoreInt].Out.InMarcia AND NOT "Motore".M[#K_MotoreInt].Allarmi.FolError AND NOT "Motore".M[#K_MotoreInt].Allarmi.Bloccato AND NOT "Motore".M[#K_MotoreInt].Allarmi.TroppoVeloce THEN
	                        "Motore".M[#K_MotoreInt].Out.FollowingError := "Motore".M[#K_MotoreInt].Out.ActPos - "Motore".M[#K_MotoreInt].Dati.TrgPosDint;
	                        IF "Motore".M[#K_MotoreInt].Dati.ContCheckFollowError > 500 THEN
	                            "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioTarget := ABS("Motore".M[#K_MotoreInt].Dati.ChFol_SpazioTarget);
	                            IF "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioTarget > #AppoMoltPrecisione THEN
	                                "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioEncoder := ABS("Motore".M[#K_MotoreInt].Dati.ChFol_SpazioEncoder);
	                                IF "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioEncoder / 5 > "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioTarget THEN
	                                    "Motore".M[#K_MotoreInt].Allarmi.TroppoVeloce := true;
	                                ELSIF "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioEncoder * 5 < "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioTarget THEN
	                                    IF NOT "Motore".M[#K_MotoreInt].Dati.MotorStop THEN
	                                        IF "Motore".M[#K_MotoreInt].Dati.AlmBloccato_Cont >= "NResetBloccato" THEN
	                                            "Motore".M[#K_MotoreInt].Allarmi.Bloccato := true;
	                                        ELSE
	                                            "Motore".M[#K_MotoreInt].Dati.AlmBloccato_Cont += 1;
	                                            "Motore".M[#K_MotoreInt].Dati.MotorStop := true;
	                                        END_IF;
	                                    END_IF;
	                                END_IF;
	                            END_IF;
	                            "Motore".M[#K_MotoreInt].Dati.ContCheckFollowError := 0;
	                            "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioEncoder := "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioTarget := 0;
	                        ELSE
	                            "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioEncoder += "Motore".M[#K_MotoreInt].Out.SpazioCicloEnc;
	                            "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioTarget += "Motore".M[#K_MotoreInt].Dati.TrgPosDint - "Motore".M[#K_MotoreInt].Dati.OldTrgPosDint;
	                            "Motore".M[#K_MotoreInt].Dati.ContCheckFollowError += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                        END_IF;
	                        "Motore".M[#K_MotoreInt].Dati.OldTrgPosDint := "Motore".M[#K_MotoreInt].Dati.TrgPosDint;
	                        IF "Motore".M[#K_MotoreInt].Prm.FollowingLimit > 0 AND NOT "Motore".M[#K_MotoreInt].Prm.Mech.EndLess THEN
	                            IF ABS("Motore".M[#K_MotoreInt].Out.FollowingError) > "Motore".M[#K_MotoreInt].Prm.FollowingLimit THEN
	                                "Motore".M[#K_MotoreInt].Allarmi.FolError := true;
	                            END_IF;
	                        END_IF;
	                    ELSE
	                        "Motore".M[#K_MotoreInt].Dati.ContCheckFollowError := 0;
	                        "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioEncoder := "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioTarget := 0;
	                    END_IF;
	                END_REGION
	                REGION Allarme direzione inversione
	                    IF NOT "Motore".M[#K_MotoreInt].Allarmi.Direzione THEN
	                        IF "Motore".M[#K_MotoreInt].Out.ActDirPos THEN
	                            "Motore".M[#K_MotoreInt].Dati.MemoCheckInversione += "Motore".M[#K_MotoreInt].Out.SpazioCicloEnc;
	                            IF "Motore".M[#K_MotoreInt].Dati.MemoCheckInversione > 0 THEN
	                                "Motore".M[#K_MotoreInt].Dati.MemoCheckInversione := 0;
	                            END_IF;
	                            IF "Motore".M[#K_MotoreInt].Dati.MemoCheckInversione < - #AppoMoltPrecisione THEN
	                                "Motore".M[#K_MotoreInt].Allarmi.Direzione := true;
	                            END_IF;
	                        ELSIF "Motore".M[#K_MotoreInt].Out.ActDirNeg THEN
	                            "Motore".M[#K_MotoreInt].Dati.MemoCheckInversione += "Motore".M[#K_MotoreInt].Out.SpazioCicloEnc;
	                            IF "Motore".M[#K_MotoreInt].Dati.MemoCheckInversione < 0 THEN
	                                "Motore".M[#K_MotoreInt].Dati.MemoCheckInversione := 0;
	                            END_IF;
	                            IF "Motore".M[#K_MotoreInt].Dati.MemoCheckInversione > #AppoMoltPrecisione THEN
	                                "Motore".M[#K_MotoreInt].Allarmi.Direzione := true;
	                            END_IF;
	                        ELSE
	                            "Motore".M[#K_MotoreInt].Dati.MemoCheckInversione := 0;
	                        END_IF;
	                    END_IF;
	                END_REGION
	                REGION Allarme Encoder Mismatch
	                    // L'allarme viene generato tutte le volte che l'encoder conta 10 volte la precisione nella dirazione non aspettata.
	                    IF "Motore".M[#K_MotoreInt].Dati.MotoreFermo AND "Motore".M[#K_MotoreInt].Dati.RitAggancioFreno THEN
	                        IF NOT "Motore".M[#K_MotoreInt].Dati.AppoImpMotoreFermo THEN
	                            "Motore".M[#K_MotoreInt].Dati.AppoImpMotoreFermo := true;
	                            "Motore".M[#K_MotoreInt].Dati.PosizioneAlloStop := "Motore".M[#K_MotoreInt].Out.ActPos;
	                        ELSIF ABS("Motore".M[#K_MotoreInt].Out.ActPos - "Motore".M[#K_MotoreInt].Dati.PosizioneAlloStop) > #AppoMoltPrecisione THEN
	                            "Motore".M[#K_MotoreInt].Allarmi.EncMismatch := true;
	                        END_IF;
	                    ELSE
	                        "Motore".M[#K_MotoreInt].Dati.AppoImpMotoreFermo := false;
	                    END_IF;
	                END_REGION
	                REGION Time Out Movimento Motore
	                    IF #FunzPositioning THEN
	                        IF NOT "Motore".M[#K_MotoreInt].Dati.AppoImpFunzPositioning THEN
	                            #ReqRicTempoProfilo := true;
	                        ELSIF #ReqCambioVel AND NOT "Motore".M[#K_MotoreInt].Dati.AppoImpCaVelPunto THEN
	                            #ReqRicTempoProfilo := true;
	                        ELSE
	                            #ReqRicTempoProfilo := #CambioReqAcc OR #CambioReqDec OR #CambioReqVel OR #REQSetup OR "Motore".M[#K_MotoreInt].Out.TrgPosFiltrata <> "Motore".M[#K_MotoreInt].Dati.TRG_OLD_POS_Select;
	                        END_IF;
	                        "Motore".M[#K_MotoreInt].Dati.AppoImpCaVelPunto := #ReqCambioVel;
	                        IF #ReqRicTempoProfilo THEN
	                            "Motore".M[#K_MotoreInt].Dati.TRG_OLD_POS_Select := "Motore".M[#K_MotoreInt].Out.TrgPosFiltrata;
	                            IF #ReqCambioVel THEN
	                                #VeloProfilo := "Motore".M[#K_MotoreInt].Dati.VeloDopoCambioRich;
	                            ELSE
	                                #VeloProfilo := "Motore".M[#K_MotoreInt].Dati.VeloRichPerc;
	                            END_IF;
	                            // Calcolo il tempo per la decelerazione
	                            IF #VeloProfilo > #VeloBassaConv THEN
	                                #TempoDec_Iniziale := (#VeloProfilo - #VeloBassaConv) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.DecReqInLavo);
	                            ELSE
	                                #TempoDec_Iniziale := 0.0;
	                            END_IF;
	                            // Tempo Decelerazione Finale
	                            #TempoDec_Finale := #VeloBassaConv / DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.DecReqFinaleInLavo);
	                            // Tempo accelerazione
	                            #TempoAcc := #VeloProfilo / DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.AccRichPerc);
	                            // Tempo a velocitÃ  fissa
	                            #TempoVFix := DINT_TO_REAL(#DistTRG_ASS) / #VeloProfilo;
	                            // Calcolo il tempo rimanente per l'esecuzione del profilo
	                            "Motore".M[#K_MotoreInt].Out.TFineProfilo := TRUNC((#TempoDec_Iniziale + #TempoDec_Finale + #TempoAcc + #TempoVFix) * 1000.0) + "Motore".M[#K_MotoreInt].Prm.TBassaVel + "Motore".M[#K_MotoreInt].Prm.TReazioneSistema;
	                            "Motore".M[#K_MotoreInt].Dati.ContTimeOutMovimento := 0;
	                            "Motore".M[#K_MotoreInt].Dati.TempoEsecuzioneProfilo := MAX(IN1 := "Motore".M[#K_MotoreInt].Out.TFineProfilo * 3, IN2 := 10000);
	                        END_IF;
	                        IF "Motore".M[#K_MotoreInt].Out.InMarcia THEN
	                            IF "Motore".M[#K_MotoreInt].Dati.ContTimeOutMovimento > "Motore".M[#K_MotoreInt].Dati.TempoEsecuzioneProfilo THEN
	                                "Motore".M[#K_MotoreInt].Allarmi.TOUTMovimento := true;
	                            ELSE
	                                "Motore".M[#K_MotoreInt].Dati.ContTimeOutMovimento += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                            END_IF;
	                        END_IF;
	                        "Motore".M[#K_MotoreInt].Dati.AppoImpFunzPositioning := true;
	                    ELSE
	                        "Motore".M[#K_MotoreInt].Dati.AppoImpFunzPositioning := false;
	                    END_IF;
	                END_REGION
	            END_IF;
	        END_REGION
	        REGION Gestione del Time Out Ricerca Sensore Azzeramento
	            // Nel caso di una richiesta di esecuzione di SetUP sul sensore
	            IF #SetUpSuSensore THEN
	                IF #REQSetupPannello AND NOT "Motore".M[#K_MotoreInt].Dati.SetupSensoreTrovato AND ("Motore".M[#K_MotoreInt].Out.ActDirPos OR "Motore".M[#K_MotoreInt].Out.ActDirNeg) THEN
	                    IF ("Motore".M[#K_MotoreInt].In.SensAzz AND "Motore".M[#K_MotoreInt].Dati.ContTimeOutAzzeramento > 5000) OR "Motore".M[#K_MotoreInt].Dati.ContTimeOutAzzeramento > 25000 THEN
	                        "Motore".M[#K_MotoreInt].Allarmi.TOUT_Azzeramento := TRUE;
	                    END_IF;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Dati.ContTimeOutAzzeramento := 0;
	                END_IF;
	            ELSE
	                "Motore".M[#K_MotoreInt].Dati.ContTimeOutAzzeramento := 0;
	            END_IF;
	        END_REGION
	        REGION ALLARME: Time-Out Anticaduta
	            IF "Motore".M[#K_MotoreInt].Prm.AnticadutaPresente THEN
	                IF "Zona".Z[#K_Zona].Out.CentralinaOk THEN
	                    "Motore".M[#K_MotoreInt].Prm.ByPassAnticaduta := false;
	                END_IF;
	                "Motore".M[#K_MotoreInt].Out.CmdAnticaduta := ("Motore".M[#K_MotoreInt].Out.InMarcia AND "Motore".M[#K_MotoreInt].Out.CmdAnticaduta OR "Zona".Z[#K_Zona].Out.CentralinaOk) AND NOT "Motore".M[#K_MotoreInt].Out.DisContattori AND NOT "Motore".M[#K_MotoreInt].In.CinghiaRotta;
	                IF "Motore".M[#K_MotoreInt].Out.CmdAnticaduta AND NOT "Motore".M[#K_MotoreInt].In.AnticadutaON (*OR
	            NOT "Motor".M[#MotorNumber].o.CmdAnticaduta AND NOT "Motor".M[#MotorNumber].i.AnticadutaOFF*)THEN
	                    IF "Motore".M[#K_MotoreInt].Dati.ContTOutAnticaduta > 4000 THEN
	                        "Motore".M[#K_MotoreInt].Allarmi.TimeOutAnticaduta := true;
	                    ELSE
	                        "Motore".M[#K_MotoreInt].Dati.ContTOutAnticaduta += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                    END_IF;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Dati.ContTOutAnticaduta := 0;
	                END_IF;
	            END_IF;
	        END_REGION
	        REGION Allarmi Generale Motore
	            "Motore".M[#K_MotoreInt].Allarmi.SezAperto := "Motore".M[#K_MotoreInt].In.SezAperto;
	            IF "Zona".Z[#K_Zona].Out.CentralinaOk THEN
	                IF "Motore".M[#K_MotoreInt].In.DriverFault THEN
	                    IF NOT "Motore".M[#K_MotoreInt].Dati.AlmInv_ResetInverter THEN
	                        IF "Motore".M[#K_MotoreInt].Dati.AlmInv_Cont >= "NResetInverter" THEN
	                            "Motore".M[#K_MotoreInt].Allarmi.InverterFault := true;
	                        ELSE
	                            "Motore".M[#K_MotoreInt].Dati.AlmInv_ContStorico += 1;
	                            "Motore".M[#K_MotoreInt].Dati.AlmInv_Cont += 1;
	                            "Motore".M[#K_MotoreInt].Dati.AlmInv_StoricoCodici["Motore".M[#K_MotoreInt].Dati.AlmInv_ContStorico MOD 10] := "Motore".M[#K_MotoreInt].HMI.CodiceAllarme;
	                            "Motore".M[#K_MotoreInt].Dati.MotorStop := true;
	                            "Motore".M[#K_MotoreInt].Dati.AlmInv_ResetInverter := true;
	                            "Motore".M[#K_MotoreInt].Dati.AlmInv_ToutReset := 0;
	                        END_IF;
	                    END_IF;
	                END_IF;
	                "Motore".M[#K_MotoreInt].Allarmi.InverterWarning := "Motore".M[#K_MotoreInt].In.DriverWarning;
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].Dati.AlmInv_ResetInverter THEN
	                IF NOT "Motore".M[#K_MotoreInt].In.DriverFault THEN
	                    "Motore".M[#K_MotoreInt].Dati.AlmInv_ResetInverter := false;
	                END_IF;
	                "Motore".M[#K_MotoreInt].Dati.AlmInv_ToutReset += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                IF "Motore".M[#K_MotoreInt].Dati.AlmInv_ToutReset > 5000 THEN
	                    "Motore".M[#K_MotoreInt].Dati.AlmInv_ResetInverter := false;
	                    "Motore".M[#K_MotoreInt].Allarmi.InverterFault := true;
	                END_IF;
	            ELSE
	                "Motore".M[#K_MotoreInt].Dati.AlmInv_ToutReset := 0;
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].In.NoComunInv THEN
	                "Motore".M[#K_MotoreInt].Allarmi.ComunInverter := true;
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].In.NoComunEnc THEN
	                "Motore".M[#K_MotoreInt].Allarmi.ComunEncoder := true;
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].In.TerVentolaOff THEN
	                "Motore".M[#K_MotoreInt].Allarmi.TermicoVentola := true;
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].In.CinghiaRotta THEN
	                "Motore".M[#K_MotoreInt].Allarmi.RotturaCinghia := true;
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].In.SpinaSicNoInPos THEN
	                "Motore".M[#K_MotoreInt].Allarmi.SpinaSicNoInPos := true;
	            END_IF;
	        END_REGION
	        
	        REGION Conteggi Manutenzione Preventiva
	            IF "Motore".M[#K_MotoreInt].Prm.AbiltManutenzionePrev THEN
	                IF NOT "Motore".M[#K_MotoreInt].Dati.MotoreFermo THEN
	                    "Motore".M[#K_MotoreInt].Dati.MP.SpazioPercorso += ABS(IN := "Motore".M[#K_MotoreInt].Out.SpazioCicloEnc);
	                    IF "Motore".M[#K_MotoreInt].Dati.MP.SpazioPercorso > 1000000 THEN
	                        "Motore".M[#K_MotoreInt].Dati.MP.MetriPercorsi += 1;
	                        "Motore".M[#K_MotoreInt].Dati.MP.SpazioPercorso -= 1000000;
	                    END_IF;
	                    "Motore".M[#K_MotoreInt].Dati.MP.TempoMovimento += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                    IF "Motore".M[#K_MotoreInt].Dati.MP.TempoMovimento > 60000 THEN
	                        "Motore".M[#K_MotoreInt].Dati.MP.MinutiLavorati += 1;
	                        "Motore".M[#K_MotoreInt].Dati.MP.TempoMovimento -= 60000;
	                    END_IF;
	                    IF NOT "Motore".M[#K_MotoreInt].Dati.MP.ImpMarcia THEN
	                        "Motore".M[#K_MotoreInt].Dati.MP.NAvviamenti += 1;
	                        "Motore".M[#K_MotoreInt].Dati.MP.ImpMarcia := true;
	                    END_IF;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Dati.MP.ImpMarcia := false;
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].Out.CmdFreno AND NOT "Motore".M[#K_MotoreInt].Dati.MP.ImpFreno THEN
	                    "Motore".M[#K_MotoreInt].Dati.MP.NSgancioFreno += 1;
	                END_IF;
	                "Motore".M[#K_MotoreInt].Dati.MP.ImpFreno := "Motore".M[#K_MotoreInt].Out.CmdFreno;
	            END_IF;
	        END_REGION
	        REGION StatoMotoreHMI
	            (* Stati Motore
	            0 = Fermo
	            1 = Disabilitato da Area Automatico
	            2 = In allarme
	            3 = Disabilitato per motivi interni    
	            4 = In premagnetizzazione con freno chiuso
	            5 = In premagnetizzazione con freno aperto
	            6 = In movimento positivo
	            7 = In movimento negativo
	            14 = In premagnetizzazione con freno chiuso con Allarme Attivo
	            15 = In premagnetizzazione con freno aperto con Allarme Attivo
	            16 = In movimento positivo con Allarme Attivo
	            17 = In movimento negativo con Allarme Attivo
	            20 = Dai Trasporti selezionato "Sempre fermo"
	            21 = Dai Trasporti selezionato "Sempre In Marcia Positivo"
	            22 = Dai Trasporti selezionato "Sempre In Marcia Negativo"
	            31 = Dai Trasporti selezionato "Sempre In Marcia Positivo" con Allarme Attivo
	            32 = Dai Trasporti selezionato "Sempre In Marcia Negativo" con Allarme Attivo
	            *)
	            IF "Motore".M[#K_MotoreInt].Out.ActDirPos THEN
	                IF "Motore".M[#K_MotoreInt].Out.Allarme THEN
	                    "Motore".M[#K_MotoreInt].HMI.Stato := 21;
	                ELSE
	                    "Motore".M[#K_MotoreInt].HMI.Stato := 6;
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].Out.Allarme THEN
	                    "Motore".M[#K_MotoreInt].HMI.Stato += 10;
	                END_IF;
	            ELSIF "Motore".M[#K_MotoreInt].Out.ActDirNeg THEN
	                IF "Motore".M[#K_MotoreInt].Allarmi.A["KAllMot_22(Word1_x6)"].Stato THEN
	                    "Motore".M[#K_MotoreInt].HMI.Stato := 22;
	                ELSE
	                    "Motore".M[#K_MotoreInt].HMI.Stato := 7;
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].Out.Allarme THEN
	                    "Motore".M[#K_MotoreInt].HMI.Stato += 10;
	                END_IF;
	            ELSIF NOT "Motore".M[#K_MotoreInt].Dati.MotoreFermo THEN
	                IF "Motore".M[#K_MotoreInt].Out.RitSgancioFreno THEN
	                    "Motore".M[#K_MotoreInt].HMI.Stato := 5;
	                ELSE
	                    "Motore".M[#K_MotoreInt].HMI.Stato := 4;
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].Out.Allarme THEN
	                    "Motore".M[#K_MotoreInt].HMI.Stato += 10;
	                END_IF;
	            ELSIF "Motore".M[#K_MotoreInt].Out.Allarme THEN
	                "Motore".M[#K_MotoreInt].HMI.Stato := 2;
	            ELSIF NOT "Zona".Z[#K_Zona].Out.CentralinaOk THEN
	                "Motore".M[#K_MotoreInt].HMI.Stato := 1;
	            ELSIF NOT "Motore".M[#K_MotoreInt].Out.Pronto THEN
	                "Motore".M[#K_MotoreInt].HMI.Stato := 3;
	            ELSE
	                "Motore".M[#K_MotoreInt].HMI.Stato := 0;
	                IF "Motore".M[#K_MotoreInt].Allarmi.A["KAllMot_23(Word1_x7)"].Stato THEN
	                    "Motore".M[#K_MotoreInt].HMI.Stato := 20;
	                END_IF;
	            END_IF;
	        END_REGION
	        REGION StatoComandoHMI
	            (* Stati Motore
	            0 = Nessuna Richiesta
	            1 = Richiesto Jog Positivo
	            2 = Richiesto Jog Negativo
	            3 = Richiesta Posizionamento Assoluto, motore giÃ  in posizione
	            4 = Richiesta Posizionamento Assoluto, motore dovrÃ  muoversi in direzione positiva
	            5 = Richiesta Posizionamento Assoluto, motore dovrÃ  muoversi in direzione negativa
	            6 = Richiesta Posizionamento Relativo, motore giÃ  in posizione
	            7 = Richiesta Posizionamento Relativo, motore dovrÃ  muoversi in direzione positiva
	            8 = Richiesta Posizionamento Relativo, motore dovrÃ  muoversi in direzione negativa
	            9 = Richiesta Premagnetizzazione Positiva
	            10= Richiesta Premagnetizzazione Negativa
	            *)
	            IF "Motore".M[#K_MotoreInt].In.CmdPosRich THEN
	                "Motore".M[#K_MotoreInt].HMI.ComandoRichiesto := 1;
	            ELSIF "Motore".M[#K_MotoreInt].In.CmdNegRich THEN
	                "Motore".M[#K_MotoreInt].HMI.ComandoRichiesto := 2;
	            ELSIF "Motore".M[#K_MotoreInt].In.Positioning THEN
	                IF "Motore".M[#K_MotoreInt].Out.RichMovPos THEN
	                    "Motore".M[#K_MotoreInt].HMI.ComandoRichiesto := 4;
	                ELSIF "Motore".M[#K_MotoreInt].Out.RichMovNeg THEN
	                    "Motore".M[#K_MotoreInt].HMI.ComandoRichiesto := 5;
	                ELSE
	                    "Motore".M[#K_MotoreInt].HMI.ComandoRichiesto := 3;
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].In.PosRelativo THEN
	                    "Motore".M[#K_MotoreInt].HMI.ComandoRichiesto += 3;
	                END_IF;
	            ELSIF "Motore".M[#K_MotoreInt].In.Premagnetizza THEN
	                IF "Motore".M[#K_MotoreInt].In.PremagnetizzaPos THEN
	                    "Motore".M[#K_MotoreInt].HMI.ComandoRichiesto := 9;
	                ELSIF "Motore".M[#K_MotoreInt].In.PremagnetizzaNeg THEN
	                    "Motore".M[#K_MotoreInt].HMI.ComandoRichiesto := 10;
	                ELSIF "Motore".M[#K_MotoreInt].Out.RichMovPos THEN
	                    "Motore".M[#K_MotoreInt].HMI.ComandoRichiesto := 9;
	                ELSIF "Motore".M[#K_MotoreInt].Out.RichMovNeg THEN
	                    "Motore".M[#K_MotoreInt].HMI.ComandoRichiesto := 10;
	                END_IF;
	            ELSE
	                "Motore".M[#K_MotoreInt].HMI.ComandoRichiesto := 0;
	            END_IF;
	        END_REGION
	    END_REGION ;
	    REGION To inverter
	        CASE "Motore".M[#K_MotoreInt].HW.TipoCollInverter OF
	            0:
	                REGION Inverter Comandato in Analogica
	                    "Motore".M[#K_MotoreInt].Out.Paw := DINT_TO_WORD(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.ValMaxRef)));
	                END_REGION ;
	            1:
	                REGION PN Mitsubishi
	                    (* Struttura Control Word
	                    Bit 00: Drive PO: Switch ON
	                    Bit 01: Drive PO: Output Shutoff Release
	                    Bit 02: Drive PO: Emergency Stop
	                    Bit 03: Drive PO: Enable
	                    Bit 04: Drive PO: Not Used
	                    Bit 05: Drive PO: Set Frequency Not retained
	                    Bit 06: Drive PO: Enble Set Point
	                    Bit 07: Drive PO: Fault Ack
	                    Bit 08: Drive PO: Not Used
	                    Bit 09: Drive PO: Used
	                    Bit 10: Drive PO: Comunication Enabled
	                    Bit 11: Drive PO: Target Torque Enabled
	                    Bit 12: Drive PO: Reverse Rotation
	                    Bit 13: Drive PO: Not Used
	                    Bit 14: Drive PO: Not Used
	                    Bit 15: Drive PO: Not Used
	                    *)
	                    #PO_Mitsubishi.CTW := w#16#200;
	                    #PO_Mitsubishi.CTW.%X0 := ("Motore".M[#K_MotoreInt].Out.CmdPosMotore OR "Motore".M[#K_MotoreInt].Out.CmdNegMotore) AND #PI_Mitsubishi.STW.%X0;
	                    #PO_Mitsubishi.CTW.%X1 := #PO_Mitsubishi.CTW.%X2 := "Zona".Z[#K_Zona].Out.CentralinaOk;
	                    #PO_Mitsubishi.CTW.%X3 := TRUE;
	                    #PO_Mitsubishi.CTW.%X5 := #PO_Mitsubishi.CTW.%X6 := true;
	                    #PO_Mitsubishi.CTW.%X12 := "Motore".M[#K_MotoreInt].Out.CmdNegMotore AND #PI_Mitsubishi.STW.%X0;
	                    #PO_Mitsubishi.CTW.%X7 := ("Zona".Z[#K_Zona].Gen.Reset OR ("Motore".M[#K_MotoreInt].Dati.AlmInv_ToutReset > 2000 AND "Zona".Comuni.Clocks.Clock1Hz)) AND "Motore".M[#K_MotoreInt].In.DriverFault;
	                    #PO_Mitsubishi.CTW.%X10 := true;
	                    #PO_Mitsubishi.Speed_SP := DINT_TO_INT(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 16384.0));
	                    #PO_Mitsubishi.Acc := TRUNC(DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.AccRichPerc) * 3.0);
	                    #PO_Mitsubishi.Dec := TRUNC(DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.DecReqInLavo) * 3.0);
	                    #PO_Mitsubishi.FStart := #VeloFrenoDir * 9000 / "Motore".M[#K_MotoreInt].Prm.C.VelMax;
	                    "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv := DPWR_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD := #PO_Mitsubishi);
	                    "Motore".M[#K_MotoreInt].HMI.CTW1 := #PO_Mitsubishi.CTW;
	                END_REGION
	            2:
	                REGION PN Siemens
	                    (* Struttura Control Word
	                    Bit 00: Drive PO: Run = 1/Stop = 0
	                    Bit 01: Drive PO: Pulse Enable = 1/Pulse Disable = 0
	                    Bit 02: Drive PO: No Quick Stop = 1/Quick Stop = 0
	                    Bit 03: Drive PO: Enable = 1/Disable = 0
	                    Bit 04: Drive PO: Ramp Generator Enable = 1/Disable = 0
	                    Bit 05: Drive PO: Ramp Generator Unfreeze = 1/Freeze = 0
	                    Bit 06: Drive PO: Setpoint Enable = 1/ Disable = 0
	                    Bit 07: Drive PO: Faults/Warnings Acknowledge
	                    Bit 08: Drive PO: Reserved
	                    Bit 09: Drive PO: Reserved
	                    Bit 10: Drive PO: PLC Control
	                    Bit 11: Drive PO: Setpoint Reverse
	                    Bit 12: Drive PO: Reserved
	                    Bit 13: Drive PO: Motor Potentiometer Up
	                    Bit 14: Drive PO: Motor Potentiometer Down
	                    Bit 15: Drive PO: Reserved
	                    *)
	                    #PO_Siemens.CTW := w#16#47f;
	                    #PO_Siemens.CTW.%X0 := "Motore".M[#K_MotoreInt].Out.CmdPosMotore OR "Motore".M[#K_MotoreInt].Out.CmdNegMotore;
	                    #PO_Siemens.CTW.%X11 := "Motore".M[#K_MotoreInt].Out.CmdNegMotore;
	                    #PO_Siemens.CTW.%X7 := "Zona".Z[#K_Zona].Gen.Reset;
	                    #PO_Siemens.Speed := DINT_TO_INT(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 16384.0));
	                    "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv := DPWR_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD := #PO_Siemens);
	                    "Motore".M[#K_MotoreInt].HMI.CTW1 := #PO_Siemens.CTW;
	                END_REGION
	            3:
	                REGION PN Schneider
	                    (* Struttura Control Word
	                    Bit 00: Switched on operating state; voltage at the power is enabled.
	                    Bit 01: 1= Coast Stop (OFF2) not active.
	                    Bit 02: 1 = Quick Stop (OFF3) not active.
	                    Bit 03: Enable electronics and pulses. The drive then runs-up to the reference frequency.
	                    Bit 04: Reserved
	                    Bit 05: Reserved
	                    Bit 06: Not used
	                    Bit 07: The fault reset function is active with a positive edge.
	                    Bit 08: Not used
	                    Bit 09: Not used
	                    Bit 10: Channel for the reference frequency and the command from the bus are active.
	                    Bit 11: Reserved
	                    Bit 12: Reserved
	                    Bit 13: Reserved
	                    Bit 14: Reserved
	                    Bit 15: Reserved
	                    *)
	                    #PO_Schneider.CTW := 0;
	                    #PO_Schneider.CTW.%X0 := #PI_Schneider.STW.%X0;
	                    // Normal Stop
	                    #PO_Schneider.CTW.%X1 := #PO_Schneider.CTW.%X2 := "Zona".Z[#K_Zona].Out.CentralinaOk AND NOT #PI_Schneider.STW.%X3;
	                    // Comando Marcia
	                    #PO_Schneider.CTW.%X3 := #PO_Schneider.CTW.%X0 AND ("Motore".M[#K_MotoreInt].Out.CmdPosMotore OR "Motore".M[#K_MotoreInt].Out.CmdNegMotore);
	                    //    Fault Reset
	                    #PO_Schneider.CTW.%X7 := "Zona".Z[#K_Zona].Gen.Reset AND #PI_Schneider.STW.%X3;
	                    // VelocitÃ  richiesta
	                    IF NOT "Motore".M[#K_MotoreInt].Out.CmdNegMotore THEN
	                        #PO_Schneider.Speed_SP := DINT_TO_INT(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 3000.0));
	                    ELSE
	                        #PO_Schneider.Speed_SP := - DINT_TO_INT(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 3000.0));
	                    END_IF;
	                    #PO_Schneider.Acc_SP := #PO_Schneider.Dec_SP := 0;
	                    "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv := DPWR_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD := #PO_Schneider);
	                    "Motore".M[#K_MotoreInt].HMI.CTW1 := #PO_Schneider.CTW;
	                END_REGION
	            4:
	                REGION PN Movimot
	                    (* Struttura Control Word
	                    Bit 08: Reserved
	                    Bit 09: Reserved
	                    Bit 10: Reserved
	                    Bit 11: Reserved
	                    Bit 12: Reserved
	                    Bit 13: Reserved
	                    Bit 14: Reserved
	                    Bit 15: Reserved
	                    Bit 00: Enable 01 Run Motor
	                    Bit 01: Enable 02 Run Motor
	                    Bit 02: Enable 03 Run Motor
	                    Bit 03: Reserved
	                    Bit 04: Reserved
	                    Bit 05: Reserved
	                    Bit 06: Reset
	                    Bit 07: Reserved
	                    *)
	                    #PO_Movimot.CTW.%X1 := #PO_Movimot.CTW.%X2 := "Motore".M[#K_MotoreInt].Out.CmdPosMotore OR "Motore".M[#K_MotoreInt].Out.CmdNegMotore;
	                    #PO_Movimot.CTW.%X6 := ("Zona".Z[#K_Zona].Gen.Reset OR ("Motore".M[#K_MotoreInt].Dati.AlmInv_ToutReset > 2000 AND "Zona".Comuni.Clocks.Clock1Hz));
	                    IF NOT "Motore".M[#K_MotoreInt].Out.CmdNegMotore THEN
	                        #PO_Movimot.Speed := DINT_TO_INT(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 16384.0));
	                    ELSE
	                        #PO_Movimot.Speed := - DINT_TO_INT(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 16384.0));
	                    END_IF;
	                    #PO_Movimot.AccRich := DINT_TO_INT(TRUNC(DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.DecEmergenza) * 400.0));
	                    "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv := DPWR_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD := #PO_Movimot);
	                    "Motore".M[#K_MotoreInt].HMI.CTW1 := #PO_Movimot.CTW;
	                    "Motore".M[#K_MotoreInt].HMI.CTW2 := INT_TO_WORD(#PO_Movimot.Speed);
	                    "Motore".M[#K_MotoreInt].HMI.CTW3 := INT_TO_WORD(#PO_Movimot.AccRich);
	                END_REGION
	            5:
	                REGION PN MoviGear
	                    
	                    (* Struttura Control Word
	                    Bit 00: Enable/Emergency Stop
	                    Bit 01: Enable/Application Stop
	                    Bit 02: Riservato
	                    Bit 03: Rilascio Freno
	                    Bit 04: Jog Positivo
	                    Bit 05: Jog Negativo
	                    Bit 06: Nuovo Movimento Relativo
	                    Bit 07: Strat/Stop
	                    Bit 08: Fault Reset
	                    Bit 09: Riservato
	                    Bit 10: Attiva Motore 2
	                    Bit 11: Riservato
	                    Bit 12: Disabilita Limiti
	                    Bit 13: Attiva Output Stage
	                    Bit 14: Attiva Stand By
	                    Bit 15: HandShake
	                    *)
	                    #PO_MoviGear.CTW := 0;
	                    // Emergenza OK
	                    #PO_MoviGear.CTW.%X0 := "Zona".Z[#K_Zona].Out.CentralinaOk;
	                    // Comando di Marcia
	                    #PO_MoviGear.CTW.%X7 := #PO_MoviGear.CTW.%X1 := "Motore".M[#K_MotoreInt].Out.CmdPosMotore OR "Motore".M[#K_MotoreInt].Out.CmdNegMotore;
	                    // Fault Reset
	                    #PO_MoviGear.CTW.%X8 := "Zona".Z[#K_Zona].Gen.Reset;
	                    // VelocitÃ  richiesta
	                    IF NOT "Motore".M[#K_MotoreInt].Out.CmdNegMotore THEN
	                        #PO_MoviGear.Target_Speed := DINT_TO_INT(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 3000.0));
	                    ELSE
	                        #PO_MoviGear.Target_Speed := - DINT_TO_INT(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 3000.0));
	                    END_IF;
	                    #PO_MoviGear.Acceleration := #PO_MoviGear.Deceleration := 30000;
	                    #PO_MoviGear."DO".%X0 := "Motore".M[#K_MotoreInt].Out.CmdUsc01Inv;
	                    #PO_MoviGear."DO".%X1 := "Motore".M[#K_MotoreInt].Out.CmdUsc02Inv;
	                    "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv := DPWR_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD := #PO_MoviGear);
	                    "Motore".M[#K_MotoreInt].HMI.CTW1 := #PO_MoviGear.CTW;
	                END_REGION
	            6:
	                REGION PN Danfoss
	                    (* Struttura Control Word
	                       Bit 08: JOG 1 OFF/ON
	                       Bit 09: JOG 2 OFF/ON
	                       Bit 10: 0=Data invalid    1=Data valid
	                       Bit 11: 0=No function        1=Slow down
	                       Bit 12: 0=No function        1=Catch up
	                       Bit 13: 0=Parameter set-up        1=Sel LSB
	                       Bit 14: 0=Parameter set-up        1=Sel MSB
	                       Bit 15: 0=No function        1=Reserve
	                       Bit 00: OFF/ON 1
	                       Bit 01: OFF/ON 2
	                       Bit 02: OFF/ON 3
	                       Bit 03: 0=Coasting        1=Not coasting
	                       Bit 04: 0=Quick stop       1=Ramp
	                       Bit 05: 0=Hold Freq.Output   1=Use Ramp
	                       Bit 06: 0=Ramp Stop        1=Start
	                       Bit 07: 0=No function        1=Reset
	                       *)
	                    #PO_Danfoss.CTW := w#16#47f;
	                    #PO_Danfoss.CTW.%X0 := #PI_Danfoss.STW.%X0;
	                    #PO_Danfoss.CTW.%X6 := ("Motore".M[#K_MotoreInt].Out.CmdPosMotore OR "Motore".M[#K_MotoreInt].Out.CmdNegMotore) AND #PO_Danfoss.CTW.%X0 AND #PI_Danfoss.STW.%X9;
	                    #PO_Danfoss.CTW.%X15 := #PO_Danfoss.CTW.%X6 AND "Motore".M[#K_MotoreInt].Out.CmdNegMotore;
	                    #PO_Danfoss.CTW.%X7 := "Zona".Z[#K_Zona].Gen.Reset AND #PI_Danfoss.STW.%X3;
	                    #PO_Danfoss.Speed := DINT_TO_INT(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 16384.0));
	                    #PO_Danfoss.AccRich := DINT_TO_INT(TRUNC(DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.AccRichPerc) * 40.0));
	                    #PO_Danfoss.DecRich := DINT_TO_INT(TRUNC(DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) / DINT_TO_REAL(#DecActRich) * 40.0));
	                    "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv := DPWR_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD := #PO_Danfoss);
	                    "Motore".M[#K_MotoreInt].HMI.CTW1 := #PO_Danfoss.CTW;
	                END_REGION ;  
	            7:
	                REGION PN MoviTrak
	                    (* Struttura Control Word
	                    Bit 08: Reserved
	                    Bit 09: Reserved
	                    Bit 10: Reserved
	                    Bit 11: Reserved
	                    Bit 12: Reserved
	                    Bit 13: Reserved
	                    Bit 14: Reserved
	                    Bit 15: Reserved
	                    Bit 00: Inhibit/Enable
	                    Bit 01: Enable/Rapid Stop
	                    Bit 02: Enable/Stop
	                    Bit 03: Reserved
	                    Bit 04: Reserved
	                    Bit 05: Reserved
	                    Bit 06: Reset
	                    Bit 07: Reserved
	                    *)
	                    #PO_MoviTrac.CTW := 0;
	                    #PO_MoviTrac.CTW.%X1 := #PO_MoviTrac.CTW.%X2 := "Motore".M[#K_MotoreInt].Out.CmdPosMotore OR "Motore".M[#K_MotoreInt].Out.CmdNegMotore;
	                    #PO_MoviTrac.CTW.%X6 := "Zona".Z[#K_Zona].Gen.Reset;
	                    IF NOT "Motore".M[#K_MotoreInt].Out.CmdNegMotore THEN
	                        #PO_MoviTrac.Speed := DINT_TO_INT(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 16384.0));
	                    ELSE
	                        #PO_MoviTrac.Speed := - DINT_TO_INT(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 16384.0));
	                    END_IF;
	                    "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv := DPWR_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD := #PO_MoviTrac);
	                    "Motore".M[#K_MotoreInt].HMI.CTW1 := #PO_MoviTrac.CTW;
	                END_REGION
	            8:
	                REGION PN INVT
	                    (* Struttura Control Word
	                    Byte 0
	                    DEC Description
	                    1   Forward running
	                    2   Reverse running
	                    3   Forward inching
	                    4   Reverse inching
	                    5   Decelerating to stop
	                    6   Coasting to stop (emergency stop)
	                    7   Fault reset
	                    8   Jogging to stop
	                    9   Decelerate to stop
	                    ////////////////////////////////////////////////
	                    Bit 8: Abilita scrittura parametri PKW
	                    ////////////////////////////////////////////////
	                    Bit 9-10:
	                    DEC DEscrizione
	                    00  Motor 1
	                    01  Motor 2
	                    ////////////////////////////////////////////////
	                    Bit 11: 0=Disable Switchig, 1=Enable Torque/Speed control Switching
	                    Bit 12: Reset Power Consumption
	                    Bit 13: Pre-Excitation
	                    Bit 14: DC-Bracking
	                    Bit 15: Heart Beat Reference
	        
	                    *)
	                    #PO_INVT.CTW.%B1 := 1;
	                    IF "Zona".Z[#K_Zona].Gen.Reset AND ("Motore".M[#K_MotoreInt].Dati.MotoreFermo OR "Motore".M[#K_MotoreInt].In.DriverFault) THEN
	                        #PO_INVT.CTW.%B0 := 7;
	                    ELSIF "Motore".M[#K_MotoreInt].Out.CmdPosMotore THEN
	                        #PO_INVT.CTW.%B0 := 1;
	                    ELSIF "Motore".M[#K_MotoreInt].Out.CmdNegMotore THEN
	                        #PO_INVT.CTW.%B0 := 2;
	                    ELSE
	                        #PO_INVT.CTW.%B0 := 6;
	                    END_IF;
	                    #PO_INVT.CTW.%X15 := NOT #PI_INVT.STW.%X15;
	                    #PO_INVT.Speed := DINT_TO_INT(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 10000.0));
	                    REGION ScritturaParametri
	                        IF #PI_INVT.PKW01 <> 0 THEN
	                            IF "Motore".M[#K_MotoreInt].Dati.PrmSend THEN
	                                "Motore".M[#K_MotoreInt].Dati.IdPrm += 1;
	                                IF "Motore".M[#K_MotoreInt].Dati.IdPrm > 1 THEN
	                                    "Motore".M[#K_MotoreInt].Dati.IdPrm := 0;
	                                END_IF;
	                                "Motore".M[#K_MotoreInt].Dati.PrmSend := false;
	                            END_IF;
	                        ELSE
	                            "Motore".M[#K_MotoreInt].Dati.PrmSend := true;
	                            CASE "Motore".M[#K_MotoreInt].Dati.IdPrm OF
	                                0:  //Acc
	                                    #PO_INVT.PKW01 := 4;
	                                    #PO_INVT.PKW02 := 11;
	                                    #PO_INVT.PKW04 := DINT_TO_WORD(TRUNC(DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.DecEmergenza) * 3.0));
	                                1:  //Dec
	                                    #PO_INVT.PKW01 := 4;
	                                    #PO_INVT.PKW02 := 12;
	                                    #PO_INVT.PKW04 := DINT_TO_WORD(TRUNC(DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.DecEmergenza) * 3.0));
	                                ELSE
	                                    "Motore".M[#K_MotoreInt].Dati.PrmSend := false;
	                                    "Motore".M[#K_MotoreInt].Dati.IdPrm := 0;
	                            END_CASE;
	                        END_IF;
	                    END_REGION
	                    "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv := DPWR_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD := #PO_INVT);
	                    "Motore".M[#K_MotoreInt].HMI.CTW1 := #PO_INVT.CTW;
	                END_REGION
	            9:
	                REGION Nidec
	                    (*
	                    BIT 00: Drive Enable
	                    BIT 01: Run Forward
	                    BIT 02: Jog Forward
	                    BIT 03: Run Reverse
	                    BIT 04: Forward/Reverse
	                    BIT 05: Run
	                    BIT 06: Not Stop
	                    BIT 07: Auto / manual
	                    BIT 08: Analog / Preset reference
	                    BIT 09: Jog Reverse
	                    BIT 10: Not used
	                    BIT 11: Not used
	                    BIT 12: Trip drive
	                    BIT 13: Reset drive
	                    BIT 14: Watchdog
	                    *)
	                    #PO_Nidec.CTW.%X7 := true;
	                    #PO_Nidec.CTW.%X0 := #PO_Nidec.CTW.%X6 := #PI_Nidec.STW.%X0 AND "Zona".Z[#K_ZonaInt].Out.CentralinaOk;
	                    //#PO_Nidec.CTW.%X1 := "Motor".M[#MotorNumber].o.CmdFWD OR "Motor".M[#MotorNumber].o.CmdBKW;
	                    //#PO_Nidec.CTW.%X3 := "Motor".M[#MotorNumber].o.CmdBKW;
	                    #PO_Nidec.CTW.%X5 := "Motore".M[#K_MotoreInt].Out.CmdPosMotore OR "Motore".M[#K_MotoreInt].Out.CmdNegMotore;
	                    #PO_Nidec.CTW.%X4 := "Motore".M[#K_MotoreInt].Out.CmdNegMotore;
	                    #PO_Nidec.CTW.%X13 := "Zona".Z[#K_Zona].Gen.Reset AND "Motore".M[#K_MotoreInt].In.DriverFault;
	                    #PO_Nidec.Speed := TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 10000.0);
	                    #PO_Nidec.RampAcc := TRUNC(DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.AccRichPerc) * 3.0);
	                    #PO_Nidec.RampDec := TRUNC(DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.DecReqEmergInLavo) * 3.0);
	                    "Motore".M[#K_MotoreInt].HMI.CTW1 := #PO_Nidec.CTW;
	                    //VariantPut(SRC := #PO_Nidec, DST := #PO_Inv);
	                END_REGION
	                ;
	        END_CASE;
	    END_REGION ;
	    REGION Update
	        IF "Motore".M[#K_MotoreInt].HMI.UpdParam THEN
	            "Motore".M[#K_MotoreInt].HMI.UpdParam := FALSE;
	            "Motore".M[#K_MotoreInt].Out.UpdParam := true;
	        ELSE
	            IF "Motore".M[#K_MotoreInt].Out.UpdParam THEN
	                "Motore".M[#K_MotoreInt].HMI.FBGestione := 100 + "Motore".M[#K_MotoreInt].HW.TipoCollInverter;
	                CASE "Motore".M[#K_MotoreInt].HW.TipoEncoder OF
	                    1: // ENCODER SICK
	                        "Motore".M[#K_MotoreInt].Dati.Encoder.RicircoloEncoder := 1073741824;
	                        "Motore".M[#K_MotoreInt].Dati.Encoder.MezzoRicircoloEncoder := "Motore".M[#K_MotoreInt].Dati.Encoder.RicircoloEncoder / 2;
	                        "Motore".M[#K_MotoreInt].Prm.Enc.ImpRev := 262144.0;
	                    10, 11: // ENCODER T+R
	                        "Motore".M[#K_MotoreInt].Dati.Encoder.RicircoloEncoder := 16#0200_0000;
	                        "Motore".M[#K_MotoreInt].Dati.Encoder.MezzoRicircoloEncoder := "Motore".M[#K_MotoreInt].Dati.Encoder.RicircoloEncoder / 2;
	                        "Motore".M[#K_MotoreInt].Prm.Enc.ImpRev := 8192.0;
	                END_CASE;
	            END_IF;
	            "Motore".M[#K_MotoreInt].Out.UpdParam := false;
	        END_IF;
	        IF "Motore".M[#K_MotoreInt].Out.UpdParam THEN
	            "Motore".M[#K_MotoreInt].In.Positioning := false;
	            "Motore".M[#K_MotoreInt].In.PosRelativo := false;
	            "Motore".M[#K_MotoreInt].In.CambioVelDaPunto := false;
	            "Motore".M[#K_MotoreInt].In.CmdPosRich := false;
	            "Motore".M[#K_MotoreInt].In.CmdNegRich := false;
	            "Motore".M[#K_MotoreInt].In.MotoreRun := false;
	            "Motore".M[#K_MotoreInt].In.AttivaLimVarPos := false;
	            "Motore".M[#K_MotoreInt].In.AttivaLimVarNeg := false;
	            "Motore".M[#K_MotoreInt].In.Premagnetizza := false;
	            "Motore".M[#K_MotoreInt].In.PremagnetizzaPos := false;
	            "Motore".M[#K_MotoreInt].In.PremagnetizzaNeg := false;
	            "Motore".M[#K_MotoreInt].In.ForzaEndLessPos := false;
	            "Motore".M[#K_MotoreInt].In.ForzaEndLessNeg := false;
	            "Motore".M[#K_MotoreInt].In.ForzaEndLessBreve := false;
	            "Motore".M[#K_MotoreInt].In.SezAperto := false;
	            "Motore".M[#K_MotoreInt].In.DriverFault := false;
	            "Motore".M[#K_MotoreInt].In.DriverWarning := false;
	            "Motore".M[#K_MotoreInt].In.NoComunInv := false;
	            "Motore".M[#K_MotoreInt].In.NoComunEnc := false;
	            "Motore".M[#K_MotoreInt].In.TerVentolaOff := false;
	            "Motore".M[#K_MotoreInt].In.CinghiaRotta := false;
	            "Motore".M[#K_MotoreInt].In.SensAzz := false;
	            "Motore".M[#K_MotoreInt].In.SpinaSicNoInPos := false;
	            "Motore".M[#K_MotoreInt].In.ConsMovimentoPos := true;
	            "Motore".M[#K_MotoreInt].In.ConsMovimentoNeg := true;
	            "Motore".M[#K_MotoreInt].In.AnticadutaOFF := false;
	            "Motore".M[#K_MotoreInt].In.AnticadutaON := false;
	            "Motore".M[#K_MotoreInt].In.PercentualeRichiesta := 100;
	            "Motore".M[#K_MotoreInt].Out.CmdPosMotore := false;
	            "Motore".M[#K_MotoreInt].Out.CmdNegMotore := false;
	            "Motore".M[#K_MotoreInt].Out.CmdAnticaduta := false;
	            "Motore".M[#K_MotoreInt].Out.Paw := 0;
	            "Motore".M[#K_MotoreInt].Out.VelEncoder := 0;
	            "Motore".M[#K_MotoreInt].Prm.ByPassAnticaduta := false;
	            "Motore".M[#K_MotoreInt].Prm.AnticadutaPresente := false;
	            "Motore".M[#K_MotoreInt].Prm.PremaNoFreno := false;
	            "Motore".M[#K_MotoreInt].Prm.EscludiFunzPos := false;
	            "Motore".M[#K_MotoreInt].Prm.CambioDirNoFreno := false;
	            "Motore".M[#K_MotoreInt].Prm.CalcTempoRimanente := false;
	            "Motore".M[#K_MotoreInt].Prm.FrenoPresente := false;
	            "Motore".M[#K_MotoreInt].Prm.DisabCicloAutoAllarme := false;
	            "Motore".M[#K_MotoreInt].Prm.DisabCicloManuAllarme := false;
	            "Motore".M[#K_MotoreInt].HMI.Setup := false;
	            "Motore".M[#K_MotoreInt].HMI.ManMov := false;
	            "Motore".M[#K_MotoreInt].HMI.Param.Read := false;
	            "Motore".M[#K_MotoreInt].HMI.Param.Write := false;
	            "Motore".M[#K_MotoreInt].HMI.Param.Save := false;
	            "Motore".M[#K_MotoreInt].HMI.Param.FactoryInit := false;
	            "Motore".M[#K_MotoreInt].HMI.Param.Init_Motor := false;
	            "Motore".M[#K_MotoreInt].HMI.FBGestione := 100 + "Motore".M[#K_MotoreInt].HW.TipoCollInverter;
	            CASE "Motore".M[#K_MotoreInt].HW.TipoEncoder OF
	                1: // ENCODER SICK
	                    "Motore".M[#K_MotoreInt].Dati.Encoder.RicircoloEncoder := 1073741824;
	                    "Motore".M[#K_MotoreInt].Dati.Encoder.MezzoRicircoloEncoder := "Motore".M[#K_MotoreInt].Dati.Encoder.RicircoloEncoder / 2;
	                    "Motore".M[#K_MotoreInt].Prm.Enc.ImpRev := 262144.0;
	                10, 11: // ENCODER T+R
	                    "Motore".M[#K_MotoreInt].Dati.Encoder.RicircoloEncoder := 16#0200_0000;
	                    "Motore".M[#K_MotoreInt].Dati.Encoder.MezzoRicircoloEncoder := "Motore".M[#K_MotoreInt].Dati.Encoder.RicircoloEncoder / 2;
	                    "Motore".M[#K_MotoreInt].Prm.Enc.ImpRev := 8192.0;
	            END_CASE;
	            REGION CalcoloSviluppoEncoder
	                CASE "Motore".M[#K_MotoreInt].Prm.Enc.Mounting OF
	                    1:
	                        // Albero Lento
	                        "Motore".M[#K_MotoreInt].Prm.C.SpazioGiroEncoder := UDINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Mech.FeedConstant);
	                    2:
	                        // Albero Veloce
	                        "Motore".M[#K_MotoreInt].Prm.C.SpazioGiroEncoder := UDINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Mech.FeedConstant * "Motore".M[#K_MotoreInt].Prm.Mech.GearIn) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Mech.GearOut);
	                    ELSE
	                        "Motore".M[#K_MotoreInt].Prm.C.SpazioGiroEncoder := UDINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Enc.FeedConstant);
	                END_CASE;
	            END_REGION
	            "Motore".M[#K_MotoreInt].Prm.C.VelMax := TRUNC(UDINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Mech.FeedConstant) * (DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Mech.GearIn) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Mech.GearOut)) * DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Mech.RPMMaxRef) / 60.0);
	            CASE "Motore".M[#K_MotoreInt].HMI.ModoInizializza OF
	                1:
	                    "Motore".M[#K_MotoreInt].Prm.TMinVCost := 200;
	                    "Motore".M[#K_MotoreInt].Prm.TCambioDir := 200;
	                    IF "Motore".M[#K_MotoreInt].HW.TipoCollInverter <> 0 THEN
	                        "Motore".M[#K_MotoreInt].Prm.VelPrema := 1;
	                    ELSE
	                        "Motore".M[#K_MotoreInt].Prm.VelPrema := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 100;
	                    END_IF;
	                    "Motore".M[#K_MotoreInt].Prm.VelBassa := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 10;
	                    "Motore".M[#K_MotoreInt].Prm.VelSgancioFrenoPos := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 50;
	                    "Motore".M[#K_MotoreInt].Prm.VelSgancioFrenoNeg := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 50;
	                    "Motore".M[#K_MotoreInt].Prm.SpazioArrestoPos := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 500;
	                    "Motore".M[#K_MotoreInt].Prm.SpazioArrestoNeg := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 500;
	                    "Motore".M[#K_MotoreInt].Prm.Precisione := MAX(IN1 := "Motore".M[#K_MotoreInt].Prm.SpazioArrestoPos, IN2 := "Motore".M[#K_MotoreInt].Prm.SpazioArrestoNeg) * 2;
	                    "Motore".M[#K_MotoreInt].Prm.Inerzia := "Motore".M[#K_MotoreInt].Prm.Precisione + 2000;
	                    "Motore".M[#K_MotoreInt].Prm.DecFinale := "Motore".M[#K_MotoreInt].Prm.C.VelMax * 2;
	                    "Motore".M[#K_MotoreInt].Prm.DecEmergenza := "Motore".M[#K_MotoreInt].Prm.C.VelMax * 3;
	                    "Motore".M[#K_MotoreInt].In.Acc := "Motore".M[#K_MotoreInt].Prm.C.VelMax * 2;
	                    "Motore".M[#K_MotoreInt].In.Dec := "Motore".M[#K_MotoreInt].Prm.C.VelMax * 2;
	                    "Motore".M[#K_MotoreInt].Prm.VelMan := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 4;
	                    "Motore".M[#K_MotoreInt].Prm.VelJog := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 10;
	                    "Motore".M[#K_MotoreInt].Prm.ValMaxRef := 27648;
	                2:
	                    "Motore".M[#K_MotoreInt].Prm.TMinVCost := 200;
	                    "Motore".M[#K_MotoreInt].Prm.TCambioDir := 200;
	                    IF "Motore".M[#K_MotoreInt].HW.TipoCollInverter <> 0 THEN
	                        "Motore".M[#K_MotoreInt].Prm.VelPrema := 1;
	                    ELSE
	                        "Motore".M[#K_MotoreInt].Prm.VelPrema := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 100;
	                    END_IF;
	                    "Motore".M[#K_MotoreInt].Prm.VelBassa := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 10;
	                    "Motore".M[#K_MotoreInt].Prm.VelSgancioFrenoPos := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 25;
	                    "Motore".M[#K_MotoreInt].Prm.VelSgancioFrenoNeg := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 25;
	                    "Motore".M[#K_MotoreInt].Prm.SpazioArrestoPos := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 500;
	                    "Motore".M[#K_MotoreInt].Prm.SpazioArrestoNeg := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 500;
	                    "Motore".M[#K_MotoreInt].Prm.Precisione := MAX(IN1 := "Motore".M[#K_MotoreInt].Prm.SpazioArrestoPos, IN2 := "Motore".M[#K_MotoreInt].Prm.SpazioArrestoNeg) * 2;
	                    "Motore".M[#K_MotoreInt].Prm.Inerzia := "Motore".M[#K_MotoreInt].Prm.Precisione + 2000;
	                    "Motore".M[#K_MotoreInt].Prm.DecFinale := "Motore".M[#K_MotoreInt].Prm.C.VelMax * 2;
	                    "Motore".M[#K_MotoreInt].Prm.DecEmergenza := "Motore".M[#K_MotoreInt].Prm.C.VelMax * 3;
	                    "Motore".M[#K_MotoreInt].In.Acc := "Motore".M[#K_MotoreInt].Prm.C.VelMax * 2;
	                    "Motore".M[#K_MotoreInt].In.Dec := "Motore".M[#K_MotoreInt].Prm.C.VelMax * 2;
	                    "Motore".M[#K_MotoreInt].Prm.VelMan := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 4;
	                    "Motore".M[#K_MotoreInt].Prm.VelJog := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 10;
	                    "Motore".M[#K_MotoreInt].Prm.ValMaxRef := 27648;
	                3:
	                    "Motore".M[#K_MotoreInt].Prm.TMinVCost := 200;
	                    "Motore".M[#K_MotoreInt].Prm.TCambioDir := 200;
	                    IF "Motore".M[#K_MotoreInt].HW.TipoCollInverter <> 0 THEN
	                        "Motore".M[#K_MotoreInt].Prm.VelPrema := 1;
	                    ELSE
	                        "Motore".M[#K_MotoreInt].Prm.VelPrema := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 100;
	                    END_IF;
	                    "Motore".M[#K_MotoreInt].Prm.VelBassa := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 10;
	                    "Motore".M[#K_MotoreInt].Prm.VelSgancioFrenoPos := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 25;
	                    "Motore".M[#K_MotoreInt].Prm.VelSgancioFrenoNeg := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 25;
	                    "Motore".M[#K_MotoreInt].Prm.SpazioArrestoPos := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 500;
	                    "Motore".M[#K_MotoreInt].Prm.SpazioArrestoNeg := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 500;
	                    "Motore".M[#K_MotoreInt].Prm.Precisione := MAX(IN1 := "Motore".M[#K_MotoreInt].Prm.SpazioArrestoPos, IN2 := "Motore".M[#K_MotoreInt].Prm.SpazioArrestoNeg) * 2;
	                    "Motore".M[#K_MotoreInt].Prm.Inerzia := "Motore".M[#K_MotoreInt].Prm.Precisione + 2000;
	                    "Motore".M[#K_MotoreInt].Prm.DecFinale := "Motore".M[#K_MotoreInt].Prm.C.VelMax;
	                    "Motore".M[#K_MotoreInt].Prm.DecEmergenza := "Motore".M[#K_MotoreInt].Prm.C.VelMax;
	                    "Motore".M[#K_MotoreInt].In.Acc := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 2;
	                    "Motore".M[#K_MotoreInt].In.Dec := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 2;
	                    "Motore".M[#K_MotoreInt].Prm.VelMan := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 4;
	                    "Motore".M[#K_MotoreInt].Prm.VelJog := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 10;
	                    "Motore".M[#K_MotoreInt].Prm.ValMaxRef := 27648;
	            END_CASE;
	            "Motore".M[#K_MotoreInt].HMI.ModoInizializza := 0;
	            "Motore".M[#K_MotoreInt].Allarmi.WordHmi_1 :=
	            "Motore".M[#K_MotoreInt].Allarmi.WordHmi_2 := 0;
	        END_IF;
	    END_REGION ;
	    REGION Motor block
	        IF "Motore".M[#K_MotoreInt].Dati.MotorStop THEN
	            IF NOT "Motore".M[#K_MotoreInt].Out.InMarcia THEN
	                IF "Motore".M[#K_MotoreInt].Dati.AlmInv_RitRestart > 1000 THEN
	                    "Motore".M[#K_MotoreInt].Dati.MotorStop := false;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Dati.AlmInv_RitRestart += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                END_IF;
	            ELSE
	                "Motore".M[#K_MotoreInt].Dati.AlmInv_RitRestart := 0;
	            END_IF;
	        END_IF;
	        IF "Motore".M[#K_MotoreInt].Dati.AlmBloccato_Cont > 0 OR "Motore".M[#K_MotoreInt].Dati.AlmInv_Cont > 0 THEN
	            "Motore".M[#K_MotoreInt].Dati.Alm_ContAzzCont += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	            IF "Motore".M[#K_MotoreInt].Dati.Alm_ContAzzCont > 60000 THEN
	                "Motore".M[#K_MotoreInt].Dati.AlmBloccato_Cont := 0;
	                "Motore".M[#K_MotoreInt].Dati.AlmInv_Cont := 0;
	                "Motore".M[#K_MotoreInt].Dati.Alm_ContAzzCont := 0;
	            END_IF;
	        ELSE
	            "Motore".M[#K_MotoreInt].Dati.Alm_ContAzzCont := 0;
	        END_IF;
	    END_REGION ;
	    REGION Riferimenti incrociati
	        "Motore".M[#K_MotoreInt].Rif_Inc.K_Analogica := "Motore".M[#K_MotoreInt].Prm.K_Analogica;
	    END_REGION ;
	    REGION Pulisco i comandi della sequenza
	        IF "Motore".M[#K_MotoreInt].Dati.InclusoInUnaSequenza THEN
	            "Motore".M[#K_MotoreInt].In.CmdPosRich :=
	            "Motore".M[#K_MotoreInt].In.CmdNegRich := False;
	        END_IF;
	    END_REGION ;
	    IF "Motore".M[#K_MotoreInt].Prm.DecFinale <> "Motore".M[#K_MotoreInt].Dati.DecReqFinaleInLavo THEN
	        IF NOT "Motore".M[#K_MotoreInt].Out.InMarcia OR "Motore".M[#K_MotoreInt].Prm.DecFinale > "Motore".M[#K_MotoreInt].Dati.DecReqFinaleInLavo THEN
	            "Motore".M[#K_MotoreInt].Dati.DecReqFinaleInLavo := "Motore".M[#K_MotoreInt].Prm.DecFinale;
	        END_IF;
	    END_IF;
	END_REGION ;
	REGION Controllo Accelerazione 
	    IF #CambioReqAcc THEN
	        "Motore".M[#K_MotoreInt].Allarmi.AccRichZero := "Motore".M[#K_MotoreInt].Dati.AccRichPerc < 100;
	        IF "Motore".M[#K_MotoreInt].Allarmi.AccRichZero THEN
	            "Motore".M[#K_MotoreInt].Dati.AccRichPerc := 100;
	            "Motore".M[#K_MotoreInt].Allarmi.Parametri := TRUE;
	        END_IF;
	        "Motore".M[#K_MotoreInt].Allarmi.AccRichMaxMaxDec := "Motore".M[#K_MotoreInt].Dati.AccRichPerc > "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec_Emergenza;
	        IF "Motore".M[#K_MotoreInt].Allarmi.AccRichMaxMaxDec THEN
	            "Motore".M[#K_MotoreInt].Dati.AccRichPerc := "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec_Emergenza;
	            "Motore".M[#K_MotoreInt].Allarmi.Parametri := TRUE;
	        END_IF;
	    END_IF;
	END_REGION ;
	    REGION Assegnazione decelerazione
	        IF "Motore".M[#K_MotoreInt].Dati.DecRichPerc <> "Motore".M[#K_MotoreInt].Dati.DecReqInLavo THEN
	            IF NOT "Motore".M[#K_MotoreInt].Out.InMarcia OR "Motore".M[#K_MotoreInt].Dati.DecRichPerc > "Motore".M[#K_MotoreInt].Dati.DecReqInLavo OR "Motore".M[#K_MotoreInt].Out.VelAss < #VeloBassaConv THEN
	                "Motore".M[#K_MotoreInt].Dati.DecReqInLavo := "Motore".M[#K_MotoreInt].Dati.DecRichPerc;
	            END_IF;
	        END_IF;
	    END_REGION
	    REGION Assegnazione decelerazione D'emergenza
	        IF "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec_Emergenza <> "Motore".M[#K_MotoreInt].Dati.DecReqEmergInLavo THEN
	            IF NOT "Motore".M[#K_MotoreInt].Out.InMarcia OR "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec_Emergenza > "Motore".M[#K_MotoreInt].Dati.DecReqEmergInLavo THEN
	                "Motore".M[#K_MotoreInt].Dati.DecReqEmergInLavo := "Motore".M[#K_MotoreInt].Dati.Memo_Req_Dec_Emergenza;
	            END_IF;
	        END_IF;
	    END_REGION
	    REGION Calcolo Lo Spazio Di Arresto
	        #ReqDecBassa := FALSE;
	        #ReqDecStop := FALSE;
	        #BloccaAcc := FALSE;
	        IF "Motore".M[#K_MotoreInt].Out.InMarcia THEN
	            IF "Motore".M[#K_MotoreInt].Out.VelAss > #VeloBassaConv THEN
	                #SpazioStop_01 := (SQR(IN := "Motore".M[#K_MotoreInt].Out.VelAss) - SQR(IN := #VeloBassaConv)) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.DecReqInLavo) / 2.0;
	                #SpazioStop_02 := DINT_TO_REAL(IN := "Motore".M[#K_MotoreInt].Prm.TBassaVel) * #VeloBassaConv / 1000.0;
	                #SpazioStop_03 := (SQR(IN := #VeloBassaConv) - SQR(IN := DINT_TO_REAL(#VeloFrenoDir))) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.DecReqFinaleInLavo) / 2.0;
	            ELSE
	                #SpazioStop_01 := 0.0;
	                #SpazioStop_02 := 0.0;
	                #SpazioStop_03 := (SQR(IN := "Motore".M[#K_MotoreInt].Out.VelAss) - SQR(IN := DINT_TO_REAL(#VeloFrenoDir))) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.DecReqFinaleInLavo) / 2.0;
	                ;
	            END_IF;
	            #SpazioStop_04 := INT_TO_REAL("Motore".M[#K_MotoreInt].Prm.TReazioneSistema) * ("Motore".M[#K_MotoreInt].Out.VelAss - DINT_TO_REAL(#VeloFrenoDir)) / 1000.0;
	            #SpazioStop := TRUNC(IN := #SpazioStop_03 + #SpazioStop_04) + #SpazioFrenoDir;
	            #SpazioBassa := TRUNC(IN := #SpazioStop_01 + #SpazioStop_02) + #SpazioStop;
	            IF #FunzPositioning THEN
	                #BloccaAcc := TRUNC(("Motore".M[#K_MotoreInt].Out.VelAss * INT_TO_REAL("Motore".M[#K_MotoreInt].Prm.TMinVCost) / 1000.0)) + #SpazioStop > #DistTRG_ASS;
	                #ReqDecBassa := #DistTRG_ASS < #SpazioBassa;
	                #ReqDecStop := #DistTRG_ASS < #SpazioStop;
	            END_IF;
	        ELSE
	            #SpazioBassa := #SpazioStop := #SpazioFrenoDir;
	        END_IF;
	    END_REGION
	    REGION Calcolo lo spazio passaggio seconda Vel.
	        IF #FunzPositioning AND "Motore".M[#K_MotoreInt].In.CambioVelDaPunto AND NOT "Motore".M[#K_MotoreInt].Dati.MotoreFermo THEN
	            // Lo spazio di cambio velocitÃ  Ã¨ dato dalla somma dei seguenti fattori:
	            
	            // 1) Spazio necessario al cambio velocitÃ  dell'asse calcolando una rampa trapezoidale.
	            // 2) Simulazione dello spazio percorso dall'asse durante la reazione del segnale analogico.
	            
	            // Condizione 01 -Trapezio passaggio dalla velocitÃ  di lavoro alla velocitÃ  bassa
	            #SpazioCambioVel_01 := ("Motore".M[#K_MotoreInt].Out.VelAss ** 2 - DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.VeloDopoCambioRich) ** 2) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.DecReqInLavo) / 2.0;
	            #SpazioCambioVel_02 := INT_TO_REAL("Motore".M[#K_MotoreInt].Prm.TReazioneSistema) * "Motore".M[#K_MotoreInt].Out.VelAss / 1000.0;
	            #SpazioCambioVel := TRUNC(#SpazioCambioVel_01 + #SpazioCambioVel_02);
	            // Continua solo se cambio velocitÃ  Ã¨ attivo
	            // Calcolo la distanza dal cambio velocitÃ 
	            IF NOT "Motore".M[#K_MotoreInt].In.PosRelativo THEN
	                IF "Motore".M[#K_MotoreInt].Prm.Mech.EndLess THEN
	                    WHILE "Motore".M[#K_MotoreInt].In.PosCambioVel > "Motore".M[#K_MotoreInt].Prm.Enc.ModuloPosEnc DO
	                        "Motore".M[#K_MotoreInt].In.PosCambioVel -= #RicircoloTotale;
	                    END_WHILE;
	                    WHILE "Motore".M[#K_MotoreInt].In.PosCambioVel < "Motore".M[#K_MotoreInt].Prm.Enc.ModuloNegEnc DO
	                        "Motore".M[#K_MotoreInt].In.PosCambioVel += #RicircoloTotale;
	                    END_WHILE;
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].Dati.ActVelPos THEN
	                    #DistCambioVel := "Motore".M[#K_MotoreInt].Out.ActPos + #SpazioCambioVel - "Motore".M[#K_MotoreInt].In.PosCambioVel;
	                ELSE
	                    #DistCambioVel := "Motore".M[#K_MotoreInt].Out.ActPos - #SpazioCambioVel - "Motore".M[#K_MotoreInt].In.PosCambioVel;
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].Prm.Mech.EndLess THEN
	                    IF #DistCambioVel > #MezzoRicircoloTotale THEN
	                        #DistCambioVel -= #RicircoloTotale;
	                    END_IF;
	                    IF #DistCambioVel < - #MezzoRicircoloTotale THEN
	                        #DistCambioVel += #RicircoloTotale;
	                    END_IF;
	                END_IF;
	                #ReqCambioVel := #DistCambioVel >= 0 AND "Motore".M[#K_MotoreInt].Dati.ActVelPos OR #DistCambioVel < 0 AND "Motore".M[#K_MotoreInt].Dati.ActVelNeg;
	            ELSE
	                #ReqCambioVel := "Motore".M[#K_MotoreInt].Dati.MovRelRichiesto - #DistTRG_ASS + #SpazioCambioVel > "Motore".M[#K_MotoreInt].In.PosCambioVel;
	            END_IF;
	        ELSE
	            #ReqCambioVel := FALSE;
	            #SpazioCambioVel := 0;
	        END_IF;
	        
	    END_REGION ;
	   
	    REGION Pos.Motore + Spazio Arresto
	        IF "Motore".M[#K_MotoreInt].Out.InMarcia THEN
	            "Motore".M[#K_MotoreInt].Out.SpazioStop := #SpazioBassa;
	            IF "Motore".M[#K_MotoreInt].Dati.ActVelPos THEN
	                "Motore".M[#K_MotoreInt].Out.ActPosPiuStop := "Motore".M[#K_MotoreInt].Out.ActPos + #SpazioBassa;
	            ELSE
	                "Motore".M[#K_MotoreInt].Out.ActPosPiuStop := "Motore".M[#K_MotoreInt].Out.ActPos - #SpazioBassa;
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].Prm.Mech.EndLess THEN
	                IF "Motore".M[#K_MotoreInt].Out.ActPosPiuStop < "Motore".M[#K_MotoreInt].Prm.Enc.ModuloNegEnc THEN
	                    "Motore".M[#K_MotoreInt].Out.ActPosPiuStop += #RicircoloTotale;
	                END_IF;
	                IF "Motore".M[#K_MotoreInt].Out.ActPosPiuStop > "Motore".M[#K_MotoreInt].Prm.Enc.ModuloPosEnc THEN
	                    "Motore".M[#K_MotoreInt].Out.ActPosPiuStop -= #RicircoloTotale;
	                END_IF;
	            END_IF;
	        ELSE
	            "Motore".M[#K_MotoreInt].Out.ActPosPiuStop := "Motore".M[#K_MotoreInt].Out.ActPos;
	            "Motore".M[#K_MotoreInt].Out.SpazioStop := 0;
	        END_IF;
	    END_REGION ;
	REGION Delay brake
	    REGION Ritrado Aggancio/Sgancio Freno
	        IF "Motore".M[#K_MotoreInt].Prm.FrenoPresente THEN
	            IF "Motore".M[#K_MotoreInt].Prm.FBKFrenoPresente THEN
	                "Motore".M[#K_MotoreInt].Dati.StatoFreno := "Motore".M[#K_MotoreInt].In.FrenoSganciato;
	            ELSE
	                "Motore".M[#K_MotoreInt].Dati.StatoFreno := "Motore".M[#K_MotoreInt].Out.CmdFreno;
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].Dati.StatoFreno THEN
	                "Motore".M[#K_MotoreInt].Dati.ContAggancioFreno := 0;
	                "Motore".M[#K_MotoreInt].Dati.RitAggancioFreno := false;
	                IF NOT "Motore".M[#K_MotoreInt].Out.RitSgancioFreno THEN
	                    "Motore".M[#K_MotoreInt].Out.RitSgancioFreno := "Motore".M[#K_MotoreInt].Dati.ContSgancioFreno >= "Motore".M[#K_MotoreInt].Prm.TSgancioFreno;
	                    "Motore".M[#K_MotoreInt].Dati.ContSgancioFreno += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                END_IF;
	            ELSE
	                "Motore".M[#K_MotoreInt].Dati.ContSgancioFreno := 0;
	                "Motore".M[#K_MotoreInt].Out.RitSgancioFreno := false;
	                IF NOT "Motore".M[#K_MotoreInt].Dati.RitAggancioFreno THEN
	                    "Motore".M[#K_MotoreInt].Dati.RitAggancioFreno := "Motore".M[#K_MotoreInt].Dati.ContAggancioFreno >= "Motore".M[#K_MotoreInt].Prm.TAggancioFreno;
	                    "Motore".M[#K_MotoreInt].Dati.ContAggancioFreno += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                END_IF;
	            END_IF;
	        ELSE
	            "Motore".M[#K_MotoreInt].Out.RitSgancioFreno := "Motore".M[#K_MotoreInt].Out.CmdFreno;
	            "Motore".M[#K_MotoreInt].Dati.RitAggancioFreno := NOT "Motore".M[#K_MotoreInt].Out.RitSgancioFreno;
	        END_IF;
	    END_REGION
	    REGION Premagnetizzazione
	        IF "Motore".M[#K_MotoreInt].Dati.MotoreFermo THEN
	            "Motore".M[#K_MotoreInt].Prm.C.ContPrema := 0;
	            "Motore".M[#K_MotoreInt].Out.PremaOK := false;
	        ELSIF NOT "Motore".M[#K_MotoreInt].Out.PremaOK THEN
	            IF "Motore".M[#K_MotoreInt].Prm.VelPrema <= 0 OR "Motore".M[#K_MotoreInt].Prm.VelPrema > #VeloFrenoDir THEN
	                "Motore".M[#K_MotoreInt].Prm.VelPrema := #VeloFrenoDir;
	            END_IF;
	            "Motore".M[#K_MotoreInt].Prm.C.ContPrema += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	            "Motore".M[#K_MotoreInt].Out.PremaOK := "Motore".M[#K_MotoreInt].Prm.C.ContPrema > "Motore".M[#K_MotoreInt].Prm.TPrema;
	        END_IF;
	    END_REGION
	    
	    IF "Motore".M[#K_MotoreInt].Out.PremaOK AND "Motore".M[#K_MotoreInt].Out.RitSgancioFreno AND #UnaDirezioneRichiesta THEN
	        "Motore".M[#K_MotoreInt].Out.InMarcia := true;
	    ELSIF "Motore".M[#K_MotoreInt].Dati.RitAggancioFreno THEN
	        "Motore".M[#K_MotoreInt].Out.InMarcia := false;
	    END_IF;
	    REGION TimeOut Premagnetizzazione
	        IF "Motore".M[#K_MotoreInt].In.Premagnetizza AND NOT "Motore".M[#K_MotoreInt].Out.InMarcia THEN
	            IF NOT "Zona".Z[#K_ZonaInt].Out.Auto OR NOT "Zona".Z[#K_Zona].Out.CentralinaOk OR "Motore".M[#K_MotoreInt].Out.Allarme OR "Motore".M[#K_MotoreInt].In.DriverFault THEN
	                "Motore".M[#K_MotoreInt].In.Premagnetizza := "Motore".M[#K_MotoreInt].In.PremagnetizzaPos := "Motore".M[#K_MotoreInt].In.PremagnetizzaNeg := false;
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].Prm.VelPrema <> 1 THEN
	                "Motore".M[#K_MotoreInt].Prm.PremaNoFreno := false;
	            END_IF;
	            "Motore".M[#K_MotoreInt].Prm.TOutPrema := MAX(IN1 := "Motore".M[#K_MotoreInt].Prm.TOutPrema, IN2 := "Motore".M[#K_MotoreInt].Prm.TPrema + 50);
	            IF NOT "Motore".M[#K_MotoreInt].Out.InMarcia THEN
	                "Motore".M[#K_MotoreInt].Out.TOUTPrema := "Motore".M[#K_MotoreInt].Dati.ContTimeOutPrema > "Motore".M[#K_MotoreInt].Prm.TOutPrema;
	                IF NOT "Motore".M[#K_MotoreInt].Out.TOUTPrema THEN
	                    "Motore".M[#K_MotoreInt].Dati.ContTimeOutPrema += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                END_IF;
	            ELSE
	                "Motore".M[#K_MotoreInt].Dati.ContTimeOutPrema := 0;
	            END_IF;
	        ELSE
	            "Motore".M[#K_MotoreInt].Dati.ContTimeOutPrema := 0;
	            "Motore".M[#K_MotoreInt].Out.TOUTPrema := false;
	        END_IF;
	    END_REGION
	END_REGION ;
	REGION Request speed and brake command
	    #ReqStop := NOT #UnaDirezioneRichiesta;
	    IF (#ReqDirPos AND "Motore".M[#K_MotoreInt].Dati.ActVelNeg) OR (#ReqDirNeg AND "Motore".M[#K_MotoreInt].Dati.ActVelPos) THEN
	        #ReqStop := true;
	        "Motore".M[#K_MotoreInt].Dati.ContAbilAccDopoCambioDir := "Motore".M[#K_MotoreInt].Prm.TReazioneSistema;
	    ELSIF "Motore".M[#K_MotoreInt].Dati.ContAbilAccDopoCambioDir > 0 THEN
	        "Motore".M[#K_MotoreInt].Dati.ContAbilAccDopoCambioDir -= REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	    END_IF;
	    IF NOT #ReqStop AND NOT #ReqDecStop THEN
	        IF NOT "Motore".M[#K_MotoreInt].Out.PremaOK AND NOT "Motore".M[#K_MotoreInt].Out.InMarcia THEN
	            "Motore".M[#K_MotoreInt].Dati.VeloMinConv := DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.VelPrema);
	        ELSE
	            "Motore".M[#K_MotoreInt].Dati.VeloMinConv := DINT_TO_REAL(#VeloFrenoDir);
	        END_IF;
	        IF NOT "Motore".M[#K_MotoreInt].Out.InMarcia THEN
	            "Motore".M[#K_MotoreInt].Dati.ReqVelConv := "Motore".M[#K_MotoreInt].Dati.VeloMinConv;
	        ELSIF #ReqDecBassa THEN
	            "Motore".M[#K_MotoreInt].Dati.ReqVelConv := #VeloBassaConv;
	        ELSIF NOT #ReqCambioVel THEN
	            "Motore".M[#K_MotoreInt].Dati.ReqVelConv := DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.VeloRichPerc);
	        ELSE
	            "Motore".M[#K_MotoreInt].Dati.ReqVelConv := DINT_TO_REAL(MIN(IN1 := "Motore".M[#K_MotoreInt].Dati.VeloDopoCambioRich, IN2 := "Motore".M[#K_MotoreInt].Dati.VeloRichPerc));
	        END_IF;
	        "Motore".M[#K_MotoreInt].Out.FaseDec := "Motore".M[#K_MotoreInt].Dati.ReqVelConv < "Motore".M[#K_MotoreInt].Out.VelAss;
	    ELSE
	        "Motore".M[#K_MotoreInt].Out.FaseDec := TRUE;
	    END_IF;
	    IF NOT "Motore".M[#K_MotoreInt].Out.FaseDec THEN
	        "Motore".M[#K_MotoreInt].Out.FaseAcc := NOT #BloccaAcc AND "Motore".M[#K_MotoreInt].Dati.ReqVelConv > "Motore".M[#K_MotoreInt].Out.VelAss AND "Motore".M[#K_MotoreInt].Dati.ContAbilAccDopoCambioDir <= 0;
	        IF "Motore".M[#K_MotoreInt].Out.FaseAcc THEN
	            // Calcolo Accelerazione
	            "Motore".M[#K_MotoreInt].Out.VelAss += DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.AccRichPerc) * INT_TO_REAL(REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r / 1000.0));
	            "Motore".M[#K_MotoreInt].Out.VelAss := LIMIT(MN := "Motore".M[#K_MotoreInt].Dati.VeloMinConv, IN := "Motore".M[#K_MotoreInt].Out.VelAss, MX := "Motore".M[#K_MotoreInt].Dati.ReqVelConv);
	        END_IF;
	    ELSE
	        "Motore".M[#K_MotoreInt].Out.FaseAcc := false;
	        // Calcolo Decelerazione
	        IF NOT "Motore".M[#K_MotoreInt].Dati.MotoreFermo THEN
	            (* Seleziono la Decelerazione con cui devo lavorare *)
	            IF NOT "Motore".M[#K_MotoreInt].Out.Pronto THEN
	                #DecActRich := "Motore".M[#K_MotoreInt].Dati.DecReqEmergInLavo;
	            ELSIF "Motore".M[#K_MotoreInt].Out.VelAss > #VeloBassaConv THEN
	                #DecActRich := "Motore".M[#K_MotoreInt].Dati.DecReqInLavo;
	            ELSE
	                #DecActRich := "Motore".M[#K_MotoreInt].Dati.DecReqFinaleInLavo;
	            END_IF;
	            "Motore".M[#K_MotoreInt].Out.VelAss -= DINT_TO_REAL(#DecActRich) * INT_TO_REAL(REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r / 1000.0));
	            "Motore".M[#K_MotoreInt].Out.VelAss := MAX(IN1 := "Motore".M[#K_MotoreInt].Dati.VeloMinConv, IN2 := "Motore".M[#K_MotoreInt].Out.VelAss);
	            // Forzo l'arresto se sono in zona di arresto
	            IF #ReqStop AND "Motore".M[#K_MotoreInt].Out.VelAss <= "Motore".M[#K_MotoreInt].Dati.VeloMinConv THEN
	                IF "Motore".M[#K_MotoreInt].Prm.CambioDirNoFreno THEN
	                    IF "Motore".M[#K_MotoreInt].Dati.ActVelPos AND #ReqDirNeg THEN
	                        "Motore".M[#K_MotoreInt].Dati.ActVelPos := false;
	                        "Motore".M[#K_MotoreInt].Dati.ActVelNeg := true;
	                        #ReqStop := false;
	                        "Motore".M[#K_MotoreInt].Dati.CambioDirezioneAlVolo := true;
	                    ELSIF "Motore".M[#K_MotoreInt].Dati.ActVelNeg AND #ReqDirPos THEN
	                        "Motore".M[#K_MotoreInt].Dati.ActVelPos := true;
	                        "Motore".M[#K_MotoreInt].Dati.ActVelNeg := false;
	                        #ReqStop := false;
	                        "Motore".M[#K_MotoreInt].Dati.CambioDirezioneAlVolo := true;
	                    ELSE
	                        "Motore".M[#K_MotoreInt].Dati.CambioDirezioneAlVolo := false;
	                    END_IF;
	                END_IF;
	                IF NOT "Motore".M[#K_MotoreInt].Dati.CambioDirezioneAlVolo THEN
	                    IF "Motore".M[#K_MotoreInt].Dati.RitAggancioFreno OR "Motore".M[#K_MotoreInt].Allarmi.Freno OR "Motore".M[#K_MotoreInt].Allarmi.Freno2 THEN
	                        "Motore".M[#K_MotoreInt].Out.VelAss := 0.0;
	                    ELSE
	                        "Motore".M[#K_MotoreInt].Out.VelAss := DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.VelPrema);
	                    END_IF;
	                END_IF;
	            END_IF;
	        END_IF;
	    END_IF;
	    REGION Gestione Direzione Del Movimento    
	        IF "Motore".M[#K_MotoreInt].Dati.MotoreFermo AND #ReqDirPos OR "Motore".M[#K_MotoreInt].Dati.ActVelPos THEN
	            "Motore".M[#K_MotoreInt].Out.Vel := "Motore".M[#K_MotoreInt].Out.VelAss;
	        ELSIF "Motore".M[#K_MotoreInt].Dati.MotoreFermo AND #ReqDirNeg OR "Motore".M[#K_MotoreInt].Dati.ActVelNeg THEN
	            "Motore".M[#K_MotoreInt].Out.Vel := - "Motore".M[#K_MotoreInt].Out.VelAss;
	        END_IF;
	    END_REGION
	    REGION Velo Premagnetizzazione
	        IF NOT "Motore".M[#K_MotoreInt].Out.InMarcia THEN
	            IF "Motore".M[#K_MotoreInt].In.Premagnetizza THEN
	                IF NOT "Motore".M[#K_MotoreInt].Out.TOUTPrema AND NOT #UnaDirezioneRichiesta THEN
	                    IF "Motore".M[#K_MotoreInt].In.PremagnetizzaPos THEN
	                        "Motore".M[#K_MotoreInt].Out.VelAss := DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.VelPrema);
	                        "Motore".M[#K_MotoreInt].Out.Vel := "Motore".M[#K_MotoreInt].Out.VelAss;
	                    ELSIF "Motore".M[#K_MotoreInt].In.PremagnetizzaNeg THEN
	                        "Motore".M[#K_MotoreInt].Out.VelAss := DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.VelPrema);
	                        "Motore".M[#K_MotoreInt].Out.Vel := - "Motore".M[#K_MotoreInt].Out.VelAss;
	                    ELSIF "Motore".M[#K_MotoreInt].Out.RichMovPos THEN
	                        "Motore".M[#K_MotoreInt].Out.VelAss := DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.VelPrema);
	                        "Motore".M[#K_MotoreInt].Out.Vel := "Motore".M[#K_MotoreInt].Out.VelAss;
	                    ELSIF "Motore".M[#K_MotoreInt].Out.RichMovNeg THEN
	                        "Motore".M[#K_MotoreInt].Out.VelAss := DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.VelPrema);
	                        "Motore".M[#K_MotoreInt].Out.Vel := - "Motore".M[#K_MotoreInt].Out.VelAss;
	                    END_IF;
	                END_IF;
	            END_IF;
	        END_IF;
	    END_REGION
	    REGION Controllo Direzione Motore
	        IF "Motore".M[#K_MotoreInt].Out.Vel > 0.0 THEN
	            "Motore".M[#K_MotoreInt].Dati.ActVelPos := TRUE;
	            "Motore".M[#K_MotoreInt].Dati.ActVelNeg := FALSE;
	            "Motore".M[#K_MotoreInt].Dati.MotoreFermo := FALSE;
	        ELSIF "Motore".M[#K_MotoreInt].Out.Vel < 0.0 THEN
	            "Motore".M[#K_MotoreInt].Dati.ActVelPos := FALSE;
	            "Motore".M[#K_MotoreInt].Dati.ActVelNeg := TRUE;
	            "Motore".M[#K_MotoreInt].Dati.MotoreFermo := FALSE;
	        ELSE
	            "Motore".M[#K_MotoreInt].Dati.ActVelPos := FALSE;
	            "Motore".M[#K_MotoreInt].Dati.ActVelNeg := FALSE;
	            "Motore".M[#K_MotoreInt].Dati.MotoreFermo := TRUE;
	        END_IF;
	        IF NOT "Motore".M[#K_MotoreInt].Prm.Mech.Direction THEN
	            "Motore".M[#K_MotoreInt].Out.CmdPosMotore := "Motore".M[#K_MotoreInt].Dati.ActVelPos;
	            "Motore".M[#K_MotoreInt].Out.CmdNegMotore := "Motore".M[#K_MotoreInt].Dati.ActVelNeg;
	        ELSE
	            "Motore".M[#K_MotoreInt].Out.CmdPosMotore := "Motore".M[#K_MotoreInt].Dati.ActVelNeg;
	            "Motore".M[#K_MotoreInt].Out.CmdNegMotore := "Motore".M[#K_MotoreInt].Dati.ActVelPos;
	        END_IF;
	        IF "Motore".M[#K_MotoreInt].Out.InMarcia THEN
	            "Motore".M[#K_MotoreInt].Out.ActDirPos := "Motore".M[#K_MotoreInt].Dati.ActVelPos;
	            "Motore".M[#K_MotoreInt].Out.ActDirNeg := "Motore".M[#K_MotoreInt].Dati.ActVelNeg;
	        ELSE
	            "Motore".M[#K_MotoreInt].Out.ActDirNeg := "Motore".M[#K_MotoreInt].Out.ActDirPos := false;
	        END_IF;
	    END_REGION
	    REGION GestioneFreno
	        IF #UnaDirezioneRichiesta AND "Motore".M[#K_MotoreInt].Out.PremaOK OR "Motore".M[#K_MotoreInt].Out.InMarcia THEN
	            #RichCmdFreno := (NOT #ReqStop AND "Motore".M[#K_MotoreInt].Out.VelAss = "Motore".M[#K_MotoreInt].Dati.VeloMinConv OR "Motore".M[#K_MotoreInt].Out.VelAss > "Motore".M[#K_MotoreInt].Dati.VeloMinConv);
	        ELSE
	            IF "Motore".M[#K_MotoreInt].Prm.PremaNoFreno THEN
	                #RichCmdFreno := "Motore".M[#K_MotoreInt].Out.PremaOK AND NOT "Motore".M[#K_MotoreInt].Out.TOUTPrema AND "Motore".M[#K_MotoreInt].Out.VelAss = 1.0;
	            ELSE
	                #RichCmdFreno := false;
	            END_IF;
	        END_IF;
	        IF #RichCmdFreno THEN
	            REGION Tempo Off Inverter Pronto    
	                IF "Motore".M[#K_MotoreInt].In.MotoreRun AND "Motore".M[#K_MotoreInt].Out.CmdFreno THEN
	                    "Motore".M[#K_MotoreInt].Dati.TOffInverterStatus := true;
	                    "Motore".M[#K_MotoreInt].Dati.ContTOffInverterStatus := 250;
	                ELSIF "Motore".M[#K_MotoreInt].Dati.TOffInverterStatus THEN
	                    "Motore".M[#K_MotoreInt].Dati.ContTOffInverterStatus -= REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                    "Motore".M[#K_MotoreInt].Dati.TOffInverterStatus := "Motore".M[#K_MotoreInt].Dati.ContTOffInverterStatus > 0;
	                END_IF;
	            END_REGION
	            "Motore".M[#K_MotoreInt].Out.CmdFreno := ("Motore".M[#K_MotoreInt].Out.Pronto AND "Motore".M[#K_MotoreInt].Dati.TOffInverterStatus OR "Motore".M[#K_MotoreInt].In.MotoreRun) AND ("Motore".M[#K_MotoreInt].Dati.ActVelPos OR "Motore".M[#K_MotoreInt].Dati.ActVelNeg);
	        ELSE
	            "Motore".M[#K_MotoreInt].Out.CmdFreno := FALSE;
	        END_IF;
	    END_REGION
	END_REGION ;
	REGION Allarms, siren, lamp
	    REGION Controllo Allarmi Presenti    
	        IF "Motore".M[#K_MotoreInt].Allarmi.Freno2 OR
	            "Motore".M[#K_MotoreInt].Allarmi.EncMismatch THEN
	            "Motore".M[#K_MotoreInt].Out.DisContattori := true;
	            "Motore".M[#K_MotoreInt].Out.Allarme := true;
	        ELSE
	            "Motore".M[#K_MotoreInt].Out.DisContattori := false;
	            IF "Motore".M[#K_MotoreInt].Allarmi.TOutMarcia OR
	                "Motore".M[#K_MotoreInt].Allarmi.Freno OR
	                "Motore".M[#K_MotoreInt].Allarmi.ConteggioEnc OR
	                "Motore".M[#K_MotoreInt].Allarmi.Bloccato OR
	                "Motore".M[#K_MotoreInt].Allarmi.TroppoVeloce OR
	                "Motore".M[#K_MotoreInt].Allarmi.FolError OR
	                "Motore".M[#K_MotoreInt].Allarmi.Direzione OR
	                "Motore".M[#K_MotoreInt].Allarmi.TOUTMovimento OR
	                "Motore".M[#K_MotoreInt].Allarmi.TOUT_Azzeramento OR
	                "Motore".M[#K_MotoreInt].Allarmi.SezAperto OR
	                "Motore".M[#K_MotoreInt].Allarmi.InverterFault OR
	                "Motore".M[#K_MotoreInt].Allarmi.ComunInverter OR
	                "Motore".M[#K_MotoreInt].Allarmi.ComunEncoder OR
	                "Motore".M[#K_MotoreInt].Allarmi.TermicoVentola OR
	                "Motore".M[#K_MotoreInt].Allarmi.RotturaCinghia OR
	                "Motore".M[#K_MotoreInt].Allarmi.TimeOutAnticaduta OR
	                "Motore".M[#K_MotoreInt].Allarmi.SpinaSicNoInPos
	            THEN
	                "Motore".M[#K_MotoreInt].Out.Allarme := true;
	            ELSE
	                "Motore".M[#K_MotoreInt].Out.Allarme := false;
	            END_IF;
	        END_IF;
	    END_REGION
	    REGION Gestione del reset, Lampada e Sirena    
	        IF "Zona".Z[#K_ZonaInt].Gen.Reset THEN
	            IF "Motore".M[#K_MotoreInt].Allarmi.EncMismatch THEN
	                "Motore".M[#K_MotoreInt].Dati.PosizioneAlloStop := "Motore".M[#K_MotoreInt].Out.ActPos;
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].Allarmi.Direzione THEN
	                "Motore".M[#K_MotoreInt].Dati.MemoCheckInversione := 0;
	            END_IF;
	            "Motore".M[#K_MotoreInt].Allarmi.TOutMarcia := false;
	            "Motore".M[#K_MotoreInt].Allarmi.Freno := false;
	            "Motore".M[#K_MotoreInt].Allarmi.Freno2 := false;
	            "Motore".M[#K_MotoreInt].Allarmi.ConteggioEnc := false;
	            "Motore".M[#K_MotoreInt].Allarmi.FolError := false;
	            "Motore".M[#K_MotoreInt].Allarmi.Bloccato := false;
	            "Motore".M[#K_MotoreInt].Allarmi.TroppoVeloce := false;
	            "Motore".M[#K_MotoreInt].Allarmi.Direzione := false;
	            "Motore".M[#K_MotoreInt].Allarmi.EncMismatch := false;
	            "Motore".M[#K_MotoreInt].Allarmi.TOUTMovimento := false;
	            "Motore".M[#K_MotoreInt].Allarmi.TOUT_Azzeramento := false;
	            "Motore".M[#K_MotoreInt].Allarmi.InverterFault := false;
	            "Motore".M[#K_MotoreInt].Allarmi.ComunInverter := false;
	            "Motore".M[#K_MotoreInt].Allarmi.ComunEncoder := false;
	            "Motore".M[#K_MotoreInt].Allarmi.TermicoVentola := false;
	            "Motore".M[#K_MotoreInt].Allarmi.RotturaCinghia := false;
	            "Motore".M[#K_MotoreInt].Allarmi.TimeOutAnticaduta := false;
	            "Motore".M[#K_MotoreInt].Allarmi.SpinaSicNoInPos := false;
	        END_IF;
	    END_REGION ;
	    REGION TimeOut Marcia Motore
	        IF NOT "Motore".M[#K_MotoreInt].Dati.MotoreFermo AND NOT "Motore".M[#K_MotoreInt].In.MotoreRun AND NOT "Motore".M[#K_MotoreInt].Allarmi.TOutMarcia AND NOT "Motore".M[#K_MotoreInt].In.DriverFault THEN
	            "Motore".M[#K_MotoreInt].Dati.ContTimeOutInverter += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	            IF "Motore".M[#K_MotoreInt].Dati.ContTimeOutInverter > 500 THEN
	                "Motore".M[#K_MotoreInt].Allarmi.TOutMarcia := true;
	            END_IF;
	        ELSE
	            "Motore".M[#K_MotoreInt].Dati.ContTimeOutInverter := 0;
	        END_IF;
	        
	    END_REGION
	    REGION Allarmi Freno
	        IF "Motore".M[#K_MotoreInt].Prm.FrenoPresente THEN
	            IF "Motore".M[#K_MotoreInt].Prm.FBKFrenoPresente THEN
	                REGION Gestione del Time Out Freno 1 (Rilascio)
	                    IF "Motore".M[#K_MotoreInt].Out.CmdFreno AND NOT "Motore".M[#K_MotoreInt].Dati.StatoFreno AND NOT "Motore".M[#K_MotoreInt].Allarmi.Freno THEN
	                        "Motore".M[#K_MotoreInt].Dati.ContTimeOutFreno1 += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                        "Motore".M[#K_MotoreInt].Allarmi.Freno := "Motore".M[#K_MotoreInt].Dati.ContTimeOutFreno1 > 500;
	                    ELSE
	                        "Motore".M[#K_MotoreInt].Dati.ContTimeOutFreno1 := 0;
	                    END_IF;
	                END_REGION
	                REGION Gestione del Time Out Freno 2 (Aggancio)
	                    // Statement section REGION
	                    IF NOT "Motore".M[#K_MotoreInt].Out.CmdFreno THEN
	                        IF "Motore".M[#K_MotoreInt].Dati.ContTimeOutFreno2 < 150 THEN
	                            "Motore".M[#K_MotoreInt].Dati.ContTimeOutFreno2 += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                        ELSIF "Motore".M[#K_MotoreInt].Dati.StatoFreno THEN
	                            "Motore".M[#K_MotoreInt].Allarmi.Freno2 := TRUE;
	                        END_IF;
	                    ELSE
	                        "Motore".M[#K_MotoreInt].Dati.ContTimeOutFreno2 := 0;
	                    END_IF;
	                END_REGION
	            END_IF;
	        END_IF;
	    END_REGION
	    REGION AllarmiEncoder
	        IF NOT "Motore".M[#K_MotoreInt].Prm.Enc.EncoderLess THEN
	            REGION Aggiornamento Stati Con Motore Fermo
	                IF NOT "Motore".M[#K_MotoreInt].Out.InMarcia OR "Motore".M[#K_MotoreInt].Dati.CambioDirezioneAlVolo THEN
	                    "Motore".M[#K_MotoreInt].Dati.CambioDirezioneAlVolo := false;
	                    "Motore".M[#K_MotoreInt].Dati.TrgPosDint := "Motore".M[#K_MotoreInt].Dati.OldTrgPosDint := "Motore".M[#K_MotoreInt].Out.ActPos;
	                    "Motore".M[#K_MotoreInt].Prm.C.TrgPos := "Motore".M[#K_MotoreInt].Prm.C.EncPos;
	                    "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioTarget := "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioEncoder := 0;
	                    "Motore".M[#K_MotoreInt].Dati.ContCheckFollowError := 0;
	                END_IF;
	            END_REGION
	            REGION Allarme conteggio Encoder
	                // Se lo spazio percorso nell'ultimo ciclo programma dell'encoder Ã¨ 20 volte superiore 
	                // Allo spazio teorico per la velocitÃ  richiesta
	                IF NOT #REQSetup THEN
	                    IF "Motore".M[#K_MotoreInt].Out.SpazioCicloEnc > "Motore".M[#K_MotoreInt].Prm.C.VelMax * REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r) / 50 THEN
	                        "Motore".M[#K_MotoreInt].Allarmi.ConteggioEnc := true;
	                    END_IF;
	                END_IF;
	            END_REGION
	            REGION Allarme d'inseguimento            
	                #AppoMoltPrecisione := "Motore".M[#K_MotoreInt].Prm.Precisione * 10;
	                IF "Motore".M[#K_MotoreInt].Out.InMarcia AND NOT "Motore".M[#K_MotoreInt].Allarmi.FolError AND NOT "Motore".M[#K_MotoreInt].Allarmi.Bloccato AND NOT "Motore".M[#K_MotoreInt].Allarmi.TroppoVeloce THEN
	                    "Motore".M[#K_MotoreInt].Out.FollowingError := "Motore".M[#K_MotoreInt].Out.ActPos - "Motore".M[#K_MotoreInt].Dati.TrgPosDint;
	                    IF "Motore".M[#K_MotoreInt].Dati.ContCheckFollowError > 500 THEN
	                        "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioTarget := ABS("Motore".M[#K_MotoreInt].Dati.ChFol_SpazioTarget);
	                        IF "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioTarget > #AppoMoltPrecisione THEN
	                            "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioEncoder := ABS("Motore".M[#K_MotoreInt].Dati.ChFol_SpazioEncoder);
	                            IF "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioEncoder / 5 > "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioTarget THEN
	                                "Motore".M[#K_MotoreInt].Allarmi.TroppoVeloce := true;
	                            ELSIF "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioEncoder * 5 < "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioTarget THEN
	                                IF NOT "Motore".M[#K_MotoreInt].Dati.MotorStop THEN
	                                    IF "Motore".M[#K_MotoreInt].Dati.AlmBloccato_Cont >= "NResetBloccato" THEN
	                                        "Motore".M[#K_MotoreInt].Allarmi.Bloccato := true;
	                                    ELSE
	                                        "Motore".M[#K_MotoreInt].Dati.AlmBloccato_Cont += 1;
	                                        "Motore".M[#K_MotoreInt].Dati.MotorStop := true;
	                                    END_IF;
	                                END_IF;
	                            END_IF;
	                        END_IF;
	                        "Motore".M[#K_MotoreInt].Dati.ContCheckFollowError := 0;
	                        "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioEncoder := "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioTarget := 0;
	                    ELSE
	                        "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioEncoder += "Motore".M[#K_MotoreInt].Out.SpazioCicloEnc;
	                        "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioTarget += "Motore".M[#K_MotoreInt].Dati.TrgPosDint - "Motore".M[#K_MotoreInt].Dati.OldTrgPosDint;
	                        "Motore".M[#K_MotoreInt].Dati.ContCheckFollowError += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                    END_IF;
	                    "Motore".M[#K_MotoreInt].Dati.OldTrgPosDint := "Motore".M[#K_MotoreInt].Dati.TrgPosDint;
	                    IF "Motore".M[#K_MotoreInt].Prm.FollowingLimit > 0 AND NOT "Motore".M[#K_MotoreInt].Prm.Mech.EndLess THEN
	                        IF ABS("Motore".M[#K_MotoreInt].Out.FollowingError) > "Motore".M[#K_MotoreInt].Prm.FollowingLimit THEN
	                            "Motore".M[#K_MotoreInt].Allarmi.FolError := true;
	                        END_IF;
	                    END_IF;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Dati.ContCheckFollowError := 0;
	                    "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioEncoder := "Motore".M[#K_MotoreInt].Dati.ChFol_SpazioTarget := 0;
	                END_IF;
	            END_REGION
	            REGION Allarme direzione inversione
	                IF NOT "Motore".M[#K_MotoreInt].Allarmi.Direzione THEN
	                    IF "Motore".M[#K_MotoreInt].Out.ActDirPos THEN
	                        "Motore".M[#K_MotoreInt].Dati.MemoCheckInversione += "Motore".M[#K_MotoreInt].Out.SpazioCicloEnc;
	                        IF "Motore".M[#K_MotoreInt].Dati.MemoCheckInversione > 0 THEN
	                            "Motore".M[#K_MotoreInt].Dati.MemoCheckInversione := 0;
	                        END_IF;
	                        IF "Motore".M[#K_MotoreInt].Dati.MemoCheckInversione < - #AppoMoltPrecisione THEN
	                            "Motore".M[#K_MotoreInt].Allarmi.Direzione := true;
	                        END_IF;
	                    ELSIF "Motore".M[#K_MotoreInt].Out.ActDirNeg THEN
	                        "Motore".M[#K_MotoreInt].Dati.MemoCheckInversione += "Motore".M[#K_MotoreInt].Out.SpazioCicloEnc;
	                        IF "Motore".M[#K_MotoreInt].Dati.MemoCheckInversione < 0 THEN
	                            "Motore".M[#K_MotoreInt].Dati.MemoCheckInversione := 0;
	                        END_IF;
	                        IF "Motore".M[#K_MotoreInt].Dati.MemoCheckInversione > #AppoMoltPrecisione THEN
	                            "Motore".M[#K_MotoreInt].Allarmi.Direzione := true;
	                        END_IF;
	                    ELSE
	                        "Motore".M[#K_MotoreInt].Dati.MemoCheckInversione := 0;
	                    END_IF;
	                END_IF;
	            END_REGION
	            REGION Allarme Encoder Mismatch
	                // L'allarme viene generato tutte le volte che l'encoder conta 10 volte la precisione nella dirazione non aspettata.
	                IF "Motore".M[#K_MotoreInt].Dati.MotoreFermo AND "Motore".M[#K_MotoreInt].Dati.RitAggancioFreno THEN
	                    IF NOT "Motore".M[#K_MotoreInt].Dati.AppoImpMotoreFermo THEN
	                        "Motore".M[#K_MotoreInt].Dati.AppoImpMotoreFermo := true;
	                        "Motore".M[#K_MotoreInt].Dati.PosizioneAlloStop := "Motore".M[#K_MotoreInt].Out.ActPos;
	                    ELSIF ABS("Motore".M[#K_MotoreInt].Out.ActPos - "Motore".M[#K_MotoreInt].Dati.PosizioneAlloStop) > #AppoMoltPrecisione THEN
	                        "Motore".M[#K_MotoreInt].Allarmi.EncMismatch := true;
	                    END_IF;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Dati.AppoImpMotoreFermo := false;
	                END_IF;
	            END_REGION
	            REGION Time Out Movimento Motore
	                IF #FunzPositioning THEN
	                    IF NOT "Motore".M[#K_MotoreInt].Dati.AppoImpFunzPositioning THEN
	                        #ReqRicTempoProfilo := true;
	                    ELSIF #ReqCambioVel AND NOT "Motore".M[#K_MotoreInt].Dati.AppoImpCaVelPunto THEN
	                        #ReqRicTempoProfilo := true;
	                    ELSE
	                        #ReqRicTempoProfilo := #CambioReqAcc OR #CambioReqDec OR #CambioReqVel OR #REQSetup OR "Motore".M[#K_MotoreInt].Out.TrgPosFiltrata <> "Motore".M[#K_MotoreInt].Dati.TRG_OLD_POS_Select;
	                    END_IF;
	                    "Motore".M[#K_MotoreInt].Dati.AppoImpCaVelPunto := #ReqCambioVel;
	                    IF #ReqRicTempoProfilo THEN
	                        "Motore".M[#K_MotoreInt].Dati.TRG_OLD_POS_Select := "Motore".M[#K_MotoreInt].Out.TrgPosFiltrata;
	                        IF #ReqCambioVel THEN
	                            #VeloProfilo := "Motore".M[#K_MotoreInt].Dati.VeloDopoCambioRich;
	                        ELSE
	                            #VeloProfilo := "Motore".M[#K_MotoreInt].Dati.VeloRichPerc;
	                        END_IF;
	                        // Calcolo il tempo per la decelerazione
	                        IF #VeloProfilo > #VeloBassaConv THEN
	                            #TempoDec_Iniziale := (#VeloProfilo - #VeloBassaConv) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.DecReqInLavo);
	                        ELSE
	                            #TempoDec_Iniziale := 0.0;
	                        END_IF;
	                        // Tempo Decelerazione Finale
	                        #TempoDec_Finale := #VeloBassaConv / DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.DecReqFinaleInLavo);
	                        // Tempo accelerazione
	                        #TempoAcc := #VeloProfilo / DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.AccRichPerc);
	                        // Tempo a velocitÃ  fissa
	                        #TempoVFix := DINT_TO_REAL(#DistTRG_ASS) / #VeloProfilo;
	                        // Calcolo il tempo rimanente per l'esecuzione del profilo
	                        "Motore".M[#K_MotoreInt].Out.TFineProfilo := TRUNC((#TempoDec_Iniziale + #TempoDec_Finale + #TempoAcc + #TempoVFix) * 1000.0) + "Motore".M[#K_MotoreInt].Prm.TBassaVel + "Motore".M[#K_MotoreInt].Prm.TReazioneSistema;
	                        "Motore".M[#K_MotoreInt].Dati.ContTimeOutMovimento := 0;
	                        "Motore".M[#K_MotoreInt].Dati.TempoEsecuzioneProfilo := MAX(IN1 := "Motore".M[#K_MotoreInt].Out.TFineProfilo * 3, IN2 := 10000);
	                    END_IF;
	                    IF "Motore".M[#K_MotoreInt].Out.InMarcia THEN
	                        IF "Motore".M[#K_MotoreInt].Dati.ContTimeOutMovimento > "Motore".M[#K_MotoreInt].Dati.TempoEsecuzioneProfilo THEN
	                            "Motore".M[#K_MotoreInt].Allarmi.TOUTMovimento := true;
	                        ELSE
	                            "Motore".M[#K_MotoreInt].Dati.ContTimeOutMovimento += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                        END_IF;
	                    END_IF;
	                    "Motore".M[#K_MotoreInt].Dati.AppoImpFunzPositioning := true;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Dati.AppoImpFunzPositioning := false;
	                END_IF;
	            END_REGION
	        END_IF;
	    END_REGION
	    REGION Gestione del Time Out Ricerca Sensore Azzeramento
	        // Nel caso di una richiesta di esecuzione di SetUP sul sensore
	        IF #SetUpSuSensore THEN
	            IF #REQSetupPannello AND NOT "Motore".M[#K_MotoreInt].Dati.SetupSensoreTrovato AND ("Motore".M[#K_MotoreInt].Out.ActDirPos OR "Motore".M[#K_MotoreInt].Out.ActDirNeg) THEN
	                IF ("Motore".M[#K_MotoreInt].In.SensAzz AND "Motore".M[#K_MotoreInt].Dati.ContTimeOutAzzeramento > 5000) OR "Motore".M[#K_MotoreInt].Dati.ContTimeOutAzzeramento > 25000 THEN
	                    "Motore".M[#K_MotoreInt].Allarmi.TOUT_Azzeramento := TRUE;
	                END_IF;
	            ELSE
	                "Motore".M[#K_MotoreInt].Dati.ContTimeOutAzzeramento := 0;
	            END_IF;
	        ELSE
	            "Motore".M[#K_MotoreInt].Dati.ContTimeOutAzzeramento := 0;
	        END_IF;
	    END_REGION
	    REGION ALLARME: Time-Out Anticaduta
	        IF "Motore".M[#K_MotoreInt].Prm.AnticadutaPresente THEN
	            IF "Zona".Z[#K_Zona].Out.CentralinaOk THEN
	                "Motore".M[#K_MotoreInt].Prm.ByPassAnticaduta := false;
	            END_IF;
	            "Motore".M[#K_MotoreInt].Out.CmdAnticaduta := ("Motore".M[#K_MotoreInt].Out.InMarcia AND "Motore".M[#K_MotoreInt].Out.CmdAnticaduta OR "Zona".Z[#K_Zona].Out.CentralinaOk) AND NOT "Motore".M[#K_MotoreInt].Out.DisContattori AND NOT "Motore".M[#K_MotoreInt].In.CinghiaRotta;
	            IF "Motore".M[#K_MotoreInt].Out.CmdAnticaduta AND NOT "Motore".M[#K_MotoreInt].In.AnticadutaON (*OR
	            NOT "Motor".M[#MotorNumber].o.CmdAnticaduta AND NOT "Motor".M[#MotorNumber].i.AnticadutaOFF*)THEN
	                IF "Motore".M[#K_MotoreInt].Dati.ContTOutAnticaduta > 4000 THEN
	                    "Motore".M[#K_MotoreInt].Allarmi.TimeOutAnticaduta := true;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Dati.ContTOutAnticaduta += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                END_IF;
	            ELSE
	                "Motore".M[#K_MotoreInt].Dati.ContTOutAnticaduta := 0;
	            END_IF;
	        END_IF;
	    END_REGION
	    REGION Allarmi Generale Motore
	        "Motore".M[#K_MotoreInt].Allarmi.SezAperto := "Motore".M[#K_MotoreInt].In.SezAperto;
	        IF "Zona".Z[#K_Zona].Out.CentralinaOk THEN
	            IF "Motore".M[#K_MotoreInt].In.DriverFault THEN
	                IF NOT "Motore".M[#K_MotoreInt].Dati.AlmInv_ResetInverter THEN
	                    IF "Motore".M[#K_MotoreInt].Dati.AlmInv_Cont >= "NResetInverter" THEN
	                        "Motore".M[#K_MotoreInt].Allarmi.InverterFault := true;
	                    ELSE
	                        "Motore".M[#K_MotoreInt].Dati.AlmInv_ContStorico += 1;
	                        "Motore".M[#K_MotoreInt].Dati.AlmInv_Cont += 1;
	                        "Motore".M[#K_MotoreInt].Dati.AlmInv_StoricoCodici["Motore".M[#K_MotoreInt].Dati.AlmInv_ContStorico MOD 10] := "Motore".M[#K_MotoreInt].HMI.CodiceAllarme;
	                        "Motore".M[#K_MotoreInt].Dati.MotorStop := true;
	                        "Motore".M[#K_MotoreInt].Dati.AlmInv_ResetInverter := true;
	                        "Motore".M[#K_MotoreInt].Dati.AlmInv_ToutReset := 0;
	                    END_IF;
	                END_IF;
	            END_IF;
	            "Motore".M[#K_MotoreInt].Allarmi.InverterWarning := "Motore".M[#K_MotoreInt].In.DriverWarning;
	        END_IF;
	        IF "Motore".M[#K_MotoreInt].Dati.AlmInv_ResetInverter THEN
	            IF NOT "Motore".M[#K_MotoreInt].In.DriverFault THEN
	                "Motore".M[#K_MotoreInt].Dati.AlmInv_ResetInverter := false;
	            END_IF;
	            "Motore".M[#K_MotoreInt].Dati.AlmInv_ToutReset += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	            IF "Motore".M[#K_MotoreInt].Dati.AlmInv_ToutReset > 5000 THEN
	                "Motore".M[#K_MotoreInt].Dati.AlmInv_ResetInverter := false;
	                "Motore".M[#K_MotoreInt].Allarmi.InverterFault := true;
	            END_IF;
	        ELSE
	            "Motore".M[#K_MotoreInt].Dati.AlmInv_ToutReset := 0;
	        END_IF;
	        IF "Motore".M[#K_MotoreInt].In.NoComunInv THEN
	            "Motore".M[#K_MotoreInt].Allarmi.ComunInverter := true;
	        END_IF;
	        IF "Motore".M[#K_MotoreInt].In.NoComunEnc THEN
	            "Motore".M[#K_MotoreInt].Allarmi.ComunEncoder := true;
	        END_IF;
	        IF "Motore".M[#K_MotoreInt].In.TerVentolaOff THEN
	            "Motore".M[#K_MotoreInt].Allarmi.TermicoVentola := true;
	        END_IF;
	        IF "Motore".M[#K_MotoreInt].In.CinghiaRotta THEN
	            "Motore".M[#K_MotoreInt].Allarmi.RotturaCinghia := true;
	        END_IF;
	        IF "Motore".M[#K_MotoreInt].In.SpinaSicNoInPos THEN
	            "Motore".M[#K_MotoreInt].Allarmi.SpinaSicNoInPos := true;
	        END_IF;
	    END_REGION
	    REGION Allarme per HMI
	        REGION Scrittura Word allarmi HMI        
	            FOR #CounterAllarme := 1 TO "K_NumAllarmiPerMotori" DO
	                IF #CounterAllarme <= 16 THEN
	                    "GestAllarme_Std"(GestioneSirena := True,
	                                      Allarme := "Motore".M[#K_MotoreInt].Allarmi.A[#CounterAllarme],
	                                      NumAllarme := #CounterAllarme,
	                                      K_Zona := #K_ZonaInt,
	                                      WordHmi := "Motore".M[#K_MotoreInt].Allarmi.WordHmi_1);
	                ELSE
	                    "GestAllarme_Std"(GestioneSirena := True,
	                                      Allarme := "Motore".M[#K_MotoreInt].Allarmi.A[#CounterAllarme],
	                                      NumAllarme := #CounterAllarme - 16,
	                                      K_Zona := #K_ZonaInt,
	                                      WordHmi := "Motore".M[#K_MotoreInt].Allarmi.WordHmi_2);
	                END_IF;
	            END_FOR;
	        END_REGION ;
	    END_REGION
	    REGION Conteggi Manutenzione Preventiva
	        IF "Motore".M[#K_MotoreInt].Prm.AbiltManutenzionePrev THEN
	            IF NOT "Motore".M[#K_MotoreInt].Dati.MotoreFermo THEN
	                "Motore".M[#K_MotoreInt].Dati.MP.SpazioPercorso += ABS(IN := "Motore".M[#K_MotoreInt].Out.SpazioCicloEnc);
	                IF "Motore".M[#K_MotoreInt].Dati.MP.SpazioPercorso > 1000000 THEN
	                    "Motore".M[#K_MotoreInt].Dati.MP.MetriPercorsi += 1;
	                    "Motore".M[#K_MotoreInt].Dati.MP.SpazioPercorso -= 1000000;
	                END_IF;
	                "Motore".M[#K_MotoreInt].Dati.MP.TempoMovimento += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	                IF "Motore".M[#K_MotoreInt].Dati.MP.TempoMovimento > 60000 THEN
	                    "Motore".M[#K_MotoreInt].Dati.MP.MinutiLavorati += 1;
	                    "Motore".M[#K_MotoreInt].Dati.MP.TempoMovimento -= 60000;
	                END_IF;
	                IF NOT "Motore".M[#K_MotoreInt].Dati.MP.ImpMarcia THEN
	                    "Motore".M[#K_MotoreInt].Dati.MP.NAvviamenti += 1;
	                    "Motore".M[#K_MotoreInt].Dati.MP.ImpMarcia := true;
	                END_IF;
	            ELSE
	                "Motore".M[#K_MotoreInt].Dati.MP.ImpMarcia := false;
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].Out.CmdFreno AND NOT "Motore".M[#K_MotoreInt].Dati.MP.ImpFreno THEN
	                "Motore".M[#K_MotoreInt].Dati.MP.NSgancioFreno += 1;
	            END_IF;
	            "Motore".M[#K_MotoreInt].Dati.MP.ImpFreno := "Motore".M[#K_MotoreInt].Out.CmdFreno;
	        END_IF;
	    END_REGION
	    REGION StatoMotoreHMI
	        (* Stati Motore
	        0 = Fermo
	        1 = Disabilitato da Area Automatico
	        2 = In allarme
	        3 = Disabilitato per motivi interni    
	        4 = In premagnetizzazione con freno chiuso
	        5 = In premagnetizzazione con freno aperto
	        6 = In movimento positivo
	        7 = In movimento negativo
	        14 = In premagnetizzazione con freno chiuso con Allarme Attivo
	        15 = In premagnetizzazione con freno aperto con Allarme Attivo
	        16 = In movimento positivo con Allarme Attivo
	        17 = In movimento negativo con Allarme Attivo
	        20 = Dai Trasporti selezionato "Sempre fermo"
	        21 = Dai Trasporti selezionato "Sempre In Marcia Positivo"
	        22 = Dai Trasporti selezionato "Sempre In Marcia Negativo"
	        31 = Dai Trasporti selezionato "Sempre In Marcia Positivo" con Allarme Attivo
	        32 = Dai Trasporti selezionato "Sempre In Marcia Negativo" con Allarme Attivo
	        *)
	        IF "Motore".M[#K_MotoreInt].Out.ActDirPos THEN
	            IF "Motore".M[#K_MotoreInt].Out.Allarme THEN
	                "Motore".M[#K_MotoreInt].HMI.Stato := 21;
	            ELSE
	                "Motore".M[#K_MotoreInt].HMI.Stato := 6;
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].Out.Allarme THEN
	                "Motore".M[#K_MotoreInt].HMI.Stato += 10;
	            END_IF;
	        ELSIF "Motore".M[#K_MotoreInt].Out.ActDirNeg THEN
	            IF "Motore".M[#K_MotoreInt].Allarmi.A["KAllMot_22(Word1_x6)"].Stato THEN
	                "Motore".M[#K_MotoreInt].HMI.Stato := 22;
	            ELSE
	                "Motore".M[#K_MotoreInt].HMI.Stato := 7;
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].Out.Allarme THEN
	                "Motore".M[#K_MotoreInt].HMI.Stato += 10;
	            END_IF;
	        ELSIF NOT "Motore".M[#K_MotoreInt].Dati.MotoreFermo THEN
	            IF "Motore".M[#K_MotoreInt].Out.RitSgancioFreno THEN
	                "Motore".M[#K_MotoreInt].HMI.Stato := 5;
	            ELSE
	                "Motore".M[#K_MotoreInt].HMI.Stato := 4;
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].Out.Allarme THEN
	                "Motore".M[#K_MotoreInt].HMI.Stato += 10;
	            END_IF;
	        ELSIF "Motore".M[#K_MotoreInt].Out.Allarme THEN
	            "Motore".M[#K_MotoreInt].HMI.Stato := 2;
	        ELSIF NOT "Zona".Z[#K_Zona].Out.CentralinaOk THEN
	            "Motore".M[#K_MotoreInt].HMI.Stato := 1;
	        ELSIF NOT "Motore".M[#K_MotoreInt].Out.Pronto THEN
	            "Motore".M[#K_MotoreInt].HMI.Stato := 3;
	        ELSE
	            "Motore".M[#K_MotoreInt].HMI.Stato := 0;
	            IF "Motore".M[#K_MotoreInt].Allarmi.A["KAllMot_23(Word1_x7)"].Stato THEN
	                "Motore".M[#K_MotoreInt].HMI.Stato := 20;
	            END_IF;
	        END_IF;
	    END_REGION
	    REGION StatoComandoHMI
	        (* Stati Motore
	        0 = Nessuna Richiesta
	        1 = Richiesto Jog Positivo
	        2 = Richiesto Jog Negativo
	        3 = Richiesta Posizionamento Assoluto, motore giÃ  in posizione
	        4 = Richiesta Posizionamento Assoluto, motore dovrÃ  muoversi in direzione positiva
	        5 = Richiesta Posizionamento Assoluto, motore dovrÃ  muoversi in direzione negativa
	        6 = Richiesta Posizionamento Relativo, motore giÃ  in posizione
	        7 = Richiesta Posizionamento Relativo, motore dovrÃ  muoversi in direzione positiva
	        8 = Richiesta Posizionamento Relativo, motore dovrÃ  muoversi in direzione negativa
	        9 = Richiesta Premagnetizzazione Positiva
	        10= Richiesta Premagnetizzazione Negativa
	        *)
	        IF "Motore".M[#K_MotoreInt].In.CmdPosRich THEN
	            "Motore".M[#K_MotoreInt].HMI.ComandoRichiesto := 1;
	        ELSIF "Motore".M[#K_MotoreInt].In.CmdNegRich THEN
	            "Motore".M[#K_MotoreInt].HMI.ComandoRichiesto := 2;
	        ELSIF "Motore".M[#K_MotoreInt].In.Positioning THEN
	            IF "Motore".M[#K_MotoreInt].Out.RichMovPos THEN
	                "Motore".M[#K_MotoreInt].HMI.ComandoRichiesto := 4;
	            ELSIF "Motore".M[#K_MotoreInt].Out.RichMovNeg THEN
	                "Motore".M[#K_MotoreInt].HMI.ComandoRichiesto := 5;
	            ELSE
	                "Motore".M[#K_MotoreInt].HMI.ComandoRichiesto := 3;
	            END_IF;
	            IF "Motore".M[#K_MotoreInt].In.PosRelativo THEN
	                "Motore".M[#K_MotoreInt].HMI.ComandoRichiesto += 3;
	            END_IF;
	        ELSIF "Motore".M[#K_MotoreInt].In.Premagnetizza THEN
	            IF "Motore".M[#K_MotoreInt].In.PremagnetizzaPos THEN
	                "Motore".M[#K_MotoreInt].HMI.ComandoRichiesto := 9;
	            ELSIF "Motore".M[#K_MotoreInt].In.PremagnetizzaNeg THEN
	                "Motore".M[#K_MotoreInt].HMI.ComandoRichiesto := 10;
	            ELSIF "Motore".M[#K_MotoreInt].Out.RichMovPos THEN
	                "Motore".M[#K_MotoreInt].HMI.ComandoRichiesto := 9;
	            ELSIF "Motore".M[#K_MotoreInt].Out.RichMovNeg THEN
	                "Motore".M[#K_MotoreInt].HMI.ComandoRichiesto := 10;
	            END_IF;
	        ELSE
	            "Motore".M[#K_MotoreInt].HMI.ComandoRichiesto := 0;
	        END_IF;
	    END_REGION
	END_REGION ;
	REGION To inverter
	    CASE "Motore".M[#K_MotoreInt].HW.TipoCollInverter OF
	        0:
	            REGION Inverter Comandato in Analogica
	                "Motore".M[#K_MotoreInt].Out.Paw := DINT_TO_WORD(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.ValMaxRef)));
	            END_REGION ;
	        1:
	            REGION PN Mitsubishi
	                (* Struttura Control Word
	                Bit 00: Drive PO: Switch ON
	                Bit 01: Drive PO: Output Shutoff Release
	                Bit 02: Drive PO: Emergency Stop
	                Bit 03: Drive PO: Enable
	                Bit 04: Drive PO: Not Used
	                Bit 05: Drive PO: Set Frequency Not retained
	                Bit 06: Drive PO: Enble Set Point
	                Bit 07: Drive PO: Fault Ack
	                Bit 08: Drive PO: Not Used
	                Bit 09: Drive PO: Used
	                Bit 10: Drive PO: Comunication Enabled
	                Bit 11: Drive PO: Target Torque Enabled
	                Bit 12: Drive PO: Reverse Rotation
	                Bit 13: Drive PO: Not Used
	                Bit 14: Drive PO: Not Used
	                Bit 15: Drive PO: Not Used
	                *)
	                #PO_Mitsubishi.CTW := w#16#200;
	                #PO_Mitsubishi.CTW.%X0 := ("Motore".M[#K_MotoreInt].Out.CmdPosMotore OR "Motore".M[#K_MotoreInt].Out.CmdNegMotore) AND #PI_Mitsubishi.STW.%X0;
	                #PO_Mitsubishi.CTW.%X1 := #PO_Mitsubishi.CTW.%X2 := "Zona".Z[#K_Zona].Out.CentralinaOk;
	                #PO_Mitsubishi.CTW.%X3 := TRUE;
	                #PO_Mitsubishi.CTW.%X5 := #PO_Mitsubishi.CTW.%X6 := true;
	                #PO_Mitsubishi.CTW.%X12 := "Motore".M[#K_MotoreInt].Out.CmdNegMotore AND #PI_Mitsubishi.STW.%X0;
	                #PO_Mitsubishi.CTW.%X7 := ("Zona".Z[#K_Zona].Gen.Reset OR ("Motore".M[#K_MotoreInt].Dati.AlmInv_ToutReset > 2000 AND "Zona".Comuni.Clocks.Clock1Hz)) AND "Motore".M[#K_MotoreInt].In.DriverFault;
	                #PO_Mitsubishi.CTW.%X10 := true;
	                #PO_Mitsubishi.Speed_SP := DINT_TO_INT(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 16384.0));
	                #PO_Mitsubishi.Acc := TRUNC(DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.AccRichPerc) * 3.0);
	                #PO_Mitsubishi.Dec := TRUNC(DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.DecReqInLavo) * 3.0);
	                #PO_Mitsubishi.FStart := #VeloFrenoDir * 9000 / "Motore".M[#K_MotoreInt].Prm.C.VelMax;
	                "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv := DPWR_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD := #PO_Mitsubishi);
	                "Motore".M[#K_MotoreInt].HMI.CTW1 := #PO_Mitsubishi.CTW;
	            END_REGION
	        2:
	            REGION PN Siemens
	                (* Struttura Control Word
	                Bit 00: Drive PO: Run = 1/Stop = 0
	                Bit 01: Drive PO: Pulse Enable = 1/Pulse Disable = 0
	                Bit 02: Drive PO: No Quick Stop = 1/Quick Stop = 0
	                Bit 03: Drive PO: Enable = 1/Disable = 0
	                Bit 04: Drive PO: Ramp Generator Enable = 1/Disable = 0
	                Bit 05: Drive PO: Ramp Generator Unfreeze = 1/Freeze = 0
	                Bit 06: Drive PO: Setpoint Enable = 1/ Disable = 0
	                Bit 07: Drive PO: Faults/Warnings Acknowledge
	                Bit 08: Drive PO: Reserved
	                Bit 09: Drive PO: Reserved
	                Bit 10: Drive PO: PLC Control
	                Bit 11: Drive PO: Setpoint Reverse
	                Bit 12: Drive PO: Reserved
	                Bit 13: Drive PO: Motor Potentiometer Up
	                Bit 14: Drive PO: Motor Potentiometer Down
	                Bit 15: Drive PO: Reserved
	                *)
	                #PO_Siemens.CTW := w#16#47f;
	                #PO_Siemens.CTW.%X0 := "Motore".M[#K_MotoreInt].Out.CmdPosMotore OR "Motore".M[#K_MotoreInt].Out.CmdNegMotore;
	                #PO_Siemens.CTW.%X11 := "Motore".M[#K_MotoreInt].Out.CmdNegMotore;
	                #PO_Siemens.CTW.%X7 := "Zona".Z[#K_Zona].Gen.Reset;
	                #PO_Siemens.Speed := DINT_TO_INT(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 16384.0));
	                "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv := DPWR_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD := #PO_Siemens);
	                "Motore".M[#K_MotoreInt].HMI.CTW1 := #PO_Siemens.CTW;
	            END_REGION
	        3:
	            REGION PN Schneider
	                (* Struttura Control Word
	                Bit 00: Switched on operating state; voltage at the power is enabled.
	                Bit 01: 1= Coast Stop (OFF2) not active.
	                Bit 02: 1 = Quick Stop (OFF3) not active.
	                Bit 03: Enable electronics and pulses. The drive then runs-up to the reference frequency.
	                Bit 04: Reserved
	                Bit 05: Reserved
	                Bit 06: Not used
	                Bit 07: The fault reset function is active with a positive edge.
	                Bit 08: Not used
	                Bit 09: Not used
	                Bit 10: Channel for the reference frequency and the command from the bus are active.
	                Bit 11: Reserved
	                Bit 12: Reserved
	                Bit 13: Reserved
	                Bit 14: Reserved
	                Bit 15: Reserved
	                *)
	                #PO_Schneider.CTW := 0;
	                #PO_Schneider.CTW.%X0 := #PI_Schneider.STW.%X0;
	                // Normal Stop
	                #PO_Schneider.CTW.%X1 := #PO_Schneider.CTW.%X2 := "Zona".Z[#K_Zona].Out.CentralinaOk AND NOT #PI_Schneider.STW.%X3;
	                // Comando Marcia
	                #PO_Schneider.CTW.%X3 := #PO_Schneider.CTW.%X0 AND ("Motore".M[#K_MotoreInt].Out.CmdPosMotore OR "Motore".M[#K_MotoreInt].Out.CmdNegMotore);
	                //    Fault Reset
	                #PO_Schneider.CTW.%X7 := "Zona".Z[#K_Zona].Gen.Reset AND #PI_Schneider.STW.%X3;
	                // VelocitÃ  richiesta
	                IF NOT "Motore".M[#K_MotoreInt].Out.CmdNegMotore THEN
	                    #PO_Schneider.Speed_SP := DINT_TO_INT(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 3000.0));
	                ELSE
	                    #PO_Schneider.Speed_SP := - DINT_TO_INT(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 3000.0));
	                END_IF;
	                #PO_Schneider.Acc_SP := #PO_Schneider.Dec_SP := 0;
	                "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv := DPWR_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD := #PO_Schneider);
	                "Motore".M[#K_MotoreInt].HMI.CTW1 := #PO_Schneider.CTW;
	            END_REGION
	        4:
	            REGION PN Movimot
	                (* Struttura Control Word
	                Bit 08: Reserved
	                Bit 09: Reserved
	                Bit 10: Reserved
	                Bit 11: Reserved
	                Bit 12: Reserved
	                Bit 13: Reserved
	                Bit 14: Reserved
	                Bit 15: Reserved
	                Bit 00: Enable 01 Run Motor
	                Bit 01: Enable 02 Run Motor
	                Bit 02: Enable 03 Run Motor
	                Bit 03: Reserved
	                Bit 04: Reserved
	                Bit 05: Reserved
	                Bit 06: Reset
	                Bit 07: Reserved
	                *)
	                #PO_Movimot.CTW.%X1 := #PO_Movimot.CTW.%X2 := "Motore".M[#K_MotoreInt].Out.CmdPosMotore OR "Motore".M[#K_MotoreInt].Out.CmdNegMotore;
	                #PO_Movimot.CTW.%X6 := ("Zona".Z[#K_Zona].Gen.Reset OR ("Motore".M[#K_MotoreInt].Dati.AlmInv_ToutReset > 2000 AND "Zona".Comuni.Clocks.Clock1Hz));
	                IF NOT "Motore".M[#K_MotoreInt].Out.CmdNegMotore THEN
	                    #PO_Movimot.Speed := DINT_TO_INT(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 16384.0));
	                ELSE
	                    #PO_Movimot.Speed := - DINT_TO_INT(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 16384.0));
	                END_IF;
	                #PO_Movimot.AccRich := DINT_TO_INT(TRUNC(DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.DecEmergenza) * 400.0));
	                "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv := DPWR_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD := #PO_Movimot);
	                "Motore".M[#K_MotoreInt].HMI.CTW1 := #PO_Movimot.CTW;
	                "Motore".M[#K_MotoreInt].HMI.CTW2 := INT_TO_WORD(#PO_Movimot.Speed);
	                "Motore".M[#K_MotoreInt].HMI.CTW3 := INT_TO_WORD(#PO_Movimot.AccRich);
	            END_REGION
	        5:
	            REGION PN MoviGear
	                
	                (* Struttura Control Word
	                Bit 00: Enable/Emergency Stop
	                Bit 01: Enable/Application Stop
	                Bit 02: Riservato
	                Bit 03: Rilascio Freno
	                Bit 04: Jog Positivo
	                Bit 05: Jog Negativo
	                Bit 06: Nuovo Movimento Relativo
	                Bit 07: Strat/Stop
	                Bit 08: Fault Reset
	                Bit 09: Riservato
	                Bit 10: Attiva Motore 2
	                Bit 11: Riservato
	                Bit 12: Disabilita Limiti
	                Bit 13: Attiva Output Stage
	                Bit 14: Attiva Stand By
	                Bit 15: HandShake
	                *)
	                #PO_MoviGear.CTW := 0;
	                // Emergenza OK
	                #PO_MoviGear.CTW.%X0 := "Zona".Z[#K_Zona].Out.CentralinaOk;
	                // Comando di Marcia
	                #PO_MoviGear.CTW.%X7 := #PO_MoviGear.CTW.%X1 := "Motore".M[#K_MotoreInt].Out.CmdPosMotore OR "Motore".M[#K_MotoreInt].Out.CmdNegMotore;
	                // Fault Reset
	                #PO_MoviGear.CTW.%X8 := "Zona".Z[#K_Zona].Gen.Reset;
	                // VelocitÃ  richiesta
	                IF NOT "Motore".M[#K_MotoreInt].Out.CmdNegMotore THEN
	                    #PO_MoviGear.Target_Speed := DINT_TO_INT(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 3000.0));
	                ELSE
	                    #PO_MoviGear.Target_Speed := - DINT_TO_INT(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 3000.0));
	                END_IF;
	                #PO_MoviGear.Acceleration := #PO_MoviGear.Deceleration := 30000;
	                #PO_MoviGear."DO".%X0 := "Motore".M[#K_MotoreInt].Out.CmdUsc01Inv;
	                #PO_MoviGear."DO".%X1 := "Motore".M[#K_MotoreInt].Out.CmdUsc02Inv;
	                "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv := DPWR_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD := #PO_MoviGear);
	                "Motore".M[#K_MotoreInt].HMI.CTW1 := #PO_MoviGear.CTW;
	            END_REGION
	        6:
	            REGION PN Danfoss
	                (* Struttura Control Word
	                   Bit 08: JOG 1 OFF/ON
	                   Bit 09: JOG 2 OFF/ON
	                   Bit 10: 0=Data invalid    1=Data valid
	                   Bit 11: 0=No function        1=Slow down
	                   Bit 12: 0=No function        1=Catch up
	                   Bit 13: 0=Parameter set-up        1=Sel LSB
	                   Bit 14: 0=Parameter set-up        1=Sel MSB
	                   Bit 15: 0=No function        1=Reserve
	                   Bit 00: OFF/ON 1
	                   Bit 01: OFF/ON 2
	                   Bit 02: OFF/ON 3
	                   Bit 03: 0=Coasting        1=Not coasting
	                   Bit 04: 0=Quick stop       1=Ramp
	                   Bit 05: 0=Hold Freq.Output   1=Use Ramp
	                   Bit 06: 0=Ramp Stop        1=Start
	                   Bit 07: 0=No function        1=Reset
	                   *)
	                #PO_Danfoss.CTW := w#16#47f;
	                #PO_Danfoss.CTW.%X0 := #PI_Danfoss.STW.%X0;
	                #PO_Danfoss.CTW.%X6 := ("Motore".M[#K_MotoreInt].Out.CmdPosMotore OR "Motore".M[#K_MotoreInt].Out.CmdNegMotore) AND #PO_Danfoss.CTW.%X0 AND #PI_Danfoss.STW.%X9;
	                #PO_Danfoss.CTW.%X15 := #PO_Danfoss.CTW.%X6 AND "Motore".M[#K_MotoreInt].Out.CmdNegMotore;
	                #PO_Danfoss.CTW.%X7 := "Zona".Z[#K_Zona].Gen.Reset AND #PI_Danfoss.STW.%X3;
	                #PO_Danfoss.Speed := DINT_TO_INT(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 16384.0));
	                #PO_Danfoss.AccRich := DINT_TO_INT(TRUNC(DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.AccRichPerc) * 40.0));
	                #PO_Danfoss.DecRich := DINT_TO_INT(TRUNC(DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) / DINT_TO_REAL(#DecActRich) * 40.0));
	                "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv := DPWR_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD := #PO_Danfoss);
	                "Motore".M[#K_MotoreInt].HMI.CTW1 := #PO_Danfoss.CTW;
	            END_REGION ;  
	        7:
	            REGION PN MoviTrak
	                (* Struttura Control Word
	                Bit 08: Reserved
	                Bit 09: Reserved
	                Bit 10: Reserved
	                Bit 11: Reserved
	                Bit 12: Reserved
	                Bit 13: Reserved
	                Bit 14: Reserved
	                Bit 15: Reserved
	                Bit 00: Inhibit/Enable
	                Bit 01: Enable/Rapid Stop
	                Bit 02: Enable/Stop
	                Bit 03: Reserved
	                Bit 04: Reserved
	                Bit 05: Reserved
	                Bit 06: Reset
	                Bit 07: Reserved
	                *)
	                #PO_MoviTrac.CTW := 0;
	                #PO_MoviTrac.CTW.%X1 := #PO_MoviTrac.CTW.%X2 := "Motore".M[#K_MotoreInt].Out.CmdPosMotore OR "Motore".M[#K_MotoreInt].Out.CmdNegMotore;
	                #PO_MoviTrac.CTW.%X6 := "Zona".Z[#K_Zona].Gen.Reset;
	                IF NOT "Motore".M[#K_MotoreInt].Out.CmdNegMotore THEN
	                    #PO_MoviTrac.Speed := DINT_TO_INT(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 16384.0));
	                ELSE
	                    #PO_MoviTrac.Speed := - DINT_TO_INT(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 16384.0));
	                END_IF;
	                "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv := DPWR_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD := #PO_MoviTrac);
	                "Motore".M[#K_MotoreInt].HMI.CTW1 := #PO_MoviTrac.CTW;
	            END_REGION
	        8:
	            REGION PN INVT
	                (* Struttura Control Word
	                Byte 0
	                DEC Description
	                1   Forward running
	                2   Reverse running
	                3   Forward inching
	                4   Reverse inching
	                5   Decelerating to stop
	                6   Coasting to stop (emergency stop)
	                7   Fault reset
	                8   Jogging to stop
	                9   Decelerate to stop
	                ////////////////////////////////////////////////
	                Bit 8: Abilita scrittura parametri PKW
	                ////////////////////////////////////////////////
	                Bit 9-10:
	                DEC DEscrizione
	                00  Motor 1
	                01  Motor 2
	                ////////////////////////////////////////////////
	                Bit 11: 0=Disable Switchig, 1=Enable Torque/Speed control Switching
	                Bit 12: Reset Power Consumption
	                Bit 13: Pre-Excitation
	                Bit 14: DC-Bracking
	                Bit 15: Heart Beat Reference
	    
	                *)
	                #PO_INVT.CTW.%B1 := 1;
	                IF "Zona".Z[#K_Zona].Gen.Reset AND ("Motore".M[#K_MotoreInt].Dati.MotoreFermo OR "Motore".M[#K_MotoreInt].In.DriverFault) THEN
	                    #PO_INVT.CTW.%B0 := 7;
	                ELSIF "Motore".M[#K_MotoreInt].Out.CmdPosMotore THEN
	                    #PO_INVT.CTW.%B0 := 1;
	                ELSIF "Motore".M[#K_MotoreInt].Out.CmdNegMotore THEN
	                    #PO_INVT.CTW.%B0 := 2;
	                ELSE
	                    #PO_INVT.CTW.%B0 := 6;
	                END_IF;
	                #PO_INVT.CTW.%X15 := NOT #PI_INVT.STW.%X15;
	                #PO_INVT.Speed := DINT_TO_INT(TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 10000.0));
	                REGION ScritturaParametri
	                    IF #PI_INVT.PKW01 <> 0 THEN
	                        IF "Motore".M[#K_MotoreInt].Dati.PrmSend THEN
	                            "Motore".M[#K_MotoreInt].Dati.IdPrm += 1;
	                            IF "Motore".M[#K_MotoreInt].Dati.IdPrm > 1 THEN
	                                "Motore".M[#K_MotoreInt].Dati.IdPrm := 0;
	                            END_IF;
	                            "Motore".M[#K_MotoreInt].Dati.PrmSend := false;
	                        END_IF;
	                    ELSE
	                        "Motore".M[#K_MotoreInt].Dati.PrmSend := true;
	                        CASE "Motore".M[#K_MotoreInt].Dati.IdPrm OF
	                            0:  //Acc
	                                #PO_INVT.PKW01 := 4;
	                                #PO_INVT.PKW02 := 11;
	                                #PO_INVT.PKW04 := DINT_TO_WORD(TRUNC(DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.DecEmergenza) * 3.0));
	                            1:  //Dec
	                                #PO_INVT.PKW01 := 4;
	                                #PO_INVT.PKW02 := 12;
	                                #PO_INVT.PKW04 := DINT_TO_WORD(TRUNC(DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.DecEmergenza) * 3.0));
	                            ELSE
	                                "Motore".M[#K_MotoreInt].Dati.PrmSend := false;
	                                "Motore".M[#K_MotoreInt].Dati.IdPrm := 0;
	                        END_CASE;
	                    END_IF;
	                END_REGION
	                "Motore".M[#K_MotoreInt].Dati.RetVal_SCR_Inv := DPWR_DAT(LADDR := "Motore".M[#K_MotoreInt].HW.HWIO_Inverter, RECORD := #PO_INVT);
	                "Motore".M[#K_MotoreInt].HMI.CTW1 := #PO_INVT.CTW;
	            END_REGION
	        9:
	            REGION Nidec
	                (*
	                BIT 00: Drive Enable
	                BIT 01: Run Forward
	                BIT 02: Jog Forward
	                BIT 03: Run Reverse
	                BIT 04: Forward/Reverse
	                BIT 05: Run
	                BIT 06: Not Stop
	                BIT 07: Auto / manual
	                BIT 08: Analog / Preset reference
	                BIT 09: Jog Reverse
	                BIT 10: Not used
	                BIT 11: Not used
	                BIT 12: Trip drive
	                BIT 13: Reset drive
	                BIT 14: Watchdog
	                *)
	                #PO_Nidec.CTW.%X7 := true;
	                #PO_Nidec.CTW.%X0 := #PO_Nidec.CTW.%X6 := #PI_Nidec.STW.%X0 AND "Zona".Z[#K_ZonaInt].Out.CentralinaOk;
	                //#PO_Nidec.CTW.%X1 := "Motor".M[#MotorNumber].o.CmdFWD OR "Motor".M[#MotorNumber].o.CmdBKW;
	                //#PO_Nidec.CTW.%X3 := "Motor".M[#MotorNumber].o.CmdBKW;
	                #PO_Nidec.CTW.%X5 := "Motore".M[#K_MotoreInt].Out.CmdPosMotore OR "Motore".M[#K_MotoreInt].Out.CmdNegMotore;
	                #PO_Nidec.CTW.%X4 := "Motore".M[#K_MotoreInt].Out.CmdNegMotore;
	                #PO_Nidec.CTW.%X13 := "Zona".Z[#K_Zona].Gen.Reset AND "Motore".M[#K_MotoreInt].In.DriverFault;
	                #PO_Nidec.Speed := TRUNC("Motore".M[#K_MotoreInt].Out.VelAss / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) * 10000.0);
	                #PO_Nidec.RampAcc := TRUNC(DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.AccRichPerc) * 3.0);
	                #PO_Nidec.RampDec := TRUNC(DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.C.VelMax) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Dati.DecReqEmergInLavo) * 3.0);
	                "Motore".M[#K_MotoreInt].HMI.CTW1 := #PO_Nidec.CTW;
	                //VariantPut(SRC := #PO_Nidec, DST := #PO_Inv);
	            END_REGION
	            ;
	    END_CASE;
	END_REGION ;
	REGION Update
	    IF "Motore".M[#K_MotoreInt].HMI.UpdParam THEN
	        "Motore".M[#K_MotoreInt].HMI.UpdParam := FALSE;
	        "Motore".M[#K_MotoreInt].Out.UpdParam := true;
	    ELSE
	        IF "Motore".M[#K_MotoreInt].Out.UpdParam THEN
	            "Motore".M[#K_MotoreInt].HMI.FBGestione := 100 + "Motore".M[#K_MotoreInt].HW.TipoCollInverter;
	            CASE "Motore".M[#K_MotoreInt].HW.TipoEncoder OF
	                1: // ENCODER SICK
	                    "Motore".M[#K_MotoreInt].Dati.Encoder.RicircoloEncoder := 1073741824;
	                    "Motore".M[#K_MotoreInt].Dati.Encoder.MezzoRicircoloEncoder := "Motore".M[#K_MotoreInt].Dati.Encoder.RicircoloEncoder / 2;
	                    "Motore".M[#K_MotoreInt].Prm.Enc.ImpRev := 262144.0;
	                10, 11: // ENCODER T+R
	                    "Motore".M[#K_MotoreInt].Dati.Encoder.RicircoloEncoder := 16#0200_0000;
	                    "Motore".M[#K_MotoreInt].Dati.Encoder.MezzoRicircoloEncoder := "Motore".M[#K_MotoreInt].Dati.Encoder.RicircoloEncoder / 2;
	                    "Motore".M[#K_MotoreInt].Prm.Enc.ImpRev := 8192.0;
	            END_CASE;
	        END_IF;
	        "Motore".M[#K_MotoreInt].Out.UpdParam := false;
	    END_IF;
	    IF "Motore".M[#K_MotoreInt].Out.UpdParam THEN
	        "Motore".M[#K_MotoreInt].In.Positioning := false;
	        "Motore".M[#K_MotoreInt].In.PosRelativo := false;
	        "Motore".M[#K_MotoreInt].In.CambioVelDaPunto := false;
	        "Motore".M[#K_MotoreInt].In.CmdPosRich := false;
	        "Motore".M[#K_MotoreInt].In.CmdNegRich := false;
	        "Motore".M[#K_MotoreInt].In.MotoreRun := false;
	        "Motore".M[#K_MotoreInt].In.AttivaLimVarPos := false;
	        "Motore".M[#K_MotoreInt].In.AttivaLimVarNeg := false;
	        "Motore".M[#K_MotoreInt].In.Premagnetizza := false;
	        "Motore".M[#K_MotoreInt].In.PremagnetizzaPos := false;
	        "Motore".M[#K_MotoreInt].In.PremagnetizzaNeg := false;
	        "Motore".M[#K_MotoreInt].In.ForzaEndLessPos := false;
	        "Motore".M[#K_MotoreInt].In.ForzaEndLessNeg := false;
	        "Motore".M[#K_MotoreInt].In.ForzaEndLessBreve := false;
	        "Motore".M[#K_MotoreInt].In.SezAperto := false;
	        "Motore".M[#K_MotoreInt].In.DriverFault := false;
	        "Motore".M[#K_MotoreInt].In.DriverWarning := false;
	        "Motore".M[#K_MotoreInt].In.NoComunInv := false;
	        "Motore".M[#K_MotoreInt].In.NoComunEnc := false;
	        "Motore".M[#K_MotoreInt].In.TerVentolaOff := false;
	        "Motore".M[#K_MotoreInt].In.CinghiaRotta := false;
	        "Motore".M[#K_MotoreInt].In.SensAzz := false;
	        "Motore".M[#K_MotoreInt].In.SpinaSicNoInPos := false;
	        "Motore".M[#K_MotoreInt].In.ConsMovimentoPos := true;
	        "Motore".M[#K_MotoreInt].In.ConsMovimentoNeg := true;
	        "Motore".M[#K_MotoreInt].In.AnticadutaOFF := false;
	        "Motore".M[#K_MotoreInt].In.AnticadutaON := false;
	        "Motore".M[#K_MotoreInt].In.PercentualeRichiesta := 100;
	        "Motore".M[#K_MotoreInt].Out.CmdPosMotore := false;
	        "Motore".M[#K_MotoreInt].Out.CmdNegMotore := false;
	        "Motore".M[#K_MotoreInt].Out.CmdAnticaduta := false;
	        "Motore".M[#K_MotoreInt].Out.Paw := 0;
	        "Motore".M[#K_MotoreInt].Out.VelEncoder := 0;
	        "Motore".M[#K_MotoreInt].Prm.ByPassAnticaduta := false;
	        "Motore".M[#K_MotoreInt].Prm.AnticadutaPresente := false;
	        "Motore".M[#K_MotoreInt].Prm.PremaNoFreno := false;
	        "Motore".M[#K_MotoreInt].Prm.EscludiFunzPos := false;
	        "Motore".M[#K_MotoreInt].Prm.CambioDirNoFreno := false;
	        "Motore".M[#K_MotoreInt].Prm.CalcTempoRimanente := false;
	        "Motore".M[#K_MotoreInt].Prm.FrenoPresente := false;
	        "Motore".M[#K_MotoreInt].Prm.DisabCicloAutoAllarme := false;
	        "Motore".M[#K_MotoreInt].Prm.DisabCicloManuAllarme := false;
	        "Motore".M[#K_MotoreInt].HMI.Setup := false;
	        "Motore".M[#K_MotoreInt].HMI.ManMov := false;
	        "Motore".M[#K_MotoreInt].HMI.Param.Read := false;
	        "Motore".M[#K_MotoreInt].HMI.Param.Write := false;
	        "Motore".M[#K_MotoreInt].HMI.Param.Save := false;
	        "Motore".M[#K_MotoreInt].HMI.Param.FactoryInit := false;
	        "Motore".M[#K_MotoreInt].HMI.Param.Init_Motor := false;
	        "Motore".M[#K_MotoreInt].HMI.FBGestione := 100 + "Motore".M[#K_MotoreInt].HW.TipoCollInverter;
	        CASE "Motore".M[#K_MotoreInt].HW.TipoEncoder OF
	            1: // ENCODER SICK
	                "Motore".M[#K_MotoreInt].Dati.Encoder.RicircoloEncoder := 1073741824;
	                "Motore".M[#K_MotoreInt].Dati.Encoder.MezzoRicircoloEncoder := "Motore".M[#K_MotoreInt].Dati.Encoder.RicircoloEncoder / 2;
	                "Motore".M[#K_MotoreInt].Prm.Enc.ImpRev := 262144.0;
	            10, 11: // ENCODER T+R
	                "Motore".M[#K_MotoreInt].Dati.Encoder.RicircoloEncoder := 16#0200_0000;
	                "Motore".M[#K_MotoreInt].Dati.Encoder.MezzoRicircoloEncoder := "Motore".M[#K_MotoreInt].Dati.Encoder.RicircoloEncoder / 2;
	                "Motore".M[#K_MotoreInt].Prm.Enc.ImpRev := 8192.0;
	        END_CASE;
	        REGION CalcoloSviluppoEncoder
	            CASE "Motore".M[#K_MotoreInt].Prm.Enc.Mounting OF
	                1:
	                    // Albero Lento
	                    "Motore".M[#K_MotoreInt].Prm.C.SpazioGiroEncoder := UDINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Mech.FeedConstant);
	                2:
	                    // Albero Veloce
	                    "Motore".M[#K_MotoreInt].Prm.C.SpazioGiroEncoder := UDINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Mech.FeedConstant * "Motore".M[#K_MotoreInt].Prm.Mech.GearIn) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Mech.GearOut);
	                ELSE
	                    "Motore".M[#K_MotoreInt].Prm.C.SpazioGiroEncoder := UDINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Enc.FeedConstant);
	            END_CASE;
	        END_REGION
	        "Motore".M[#K_MotoreInt].Prm.C.VelMax := TRUNC(UDINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Mech.FeedConstant) * (DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Mech.GearIn) / DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Mech.GearOut)) * DINT_TO_REAL("Motore".M[#K_MotoreInt].Prm.Mech.RPMMaxRef) / 60.0);
	        CASE "Motore".M[#K_MotoreInt].HMI.ModoInizializza OF
	            1:
	                "Motore".M[#K_MotoreInt].Prm.TMinVCost := 200;
	                "Motore".M[#K_MotoreInt].Prm.TCambioDir := 200;
	                IF "Motore".M[#K_MotoreInt].HW.TipoCollInverter <> 0 THEN
	                    "Motore".M[#K_MotoreInt].Prm.VelPrema := 1;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Prm.VelPrema := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 100;
	                END_IF;
	                "Motore".M[#K_MotoreInt].Prm.VelBassa := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 10;
	                "Motore".M[#K_MotoreInt].Prm.VelSgancioFrenoPos := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 50;
	                "Motore".M[#K_MotoreInt].Prm.VelSgancioFrenoNeg := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 50;
	                "Motore".M[#K_MotoreInt].Prm.SpazioArrestoPos := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 500;
	                "Motore".M[#K_MotoreInt].Prm.SpazioArrestoNeg := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 500;
	                "Motore".M[#K_MotoreInt].Prm.Precisione := MAX(IN1 := "Motore".M[#K_MotoreInt].Prm.SpazioArrestoPos, IN2 := "Motore".M[#K_MotoreInt].Prm.SpazioArrestoNeg) * 2;
	                "Motore".M[#K_MotoreInt].Prm.Inerzia := "Motore".M[#K_MotoreInt].Prm.Precisione + 2000;
	                "Motore".M[#K_MotoreInt].Prm.DecFinale := "Motore".M[#K_MotoreInt].Prm.C.VelMax * 2;
	                "Motore".M[#K_MotoreInt].Prm.DecEmergenza := "Motore".M[#K_MotoreInt].Prm.C.VelMax * 3;
	                "Motore".M[#K_MotoreInt].In.Acc := "Motore".M[#K_MotoreInt].Prm.C.VelMax * 2;
	                "Motore".M[#K_MotoreInt].In.Dec := "Motore".M[#K_MotoreInt].Prm.C.VelMax * 2;
	                "Motore".M[#K_MotoreInt].Prm.VelMan := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 4;
	                "Motore".M[#K_MotoreInt].Prm.VelJog := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 10;
	                "Motore".M[#K_MotoreInt].Prm.ValMaxRef := 27648;
	            2:
	                "Motore".M[#K_MotoreInt].Prm.TMinVCost := 200;
	                "Motore".M[#K_MotoreInt].Prm.TCambioDir := 200;
	                IF "Motore".M[#K_MotoreInt].HW.TipoCollInverter <> 0 THEN
	                    "Motore".M[#K_MotoreInt].Prm.VelPrema := 1;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Prm.VelPrema := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 100;
	                END_IF;
	                "Motore".M[#K_MotoreInt].Prm.VelBassa := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 10;
	                "Motore".M[#K_MotoreInt].Prm.VelSgancioFrenoPos := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 25;
	                "Motore".M[#K_MotoreInt].Prm.VelSgancioFrenoNeg := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 25;
	                "Motore".M[#K_MotoreInt].Prm.SpazioArrestoPos := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 500;
	                "Motore".M[#K_MotoreInt].Prm.SpazioArrestoNeg := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 500;
	                "Motore".M[#K_MotoreInt].Prm.Precisione := MAX(IN1 := "Motore".M[#K_MotoreInt].Prm.SpazioArrestoPos, IN2 := "Motore".M[#K_MotoreInt].Prm.SpazioArrestoNeg) * 2;
	                "Motore".M[#K_MotoreInt].Prm.Inerzia := "Motore".M[#K_MotoreInt].Prm.Precisione + 2000;
	                "Motore".M[#K_MotoreInt].Prm.DecFinale := "Motore".M[#K_MotoreInt].Prm.C.VelMax * 2;
	                "Motore".M[#K_MotoreInt].Prm.DecEmergenza := "Motore".M[#K_MotoreInt].Prm.C.VelMax * 3;
	                "Motore".M[#K_MotoreInt].In.Acc := "Motore".M[#K_MotoreInt].Prm.C.VelMax * 2;
	                "Motore".M[#K_MotoreInt].In.Dec := "Motore".M[#K_MotoreInt].Prm.C.VelMax * 2;
	                "Motore".M[#K_MotoreInt].Prm.VelMan := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 4;
	                "Motore".M[#K_MotoreInt].Prm.VelJog := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 10;
	                "Motore".M[#K_MotoreInt].Prm.ValMaxRef := 27648;
	            3:
	                "Motore".M[#K_MotoreInt].Prm.TMinVCost := 200;
	                "Motore".M[#K_MotoreInt].Prm.TCambioDir := 200;
	                IF "Motore".M[#K_MotoreInt].HW.TipoCollInverter <> 0 THEN
	                    "Motore".M[#K_MotoreInt].Prm.VelPrema := 1;
	                ELSE
	                    "Motore".M[#K_MotoreInt].Prm.VelPrema := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 100;
	                END_IF;
	                "Motore".M[#K_MotoreInt].Prm.VelBassa := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 10;
	                "Motore".M[#K_MotoreInt].Prm.VelSgancioFrenoPos := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 25;
	                "Motore".M[#K_MotoreInt].Prm.VelSgancioFrenoNeg := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 25;
	                "Motore".M[#K_MotoreInt].Prm.SpazioArrestoPos := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 500;
	                "Motore".M[#K_MotoreInt].Prm.SpazioArrestoNeg := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 500;
	                "Motore".M[#K_MotoreInt].Prm.Precisione := MAX(IN1 := "Motore".M[#K_MotoreInt].Prm.SpazioArrestoPos, IN2 := "Motore".M[#K_MotoreInt].Prm.SpazioArrestoNeg) * 2;
	                "Motore".M[#K_MotoreInt].Prm.Inerzia := "Motore".M[#K_MotoreInt].Prm.Precisione + 2000;
	                "Motore".M[#K_MotoreInt].Prm.DecFinale := "Motore".M[#K_MotoreInt].Prm.C.VelMax;
	                "Motore".M[#K_MotoreInt].Prm.DecEmergenza := "Motore".M[#K_MotoreInt].Prm.C.VelMax;
	                "Motore".M[#K_MotoreInt].In.Acc := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 2;
	                "Motore".M[#K_MotoreInt].In.Dec := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 2;
	                "Motore".M[#K_MotoreInt].Prm.VelMan := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 4;
	                "Motore".M[#K_MotoreInt].Prm.VelJog := "Motore".M[#K_MotoreInt].Prm.C.VelMax / 10;
	                "Motore".M[#K_MotoreInt].Prm.ValMaxRef := 27648;
	        END_CASE;
	        "Motore".M[#K_MotoreInt].HMI.ModoInizializza := 0;
	        "Motore".M[#K_MotoreInt].Allarmi.WordHmi_1 :=
	        "Motore".M[#K_MotoreInt].Allarmi.WordHmi_2 := 0;
	    END_IF;
	END_REGION ;
	REGION Motor block
	    IF "Motore".M[#K_MotoreInt].Dati.MotorStop THEN
	        IF NOT "Motore".M[#K_MotoreInt].Out.InMarcia THEN
	            IF "Motore".M[#K_MotoreInt].Dati.AlmInv_RitRestart > 1000 THEN
	                "Motore".M[#K_MotoreInt].Dati.MotorStop := false;
	            ELSE
	                "Motore".M[#K_MotoreInt].Dati.AlmInv_RitRestart += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	            END_IF;
	        ELSE
	            "Motore".M[#K_MotoreInt].Dati.AlmInv_RitRestart := 0;
	        END_IF;
	    END_IF;
	    IF "Motore".M[#K_MotoreInt].Dati.AlmBloccato_Cont > 0 OR"Motore".M[#K_MotoreInt].Dati.AlmInv_Cont > 0 THEN
	        "Motore".M[#K_MotoreInt].Dati.Alm_ContAzzCont += REAL_TO_INT("Zona".Comuni.TempoCicloCpu_r);
	        IF "Motore".M[#K_MotoreInt].Dati.Alm_ContAzzCont > 60000 THEN
	            "Motore".M[#K_MotoreInt].Dati.AlmBloccato_Cont := 0;
	            "Motore".M[#K_MotoreInt].Dati.AlmInv_Cont := 0;
	            "Motore".M[#K_MotoreInt].Dati.Alm_ContAzzCont := 0;
	        END_IF;
	    ELSE
	        "Motore".M[#K_MotoreInt].Dati.Alm_ContAzzCont := 0;
	    END_IF;
	END_REGION ;
	REGION Riferimenti incrociati
	    "Motore".M[#K_MotoreInt].Rif_Inc.K_Analogica := "Motore".M[#K_MotoreInt].Prm.K_Analogica;
	    "Motore".M[#K_MotoreInt].Rif_Inc.K_Zona := #K_ZonaInt;
	END_REGION ;
	REGION Pulisco i comandi della sequenza
	    IF "Motore".M[#K_MotoreInt].Dati.InclusoInUnaSequenza THEN
	        "Motore".M[#K_MotoreInt].In.CmdPosRich :=
	        "Motore".M[#K_MotoreInt].In.CmdNegRich := False;
	    END_IF;
	END_REGION ;
END_FUNCTION

